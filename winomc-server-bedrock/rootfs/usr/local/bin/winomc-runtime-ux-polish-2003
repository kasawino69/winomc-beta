#!/usr/bin/env python3
from pathlib import Path

CONSOLE = Path("/usr/local/bin/winomc-console-server")
NATIVE_START = Path("/usr/local/bin/winomc-native-start")
WRITE_PROPS = Path("/usr/local/bin/winomc-write-server-properties")

VERSION = "2.0.0.6b"
RIGHTS_MARKER = "v2.0.0.6b direct player rights"
PROFILE_MARKER = "v2.0.0.6b profile loader"
MODE_MARKER = "v2.0.0.6b safe mode boundary"
START_MARKER = "v2.0.0.6b preserve ui access files"
PROPS_MARKER = "v2.0.0.6b preserve profile properties"


def replace_once(text, old, new):
    if old not in text:
        return text
    return text.replace(old, new, 1)


def patch_console():
    if not CONSOLE.exists():
        print("WinoMC console patch skipped: console server not found")
        return

    t = CONSOLE.read_text(encoding="utf-8")
    o = t

    for old in ("2.0.0.5b", "2.0.0.4b", "2.0.0.3b", "2.0.0.2b"):
        t = t.replace(old, VERSION)

    t = t.replace("{ action: 'repair_all_safe', mode: 'safe', confirm: true }", "{ action: 'repair_all_safe', mode: 'expert', confirm: true }")
    t = t.replace("{ action: t.dataset.diagnosticsRepair, mode: 'safe', confirm: true }", "{ action: t.dataset.diagnosticsRepair, mode: 'expert', confirm: true }")
    t = t.replace("alert(result.message || 'Reparatur abgeschlossen.');", "appendLine('[Diagnose] ' + (result.message || 'Reparatur abgeschlossen.'), 'info');")
    t = t.replace("frameworkCard('Keine Packs','-', 'Installierte Packs erscheinen hier.', 'Warnung')", "frameworkCard('Keine Packs','0', 'Keine lokalen Nutzer-Packs installiert.', 'OK')")

    old_update = "data.checks.map(c=>frameworkCard(c.title,c.status,c.message,c.status)).join('') + '<div class=\"tile\"><button class=\"primary\" id=\"updatesPrepare2\" type=\"button\">Update vorbereiten</button><p>Erstellt Backup und markiert Update-Bereitschaft. Danach Add-on neu starten.</p></div>'"
    new_update = "data.checks.map(c=>frameworkCard(c.title,c.status,c.message,c.status)).join('') + '<article class=\"tile\"><div class=\"tile-title\">Update-Ablauf</div><div class=\"tile-desc\">Kein Extra-Vorbereitungsschritt: Bei aktivem BDS_AUTO_UPDATE oder gesetzter VERSION reicht ein Add-on-Neustart. Erstelle vorher bei Bedarf ein Backup.</div></article>'"
    t = t.replace(old_update, new_update)

    mode_css = r'''
    /* v2.0.0.6b safe mode boundary */
    body.winomc-mode-mobile:not(.desktop-mode) .desktop-layer,
    body.winomc-mode-mobile:not(.desktop-mode) .desktop-taskbar,
    body.winomc-mode-mobile:not(.desktop-mode) .desktop-start-menu,
    body.winomc-mode-pc:not(.desktop-mode) .desktop-layer,
    body.winomc-mode-pc:not(.desktop-mode) .desktop-taskbar,
    body.winomc-mode-pc:not(.desktop-mode) .desktop-start-menu {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
    body.winomc-mode-mobile:not(.desktop-mode) [data-mode-scope="pc"],
    body.winomc-mode-mobile:not(.desktop-mode) [data-mode-scope="desktop"],
    body.winomc-mode-pc:not(.desktop-mode) [data-mode-scope="mobile"],
    body.winomc-mode-pc:not(.desktop-mode) [data-mode-scope="desktop"],
    body.winomc-mode-desktop [data-mode-scope="mobile"],
    body.winomc-mode-desktop [data-mode-scope="pc"] {
      display: none !important;
      pointer-events: none !important;
    }
'''
    if MODE_MARKER not in t:
        t = t.replace("  </style>", mode_css + "  </style>", 1)

    rights_block = r'''


# v2.0.0.6b direct player rights
def _player_name_key_2006(name):
    return re.sub(r"\s+", " ", str(name or "").strip()).lower().replace(" ", "")

def _player_key_2006(player):
    xuid = str(player.get("xuid") or "").strip()
    if xuid:
        return "xuid:" + xuid
    return "name:" + _player_name_key_2006(player.get("name"))

def known_player_xuid_2006(name):
    wanted = _player_name_key_2006(name)
    if not wanted:
        return ""
    known = {}
    def add(n, x):
        n = _player_name_key_2006(n)
        x = str(x or "").strip()
        if n and re.match(r"^[0-9]{5,32}$", x):
            known[n] = x
    for raw in re.split(r"[,;\n]+", os.environ.get("ALLOW_LIST_USERS", "") or ""):
        if ":" in raw:
            n, x = raw.split(":", 1)
            add(n, x)
        elif "=" in raw:
            n, x = raw.split("=", 1)
            add(n, x)
    allow, _ = json_file(os.path.join(DATA_DIR, "allowlist.json"), [])
    if isinstance(allow, list):
        for item in allow:
            if isinstance(item, dict):
                add(item.get("name"), item.get("xuid"))
    patterns = (
        re.compile(r"Player connected:\s*([^,\n]+),\s*xuid:\s*([0-9]{5,32})", re.I),
        re.compile(r"\bname[:=\s]+([^,\n]+).*?\bxuid[:=\s]+([0-9]{5,32})", re.I),
    )
    for log_path in (runtime_log_path(), LOG_PATH):
        try:
            if not os.path.exists(log_path):
                continue
            with open(log_path, "r", encoding="utf-8", errors="replace") as handle:
                for line in handle.readlines()[-3000:]:
                    for pattern in patterns:
                        match = pattern.search(line)
                        if match:
                            add(match.group(1), match.group(2))
        except Exception:
            pass
    return known.get(wanted, "")

def _normalize_player_entry_direct_2006(item):
    if not isinstance(item, dict):
        raise ValueError("Spieler-Eintrag ist ungültig.")
    name = str(item.get("name") or "").strip()
    xuid = str(item.get("xuid") or "").strip()
    if name and not xuid:
        xuid = known_player_xuid_2006(name)
    if not name and not xuid:
        raise ValueError("Spieler braucht mindestens Gamertag oder XUID.")
    if xuid and not re.match(r"^[0-9]{5,32}$", xuid):
        raise ValueError("XUID sieht ungültig aus: %s" % xuid)
    role = normalize_role(item.get("role", "member"))
    if role != "member" and not xuid:
        raise ValueError("Für Operator oder Visitor braucht Bedrock eine XUID. Lass den Spieler einmal verbinden oder trage Name:XUID in ALLOW_LIST_USERS ein.")
    return {"name": name, "xuid": xuid, "allowlisted": bool(item.get("allowlisted", True)), "role": role}

def players_payload():
    allow, ae = json_file(os.path.join(DATA_DIR, "allowlist.json"), [])
    perms, pe = json_file(os.path.join(DATA_DIR, "permissions.json"), [])
    allow = allow if isinstance(allow, list) else []
    perms = perms if isinstance(perms, list) else []
    by = {}
    for item in allow:
        if not isinstance(item, dict):
            continue
        row = {"name": item.get("name", "-"), "xuid": item.get("xuid", ""), "allowlisted": True, "role": "member", "issues": []}
        key = _player_key_2006(row)
        existing = by.setdefault(key, row)
        existing["allowlisted"] = True
        if row.get("xuid"):
            existing["xuid"] = row["xuid"]
        if row.get("name") and existing.get("name") in ("", "-"):
            existing["name"] = row["name"]
    for perm in perms:
        if not isinstance(perm, dict):
            continue
        row = {"name": perm.get("name", "-"), "xuid": perm.get("xuid", ""), "allowlisted": False, "role": normalize_role(perm.get("permission", "member")), "issues": []}
        key = _player_key_2006(row)
        existing = by.setdefault(key, row)
        existing["role"] = normalize_role(perm.get("permission", "member"))
        if row.get("xuid"):
            existing["xuid"] = row["xuid"]
    for row in by.values():
        if row.get("name") and not row.get("xuid"):
            row["xuid"] = known_player_xuid_2006(row.get("name"))
        if row.get("role") == "operator" and not row.get("allowlisted"):
            row.setdefault("issues", []).append("OP ist nicht auf der Allowlist.")
    warnings = []
    if ae:
        warnings.append("allowlist.json: " + ae)
    if pe:
        warnings.append("permissions.json: " + pe)
    if parse_bool(os.environ.get("ALLOW_LIST"), False) and not allow:
        warnings.append("Allowlist ist aktiv, aber leer.")
    if not parse_bool(os.environ.get("ONLINE_MODE"), True):
        warnings.append("Online Mode ist deaktiviert und sollte nur bewusst genutzt werden.")
    return {"ok": True, "players": list(by.values()), "warnings": warnings}

def save_players(players):
    if not isinstance(players, list):
        raise ValueError("players muss eine Liste sein.")
    normalized = [_normalize_player_entry_direct_2006(item) for item in players]
    seen = set()
    for player in normalized:
        key = _player_key_2006(player)
        if key in seen:
            raise ValueError("Doppelter Spieler/XUID: %s" % key)
        seen.add(key)
    allowlist = []
    permissions = []
    for player in normalized:
        if player["allowlisted"]:
            entry = {"name": player["name"] or player["xuid"], "ignoresPlayerLimit": False}
            if player["xuid"]:
                entry["xuid"] = player["xuid"]
            allowlist.append(entry)
        if player["xuid"] and player["role"] != "member":
            permissions.append({"permission": player["role"], "xuid": player["xuid"]})
    allow_result = atomic_write_json_root("config", "/allowlist.json", allowlist, backup=True)
    perm_result = atomic_write_json_root("config", "/permissions.json", permissions, backup=True)
    payload = players_payload()
    payload.update({"saved": True, "allowlist_result": allow_result, "permissions_result": perm_result, "message": "Spielerrechte wurden direkt in allowlist.json und permissions.json gespeichert."})
    return payload
'''
    if RIGHTS_MARKER not in t:
        t = t.replace("\n\ndef find_backup_meta(backup_name):", rights_block + "\n\ndef find_backup_meta(backup_name):", 1)

    profile_mode_js = r'''
    /* v2.0.0.6b profile loader + safe mode boundary */
    (() => {
      function getBody2006() { return document.body; }
      function currentWinoMode2006() {
        const body = getBody2006();
        if (!body) return 'pc';
        if (body.classList.contains('desktop-mode')) return 'desktop';
        if (body.classList.contains('winomc-mobile')) return 'mobile';
        if (body.classList.contains('ux-mobile')) return 'mobile';
        try {
          if (window.WinoMCMobileUI?.isActive?.()) return 'mobile';
        } catch (_) {}
        if (body.classList.contains('winomc-pc')) return 'pc';
        return 'pc';
      }
      function syncWinoMode2006() {
        const body = getBody2006();
        if (!body) return;
        const mode = currentWinoMode2006();
        body.dataset.winomcMode = mode;
        body.classList.toggle('winomc-mode-mobile', mode === 'mobile');
        body.classList.toggle('winomc-mode-pc', mode === 'pc');
        body.classList.toggle('winomc-mode-desktop', mode === 'desktop');
        if (mode !== 'desktop') body.classList.remove('desktop-dragging', 'desktop-resizing');
      }
      window.WinoMCMode = {
        sync: syncWinoMode2006,
        current: () => document.body?.dataset?.winomcMode || currentWinoMode2006(),
        isMobile: () => (document.body?.dataset?.winomcMode || currentWinoMode2006()) === 'mobile',
        isPC: () => (document.body?.dataset?.winomcMode || currentWinoMode2006()) === 'pc',
        isDesktop: () => (document.body?.dataset?.winomcMode || currentWinoMode2006()) === 'desktop'
      };
      function installModeObserver2006() {
        const body = getBody2006();
        if (!body || body.dataset.winomcModeObserver === '1') return;
        body.dataset.winomcModeObserver = '1';
        const observer = new MutationObserver(syncWinoMode2006);
        observer.observe(body, { attributes: true, attributeFilter: ['class'] });
        window.addEventListener('resize', syncWinoMode2006, { passive: true });
        syncWinoMode2006();
        window.setTimeout(syncWinoMode2006, 50);
        window.setTimeout(syncWinoMode2006, 250);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', installModeObserver2006, { once: true });
      else installModeObserver2006();

      window.loadProfiles2 = async function loadProfiles2Stable2006() {
        const target = document.getElementById('profilesGrid');
        const button = document.getElementById('profilesLoad');
        try {
          if (button) { button.disabled = true; button.textContent = 'Lade Profile…'; }
          if (target) target.innerHTML = '<article class="tile"><div class="tile-title">Profile werden geladen…</div><div class="tile-desc">WinoMC liest die verfügbaren Erststart-Profile.</div></article>';
          const data = await fetchJson('/api/profiles');
          const profiles = Array.isArray(data.profiles) ? data.profiles : [];
          if (!target) return;
          target.innerHTML = profiles.map(profile =>
            '<article class="tile"><div class="tile-title">'+escapeHtml(profile.name || 'Profil')+'</div><div class="tile-desc">'+escapeHtml(profile.description || '')+'</div><pre>'+escapeHtml(JSON.stringify(profile.defaults || {}, null, 2))+'</pre><button class="primary" data-profile-apply="'+escapeHtml(profile.name || '')+'">Profil anwenden</button></article>'
          ).join('') || '<article class="tile"><div class="tile-title">Keine Profile gefunden</div><div class="tile-desc">Der Server hat keine Erststart-Profile geliefert.</div></article>';
        } catch (err) {
          if (target) target.innerHTML = '<article class="tile"><div class="tile-title">Profile konnten nicht geladen werden</div><div class="tile-desc">'+escapeHtml(err.message || err)+'</div></article>';
          appendLine('[Erststart] ' + (err.message || err), 'error');
        } finally {
          if (button) { button.disabled = false; button.textContent = 'Profile laden'; }
        }
      };

      document.addEventListener('click', async event => {
        const button = event.target.closest('button');
        if (!button) return;
        if (button.id === 'profilesLoad') {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          await window.loadProfiles2();
        }
      }, true);
    })();
'''
    if PROFILE_MARKER not in t:
        t = t.replace("</script>", profile_mode_js + "\n</script>", 1)

    if t != o:
        CONSOLE.write_text(t, encoding="utf-8")
        print("WinoMC %s console polish applied" % VERSION)
    else:
        print("WinoMC %s console polish already present" % VERSION)


def patch_native_start():
    if not NATIVE_START.exists():
        print("WinoMC native-start patch skipped: file not found")
        return
    t = NATIVE_START.read_text(encoding="utf-8")
    o = t

    helper = r'''
# v2.0.0.6b preserve ui access files
has_list_values() {
  values="$(list_values "${1:-}")"
  old_ifs="${IFS}"
  IFS=','

  for entry in ${values}; do
    entry="$(trim_value "${entry}")"
    if [ -n "${entry}" ]; then
      IFS="${old_ifs}"
      return 0
    fi
  done

  IFS="${old_ifs}"
  return 1
}
'''
    if START_MARKER not in t:
        t = t.replace('\nwrite_allowlist_entry() {\n', helper + '\nwrite_allowlist_entry() {\n', 1)

    old_write_allowlist = r'''write_allowlist() {
  tmp_file="$(mktemp)"
  allowed_values="$(list_values "${ALLOW_LIST_USERS:-}")"

  old_ifs="${IFS}"
  IFS=','

  for entry in ${allowed_values}; do
    entry="$(trim_value "${entry}")"

    if [ -z "${entry}" ]; then
      continue
    fi

    write_allowlist_entry "${entry}" "${tmp_file}"
  done

  IFS="${old_ifs}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/allowlist.json"
  rm -f "${tmp_file}"

  echo "WinoMC native allowlist.json written"
}
'''
    new_write_allowlist = r'''write_allowlist() {
  if ! has_list_values "${ALLOW_LIST_USERS:-}"; then
    if [ -f "${SERVER_DATA_DIR}/allowlist.json" ]; then
      echo "WinoMC native allowlist.json preserved"
      return 0
    fi
  fi

  tmp_file="$(mktemp)"
  allowed_values="$(list_values "${ALLOW_LIST_USERS:-}")"

  old_ifs="${IFS}"
  IFS=','

  for entry in ${allowed_values}; do
    entry="$(trim_value "${entry}")"

    if [ -z "${entry}" ]; then
      continue
    fi

    write_allowlist_entry "${entry}" "${tmp_file}"
  done

  IFS="${old_ifs}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/allowlist.json"
  rm -f "${tmp_file}"

  echo "WinoMC native allowlist.json written"
}
'''
    t = replace_once(t, old_write_allowlist, new_write_allowlist)

    old_write_permissions = r'''write_permissions() {
  tmp_file="$(mktemp)"

  append_permission_entries "operator" "${OPS:-}" "${tmp_file}"
  append_permission_entries "member" "${MEMBERS:-}" "${tmp_file}"
  append_permission_entries "visitor" "${VISITORS:-}" "${tmp_file}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/permissions.json"
  rm -f "${tmp_file}"

  echo "WinoMC native permissions.json written"
}
'''
    new_write_permissions = r'''write_permissions() {
  if ! has_list_values "${OPS:-}" && ! has_list_values "${MEMBERS:-}" && ! has_list_values "${VISITORS:-}"; then
    if [ -f "${SERVER_DATA_DIR}/permissions.json" ]; then
      echo "WinoMC native permissions.json preserved"
      return 0
    fi
  fi

  tmp_file="$(mktemp)"

  append_permission_entries "operator" "${OPS:-}" "${tmp_file}"
  append_permission_entries "member" "${MEMBERS:-}" "${tmp_file}"
  append_permission_entries "visitor" "${VISITORS:-}" "${tmp_file}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/permissions.json"
  rm -f "${tmp_file}"

  echo "WinoMC native permissions.json written"
}
'''
    t = replace_once(t, old_write_permissions, new_write_permissions)

    if t != o:
        NATIVE_START.write_text(t, encoding="utf-8")
        print("WinoMC %s native-start persistence patch applied" % VERSION)
    else:
        print("WinoMC %s native-start persistence patch already present" % VERSION)


def patch_write_properties():
    if not WRITE_PROPS.exists():
        print("WinoMC write-server-properties patch skipped: file not found")
        return
    t = WRITE_PROPS.read_text(encoding="utf-8")
    o = t

    if PROPS_MARKER not in t:
        t = t.replace('PROPERTIES_FILE="${SERVER_DATA_DIR}/server.properties"\n',
                      'PROPERTIES_FILE="${SERVER_DATA_DIR}/server.properties"\nPROFILE_STATE_FILE="${SERVER_DATA_DIR}/.winomc/applied-profile.json"\n', 1)
        guard = r'''
# v2.0.0.6b preserve profile properties
if [ "${WINOMC_PRESERVE_PROFILE_PROPERTIES:-true}" != "false" ] && [ -f "${PROFILE_STATE_FILE}" ] && [ -f "${PROPERTIES_FILE}" ]; then
  echo "WinoMC native server.properties preserved: applied profile is active"
  exit 0
fi

'''
        t = t.replace('mkdir -p "${SERVER_DATA_DIR}"\n\ncat > "${PROPERTIES_FILE}" <<EOF\n',
                      'mkdir -p "${SERVER_DATA_DIR}"\n\n' + guard + 'cat > "${PROPERTIES_FILE}" <<EOF\n', 1)

    if t != o:
        WRITE_PROPS.write_text(t, encoding="utf-8")
        print("WinoMC %s server.properties persistence patch applied" % VERSION)
    else:
        print("WinoMC %s server.properties persistence patch already present" % VERSION)


def main():
    patch_console()
    patch_native_start()
    patch_write_properties()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
