#!/usr/bin/env python3
from pathlib import Path

p = Path('/usr/local/bin/winomc-console-server')
t = p.read_text(encoding='utf-8')
o = t

t = t.replace('2.0.0.2b', '2.0.0.3b')
t = t.replace("{ action: 'repair_all_safe', mode: 'safe', confirm: true }", "{ action: 'repair_all_safe', mode: 'expert', confirm: true }")
t = t.replace("{ action: t.dataset.diagnosticsRepair, mode: 'safe', confirm: true }", "{ action: t.dataset.diagnosticsRepair, mode: 'expert', confirm: true }")
t = t.replace("alert(result.message || 'Reparatur abgeschlossen.');", "appendLine('[Diagnose] ' + (result.message || 'Reparatur abgeschlossen.'), 'info');")
t = t.replace("frameworkCard('Keine Packs','-', 'Installierte Packs erscheinen hier.', 'Warnung')", "frameworkCard('Keine Packs','0', 'Keine lokalen Nutzer-Packs installiert.', 'OK')")

old = "data.checks.map(c=>frameworkCard(c.title,c.status,c.message,c.status)).join('') + '<div class=\"tile\"><button class=\"primary\" id=\"updatesPrepare2\" type=\"button\">Update vorbereiten</button><p>Erstellt Backup und markiert Update-Bereitschaft. Danach Add-on neu starten.</p></div>'"
new = "data.checks.map(c=>frameworkCard(c.title,c.status,c.message,c.status)).join('') + '<article class=\"tile\"><div class=\"tile-title\">Update-Ablauf</div><div class=\"tile-desc\">Kein Extra-Vorbereitungsschritt: Bei aktivem BDS_AUTO_UPDATE oder gesetzter VERSION reicht ein Add-on-Neustart. Erstelle vorher bei Bedarf ein Backup.</div></article>'"
t = t.replace(old, new)

xuid_helper = r'''

def known_player_xuid_2003(name):
    wanted = re.sub(r"\s+", " ", str(name or "").strip()).lower()
    if not wanted:
        return ""
    known = {}
    def add(n, x):
        n = str(n or "").strip()
        x = str(x or "").strip()
        if n and re.match(r"^[0-9]{5,32}$", x):
            key = re.sub(r"\s+", " ", n).lower()
            known[key] = x
            known[key.replace(" ", "")] = x
    for raw in re.split(r"[,;\n]+", os.environ.get("ALLOW_LIST_USERS", "") or ""):
        if ":" in raw:
            n, x = raw.split(":", 1)
            add(n, x)
    allow, _ = json_file(os.path.join(DATA_DIR, "allowlist.json"), [])
    if isinstance(allow, list):
        for item in allow:
            if isinstance(item, dict):
                add(item.get("name"), item.get("xuid"))
    patterns = (
        re.compile(r"Player connected:\s*([^,\n]+),\s*xuid:\s*([0-9]{5,32})", re.I),
        re.compile(r"\bname[:=\s]+([^,\n]+).*?\bxuid[:=\s]+([0-9]{5,32})", re.I),
    )
    for log_path in (runtime_log_path(), LOG_PATH):
        try:
            if not os.path.exists(log_path):
                continue
            with open(log_path, "r", encoding="utf-8", errors="replace") as handle:
                for line in handle.readlines()[-2500:]:
                    for pat in patterns:
                        m = pat.search(line)
                        if m:
                            add(m.group(1), m.group(2))
        except Exception:
            pass
    return known.get(wanted) or known.get(wanted.replace(" ", ""), "")
'''
if 'known_player_xuid_2003' not in t:
    t = t.replace('\n\ndef normalize_player_entry(item):', xuid_helper + '\n\ndef normalize_player_entry(item):', 1)

t = t.replace('    xuid = str(item.get("xuid") or "").strip()\n    if not name and not xuid:', '    xuid = str(item.get("xuid") or "").strip()\n    if name and not xuid:\n        xuid = known_player_xuid_2003(name)\n    if not name and not xuid:', 1)

persistent_block = r'''

# v2.0.0.3b persistent player-rights overlay
def _player_name_key_2003(name):
    return re.sub(r"\s+", " ", str(name or "").strip()).lower().replace(" ", "")

def _player_key_2003(player):
    xuid = str(player.get("xuid") or "").strip()
    if xuid:
        return "xuid:" + xuid
    return "name:" + _player_name_key_2003(player.get("name"))

def player_rights_store_path_2003():
    base = os.path.join(DATA_DIR, ".winomc")
    os.makedirs(base, exist_ok=True)
    return os.path.join(base, "player-rights.json")

def load_desired_player_rights_2003():
    data, err = json_file(player_rights_store_path_2003(), [])
    if err or not isinstance(data, list):
        return []
    clean = []
    for item in data:
        if not isinstance(item, dict):
            continue
        try:
            name = str(item.get("name") or "").strip()
            xuid = str(item.get("xuid") or "").strip()
            if not name and not xuid:
                continue
            if xuid and not re.match(r"^[0-9]{5,32}$", xuid):
                xuid = ""
            clean.append({"name": name, "xuid": xuid, "allowlisted": bool(item.get("allowlisted", True)), "role": normalize_role(item.get("role", "member")), "source": "WinoMC"})
        except Exception:
            continue
    return clean

def write_desired_player_rights_2003(players):
    path = player_rights_store_path_2003()
    rows = []
    seen = set()
    for player in players:
        key = _player_key_2003(player)
        if not key or key in seen:
            continue
        seen.add(key)
        rows.append({"name": player.get("name", ""), "xuid": player.get("xuid", ""), "allowlisted": bool(player.get("allowlisted", True)), "role": normalize_role(player.get("role", "member")), "updated_at": time.strftime("%Y-%m-%d_%H-%M-%S")})
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as handle:
        json.dump(rows, handle, ensure_ascii=False, indent=2)
        handle.write("\n")
    os.replace(tmp, path)
    return {"path": "/.winomc/player-rights.json", "count": len(rows)}

def players_payload():
    allow, ae = json_file(os.path.join(DATA_DIR, "allowlist.json"), [])
    perms, pe = json_file(os.path.join(DATA_DIR, "permissions.json"), [])
    allow = allow if isinstance(allow, list) else []
    perms = perms if isinstance(perms, list) else []
    by = {}
    for desired in load_desired_player_rights_2003():
        key = _player_key_2003(desired)
        by[key] = {"name": desired.get("name") or "-", "xuid": desired.get("xuid", ""), "allowlisted": bool(desired.get("allowlisted", True)), "role": normalize_role(desired.get("role", "member")), "issues": []}
    for item in allow:
        if not isinstance(item, dict):
            continue
        row = {"name": item.get("name", "-"), "xuid": item.get("xuid", ""), "allowlisted": True, "role": "member", "issues": []}
        key = _player_key_2003(row)
        existing = by.setdefault(key, row)
        existing["allowlisted"] = True
        if item.get("xuid"):
            existing["xuid"] = item.get("xuid")
        if item.get("name") and existing.get("name") in ("", "-"):
            existing["name"] = item.get("name")
    for perm in perms:
        if not isinstance(perm, dict):
            continue
        row = {"name": perm.get("name", "-"), "xuid": perm.get("xuid", ""), "allowlisted": False, "role": normalize_role(perm.get("permission", "member")), "issues": []}
        key = _player_key_2003(row)
        existing = by.setdefault(key, row)
        existing["role"] = normalize_role(perm.get("permission", "member"))
        if perm.get("xuid"):
            existing["xuid"] = perm.get("xuid")
    for row in by.values():
        if row.get("name") and not row.get("xuid"):
            row["xuid"] = known_player_xuid_2003(row.get("name"))
        if row.get("role") != "member" and not row.get("xuid"):
            row.setdefault("issues", []).append("Role is saved in WinoMC; Bedrock permissions.json needs XUID before it can take effect.")
        if row.get("role") == "operator" and not row.get("allowlisted"):
            row.setdefault("issues", []).append("OP is not on allowlist")
    warnings = []
    if ae: warnings.append("allowlist.json: " + ae)
    if pe: warnings.append("permissions.json: " + pe)
    if parse_bool(os.environ.get("ALLOW_LIST"), False) and not allow:
        warnings.append("Allowlist is enabled but empty.")
    if not parse_bool(os.environ.get("ONLINE_MODE"), True):
        warnings.append("Online mode is disabled and should only be used deliberately.")
    return {"ok": True, "players": list(by.values()), "warnings": warnings}

def save_players(players):
    if not isinstance(players, list):
        raise ValueError("players must be a list.")
    normalized = [normalize_player_entry(item) for item in players]
    seen = set()
    for player in normalized:
        key = _player_key_2003(player)
        if key in seen:
            raise ValueError("Duplicate player/XUID: %s" % key)
        seen.add(key)
    desired_result = write_desired_player_rights_2003(normalized)
    allowlist = []
    permissions = []
    staged = []
    for player in normalized:
        if player["allowlisted"]:
            entry = {"name": player["name"] or player["xuid"], "ignoresPlayerLimit": False}
            if player["xuid"]:
                entry["xuid"] = player["xuid"]
            allowlist.append(entry)
        if player["xuid"]:
            permissions.append({"permission": player["role"], "xuid": player["xuid"]})
        elif player["role"] != "member":
            staged.append(player["name"] or player["xuid"])
    allow_result = atomic_write_json_root("config", "/allowlist.json", allowlist, backup=True)
    perm_result = atomic_write_json_root("config", "/permissions.json", permissions, backup=True)
    payload = players_payload()
    message = "Player rights saved persistently."
    if staged:
        message += " Some non-member roles are staged until XUID is known: " + ", ".join(staged)
    payload.update({"saved": True, "desired_result": desired_result, "allowlist_result": allow_result, "permissions_result": perm_result, "message": message})
    return payload
'''
if 'persistent player-rights overlay' not in t:
    t = t.replace('\n\ndef find_backup_meta(backup_name):', persistent_block + '\n\ndef find_backup_meta(backup_name):', 1)

js = r'''
    /* v2.0.0.3b feedback polish */
    (() => {
      const setBox = (id, message) => { const el = document.getElementById(id); if (el) { el.className = 'info'; el.textContent = message; } };
      document.addEventListener('click', event => {
        const b = event.target.closest('button');
        if (!b) return;
        if (b.id === 'diagnosticsRun') setBox('diagnosticsSummary', 'Diagnose läuft… Dateien, Ordner und Serverstatus werden geprüft.');
        if (b.id === 'updatesCheck') { const e = document.getElementById('updatesSummary'); if (e) e.innerHTML = '<article class="tile"><div class="tile-title">Update-Check läuft…</div><div class="tile-desc">Backup, Speicherplatz, Zielversion und Schreibrechte werden geprüft.</div></article>'; }
        if (b.id === 'profilesLoad') { const e = document.getElementById('profilesGrid'); if (e) e.innerHTML = '<article class="tile"><div class="tile-title">Profile werden geladen…</div><div class="tile-desc">WinoMC liest die verfügbaren Erststart-Profile.</div></article>'; }
        if (b.id === 'updatesPrepare2') { event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation(); const e = document.getElementById('updatesSummary'); if (e) e.innerHTML += '<article class="tile"><div class="tile-title">Nicht nötig</div><div class="tile-desc">Dieser Schritt wurde entfernt. Ein Add-on-Neustart reicht bei Auto-Update oder gesetzter VERSION.</div></article>'; }
      }, true);
    })();
'''
if 'v2.0.0.3b feedback polish' not in t:
    t = t.replace('</script>', js + '\n</script>', 1)

if t != o:
    p.write_text(t, encoding='utf-8')
    print('WinoMC 2.0.0.3b polish applied')
else:
    print('WinoMC 2.0.0.3b polish already present')
