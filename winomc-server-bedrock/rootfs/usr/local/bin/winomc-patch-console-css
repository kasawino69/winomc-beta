#!/bin/sh
set -eu

python3 - <<'PY'
from pathlib import Path
import re

path = Path('/usr/local/bin/winomc-console-server')
if not path.exists():
    path = Path('winomc-server-bedrock/rootfs/usr/local/bin/winomc-console-server')

text = path.read_text(encoding='utf-8')
original = text

text = re.sub(
    r'<title>WinoMC Adaptive Workbench [^<]+</title>',
    '<title>WinoMC Adaptive Workbench 1.6.14.17</title>',
    text,
    count=1,
)
text = re.sub(
    r'server_version = "WinoMCConsole/[^"]+"',
    'server_version = "WinoMCConsole/1.6.14.17"',
    text,
    count=1,
)

# Remove only the risky runtime overlays from earlier beta repairs when present.
# They could keep stale handlers alive in a freshly patched console file.
for fn in (
    'hardenClassicPcDashboardEditor161414',
    'hardenPcDashboardFilesEditor161415',
    'separatePcEditorFilesDashboard161416',
):
    text = re.sub(
        r'\n\s*/\*[^*]*v1\.6\.14\.(?:14|15|16)b[\s\S]*?\*/\s*\n\s*\(function ' + fn + r'\(\) \{[\s\S]*?\n\s*\}\)\(\);\s*\n',
        '\n',
        text,
        count=1,
    )

css_fix = r'''

    /* v1.6.14.17b PC editor + desktop file explorer repair
       Minimaler Reparatur-Override nach 1.6.14.16b:
       - Mobile: nur der aktive Tab darf sichtbar sein.
       - PC: Editor ist ein eigenes großes Overlay, nicht Teil des Explorer-Grids.
       - Desktop-Dateifenster: Explorer belegt die Fensterhöhe, Liste scrollt intern. */
    body.ux-mobile:not(.desktop-mode) .content > .tab-panel,
    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    body.ux-mobile:not(.desktop-mode) .content > .tab-panel.active {
      display: grid !important;
      visibility: visible !important;
      pointer-events: auto !important;
    }

    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .file-manager-grid,
    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .file-explorer-panel,
    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .editor-panel {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    @media (min-width: 1051px) {
      body.ux-desktop.editor-fullscreen-active::after,
      body.ux-desktop.has-maximized-card.editor-fullscreen-active::after,
      body.desktop-mode.has-maximized-card.editor-fullscreen-active::after,
      body.desktop-mode.editor-fullscreen-active::after {
        content: none !important;
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
        backdrop-filter: none !important;
        background: transparent !important;
      }

      body.ux-desktop .editor-panel.editor-open,
      body.ux-desktop .editor-panel.editor-fullscreen,
      body.desktop-mode .editor-panel.editor-open,
      body.desktop-mode .editor-panel.editor-fullscreen {
        position: fixed !important;
        z-index: 220 !important;
        width: auto !important;
        height: auto !important;
        min-width: 0 !important;
        min-height: 0 !important;
        max-width: none !important;
        max-height: none !important;
        display: flex !important;
        flex-direction: column !important;
        overflow: hidden !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
        background: rgba(15, 23, 42, .99) !important;
        border: 1px solid rgba(96, 165, 250, .38) !important;
        box-shadow: 0 28px 90px rgba(0, 0, 0, .72) !important;
        backdrop-filter: none !important;
      }

      body.ux-desktop:not(.desktop-mode):not(.console-maximized) .editor-panel.editor-open,
      body.ux-desktop:not(.desktop-mode):not(.console-maximized) .editor-panel.editor-fullscreen {
        inset: 18px 18px calc(var(--console-height) + 18px) 18px !important;
      }

      body.ux-desktop.console-maximized .editor-panel.editor-open,
      body.ux-desktop.console-maximized .editor-panel.editor-fullscreen,
      body.desktop-mode .editor-panel.editor-open,
      body.desktop-mode .editor-panel.editor-fullscreen {
        inset: 18px !important;
      }

      body.ux-desktop .editor-panel.editor-open::before,
      body.ux-desktop .editor-panel.editor-fullscreen::before,
      body.desktop-mode .editor-panel.editor-open::before,
      body.desktop-mode .editor-panel.editor-fullscreen::before {
        content: none !important;
        display: none !important;
        pointer-events: none !important;
      }

      body.ux-desktop .editor-panel.editor-open .editor-box,
      body.ux-desktop .editor-panel.editor-fullscreen .editor-box,
      body.desktop-mode .editor-panel.editor-open .editor-box,
      body.desktop-mode .editor-panel.editor-fullscreen .editor-box {
        flex: 1 1 auto !important;
        height: auto !important;
        min-height: 0 !important;
        max-height: none !important;
        resize: none !important;
        overflow: auto !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"].desktop-open:not(.desktop-minimized) {
        display: grid !important;
        grid-template-rows: auto minmax(0, 1fr) !important;
        align-content: stretch !important;
        overflow: hidden !important;
        min-width: min(1120px, calc(100dvw - 32px)) !important;
        min-height: min(760px, calc(100dvh - 72px)) !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"].desktop-maximized {
        min-width: 0 !important;
        min-height: 0 !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .file-manager-grid,
      body.desktop-mode .tab-panel[data-panel="files"] .file-manager-grid.editor-visible,
      body.desktop-mode .tab-panel[data-panel="files"] .file-manager-grid:not(.editor-visible) {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) !important;
        grid-template-rows: minmax(0, 1fr) !important;
        gap: 0 !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
        align-items: stretch !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .split-resizer {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .editor-panel:not(.editor-open):not(.editor-fullscreen) {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .file-explorer-panel {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .file-explorer-panel > .card-header,
      body.desktop-mode .tab-panel[data-panel="files"] .file-explorer-panel > .drop-zone {
        flex: 0 0 auto !important;
      }

      body.desktop-mode .tab-panel[data-panel="files"] .file-table-wrap {
        flex: 1 1 auto !important;
        min-height: 320px !important;
        height: auto !important;
        max-height: none !important;
        overflow: auto !important;
        padding-bottom: 18px !important;
        scroll-padding-bottom: 18px !important;
        scrollbar-gutter: stable !important;
        overscroll-behavior: contain !important;
      }

      body.ux-desktop:not(.desktop-mode) .tab-panel[data-panel="dashboard"].active {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
      }

      body.ux-desktop:not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-layout,
      body.ux-desktop:not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-add-card {
        flex: 0 0 auto !important;
        min-height: 0 !important;
      }

      body.ux-desktop:not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-active-card {
        flex: 1 1 auto !important;
        min-height: 0 !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
        scrollbar-gutter: stable !important;
        overscroll-behavior: contain !important;
        padding-bottom: 22px !important;
      }
    }
'''

if 'v1.6.14.17b PC editor + desktop file explorer repair' not in text:
    text = text.replace('  </style>', css_fix + '  </style>', 1)

runtime_fix = r'''

    /* v1.6.14.17b runtime repair: mobile tab isolation + PC editor overlay */
    (function repairUiAfter161416() {
      function clearEditorCardState161417() {
        document.body.classList.remove('has-maximized-card');
        document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));
      }

      function isMobileShell161417() {
        return document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode');
      }

      function isolateMobileTabs161417() {
        if (!isMobileShell161417()) return;
        document.body.classList.remove('desktop-mode', 'has-maximized-card', 'editor-fullscreen-active');
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('desktop-open', 'desktop-minimized', 'desktop-maximized'));
        const activePanel = document.querySelector('.tab-panel.active') || document.querySelector('.tab-panel[data-panel="overview"]');
        const active = activePanel?.dataset?.panel || 'overview';
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === active));
        document.querySelectorAll('[data-tab]').forEach(button => button.classList.toggle('active', button.dataset.tab === active));
      }

      function setEditorOverlay161417(fullscreen) {
        if (!editorPanel) return;
        clearEditorCardState161417();
        editorPanel.classList.add('editor-open');
        editorPanel.classList.toggle('editor-fullscreen', Boolean(fullscreen));
        document.body.classList.toggle('editor-fullscreen-active', Boolean(fullscreen));
        if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
        if (editorFullscreen) editorFullscreen.textContent = fullscreen ? 'Normal' : 'Vollbild';
        window.requestAnimationFrame(() => fileEditor?.focus({ preventScroll: true }));
      }

      function closeEditorOverlay161417() {
        if (!editorPanel) return;
        editorPanel.classList.remove('editor-open', 'editor-fullscreen');
        document.body.classList.remove('editor-fullscreen-active');
        if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
        if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      }

      const previousOpenEditorOverlay161417 = openEditorOverlay;
      openEditorOverlay = function() {
        const result = previousOpenEditorOverlay161417.apply(this, arguments);
        if (document.body.classList.contains('ux-desktop') || document.body.classList.contains('desktop-mode')) {
          setEditorOverlay161417(false);
        }
        isolateMobileTabs161417();
        return result;
      };

      closeEditorOverlay = function() {
        closeEditorOverlay161417();
      };

      if (editorFullscreen) {
        editorFullscreen.addEventListener('click', event => {
          if (!(document.body.classList.contains('ux-desktop') || document.body.classList.contains('desktop-mode'))) return;
          event.preventDefault();
          event.stopImmediatePropagation();
          setEditorOverlay161417(!editorPanel.classList.contains('editor-fullscreen'));
        }, true);
      }

      function repairDesktopFilesWindow161417() {
        if (!document.body.classList.contains('desktop-mode')) return;
        const panel = document.querySelector('.tab-panel[data-panel="files"]');
        if (!panel || !panel.classList.contains('desktop-open') || panel.classList.contains('desktop-minimized') || panel.classList.contains('desktop-maximized')) return;
        if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
        const rect = panel.getBoundingClientRect();
        const minWidth = Math.min(window.innerWidth - 32, 1120);
        const minHeight = Math.min(window.innerHeight - 72, 760);
        let changed = false;
        if (rect.width < minWidth) { panel.style.width = Math.max(760, minWidth) + 'px'; changed = true; }
        if (rect.height < minHeight) { panel.style.height = Math.max(560, minHeight) + 'px'; changed = true; }
        if (changed && typeof saveDesktopPosition === 'function') saveDesktopPosition('files', panel);
      }

      const previousOpenDesktopWindow161417 = openDesktopWindow;
      openDesktopWindow = function(id) {
        const result = previousOpenDesktopWindow161417.apply(this, arguments);
        window.requestAnimationFrame(() => {
          if (id === 'files') repairDesktopFilesWindow161417();
          isolateMobileTabs161417();
        });
        return result;
      };

      document.querySelectorAll('[data-tab]').forEach(button => {
        button.addEventListener('click', () => window.requestAnimationFrame(isolateMobileTabs161417), true);
      });

      window.addEventListener('resize', () => window.requestAnimationFrame(() => {
        isolateMobileTabs161417();
        repairDesktopFilesWindow161417();
      }), { passive: true });

      window.requestAnimationFrame(() => {
        isolateMobileTabs161417();
        repairDesktopFilesWindow161417();
      });
      window.setTimeout(() => {
        isolateMobileTabs161417();
        repairDesktopFilesWindow161417();
      }, 300);
    })();
'''

if 'v1.6.14.17b runtime repair: mobile tab isolation + PC editor overlay' not in text:
    text = text.replace('\n</script>\n</body>\n</html>', runtime_fix + '\n</script>\n</body>\n</html>', 1)

if text != original:
    path.write_text(text, encoding='utf-8')
PY
