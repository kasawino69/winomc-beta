#!/bin/sh
set -eu

python3 - <<'PY'
from pathlib import Path
import re

console_path = Path('/usr/local/bin/winomc-console-server')
if not console_path.exists():
    console_path = Path('winomc-server-bedrock/rootfs/usr/local/bin/winomc-console-server')

asset_root = Path('/usr/local/share/winomc-console')
if not asset_root.exists():
    asset_root = Path('winomc-server-bedrock/rootfs/usr/local/share/winomc-console')

required_assets = {
    'pc_css': asset_root / 'pc.css',
    'mobile_css': asset_root / 'mobile.css',
    'pc_js': asset_root / 'pc.js',
    'mobile_js': asset_root / 'mobile.js',
    'router_js': asset_root / 'shell-router.js',
}
missing = [str(path) for path in required_assets.values() if not path.exists()]
if missing:
    raise SystemExit('WinoMC UI split assets missing: ' + ', '.join(missing))

text = console_path.read_text(encoding='utf-8')
original = text

text = re.sub(
    r'<title>WinoMC Adaptive Workbench [^<]+</title>',
    '<title>WinoMC Adaptive Workbench 1.6.14.22</title>',
    text,
    count=1,
)
text = re.sub(
    r'server_version = "WinoMCConsole/[^"]+"',
    'server_version = "WinoMCConsole/1.6.14.22"',
    text,
    count=1,
)

# Remove all older injected UI repair blocks. The point of 1.6.14.22b is to
# stop layering emergency fixes and install one strict PC/Mobile split.
style_ids = (
    'winomc-split-overrides-161418',
    'winomc-pc-mobile-split-161419',
    'winomc-pc-editor-stable-161420',
    'winomc-pc-ui-161421',
    'winomc-mobile-ui-161421',
    'winomc-pc-ui-161422',
    'winomc-mobile-ui-161422',
)
for style_id in style_ids:
    text = re.sub(
        r'\n\s*<style id="' + re.escape(style_id) + r'">[\s\S]*?</style>\s*\n',
        '\n',
        text,
        count=0,
    )

# Remove older inline runtime guards and any previous 1.6.14.22b injection.
runtime_functions = (
    'hardenClassicPcDashboardEditor161414',
    'hardenPcDashboardFilesEditor161415',
    'separatePcEditorFilesDashboard161416',
    'repairUiAfter161416',
    'splitMobileAndPcRuntime161418',
    'splitPcMobileRuntime161419',
    'stablePcEditorRuntime161420',
    'WinoMCPCUI',
    'WinoMCMobileUI',
    'WinoMCShellRouter',
)
for fn in runtime_functions:
    text = re.sub(
        r'\n\s*/\*[^*]*(?:v1\.6\.14\.(?:14|15|16|17|18|19|20|21|22)b|WinoMC (?:PC|Mobile|shell router) UI 1\.6\.14\.(?:21|22)b|BEGIN winomc-[^*]+)[\s\S]*?\*/\s*\n\s*\(function ' + re.escape(fn) + r'\(\) \{[\s\S]*?\n\s*\}\)\(\);\s*\n',
        '\n',
        text,
        count=0,
    )

# Also remove explicit marked 1.6.14.22b script blocks if the patcher is run
# repeatedly against an already patched console-server.
for marker in ('pc-ui', 'mobile-ui', 'shell-router'):
    text = re.sub(
        r'\n\s*/\* BEGIN winomc-' + marker + r'-161422 \*/[\s\S]*?/\* END winomc-' + marker + r'-161422 \*/\s*\n',
        '\n',
        text,
        count=0,
    )

pc_css = required_assets['pc_css'].read_text(encoding='utf-8').strip()
mobile_css = required_assets['mobile_css'].read_text(encoding='utf-8').strip()
pc_js = required_assets['pc_js'].read_text(encoding='utf-8').strip()
mobile_js = required_assets['mobile_js'].read_text(encoding='utf-8').strip()
router_js = required_assets['router_js'].read_text(encoding='utf-8').strip()

style_block = (
    '\n  <style id="winomc-pc-ui-161422">\n'
    + pc_css
    + '\n  </style>\n'
    + '  <style id="winomc-mobile-ui-161422">\n'
    + mobile_css
    + '\n  </style>\n'
)
if '</head>' not in text:
    raise SystemExit('Could not find closing head marker in winomc-console-server')
text = text.replace('</head>', style_block + '\n</head>', 1)

script_block = (
    '\n    /* BEGIN winomc-pc-ui-161422 */\n'
    + pc_js
    + '\n    /* END winomc-pc-ui-161422 */\n'
    + '\n    /* BEGIN winomc-mobile-ui-161422 */\n'
    + mobile_js
    + '\n    /* END winomc-mobile-ui-161422 */\n'
    + '\n    /* BEGIN winomc-shell-router-161422 */\n'
    + router_js
    + '\n    /* END winomc-shell-router-161422 */\n'
)
closing = '\n</' + 'script>\n</body>\n</html>'
if closing not in text:
    raise SystemExit('Could not find closing script/body/html marker in winomc-console-server')
text = text.replace(closing, script_block + closing, 1)

if text != original:
    console_path.write_text(text, encoding='utf-8')
PY
