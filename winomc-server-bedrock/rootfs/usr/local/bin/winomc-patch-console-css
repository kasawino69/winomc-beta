#!/bin/sh
set -eu

python3 - <<'PY'
from pathlib import Path
import re

path = Path('/usr/local/bin/winomc-console-server')
if not path.exists():
    path = Path('winomc-server-bedrock/rootfs/usr/local/bin/winomc-console-server')

text = path.read_text(encoding='utf-8')
original = text

text = re.sub(
    r'<title>WinoMC Adaptive Workbench [^<]+</title>',
    '<title>WinoMC Adaptive Workbench 1.6.14.18</title>',
    text,
    count=1,
)
text = re.sub(
    r'server_version = "WinoMCConsole/[^"]+"',
    'server_version = "WinoMCConsole/1.6.14.18"',
    text,
    count=1,
)

# Runtime-Guards aus vorherigen Beta-Fixes entfernen. Diese wurden am Ende des
# Skripts eingefügt und konnten Klicks/Editor-Zustände doppelt behandeln.
for fn in (
    'hardenClassicPcDashboardEditor161414',
    'hardenPcDashboardFilesEditor161415',
    'separatePcEditorFilesDashboard161416',
    'repairUiAfter161416',
):
    text = re.sub(
        r'\n\s*/\*[^*]*v1\.6\.14\.(?:14|15|16|17)b[\s\S]*?\*/\s*\n\s*\(function ' + fn + r'\(\) \{[\s\S]*?\n\s*\}\)\(\);\s*\n',
        '\n',
        text,
        count=1,
    )

# Core-Funktionen hart trennen: Mobile nutzt sein Modal; PC nutzt ein eigenes
# großes Editor-Overlay ohne Card-Maximize/Blur-Backdrop. Die Funktionen werden
# im eigentlichen Webconsole-Code ersetzt, nicht als weiterer Button-Flicker.
old_open = """    function openEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.add('editor-open');
      editorPanel.classList.remove('editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      if (fileCloseEditor) fileCloseEditor.textContent = 'Schließen';
      if (document.body.classList.contains('ux-mobile') && !document.body.classList.contains('console-collapsed')) setConsoleMode('collapsed');
      window.setTimeout(() => fileEditor?.focus({ preventScroll: true }), 80);
    }
"""
new_open = """    function isPcShell() {
      return (document.body.classList.contains('ux-desktop') || document.body.classList.contains('desktop-mode')) && !document.body.classList.contains('ux-mobile');
    }

    function isMobileShell() {
      return document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode');
    }

    function clearPcEditorBlockers() {
      document.body.classList.remove('has-maximized-card');
      document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));
      document.querySelectorAll('.editor-modal-backdrop, .modal-backdrop').forEach(backdrop => {
        backdrop.setAttribute('aria-hidden', 'true');
        backdrop.style.display = 'none';
        backdrop.style.visibility = 'hidden';
        backdrop.style.pointerEvents = 'none';
        backdrop.style.opacity = '0';
      });
    }

    function openEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.add('editor-open');
      editorPanel.classList.remove('editor-fullscreen');
      if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      if (fileCloseEditor) fileCloseEditor.textContent = 'Schließen';
      if (isPcShell()) {
        document.body.classList.remove('editor-modal-open');
        document.body.classList.add('pc-editor-open');
        document.body.classList.remove('pc-editor-fullscreen');
        clearPcEditorBlockers();
      } else if (isMobileShell()) {
        document.body.classList.add('editor-modal-open');
        document.body.classList.remove('pc-editor-open', 'pc-editor-fullscreen');
        if (!document.body.classList.contains('console-collapsed')) setConsoleMode('collapsed');
      }
      window.setTimeout(() => fileEditor?.focus({ preventScroll: true }), 80);
    }
"""
if old_open in text:
    text = text.replace(old_open, new_open, 1)

old_close = """    function closeEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.remove('editor-open', 'editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
    }
"""
new_close = """    function closeEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.remove('editor-open', 'editor-fullscreen');
      document.body.classList.remove('editor-modal-open', 'pc-editor-open', 'pc-editor-fullscreen');
      if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      if (isPcShell()) clearPcEditorBlockers();
    }
"""
if old_close in text:
    text = text.replace(old_close, new_close, 1)

old_toggle = """    function toggleEditorFullscreen() {
      editorPanel.classList.add('editor-open');
      editorPanel.classList.toggle('editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = editorPanel.classList.contains('editor-fullscreen') ? 'Normal' : 'Vollbild';
    }
"""
new_toggle = """    function toggleEditorFullscreen(event) {
      if (event) {
        event.preventDefault();
        event.stopPropagation();
      }
      if (!editorPanel) return;
      editorPanel.classList.add('editor-open');
      const nextFullscreen = !editorPanel.classList.contains('editor-fullscreen');
      editorPanel.classList.toggle('editor-fullscreen', nextFullscreen);
      if (isPcShell()) {
        document.body.classList.remove('editor-modal-open');
        document.body.classList.add('pc-editor-open');
        document.body.classList.toggle('pc-editor-fullscreen', nextFullscreen);
        clearPcEditorBlockers();
      }
      if (editorFullscreen) editorFullscreen.textContent = nextFullscreen ? 'Normal' : 'Vollbild';
      window.requestAnimationFrame(() => fileEditor?.focus({ preventScroll: true }));
    }
"""
if old_toggle in text:
    text = text.replace(old_toggle, new_toggle, 1)

mobile_css = r'''

    /* v1.6.14.18b MOBILE SCOPE ONLY
       Mobile ist getrennt: nur der aktive Menüpunkt wird angezeigt. Keine PC-
       Workbench-/Desktop-Fensterregeln greifen hier. */
    body.ux-mobile:not(.desktop-mode) .content > .tab-panel:not(.active) {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    body.ux-mobile:not(.desktop-mode) .content > .tab-panel.active {
      display: grid !important;
      visibility: visible !important;
      pointer-events: auto !important;
    }

    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .file-manager-grid,
    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .file-explorer-panel,
    body.ux-mobile:not(.desktop-mode) .tab-panel[data-panel="files"]:not(.active) .editor-panel {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
'''

pc_css = r'''

    /* v1.6.14.18b PC SCOPE ONLY
       PC wird neu abgegrenzt: Dateiexplorer nutzt ein einspaltiges, hohes Fenster.
       Der Editor ist ein eigenes Vordergrundfenster und nicht mehr Teil des
       Explorer-Grids. Dadurch beeinflusst Mobile diese Regeln nicht mehr. */
    @media (min-width: 1051px) {
      body.ux-desktop:not(.ux-mobile) .editor-modal-backdrop,
      body.ux-desktop:not(.ux-mobile).editor-modal-open .editor-modal-backdrop,
      body.desktop-mode:not(.ux-mobile) .editor-modal-backdrop,
      body.desktop-mode:not(.ux-mobile).editor-modal-open .editor-modal-backdrop,
      body.ux-desktop:not(.ux-mobile) .modal-backdrop:not(.open),
      body.desktop-mode:not(.ux-mobile) .modal-backdrop:not(.open) {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
        opacity: 0 !important;
        backdrop-filter: none !important;
      }

      body.ux-desktop:not(.ux-mobile).pc-editor-open,
      body.ux-desktop:not(.ux-mobile).pc-editor-fullscreen,
      body.desktop-mode:not(.ux-mobile).pc-editor-open,
      body.desktop-mode:not(.ux-mobile).pc-editor-fullscreen {
        overflow: hidden !important;
      }

      body.ux-desktop:not(.ux-mobile).pc-editor-open::after,
      body.ux-desktop:not(.ux-mobile).pc-editor-fullscreen::after,
      body.desktop-mode:not(.ux-mobile).pc-editor-open::after,
      body.desktop-mode:not(.ux-mobile).pc-editor-fullscreen::after,
      body.ux-desktop:not(.ux-mobile).has-maximized-card.pc-editor-open::after,
      body.desktop-mode:not(.ux-mobile).has-maximized-card.pc-editor-open::after {
        content: none !important;
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
        backdrop-filter: none !important;
        background: transparent !important;
      }

      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-open,
      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-fullscreen,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-open,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-fullscreen {
        position: fixed !important;
        z-index: 260 !important;
        inset: 20px !important;
        width: auto !important;
        height: auto !important;
        min-width: 0 !important;
        min-height: 0 !important;
        max-width: none !important;
        max-height: none !important;
        display: flex !important;
        flex-direction: column !important;
        overflow: hidden !important;
        visibility: visible !important;
        opacity: 1 !important;
        pointer-events: auto !important;
        background: rgba(15, 23, 42, .995) !important;
        border: 1px solid rgba(96, 165, 250, .40) !important;
        border-radius: 16px !important;
        box-shadow: 0 34px 110px rgba(0, 0, 0, .76) !important;
        backdrop-filter: none !important;
      }

      body.ux-desktop:not(.ux-mobile):not(.desktop-mode):not(.console-maximized) .editor-panel.editor-open,
      body.ux-desktop:not(.ux-mobile):not(.desktop-mode):not(.console-maximized) .editor-panel.editor-fullscreen {
        inset: 18px 18px calc(var(--console-height) + 18px) 18px !important;
      }

      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-open::before,
      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-fullscreen::before,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-open::before,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-fullscreen::before {
        content: none !important;
        display: none !important;
        pointer-events: none !important;
      }

      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-open .editor-box,
      body.ux-desktop:not(.ux-mobile) .editor-panel.editor-fullscreen .editor-box,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-open .editor-box,
      body.desktop-mode:not(.ux-mobile) .editor-panel.editor-fullscreen .editor-box {
        flex: 1 1 auto !important;
        height: auto !important;
        min-height: 0 !important;
        max-height: none !important;
        resize: none !important;
        overflow: auto !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"].desktop-open:not(.desktop-minimized) {
        display: grid !important;
        grid-template-rows: auto minmax(0, 1fr) !important;
        align-content: stretch !important;
        overflow: hidden !important;
        width: min(1280px, calc(100dvw - 32px)) !important;
        height: min(820px, calc(100dvh - 72px)) !important;
        min-width: min(960px, calc(100dvw - 32px)) !important;
        min-height: min(680px, calc(100dvh - 72px)) !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"].desktop-maximized {
        left: 8px !important;
        top: 8px !important;
        width: calc(100dvw - 16px) !important;
        height: calc(100dvh - 64px) !important;
        min-width: 0 !important;
        min-height: 0 !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-manager-grid,
      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-manager-grid.editor-visible,
      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-manager-grid:not(.editor-visible) {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) !important;
        grid-template-rows: minmax(0, 1fr) !important;
        gap: 0 !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
        align-items: stretch !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .split-resizer,
      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .editor-panel:not(.editor-open):not(.editor-fullscreen) {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-explorer-panel {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-explorer-panel > .card-header,
      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-explorer-panel > .drop-zone {
        flex: 0 0 auto !important;
      }

      body.desktop-mode:not(.ux-mobile) .tab-panel[data-panel="files"] .file-table-wrap {
        flex: 1 1 auto !important;
        min-height: 360px !important;
        height: auto !important;
        max-height: none !important;
        overflow: auto !important;
        padding-bottom: 24px !important;
        scroll-padding-bottom: 24px !important;
        scrollbar-gutter: stable !important;
        overscroll-behavior: contain !important;
      }

      body.ux-desktop:not(.ux-mobile):not(.desktop-mode) .tab-panel[data-panel="dashboard"].active {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        min-height: 0 !important;
        max-height: 100% !important;
        overflow: hidden !important;
      }

      body.ux-desktop:not(.ux-mobile):not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-layout,
      body.ux-desktop:not(.ux-mobile):not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-add-card {
        flex: 0 0 auto !important;
        min-height: 0 !important;
      }

      body.ux-desktop:not(.ux-mobile):not(.desktop-mode) .tab-panel[data-panel="dashboard"] .dashboard-active-card {
        flex: 1 1 auto !important;
        min-height: 0 !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
        scrollbar-gutter: stable !important;
        overscroll-behavior: contain !important;
        padding-bottom: 22px !important;
      }
    }
'''

if 'v1.6.14.18b MOBILE SCOPE ONLY' not in text:
    text = text.replace('  </style>', mobile_css + '  </style>', 1)
if 'v1.6.14.18b PC SCOPE ONLY' not in text:
    text = text.replace('  </style>', pc_css + '  </style>', 1)

runtime = r'''

    /* v1.6.14.18b split runtime: Mobile stays mobile, PC gets its own editor/window logic. */
    (function splitMobileAndPcRuntime161418() {
      function mobileShell161418() {
        return document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode');
      }
      function pcShell161418() {
        return !document.body.classList.contains('ux-mobile') && (document.body.classList.contains('ux-desktop') || document.body.classList.contains('desktop-mode'));
      }
      function clearPcBlockers161418() {
        if (!pcShell161418()) return;
        document.body.classList.remove('editor-modal-open', 'has-maximized-card');
        document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));
        document.querySelectorAll('.editor-modal-backdrop, .modal-backdrop').forEach(backdrop => {
          backdrop.setAttribute('aria-hidden', 'true');
          backdrop.style.display = 'none';
          backdrop.style.visibility = 'hidden';
          backdrop.style.pointerEvents = 'none';
          backdrop.style.opacity = '0';
        });
      }
      function isolateMobileTabs161418() {
        if (!mobileShell161418()) return;
        document.body.classList.remove('desktop-mode', 'pc-editor-open', 'pc-editor-fullscreen', 'has-maximized-card');
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('desktop-open', 'desktop-minimized', 'desktop-maximized'));
        const activePanel = document.querySelector('.tab-panel.active') || document.querySelector('.tab-panel[data-panel="overview"]');
        const active = activePanel?.dataset?.panel || 'overview';
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === active));
        document.querySelectorAll('[data-tab]').forEach(button => button.classList.toggle('active', button.dataset.tab === active));
      }
      function repairPcFilesWindow161418() {
        if (!document.body.classList.contains('desktop-mode') || document.body.classList.contains('ux-mobile')) return;
        const panel = document.querySelector('.tab-panel[data-panel="files"]');
        if (!panel || !panel.classList.contains('desktop-open') || panel.classList.contains('desktop-minimized') || panel.classList.contains('desktop-maximized')) return;
        if (fileManagerGrid) fileManagerGrid.classList.remove('editor-visible');
        const minWidth = Math.min(window.innerWidth - 32, 1120);
        const minHeight = Math.min(window.innerHeight - 72, 720);
        const rect = panel.getBoundingClientRect();
        let changed = false;
        if (rect.width < minWidth) { panel.style.width = Math.max(860, minWidth) + 'px'; changed = true; }
        if (rect.height < minHeight) { panel.style.height = Math.max(620, minHeight) + 'px'; changed = true; }
        if (changed && typeof saveDesktopPosition === 'function') saveDesktopPosition('files', panel);
      }

      const originalActivateTab161418 = activateTab;
      activateTab = function(tab) {
        const result = originalActivateTab161418.apply(this, arguments);
        window.requestAnimationFrame(() => {
          isolateMobileTabs161418();
          clearPcBlockers161418();
          repairPcFilesWindow161418();
        });
        return result;
      };

      const originalOpenDesktopWindow161418 = openDesktopWindow;
      openDesktopWindow = function(id) {
        const result = originalOpenDesktopWindow161418.apply(this, arguments);
        window.requestAnimationFrame(() => {
          clearPcBlockers161418();
          if (id === 'files') repairPcFilesWindow161418();
        });
        return result;
      };

      document.addEventListener('click', event => {
        if (event.target.closest('#editorFullscreen') && pcShell161418()) {
          event.preventDefault();
          event.stopImmediatePropagation();
          toggleEditorFullscreen(event);
        }
      }, true);

      window.addEventListener('resize', () => window.requestAnimationFrame(() => {
        isolateMobileTabs161418();
        clearPcBlockers161418();
        repairPcFilesWindow161418();
      }), { passive: true });

      window.requestAnimationFrame(() => {
        isolateMobileTabs161418();
        clearPcBlockers161418();
        repairPcFilesWindow161418();
      });
      window.setTimeout(() => {
        isolateMobileTabs161418();
        clearPcBlockers161418();
        repairPcFilesWindow161418();
      }, 300);
    })();
'''

if 'v1.6.14.18b split runtime' not in text:
    text = text.replace('\n</script>\n</body>\n</html>', runtime + '\n</script>\n</body>\n</html>', 1)

if text != original:
    path.write_text(text, encoding='utf-8')
PY
