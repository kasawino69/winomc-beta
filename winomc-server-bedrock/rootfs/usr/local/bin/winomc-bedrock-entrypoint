#!/bin/sh
set -eu

OPTIONS_FILE="/data/options.json"
SERVER_DATA_DIR="${WINOMC_DATA_DIR:-/config}"

export EULA="TRUE"
export WINOMC_DATA_DIR="${SERVER_DATA_DIR}"

# Export Home-Assistant add-on options as environment variables.
if [ -f "${OPTIONS_FILE}" ]; then
  for key in $(jq -r 'keys[]' "${OPTIONS_FILE}"); do
    case "${key}" in
      *[!A-Z0-9_]*|"")
        echo "Skipping invalid option key: ${key}"
        continue
        ;;
    esac
    value="$(jq -r --arg key "${key}" '.[$key] | if type == "boolean" then tostring elif . == null then "" else tostring end' "${OPTIONS_FILE}")"
    if [ -n "${value}" ]; then
      export "${key}=${value}"
    fi
  done
fi

WINOMC_MANAGER_PORT="${WINOMC_MANAGER_PORT:-${WINOMC_CONSOLE_PORT:-8099}}"
WINOMC_SECURITY_MODE="${WINOMC_SECURITY_MODE:-protected}"
WINOMC_LOG_LEVEL="${WINOMC_LOG_LEVEL:-info}"
WINOMC_IMPORT_DIR="${WINOMC_IMPORT_DIR:-/share/winomc/import}"
WINOMC_EXPORT_DIR="${WINOMC_EXPORT_DIR:-/share/winomc/export}"
WINOMC_BACKUP_DIR="${WINOMC_BACKUP_DIR:-/share/winomc/backups}"
WINOMC_MANAGER_UI_DIR="${WINOMC_MANAGER_UI_DIR:-/usr/local/share/winomc-manager}"
WINOMC_CONSOLE_LOG="${WINOMC_CONSOLE_LOG:-/tmp/winomc-manager.log}"
WINOMC_STATE_DIR="${WINOMC_STATE_DIR:-${SERVER_DATA_DIR}/.winomc}"
WINOMC_INSTANCES_DIR="${WINOMC_INSTANCES_DIR:-${SERVER_DATA_DIR}/instances}"
WINOMC_BDS_SHARED_DIR="${WINOMC_BDS_SHARED_DIR:-${WINOMC_STATE_DIR}/bds/shared}"
WINOMC_CONSOLE_ALLOWED_PROXIES="${WINOMC_CONSOLE_ALLOWED_PROXIES:-172.30.32.2,127.0.0.1,::1}"

export WINOMC_MANAGER_PORT
export WINOMC_CONSOLE_PORT="${WINOMC_MANAGER_PORT}"
export WINOMC_SECURITY_MODE
export WINOMC_LOG_LEVEL
export WINOMC_IMPORT_DIR
export WINOMC_EXPORT_DIR
export WINOMC_BACKUP_DIR
export WINOMC_MANAGER_UI_DIR
export WINOMC_CONSOLE_LOG
export WINOMC_STATE_DIR
export WINOMC_INSTANCES_DIR
export WINOMC_BDS_SHARED_DIR
export WINOMC_CONSOLE_ALLOWED_PROXIES

mkdir -p \
  "${SERVER_DATA_DIR}" \
  "${WINOMC_STATE_DIR}" \
  "${WINOMC_INSTANCES_DIR}" \
  "${WINOMC_BDS_SHARED_DIR}" \
  "${WINOMC_IMPORT_DIR}" \
  "${WINOMC_EXPORT_DIR}" \
  "${WINOMC_BACKUP_DIR}"

touch "${WINOMC_CONSOLE_LOG}"
cd "${SERVER_DATA_DIR}"

cat <<LOG
Starting WinoMC Manager 2.1b.1
DATA_DIR=${SERVER_DATA_DIR}
INSTANCES_DIR=${WINOMC_INSTANCES_DIR}
IMPORT_DIR=${WINOMC_IMPORT_DIR}
EXPORT_DIR=${WINOMC_EXPORT_DIR}
BACKUP_DIR=${WINOMC_BACKUP_DIR}
BDS_SHARED_DIR=${WINOMC_BDS_SHARED_DIR}
MANAGER_UI_DIR=${WINOMC_MANAGER_UI_DIR}
SECURITY_MODE=${WINOMC_SECURITY_MODE}
WINOMC_MANAGER_PORT=${WINOMC_MANAGER_PORT}
Manager-only boot: no global Single-Server runtime is started automatically.
Create and start Bedrock instances from the WinoMC Manager webpanel.
LOG

if [ ! -f "${WINOMC_MANAGER_UI_DIR}/index.html" ]; then
  echo "WARN: Manager UI index missing at ${WINOMC_MANAGER_UI_DIR}/index.html"
fi

exec /usr/local/bin/winomc-console-server
