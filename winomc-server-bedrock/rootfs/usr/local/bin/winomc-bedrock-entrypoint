#!/bin/sh

set -eu

OPTIONS_FILE="/data/options.json"
SERVER_DATA_DIR="/config"
COMMAND_FIFO="/tmp/winomc-bedrock-console.fifo"
CONSOLE_LOG="/tmp/winomc-bedrock-console.log"
CONSOLE_WEB_PID=""

export EULA="TRUE"

mkdir -p "${SERVER_DATA_DIR}"
mkdir -p "${SERVER_DATA_DIR}/worlds"
mkdir -p "${SERVER_DATA_DIR}/behavior_packs"
mkdir -p "${SERVER_DATA_DIR}/resource_packs"
mkdir -p "${SERVER_DATA_DIR}/world_templates"
mkdir -p "${SERVER_DATA_DIR}/config"

if [ -d "/share" ]; then
  mkdir -p /share/winomc/import
  mkdir -p /share/winomc/export
fi

cd "${SERVER_DATA_DIR}"

# Alle Add-on-Optionen als Umgebungsvariablen exportieren.
if [ -f "${OPTIONS_FILE}" ]; then
  for key in $(jq -r 'keys[]' "${OPTIONS_FILE}"); do
    case "${key}" in
      *[!A-Z0-9_]*|"")
        echo "Skipping invalid option key: ${key}"
        continue
        ;;
    esac

    value="$(jq -r --arg key "${key}" '
      .[$key]
      | if type == "boolean" then tostring
        elif . == null then ""
        else tostring
        end
    ' "${OPTIONS_FILE}")"

    if [ -n "${value}" ]; then
      export "${key}=${value}"
    fi
  done
fi

ENABLE_WEB_CONSOLE="${ENABLE_WEB_CONSOLE:-true}"
WINOMC_CONSOLE_PORT="${WINOMC_CONSOLE_PORT:-8099}"
WINOMC_CONSOLE_HISTORY_LIMIT="${WINOMC_CONSOLE_HISTORY_LIMIT:-300}"
WINOMC_CONSOLE_ALLOWED_PROXIES="${WINOMC_CONSOLE_ALLOWED_PROXIES:-172.30.32.2,127.0.0.1,::1}"

export ENABLE_WEB_CONSOLE
export WINOMC_CONSOLE_PORT
export WINOMC_CONSOLE_HISTORY_LIMIT
export WINOMC_CONSOLE_ALLOWED_PROXIES
export WINOMC_CONSOLE_FIFO="${COMMAND_FIFO}"
export WINOMC_CONSOLE_LOG="${CONSOLE_LOG}"

touch "${CONSOLE_LOG}"

echo "Starting WinoMC Bedrock"
echo "DATA_DIR=${SERVER_DATA_DIR}"
echo "WORLDS_DIR=${SERVER_DATA_DIR}/worlds"
echo "PACKS_DIR=${SERVER_DATA_DIR}/behavior_packs and ${SERVER_DATA_DIR}/resource_packs"
echo "IMPORT_DIR=/share/winomc/import"
echo "VERSION=${VERSION:-LATEST}"
echo "SERVER_NAME=${SERVER_NAME:-WinoMC Server}"
echo "LEVEL_NAME=${LEVEL_NAME:-World}"
echo "SERVER_PORT=${SERVER_PORT:-19132}"
echo "SERVER_PORT_V6=${SERVER_PORT_V6:-19133}"
echo "ENABLE_LAN_VISIBILITY=${ENABLE_LAN_VISIBILITY:-true}"
echo "ENABLE_BDS_V6BIND_FIX=${ENABLE_BDS_V6BIND_FIX:-false}"
echo "ENABLE_WEB_CONSOLE=${ENABLE_WEB_CONSOLE}"
echo "WINOMC_CONSOLE_PORT=${WINOMC_CONSOLE_PORT}"

prepare_console_fifo() {
  rm -f "${COMMAND_FIFO}"
  mkfifo "${COMMAND_FIFO}"
  echo "WinoMC console FIFO created: ${COMMAND_FIFO}"
}

patch_console_overlay() {
  if [ ! -f "/usr/local/bin/winomc-console-server" ]; then
    echo "WinoMC web console desktop patch skipped: console server not found"
    return 0
  fi

  python3 - <<'PY'
from pathlib import Path

path = Path("/usr/local/bin/winomc-console-server")
text = path.read_text(encoding="utf-8")
original = text

for old_title in (
    "<title>WinoMC Desktop Workbench 1.5.7.1</title>",
    "<title>WinoMC Desktop Workbench 1.5.7.5</title>",
):
    text = text.replace(old_title, "<title>WinoMC Desktop Workbench 1.5.7.6</title>")

css_guard = r'''

    /* v1.5.7.5 Desktop Ingress Breakpoint Fix
       Ursache: Bei breiteren Home-Assistant-Ingress-Flächen nutzte der Desktop-Layer
       ein anderes Layout als im kleinen Breakpoint. Dadurch wirkte eine dunkle Fläche
       wie ein blockierender Hintergrund, während die Icons erst bei kleinerem Fenster
       sichtbar wurden. Der Desktop nutzt nun auch auf breiteren Ingress-Flächen ein
       stabiles, relatives Icon-Grid. */
    :root:has(body.desktop-mode) {
      overflow: hidden !important;
      height: 100% !important;
    }
    body.desktop-mode {
      position: fixed !important;
      inset: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      height: 100dvh !important;
      min-height: 100vh !important;
      min-height: 100dvh !important;
      overflow: hidden !important;
      overscroll-behavior: none !important;
    }
    body.desktop-mode .layout {
      height: 100vh !important;
      height: 100dvh !important;
      overflow: hidden !important;
    }
    body.desktop-mode main.content {
      position: fixed !important;
      inset: 0 0 46px 0 !important;
      min-height: 0 !important;
      height: auto !important;
      overflow: auto !important;
      isolation: isolate;
    }
    body.desktop-mode header,
    body.desktop-mode nav,
    body.desktop-mode .hero {
      display: none !important;
      pointer-events: none !important;
    }
    body.desktop-mode.has-maximized-card::after,
    body.desktop-mode::before {
      content: none !important;
      display: none !important;
      pointer-events: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
    }
    body.desktop-mode .desktop-layer {
      display: block !important;
      position: relative !important;
      inset: auto !important;
      z-index: 1 !important;
      min-height: calc(100dvh - 58px) !important;
      padding: 16px 18px 340px !important;
      pointer-events: none !important;
    }
    body.desktop-mode .desktop-brand {
      position: static !important;
      right: auto !important;
      top: auto !important;
      text-align: left !important;
      font-size: clamp(22px, 3vw, 36px) !important;
      line-height: 1.08 !important;
      margin: 0 0 16px !important;
      color: rgba(226, 232, 240, .34) !important;
    }
    body.desktop-mode .desktop-icon-grid {
      width: 100% !important;
      max-width: none !important;
      display: grid !important;
      grid-template-columns: repeat(auto-fit, minmax(118px, 1fr)) !important;
      gap: 12px !important;
      align-content: start !important;
      pointer-events: auto !important;
    }
    body.desktop-mode .desktop-icon {
      width: 100% !important;
      min-height: 86px !important;
      pointer-events: auto !important;
    }
    body.desktop-mode .tab-panel.desktop-open:not(.desktop-minimized) {
      pointer-events: auto !important;
      max-width: calc(100vw - 24px) !important;
      max-height: calc(100dvh - 70px) !important;
    }
    body.desktop-mode .tab-panel.desktop-maximized {
      left: 8px !important;
      top: 8px !important;
      width: calc(100vw - 16px) !important;
      height: calc(100dvh - 64px) !important;
    }
    body.desktop-mode .desktop-taskbar {
      z-index: 90 !important;
    }
    body.desktop-mode .desktop-start-menu {
      z-index: 95 !important;
    }
    body.desktop-mode .card.maximized {
      position: static !important;
      inset: auto !important;
      z-index: auto !important;
      overflow: visible !important;
      box-shadow: none !important;
      background: transparent !important;
      transform: none !important;
    }
'''

if "v1.5.7.5 Desktop Ingress Breakpoint Fix" not in text:
    text = text.replace("  </style>", css_guard + "  </style>", 1)

expert_menu_button = '<button class="tab-button" data-tab="expert" aria-label="Experten"><span class="icon">🧰</span> Experten</button>'
classic_desktop_menu_button = '<button class="tab-button" type="button" data-enable-desktop-mode aria-label="Desktop-Modus"><span class="icon">🖥️</span> Desktop-Modus</button>'
if "data-enable-desktop-mode" not in text and expert_menu_button in text:
    text = text.replace(expert_menu_button, expert_menu_button + "\n      " + classic_desktop_menu_button, 1)

text = text.replace(
    "return getStoredJson(STORE_DESKTOP_WINDOWS, ['overview']);",
    "return getStoredJson(STORE_DESKTOP_WINDOWS, []);",
)

old_clear = """    function clearDesktopBlockingOverlays() {
      document.body.classList.remove('has-maximized-card');
      document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));
    }
"""
new_clear = """    function clearDesktopBlockingOverlays() {
      // v1.5.7.5 desktop overlay and ingress breakpoint runtime guard
      document.body.classList.remove('has-maximized-card');
      document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));
      const layer = document.getElementById('desktopLayer');
      if (layer) {
        layer.style.pointerEvents = 'none';
        layer.style.zIndex = '1';
      }
    }
"""
if "v1.5.7.5 desktop overlay and ingress breakpoint runtime guard" not in text and old_clear in text:
    text = text.replace(old_clear, new_clear)

viewport_guard = """    function clampDesktopPanelToViewport(panel) {
      if (!panel || !document.body.classList.contains('desktop-mode') || isDesktopMobile()) return;
      if (panel.classList.contains('desktop-maximized')) return;
      const taskbarHeight = 58;
      const margin = 10;
      const maxWidth = Math.max(320, window.innerWidth - margin * 2);
      const maxHeight = Math.max(260, window.innerHeight - taskbarHeight - margin * 2);
      const rect = panel.getBoundingClientRect();
      const nextWidth = clamp(rect.width || 720, Math.min(420, maxWidth), maxWidth);
      const nextHeight = clamp(rect.height || 520, Math.min(280, maxHeight), maxHeight);
      const nextLeft = clamp(rect.left || margin, margin, Math.max(margin, window.innerWidth - nextWidth - margin));
      const nextTop = clamp(rect.top || margin, margin, Math.max(margin, window.innerHeight - taskbarHeight - nextHeight - margin));
      panel.style.left = Math.round(nextLeft) + 'px';
      panel.style.top = Math.round(nextTop) + 'px';
      panel.style.width = Math.round(nextWidth) + 'px';
      panel.style.height = Math.round(nextHeight) + 'px';
    }

    function applyDesktopStartupLayout(ids) {
      const migrationKey = 'winomcDesktopIngressFixV1575';
      if (localStorage.getItem(migrationKey) !== 'done') {
        localStorage.removeItem(STORE_DESKTOP_POSITIONS);
        localStorage.setItem(STORE_DESKTOP_WINDOWS, JSON.stringify([]));
        localStorage.setItem(migrationKey, 'done');
        return [];
      }
      return Array.isArray(ids) ? ids.filter(Boolean) : [];
    }

    function fixDesktopViewportLayout() {
      if (!document.body.classList.contains('desktop-mode')) return;
      clearDesktopBlockingOverlays();
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      if (desktopLayer) {
        desktopLayer.style.position = 'relative';
        desktopLayer.style.inset = 'auto';
        desktopLayer.style.pointerEvents = 'none';
      }
      document.querySelectorAll('.tab-panel.desktop-open').forEach(clampDesktopPanelToViewport);
    }

    function initDesktopOverlayGuard() {
      const scheduleGuard = () => requestAnimationFrame(fixDesktopViewportLayout);
      scheduleGuard();
      window.addEventListener('resize', scheduleGuard, { passive: true });
      const observer = new MutationObserver(scheduleGuard);
      observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
      document.querySelectorAll('.tab-panel').forEach(panel => observer.observe(panel, { attributes: true, attributeFilter: ['class', 'style'] }));
    }

"""
if "function clampDesktopPanelToViewport(panel)" not in text:
    text = text.replace("    function connectLogs() {", viewport_guard + "    function connectLogs() {", 1)

old_desktop_start = """        const ids = desktopOpenIds();
        if (!ids.length) ids.push('overview');
        ids.forEach(openDesktopWindow);
        if (!document.querySelector('.tab-panel.desktop-open')) openDesktopWindow('overview');
        updateDesktopClock();
"""
new_desktop_start = """        const ids = applyDesktopStartupLayout(desktopOpenIds());
        ids.forEach(openDesktopWindow);
        fixDesktopViewportLayout();
        updateDesktopClock();
"""
if old_desktop_start in text:
    text = text.replace(old_desktop_start, new_desktop_start, 1)

old_click_handler = """document.addEventListener('click', event => { const actionBtn = event.target.closest('[data-action-id]'); if (actionBtn) { runAction(ACTION_BY_ID[actionBtn.dataset.actionId]); return; } const jump = event.target.closest('[data-jump-tab]'); if (jump) { activateTab(jump.dataset.jumpTab); return; } const openRootBtn = event.target.closest('[data-open-root]'); if (openRootBtn) { openRoot(openRootBtn.dataset.openRoot, '/'); return; } });"""
new_click_handler = """document.addEventListener('click', event => { const desktopModeMenu = event.target.closest('[data-enable-desktop-mode]'); if (desktopModeMenu) { setDesktopMode(true); return; } const actionBtn = event.target.closest('[data-action-id]'); if (actionBtn) { runAction(ACTION_BY_ID[actionBtn.dataset.actionId]); return; } const jump = event.target.closest('[data-jump-tab]'); if (jump) { activateTab(jump.dataset.jumpTab); return; } const openRootBtn = event.target.closest('[data-open-root]'); if (openRootBtn) { openRoot(openRootBtn.dataset.openRoot, '/'); return; } });"""
if "data-enable-desktop-mode" in text and "const desktopModeMenu = event.target.closest('[data-enable-desktop-mode]')" not in text and old_click_handler in text:
    text = text.replace(old_click_handler, new_click_handler, 1)

old_init = "initDesktopConsoleWindow(); initFileSplitResize(); initCardChrome(); initDesktopWorkbench(); renderDashboard(); connectLogs(); loadStatus();"
new_init = "initDesktopConsoleWindow(); initFileSplitResize(); initCardChrome(); initDesktopWorkbench(); initDesktopOverlayGuard(); renderDashboard(); connectLogs(); loadStatus();"
if old_init in text and new_init not in text:
    text = text.replace(old_init, new_init, 1)

if text != original:
    path.write_text(text, encoding="utf-8")
    print("WinoMC web console desktop menu patch applied")
else:
    print("WinoMC web console desktop menu patch already present")
PY
}

start_console_web() {
  if [ "${ENABLE_WEB_CONSOLE}" != "true" ]; then
    echo "WinoMC web console disabled"
    return 0
  fi

  patch_console_overlay
  echo "Starting WinoMC web console on port ${WINOMC_CONSOLE_PORT}"
  /usr/local/bin/winomc-console-server &
  CONSOLE_WEB_PID="$!"
  echo "WinoMC web console process started with PID ${CONSOLE_WEB_PID}"
}

send_bedrock_command() {
  command_line="$1"

  if [ -z "${command_line}" ] || [ "${command_line}" = "null" ]; then
    echo "WinoMC STDIN ignored empty command"
    return 0
  fi

  if [ ! -p "${COMMAND_FIFO}" ]; then
    echo "WinoMC STDIN error: console FIFO missing"
    return 1
  fi

  echo "WinoMC console command: ${command_line}"

  if printf '%s\n' "${command_line}" > "${COMMAND_FIFO}"; then
    echo "WinoMC console command written"
  else
    echo "WinoMC console command failed: ${command_line}"
    return 1
  fi
}

run_stdin_bridge() {
  echo "WinoMC STDIN bridge active"

  while IFS= read -r line || [ -n "${line}" ]; do
    if [ -z "${line}" ]; then
      continue
    fi

    echo "WinoMC STDIN raw input: ${line}"

    command_line="$(printf '%s' "${line}" | jq -r '
      if type == "object" and has("command") then .command
      elif type == "object" and has("input") then .input
      elif type == "string" then .
      else empty
      end
    ' 2>/dev/null || true)"

    if [ -z "${command_line}" ]; then
      command_line="${line}"
    fi

    echo "WinoMC STDIN command received: ${command_line}"
    send_bedrock_command "${command_line}" || true
  done

  echo "WinoMC STDIN bridge stopped"
}

shutdown_bedrock() {
  echo "Stopping WinoMC Bedrock"

  if [ -p "${COMMAND_FIFO}" ]; then
    send_bedrock_command "say Server wird beendet..." || true
    send_bedrock_command "stop" || true
  fi

  if [ -n "${CONSOLE_WEB_PID:-}" ]; then
    kill -TERM "${CONSOLE_WEB_PID}" 2>/dev/null || true
    wait "${CONSOLE_WEB_PID}" 2>/dev/null || true
  fi

  if [ -n "${BEDROCK_PID:-}" ]; then
    kill -TERM "${BEDROCK_PID}" 2>/dev/null || true
    wait "${BEDROCK_PID}" 2>/dev/null || true
  fi

  rm -f "${COMMAND_FIFO}"

  exit 0
}

trap shutdown_bedrock TERM INT

prepare_console_fifo
start_console_web

# Bedrock bekommt nicht direkt den Home-Assistant-STDIN.
# Stattdessen bekommt Bedrock ein eigenes FIFO als Konsolen-Eingang.
# Die Ausgabe wird zusätzlich in eine Logdatei geschrieben, damit die Ingress-Konsole live mitlesen kann.
: > "${CONSOLE_LOG}"
echo "[WinoMC Console] Log gestartet" >> "${CONSOLE_LOG}"
WINOMC_RUNTIME_MODE="${WINOMC_RUNTIME_MODE:-native}"
export SERVER_DATA_DIR

if [ "${WINOMC_RUNTIME_MODE}" != "native" ]; then
  echo "WARN: WINOMC_RUNTIME_MODE=${WINOMC_RUNTIME_MODE} is no longer available in the native image"
  echo "WARN: Falling back to WINOMC_RUNTIME_MODE=native"
  WINOMC_RUNTIME_MODE="native"
fi

echo "WINOMC_RUNTIME_MODE=${WINOMC_RUNTIME_MODE}"

/usr/local/bin/winomc-native-start < "${COMMAND_FIFO}" 2>&1 | tee -a "${CONSOLE_LOG}" &
BEDROCK_PID="$!"

# FIFO dauerhaft offen halten, damit Bedrock keinen EOF bekommt.
exec 3>"${COMMAND_FIFO}"

echo "WinoMC Bedrock process started with PID ${BEDROCK_PID}"
echo "WinoMC console FIFO ready"

# Die Home-Assistant-STDIN-Bridge läuft im Vordergrund.
run_stdin_bridge
