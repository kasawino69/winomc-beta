class WinoMCRuntimeError(RuntimeError):
    def __init__(self, code, message, instance_id=None, component="runtime", suggested_action=None, details=None):
        super().__init__(message)
        self.code = code
        self.message = message
        self.instance_id = instance_id
        self.component = component
        self.suggested_action = suggested_action
        self.details = details or {}

    def to_payload(self):
        payload = {"ok": False, "error": self.message, "code": self.code, "message": self.message, "component": self.component}
        if self.instance_id: payload["instance_id"] = self.instance_id
        if self.suggested_action: payload["suggested_action"] = self.suggested_action
        if self.details: payload["details"] = self.details
        return payload

def runtime_error_payload(exc, instance_id=None, component="runtime", code="runtime_error"):
    if isinstance(exc, WinoMCRuntimeError):
        return exc.to_payload()
    return {"ok": False, "error": str(exc), "code": code, "message": str(exc), "instance_id": instance_id, "component": component}

def manager_now():
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

def slugify_instance_id(value):
    value = re.sub(r"[^a-z0-9_-]+", "-", str(value or "").lower()).strip("-_")
    return (value or "server")[:32]

def validate_instance_id(instance_id):
    instance_id = slugify_instance_id(instance_id)
    if not INSTANCE_ID_RE.match(instance_id):
        raise ValueError("UngÃ¼ltige Instanz-ID. Erlaubt sind 2-32 Zeichen: a-z, 0-9, - und _.")
    return instance_id

def instance_path(instance_id, *parts):
    iid = validate_instance_id(instance_id)
    base = os.path.realpath(os.path.join(INSTANCES_DIR, iid))
    root = os.path.realpath(INSTANCES_DIR)
    if base != root and not base.startswith(root + os.sep):
        raise ValueError("Instanzpfad verlÃ¤sst den Instanzbereich.")
    return os.path.join(base, *parts)

def read_json_file(path, fallback):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return json.load(handle)
    except FileNotFoundError:
        return fallback

def write_json_file(path, payload):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=os.path.basename(path) + ".", suffix=".tmp", dir=os.path.dirname(path))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, ensure_ascii=False, indent=2)
            handle.write("\n")
        os.replace(tmp, path)
    finally:
        if os.path.exists(tmp):
            try: os.remove(tmp)
            except OSError: pass


def normalize_instance_automation(payload=None):
    payload = payload or {}
    return {
        "autostart": bool(payload.get("autostart", False)),
        "watchdog": bool(payload.get("watchdog", False)),
    }

def ensure_instance_automation(config):
    config.setdefault("automation", normalize_instance_automation({}))
    config["automation"] = normalize_instance_automation(config.get("automation", {}))
    return config


def default_instance_config(instance_id, name=None, profile="vanilla-survival", port=None):
    profile_data = BEDROCK_PROFILES.get(profile, BEDROCK_PROFILES["vanilla-survival"])
    defaults = dict(profile_data["defaults"])
    port = int(port or next_free_instance_port())

    return {
        "schema_version": 1,
        "id": instance_id,
        "name": name or instance_id,
        "engine": "bedrock",
        "profile": profile,
        "created_at": manager_now(),
        "updated_at": manager_now(),
        "bedrock": {
            "version": "LATEST",
            "server_name": name or instance_id,
            "level_name": "world",
            "server_port": port,
            "server_port_v6": port + 1,
            **defaults,
        },
        "automation": normalize_instance_automation({}),
        "paths": {"root": instance_path(instance_id)},
        "backup": {"keep": BACKUP_KEEP, "export_dir": EXPORT_DIR},
        "schedule": {"restarts": [], "commands": []},
    }


