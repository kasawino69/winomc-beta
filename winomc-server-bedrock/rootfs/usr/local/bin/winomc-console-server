def log_warning(message):
    print("[WinoMC Console] WARNUNG: %s" % message, file=sys.stderr, flush=True)


def canonical_path(path):
    # Normalize and resolve symlinks before any path check.
    return os.path.normpath(os.path.realpath(os.path.abspath(str(path or ""))))


class VerifiedPath:
    """PathLike wrapper for filesystem paths that passed WinoMC validation.

    The wrapper keeps raw user-controlled strings away from filesystem sinks.
    All open/stat/list/remove/copy/move operations below receive a PathLike
    object produced only after root-prefix and symlink checks succeeded.
    """

    __slots__ = ("_path",)

    def __init__(self, path):
        self._path = os.path.normpath(os.path.realpath(os.path.abspath(str(path or ""))))

    def __fspath__(self):
        return self._path

    def __str__(self):
        return self._path

    def __repr__(self):
        return "VerifiedPath(%r)" % self._path

    @property
    def path(self):
        return self._path

    def exists(self):
        return os.path.exists(self)

    def lexists(self):
        return os.path.lexists(self)

    def is_file(self):
        return os.path.isfile(self)

    def is_dir(self):
        return os.path.isdir(self)

    def is_link(self):
        return os.path.islink(self)

    def stat(self):
        return os.stat(self)

    def lstat(self):
        return os.lstat(self)

    def getsize(self):
        return os.path.getsize(self)

    def getmtime(self):
        return os.path.getmtime(self)

    def listdir(self):
        return os.listdir(self)

    def makedirs(self, exist_ok=True):
        os.makedirs(self, exist_ok=exist_ok)
        return self

    def open(self, mode, *args, **kwargs):
        if "opener" not in kwargs:
            kwargs["opener"] = safe_open_opener
        return open(self, mode, *args, **kwargs)

    def os_open(self, flags, mode=0o600):
        return os.open(self, flags, mode)

    def remove(self):
        os.remove(self)

    def rmtree(self):
        shutil.rmtree(self)

    def replace_to(self, target):
        os.replace(self, target)

    def copy2_to(self, target):
        shutil.copy2(self, target)

    def move_to(self, target):
        return shutil.move(self, target)


def fs_path(value):
    if isinstance(value, VerifiedPath):
        return value.path
    return str(value or "")


def safe_component(value):
    value = str(value or "")
    if not value or value in (".", ".."):
        raise ValueError("Unsicheres Pfadsegment blockiert.")
    if "/" in value or "\\" in value or "\x00" in value:
        raise ValueError("Unsicheres Pfadsegment blockiert.")
    if any(ord(ch) < 32 for ch in value):
        raise ValueError("Unsicheres Pfadsegment blockiert.")
    return value


def safe_rel_parts(rel_path):
    raw = unquote(str(rel_path or "/")).replace("\\", "/")
    if "\x00" in raw or any(ord(ch) < 32 for ch in raw):
        raise ValueError("Unsichere Steuerzeichen im Pfad blockiert.")
    parts = []
    for part in raw.split("/"):
        if not part or part == ".":
            continue
        if part == "..":
            raise ValueError("Pfadnavigation außerhalb des erlaubten Bereichs blockiert.")
        parts.append(safe_component(part))
    return parts


def normalize_rel_path(rel_path):
    parts = safe_rel_parts(rel_path)
    return "/" + "/".join(parts) if parts else "/"


def is_inside_base(base_path, candidate_path):
    base_path = canonical_path(base_path)
    candidate_path = canonical_path(fs_path(candidate_path))
    base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
    return candidate_path == base_path or candidate_path.startswith(base_prefix)


def assert_no_symlink_component(base_path, candidate_path, allow_missing=True):
    base_path = canonical_path(base_path)
    absolute_candidate = os.path.abspath(fs_path(candidate_path))
    try:
        relative = os.path.relpath(absolute_candidate, base_path)
    except ValueError:
        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
    if relative == ".":
        return
    if relative.startswith(".." + os.sep) or relative == "..":
        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
    current = base_path
    for part in relative.split(os.sep):
        if not part or part == ".":
            continue
        if part == "..":
            raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
        current = os.path.join(current, part)
        current_path = VerifiedPath(current)
        try:
            mode = current_path.lstat().st_mode
        except FileNotFoundError:
            if allow_missing:
                return
            raise
        if stat.S_ISLNK(mode):
            raise ValueError("Symbolische Links sind im Dateimanager aus Sicherheitsgründen blockiert.")


def allowed_root_base(root_key):
    root_key = str(root_key or "config")
    if root_key not in FILE_ROOTS:
        raise ValueError("Unbekannter Dateibereich.")
    base_path = canonical_path(FILE_ROOTS[root_key]["path"])
    assert_no_symlink_component(os.path.dirname(base_path), base_path, allow_missing=True)
    return base_path


def verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True):
    base_path = allowed_root_base(root_key)
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    candidate_real = os.path.normpath(os.path.realpath(candidate_abs))
    base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
    if candidate_real != base_path and not candidate_real.startswith(base_prefix):
        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
    assert_no_symlink_component(base_path, candidate_abs, allow_missing=allow_missing)
    verified = VerifiedPath(candidate_real)
    if require_exists and not verified.exists():
        raise FileNotFoundError("Pfad existiert nicht.")
    return verified


def verify_internal_path(base_dir, candidate_path, require_exists=False, allow_missing=True):
    base_path = canonical_path(base_dir)
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    candidate_real = os.path.normpath(os.path.realpath(candidate_abs))
    base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
    if candidate_real != base_path and not candidate_real.startswith(base_prefix):
        raise ValueError("Interner Pfad außerhalb des erlaubten Bereichs blockiert.")
    assert_no_symlink_component(base_path, candidate_abs, allow_missing=allow_missing)
    verified = VerifiedPath(candidate_real)
    if require_exists and not verified.exists():
        raise FileNotFoundError("Interner Pfad existiert nicht.")
    return verified


def resolve_safe_path(root_key, rel_path="/"):
    base_path = allowed_root_base(root_key)
    parts = safe_rel_parts(rel_path)
    normalized_rel = "/" + "/".join(parts) if parts else "/"
    candidate_abs = os.path.join(base_path, *parts) if parts else base_path
    verified = verify_root_path(root_key, candidate_abs, require_exists=False, allow_missing=True)
    return verified.path, normalized_rel


def assert_safe_path(root_key, candidate_path, require_exists=False):
    return verify_root_path(root_key, candidate_path, require_exists=require_exists, allow_missing=not require_exists).path


def assert_safe_internal_path(base_dir, candidate_path, require_exists=False):
    return verify_internal_path(base_dir, candidate_path, require_exists=require_exists, allow_missing=not require_exists).path


def allowed_runtime_bases():
    return [canonical_path(tempfile.gettempdir()), canonical_path(os.path.join(DATA_DIR, ".winomc"))]


def verify_runtime_path(candidate_path, require_exists=False, allow_missing=True):
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    candidate_real = os.path.normpath(os.path.realpath(candidate_abs))
    for base_path in allowed_runtime_bases():
        base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
        if candidate_real == base_path or candidate_real.startswith(base_prefix):
            assert_no_symlink_component(base_path, candidate_abs, allow_missing=allow_missing)
            verified = VerifiedPath(candidate_real)
            if require_exists and not verified.exists():
                raise FileNotFoundError("Runtime-Pfad existiert nicht.")
            return verified
    raise ValueError("Runtime-Pfad außerhalb der erlaubten Bereiche blockiert.")


def assert_runtime_path(candidate_path, require_exists=False):
    return verify_runtime_path(candidate_path, require_exists=require_exists, allow_missing=not require_exists).path


def runtime_log_path():
    try:
        return assert_runtime_path(LOG_PATH)
    except Exception as exc:
        fallback = os.path.join(tempfile.gettempdir(), "winomc-bedrock-console.log")
        log_warning("Unsicherer LOG_PATH wurde durch Standardpfad ersetzt: %s" % exc)
        return assert_runtime_path(fallback)


def runtime_fifo_path():
    try:
        return assert_runtime_path(FIFO_PATH, require_exists=False)
    except Exception as exc:
        raise RuntimeError("Unsicherer FIFO-Pfad blockiert: %s" % exc)


def ensure_runtime_parent_dir(path):
    verified = verify_runtime_path(path, require_exists=False, allow_missing=True)
    parent = VerifiedPath(os.path.dirname(verified.path))
    allowed = False
    for base_path in allowed_runtime_bases():
        base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
        if parent.path == base_path or parent.path.startswith(base_prefix):
            allowed = True
            break
    if not allowed:
        raise ValueError("Runtime-Elternpfad außerhalb der erlaubten Bereiche blockiert.")
    parent.makedirs(exist_ok=True)
    return parent.path


def safe_open_opener(path, flags):
    return os.open(path, flags | getattr(os, "O_NOFOLLOW", 0), 0o600)


def open_runtime(candidate_path, mode, *args, **kwargs):
    write_mode = any(flag in str(mode) for flag in ("w", "a", "x", "+"))
    verified = verify_runtime_path(candidate_path, require_exists=not write_mode, allow_missing=write_mode)
    if write_mode:
        parent = VerifiedPath(os.path.dirname(verified.path))
        if not parent.is_dir():
            raise FileNotFoundError("Runtime-Zielordner existiert nicht.")
        if verified.lexists() and verified.is_link():
            raise ValueError("Schreiben auf symbolische Links ist blockiert.")
    return verified.open(mode, *args, **kwargs)


def open_safe(root_key, candidate_path, mode, *args, **kwargs):
    write_mode = any(flag in str(mode) for flag in ("w", "a", "x", "+"))
    verified = verify_root_path(root_key, candidate_path, require_exists=not write_mode, allow_missing=write_mode)
    if write_mode:
        parent = VerifiedPath(os.path.dirname(verified.path))
        if not parent.is_dir():
            raise FileNotFoundError("Zielordner existiert nicht.")
        if verified.lexists() and verified.is_link():
            raise ValueError("Schreiben auf symbolische Links ist blockiert.")
    return verified.open(mode, *args, **kwargs)


def open_safe_internal(base_dir, candidate_path, mode, *args, **kwargs):
    write_mode = any(flag in str(mode) for flag in ("w", "a", "x", "+"))
    verified = verify_internal_path(base_dir, candidate_path, require_exists=not write_mode, allow_missing=write_mode)
    if write_mode:
        parent = VerifiedPath(os.path.dirname(verified.path))
        if not parent.is_dir():
            raise FileNotFoundError("Interner Zielordner existiert nicht.")
        if verified.lexists() and verified.is_link():
            raise ValueError("Schreiben auf symbolische Links ist blockiert.")
    return verified.open(mode, *args, **kwargs)


def path_exists_internal(base_dir, candidate_path):
    return verify_internal_path(base_dir, candidate_path, require_exists=False, allow_missing=True).exists()


def listdir_internal(base_dir, candidate_path):
    verified = verify_internal_path(base_dir, candidate_path, require_exists=True, allow_missing=False)
    if not verified.is_dir():
        raise FileNotFoundError("Interner Ordner existiert nicht.")
    return verified.listdir()


def getmtime_internal(base_dir, candidate_path):
    return verify_internal_path(base_dir, candidate_path, require_exists=True, allow_missing=False).getmtime()


def replace_internal(base_dir, source_path, target_path):
    safe_source = verify_internal_path(base_dir, source_path, require_exists=True, allow_missing=False)
    safe_target = verify_internal_path(base_dir, target_path, require_exists=False, allow_missing=True)
    safe_source.replace_to(safe_target)


def path_exists_root(root_key, candidate_path):
    return verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True).exists()


def path_is_file_root(root_key, candidate_path):
    return verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True).is_file()


def path_is_dir_root(root_key, candidate_path):
    return verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True).is_dir()


def path_is_link_root(root_key, candidate_path):
    base_path = allowed_root_base(root_key)
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    safe_path = verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True)
    base_prefix = base_path if base_path.endswith(os.sep) else base_path + os.sep
    if candidate_abs != base_path and not os.path.normpath(candidate_abs).startswith(base_prefix):
        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
    return VerifiedPath(candidate_abs).is_link() or safe_path.is_link()


def stat_root(root_key, candidate_path):
    return verify_root_path(root_key, candidate_path, require_exists=True, allow_missing=False).stat()


def getsize_root(root_key, candidate_path):
    return verify_root_path(root_key, candidate_path, require_exists=True, allow_missing=False).getsize()


def listdir_root(root_key, candidate_path):
    verified = verify_root_path(root_key, candidate_path, require_exists=True, allow_missing=False)
    if not verified.is_dir():
        raise ValueError("Pfad ist kein Ordner.")
    return verified.listdir()


def makedirs_root(root_key, candidate_path, exist_ok=True):
    verified = verify_root_path(root_key, candidate_path, require_exists=False, allow_missing=True)
    verified.makedirs(exist_ok=exist_ok)
    return verify_root_path(root_key, verified, require_exists=True, allow_missing=False).path


def makedirs_internal(base_dir, candidate_path, exist_ok=True):
    verified = verify_internal_path(base_dir, candidate_path, require_exists=False, allow_missing=True)
    verified.makedirs(exist_ok=exist_ok)
    return verify_internal_path(base_dir, verified, require_exists=True, allow_missing=False).path


def safe_temp_affix(value, fallback):
    value = str(value or fallback)
    value = re.sub(r"[^A-Za-z0-9._-]+", "_", value).strip("._-")
    return value or fallback


def mkstemp_root(root_key, parent_path, prefix, suffix=""):
    parent = verify_root_path(root_key, parent_path, require_exists=True, allow_missing=False)
    if not parent.is_dir():
        raise FileNotFoundError("Zielordner existiert nicht.")
    fd, temp_path = tempfile.mkstemp(prefix=safe_temp_affix(prefix, ".winomc-"), suffix=safe_temp_affix(suffix, "") if suffix else "", dir=parent)
    return fd, verify_root_path(root_key, temp_path, require_exists=True, allow_missing=False).path


def mkstemp_internal(base_dir, parent_path, prefix, suffix=""):
    parent = verify_internal_path(base_dir, parent_path, require_exists=True, allow_missing=False)
    if not parent.is_dir():
        raise FileNotFoundError("Interner Zielordner existiert nicht.")
    fd, temp_path = tempfile.mkstemp(prefix=safe_temp_affix(prefix, ".winomc-"), suffix=safe_temp_affix(suffix, "") if suffix else "", dir=parent)
    return fd, verify_internal_path(base_dir, temp_path, require_exists=True, allow_missing=False).path


def replace_safe(root_key, source_path, target_path):
    safe_source = verify_root_path(root_key, source_path, require_exists=True, allow_missing=False)
    safe_target = verify_root_path(root_key, target_path, require_exists=False, allow_missing=True)
    parent = verify_root_path(root_key, os.path.dirname(safe_target.path), require_exists=True, allow_missing=False)
    if not parent.is_dir():
        raise FileNotFoundError("Zielordner existiert nicht.")
    if safe_target.lexists() and safe_target.is_link():
        raise ValueError("Ersetzen eines symbolischen Links ist blockiert.")
    safe_source.replace_to(safe_target)


def remove_safe(root_key, candidate_path):
    verified = verify_root_path(root_key, candidate_path, require_exists=True, allow_missing=False)
    original = VerifiedPath(os.path.abspath(fs_path(candidate_path)))
    if verified.is_dir() and not original.is_link():
        verified.rmtree()
    else:
        verified.remove()


def remove_safe_internal(base_dir, candidate_path):
    verified = verify_internal_path(base_dir, candidate_path, require_exists=True, allow_missing=False)
    original = VerifiedPath(os.path.abspath(fs_path(candidate_path)))
    if verified.is_dir() and not original.is_link():
        verified.rmtree()
    else:
        verified.remove()


def copy2_safe(root_key, source_path, target_path):
    safe_source = verify_root_path(root_key, source_path, require_exists=True, allow_missing=False)
    target_base = canonical_path(os.path.dirname(fs_path(target_path)))
    safe_target = verify_internal_path(target_base, target_path, require_exists=False, allow_missing=True)
    safe_source.copy2_to(safe_target)


def move_safe_root_to_internal(root_key, source_path, internal_base, target_path):
    safe_source = verify_root_path(root_key, source_path, require_exists=True, allow_missing=False)
    safe_target = verify_internal_path(internal_base, target_path, require_exists=False, allow_missing=True)
    return safe_source.move_to(safe_target)


def move_safe_internal_to_root(internal_base, source_path, root_key, target_path):
    safe_source = verify_internal_path(internal_base, source_path, require_exists=True, allow_missing=False)
    safe_target = verify_root_path(root_key, target_path, require_exists=False, allow_missing=True)
    parent = verify_root_path(root_key, os.path.dirname(safe_target.path), require_exists=True, allow_missing=False)
    if not parent.is_dir():
        raise FileNotFoundError("Zielordner existiert nicht.")
    return safe_source.move_to(safe_target)


def assert_safe_download_path(candidate_path):
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    for base_path in [allowed_root_base(key) for key in FILE_ROOTS] + [canonical_path(tempfile.gettempdir())]:
        try:
            return verify_internal_path(base_path, candidate_abs, require_exists=True, allow_missing=False).path
        except ValueError:
            continue
    raise ValueError("Download-Pfad außerhalb der erlaubten Bereiche blockiert.")


def open_safe_download(candidate_path, mode="rb"):
    candidate_abs = os.path.abspath(fs_path(candidate_path))
    for base_path in [allowed_root_base(key) for key in FILE_ROOTS] + [canonical_path(tempfile.gettempdir())]:
        try:
            verified = verify_internal_path(base_path, candidate_abs, require_exists=True, allow_missing=False)
            if not verified.is_file():
                raise FileNotFoundError("Datei nicht gefunden.")
            return verified.open(mode)
        except ValueError:
            continue
    raise ValueError("Download-Pfad außerhalb der erlaubten Bereiche blockiert.")


def ensure_directories():
    for path in (DATA_DIR, WORLDS_DIR, RESOURCE_PACKS_DIR, BEHAVIOR_PACKS_DIR, WORLD_TEMPLATES_DIR, IMPORT_DIR, EXPORT_DIR, BACKUP_DIR, FILE_BACKUP_DIR, TRASH_DIR, WINOMC_STATE_DIR, QUARANTINE_DIR):
        try:
            os.makedirs(canonical_path(path), exist_ok=True)
        except OSError as exc:
            log_warning("Verzeichnis konnte nicht erstellt werden: %s (%s)" % (path, exc))


def client_allowed(client_ip):
    if not ALLOWED_PROXIES:
        return True
    return client_ip in ALLOWED_PROXIES


def read_recent_lines(path, limit):
    lines = deque(maxlen=max(1, limit))
    try:
        safe_path = assert_runtime_path(path, require_exists=True)
        with open_runtime(safe_path, "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                lines.append(line.rstrip("\n"))
    except FileNotFoundError:
        return []
    except Exception as exc:
        log_warning("Log konnte nicht gelesen werden: %s" % exc)
        return []
    return list(lines)


def sanitize_command(command):
    command = str(command or "").replace("\x00", "").strip()
    if command.startswith("/"):
        command = command[1:].strip()
    command = "".join(ch for ch in command if ch == "\t" or ord(ch) >= 32)
    if len(command) > MAX_COMMAND_LENGTH:
        raise ValueError("Befehl ist zu lang. Maximum: %s Zeichen." % MAX_COMMAND_LENGTH)
    if not command:
        raise ValueError("Leerer Befehl.")
    return command


def write_command(command):
    fifo_path = runtime_fifo_path()
    fifo_verified = verify_runtime_path(fifo_path, require_exists=True, allow_missing=False)
    mode = fifo_verified.lstat().st_mode
    if stat.S_ISLNK(mode) or not stat.S_ISFIFO(mode):
        raise RuntimeError("Console FIFO ist kein sicherer FIFO-Pfad.")
    log_path = runtime_log_path()
    ensure_runtime_parent_dir(log_path)
    if not runtime_path_exists(log_path):
        with open_runtime(log_path, "a", encoding="utf-8"):
            pass
    fd = fifo_verified.os_open(os.O_WRONLY | os.O_NONBLOCK | getattr(os, "O_NOFOLLOW", 0), 0o600)
    try:
        os.write(fd, (command + "\n").encode("utf-8"))
    finally:
        os.close(fd)
    append_console_note("> " + command)

def append_console_note(message):
    try:
        log_path = runtime_log_path()
        ensure_runtime_parent_dir(log_path)
        with open_runtime(log_path, "a", encoding="utf-8", errors="replace") as log_handle:
            log_handle.write("[WinoMC Console] %s\n" % message)
    except Exception as exc:
        log_warning("Console-Log konnte nicht geschrieben werden: %s" % exc)


def safe_download_name(name, fallback="winomc-download"):
    name = str(name or fallback).strip()
    name = re.sub(r"[^A-Za-z0-9._-]+", "_", name)
    name = name.strip("._-")
    return name or fallback


def safe_temp_affix(value, fallback=""):
    value = str(value or fallback)
    value = value.replace("/", "_").replace("\\", "_").replace("\x00", "")
    value = "".join(ch for ch in value if ord(ch) >= 32)
    value = re.sub(r"[^A-Za-z0-9._-]+", "_", value)
    return value or fallback


def console_settings_paths():
    settings_dir = canonical_path(os.path.join(DATA_DIR, ".winomc"))
    settings_name = safe_download_name(os.path.basename(CONSOLE_SETTINGS_FILE), "web_console_settings.json")
    settings_file = assert_safe_internal_path(settings_dir, os.path.join(settings_dir, settings_name))
    return settings_dir, settings_file

def parse_bool(value, default=False):
    if value is None:
        return default
    return str(value).strip().lower() in ("1", "true", "yes", "on", "ja")


def file_extension(path):
    return os.path.splitext(str(path or ""))[1].lower()


def is_editable_text_file(path):
    name = os.path.basename(path).lower()
    ext = file_extension(path)
    if ext in EDITABLE_TEXT_EXTENSIONS:
        return True
    return name in {
        "server.properties", "allowlist.json", "permissions.json", "valid_known_packs.json",
        "world_resource_packs.json", "world_behavior_packs.json", "manifest.json"
    }


def validate_json_if_needed(path, content):
    if file_extension(path) not in JSON_EXTENSIONS:
        return
    try:
        json.loads(content or "")
    except json.JSONDecodeError as exc:
        raise ValueError("JSON ist ungültig: Zeile %s, Spalte %s: %s" % (exc.lineno, exc.colno, exc.msg))


def make_file_backup(file_path, root_key, rel_path):
    file_path = assert_safe_path(root_key, file_path, require_exists=False)
    if not path_exists_root(root_key, file_path) or not path_is_file_root(root_key, file_path):
        return None
    backup_base = makedirs_internal(FILE_BACKUP_DIR, FILE_BACKUP_DIR, exist_ok=True)
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    rel_name = normalize_rel_path(rel_path).replace("/", "__")
    backup_name = safe_download_name("%s-%s-%s" % (timestamp, root_key, rel_name), "winomc-file-backup")
    backup_path = assert_safe_internal_path(backup_base, os.path.join(backup_base, backup_name))
    if path_exists_internal(backup_base, backup_path):
        backup_path = assert_safe_internal_path(backup_base, backup_path + ".bak")
    copy2_safe(root_key, file_path, backup_path)
    return backup_path


def list_file_roots():
    cleanup_trash()
    roots = []
    for key, info in FILE_ROOTS.items():
        path = allowed_root_base(key)
        roots.append({"key": key, "label": info["label"], "description": info.get("description", ""), "path": path, "exists": os.path.exists(path), "readable": os.path.isdir(path) and os.access(path, os.R_OK)})
    return roots


def list_directory(root_key, rel_path="/"):
    full_path, rel_path = resolve_safe_path(root_key, rel_path)
    if not path_exists_root(root_key, full_path):
        raise FileNotFoundError("Pfad existiert nicht.")
    if not path_is_dir_root(root_key, full_path):
        raise ValueError("Pfad ist kein Ordner.")
    root_base = allowed_root_base(root_key)
    entries = []
    for name in sorted(listdir_root(root_key, full_path), key=lambda item: item.lower()):
        if root_key == "trash" and name.endswith(".winomc-trash.json"):
            continue
        child_path = os.path.join(full_path, name)
        if path_is_link_root(root_key, child_path):
            continue
        if not is_inside_base(root_base, child_path):
            continue
        try:
            stat = stat_root(root_key, child_path)
        except OSError:
            continue
        is_dir = path_is_dir_root(root_key, child_path)
        child_rel_path = normalize_rel_path(posixpath.join(rel_path, name))
        entry = {"name": name, "path": child_rel_path, "type": "directory" if is_dir else "file", "size": stat.st_size, "modified": int(stat.st_mtime), "downloadable": not is_dir, "zipable": True, "editable": (not is_dir and is_editable_text_file(child_path)), "extractable": (not is_dir and file_extension(child_path) in ZIP_EXTENSIONS)}
        if root_key == "trash":
            meta_path = child_path + ".winomc-trash.json"
            try:
                with open_safe("trash", meta_path, "r", encoding="utf-8") as handle:
                    meta = json.load(handle)
                entry["trash_meta"] = meta
                entry["original_root"] = meta.get("original_root", "")
                entry["original_path"] = meta.get("original_path", "")
                entry["deleted_at"] = meta.get("deleted_at", "")
            except Exception:
                entry["trash_meta"] = None
        entries.append(entry)
    entries.sort(key=lambda item: (item["type"] != "directory", item["name"].lower()))
    parent = None if rel_path == "/" else normalize_rel_path(posixpath.dirname(rel_path))
    return {"ok": True, "root": root_key, "path": rel_path, "parent": parent, "entries": entries}


def read_text_file(root_key, rel_path):
    file_path, rel_path = resolve_safe_path(root_key, rel_path)
    if not path_exists_root(root_key, file_path):
        raise FileNotFoundError("Datei existiert nicht.")
    if not path_is_file_root(root_key, file_path):
        raise ValueError("Nur Dateien können im Editor geöffnet werden.")
    if not is_editable_text_file(file_path):
        raise ValueError("Dieser Dateityp ist nicht für den Texteditor freigegeben.")
    size = getsize_root(root_key, file_path)
    if size > MAX_TEXT_FILE_BYTES:
        raise ValueError("Datei ist zu groß für den Editor. Maximum: %s Bytes." % MAX_TEXT_FILE_BYTES)
    with open_safe(root_key, file_path, "r", encoding="utf-8", errors="replace") as handle:
        content = handle.read()
    file_stat = stat_root(root_key, file_path)
    return {"ok": True, "root": root_key, "path": rel_path, "name": os.path.basename(file_path), "size": file_stat.st_size, "modified": int(file_stat.st_mtime), "editable": True, "json": file_extension(file_path) in JSON_EXTENSIONS, "content": content}


def write_text_file(root_key, rel_path, content):
    if root_key == "trash":
        raise ValueError("Papierkorb-Dateien sind nur als Vorschau geöffnet. Bitte zuerst wiederherstellen.")
    file_path, rel_path = resolve_safe_path(root_key, rel_path)
    if path_is_dir_root(root_key, file_path):
        raise ValueError("Ordner können nicht als Datei gespeichert werden.")
    parent = assert_safe_path(root_key, os.path.dirname(file_path), require_exists=True)
    if not path_is_dir_root(root_key, parent):
        raise FileNotFoundError("Zielordner existiert nicht.")
    if not is_editable_text_file(file_path):
        raise ValueError("Dieser Dateityp ist nicht für den Texteditor freigegeben.")
    content = str(content or "")
    validate_json_if_needed(file_path, content)
    backup_path = make_file_backup(file_path, root_key, rel_path)
    fd, temp_path = mkstemp_root(root_key, parent, prefix=".winomc-edit-")
    os.close(fd)
    try:
        with open_safe(root_key, temp_path, "w", encoding="utf-8", newline="") as handle:
            handle.write(content)
        replace_safe(root_key, temp_path, file_path)
    except Exception:
        try:
            remove_safe(root_key, temp_path)
        except OSError as exc:
            log_warning("Temporäre Editor-Datei konnte nicht entfernt werden: %s" % exc)
        raise
    return {"ok": True, "root": root_key, "path": rel_path, "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Datei gespeichert."}


def prepare_upload_target(root_key, dir_rel_path, filename, overwrite=False):
    dir_path, dir_rel_path = resolve_safe_path(root_key, dir_rel_path)
    if not path_exists_root(root_key, dir_path):
        raise FileNotFoundError("Upload-Zielordner existiert nicht.")
    if not path_is_dir_root(root_key, dir_path):
        raise ValueError("Upload-Ziel ist kein Ordner.")
    filename = safe_download_name(unquote(filename or ""), "upload.bin")
    target_path = assert_safe_path(root_key, os.path.join(dir_path, filename))
    if path_exists_root(root_key, target_path) and not overwrite:
        raise FileExistsError("Datei existiert bereits. Überschreiben wurde nicht erlaubt.")
    target_rel_path = normalize_rel_path(posixpath.join(dir_rel_path, filename))
    return target_path, target_rel_path


def create_zip_from_paths(root_key, rel_paths, save_to_export=False):
    if not rel_paths:
        raise ValueError("Keine Dateien oder Ordner ausgewählt.")
    root_base = allowed_root_base(root_key)
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")

    # The physical ZIP target is server-generated. Request data only decides
    # which already-validated files are copied into the archive.
    if save_to_export:
        export_dir, _ = resolve_safe_path("export", "/")
        makedirs_root("export", export_dir, exist_ok=True)
        fd, zip_path = mkstemp_root("export", export_dir, prefix="winomc-export-%s-" % timestamp, suffix=".zip")
        zip_handle = os.fdopen(fd, "w+b")
        cleanup = False
        zip_name = safe_download_name(os.path.basename(zip_path), "winomc-export.zip")
    else:
        zip_handle = tempfile.TemporaryFile(mode="w+b")
        cleanup = True
        zip_name = safe_download_name("winomc-export-%s.zip" % timestamp, "winomc-export.zip")

    try:
        with zipfile.ZipFile(zip_handle, "w", compression=zipfile.ZIP_DEFLATED) as archive:
            for rel_path in rel_paths:
                source_path, normalized_rel_path = resolve_safe_path(root_key, rel_path)
                if not path_exists_root(root_key, source_path):
                    raise FileNotFoundError("Nicht gefunden: %s" % normalized_rel_path)
                if path_is_link_root(root_key, source_path):
                    continue
                if not is_inside_base(root_base, source_path):
                    raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
                source_name = safe_download_name(os.path.basename(source_path.rstrip(os.sep)) or FILE_ROOTS[root_key]["label"], "winomc-files")
                if path_is_file_root(root_key, source_path):
                    source_abs = os.path.abspath(str(source_path or ""))
                    safe_source = os.path.normpath(os.path.realpath(source_abs))
                    root_prefix = root_base if root_base.endswith(os.sep) else root_base + os.sep
                    if safe_source != root_base and not safe_source.startswith(root_prefix):
                        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
                    assert_no_symlink_component(root_base, source_abs, allow_missing=False)
                    archive.write(safe_source, source_name)
                    continue
                parent_path = os.path.dirname(source_path.rstrip(os.sep))
                walk_abs = os.path.abspath(str(source_path or ""))
                safe_walk_root = os.path.normpath(os.path.realpath(walk_abs))
                root_prefix = root_base if root_base.endswith(os.sep) else root_base + os.sep
                if safe_walk_root != root_base and not safe_walk_root.startswith(root_prefix):
                    raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
                assert_no_symlink_component(root_base, walk_abs, allow_missing=False)
                for current_root, dirs, files in os.walk(safe_walk_root, followlinks=False):
                    dirs[:] = [dirname for dirname in dirs if not os.path.islink(os.path.join(current_root, dirname)) and is_inside_base(root_base, os.path.join(current_root, dirname))]
                    for filename in files:
                        file_path = os.path.join(current_root, filename)
                        file_abs = os.path.abspath(str(file_path or ""))
                        safe_file_path = os.path.normpath(os.path.realpath(file_abs))
                        if os.path.islink(file_abs) or (safe_file_path != root_base and not safe_file_path.startswith(root_prefix)):
                            continue
                        archive_name = os.path.relpath(safe_file_path, parent_path)
                        archive.write(safe_file_path, archive_name)
        zip_handle.seek(0, os.SEEK_END)
        zip_size = zip_handle.tell()
        zip_handle.seek(0)
        if save_to_export:
            zip_handle.close()
            return {"zip_path": zip_path, "zip_name": zip_name, "cleanup": cleanup, "saved_to_export": True, "export_path": normalize_rel_path("/" + zip_name)}
        return {"zip_file": zip_handle, "zip_size": zip_size, "zip_name": zip_name, "cleanup": cleanup, "saved_to_export": False, "export_path": None}
    except Exception:
        try:
            zip_handle.close()
        except Exception as exc:
            log_warning("ZIP-Handle konnte nach Fehler nicht geschlossen werden: %s" % exc)
        if save_to_export and zip_path:
            try:
                remove_safe("export", zip_path)
            except OSError as exc:
                log_warning("Unvollständiges ZIP konnte nicht entfernt werden: %s" % exc)
        raise

def extract_zip_file(root_key, archive_rel_path, destination_rel_path="/", overwrite=False):
    archive_path, archive_rel_path = resolve_safe_path(root_key, archive_rel_path)
    destination_path, destination_rel_path = resolve_safe_path(root_key, destination_rel_path)
    if not path_is_file_root(root_key, archive_path):
        raise FileNotFoundError("ZIP-Datei nicht gefunden.")
    if file_extension(archive_path) not in ZIP_EXTENSIONS:
        raise ValueError("Nur .zip, .mcpack, .mcaddon, .mcworld und .mctemplate können entpackt werden.")
    if not path_is_dir_root(root_key, destination_path):
        raise ValueError("Ziel zum Entpacken ist kein Ordner.")
    root_base = allowed_root_base(root_key)
    extracted_files = 0
    extracted_dirs = 0
    total_size = 0
    archive_abs = os.path.abspath(str(archive_path or ""))
    safe_archive_path = os.path.normpath(os.path.realpath(archive_abs))
    root_prefix = root_base if root_base.endswith(os.sep) else root_base + os.sep
    if safe_archive_path != root_base and not safe_archive_path.startswith(root_prefix):
        raise ValueError("Archiv-Pfad außerhalb des erlaubten Bereichs blockiert.")
    assert_no_symlink_component(root_base, archive_abs, allow_missing=False)
    with zipfile.ZipFile(safe_archive_path, "r") as archive:
        for member in archive.infolist():
            total_size += int(member.file_size or 0)
            if total_size > MAX_ZIP_UNPACK_BYTES:
                raise ValueError("Archiv ist zu groß zum Entpacken.")
        for member in archive.infolist():
            raw_name = str(member.filename or "").replace("\\", "/")
            if not raw_name or raw_name.startswith("/") or raw_name.startswith("../") or "/../" in raw_name:
                raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw_name)
            normalized_name = posixpath.normpath(raw_name)
            if normalized_name in ("", ".") or normalized_name.startswith("../") or normalized_name == "..":
                raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw_name)
            target_candidate = os.path.join(destination_path, normalized_name)
            target_path = assert_safe_path(root_key, target_candidate)
            if not is_inside_base(destination_path, target_path) or not is_inside_base(root_base, target_path):
                raise ValueError("Archiv-Pfad außerhalb des erlaubten Bereichs blockiert: %s" % raw_name)
            if member.is_dir():
                makedirs_root(root_key, target_path, exist_ok=True)
                extracted_dirs += 1
                continue
            if path_exists_root(root_key, target_path) and not overwrite:
                raise FileExistsError("Datei existiert bereits: %s" % normalized_name)
            makedirs_root(root_key, os.path.dirname(target_path), exist_ok=True)
            with archive.open(member, "r") as source, open_safe(root_key, target_path, "wb") as target:
                shutil.copyfileobj(source, target, length=1024 * 1024)
            extracted_files += 1
    return {"ok": True, "root": root_key, "archive": archive_rel_path, "destination": destination_rel_path, "files": extracted_files, "directories": extracted_dirs, "message": "Archiv wurde entpackt."}


def create_safe_world_export(world_rel_path="/world", save_to_export=True):
    world_rel_path = normalize_rel_path(world_rel_path)
    world_path, _ = resolve_safe_path("worlds", world_rel_path)
    if not path_is_dir_root("worlds", world_path):
        raise FileNotFoundError("Weltordner wurde nicht gefunden.")
    hold_sent = False
    try:
        append_console_note("Sicherer Welt-Export gestartet.")
        write_command("save hold")
        hold_sent = True
        time.sleep(1.0)
        write_command("save query")
        time.sleep(2.0)
        zip_info = create_zip_from_paths("worlds", [world_rel_path], save_to_export=save_to_export)
        append_console_note("Sicherer Welt-Export wurde erstellt.")
        return zip_info
    finally:
        if hold_sent:
            try:
                write_command("save resume")
                append_console_note("save resume nach sicherem Welt-Export ausgeführt.")
            except Exception as exc:
                append_console_note("WARNUNG: save resume konnte nicht automatisch ausgeführt werden: %s" % exc)




def load_console_settings():
    defaults = {"trash_retention_days": TRASH_RETENTION_DAYS}
    try:
        settings_dir, settings_file = console_settings_paths()
        with open_safe_internal(settings_dir, settings_file, "r", encoding="utf-8") as handle:
            data = json.load(handle)
        if not isinstance(data, dict):
            return defaults
        defaults.update(data)
    except FileNotFoundError:
        return defaults
    except Exception as exc:
        log_warning("Console-Einstellungen konnten nicht gelesen werden: %s" % exc)
    return defaults


def save_console_settings(settings):
    settings_dir, settings_file = console_settings_paths()
    makedirs_internal(settings_dir, settings_dir, exist_ok=True)
    current = load_console_settings()
    current.update(settings)
    fd, temp_path = mkstemp_internal(settings_dir, settings_dir, prefix=".winomc-settings-")
    os.close(fd)
    try:
        with open_safe_internal(settings_dir, temp_path, "w", encoding="utf-8") as handle:
            json.dump(current, handle, indent=2, ensure_ascii=False)
            handle.write("\n")
        replace_internal(settings_dir, temp_path, settings_file)
    except Exception:
        try:
            remove_safe_internal(settings_dir, temp_path)
        except OSError as exc:
            log_warning("Temporäre Einstellungsdatei konnte nicht entfernt werden: %s" % exc)
        raise
    return current


def get_trash_retention_days():
    try:
        value = int(load_console_settings().get("trash_retention_days", TRASH_RETENTION_DAYS))
    except Exception as exc:
        log_warning("Papierkorb-Aufbewahrung konnte nicht gelesen werden: %s" % exc)
        value = TRASH_RETENTION_DAYS
    if value < 0:
        value = TRASH_RETENTION_DAYS
    return value


def set_trash_retention_days(days):
    days = int(days)
    allowed = {0, 3, 7, 14, 30, 60, 90}
    if days not in allowed:
        raise ValueError("Ungültige Papierkorb-Aufbewahrung. Erlaubt: nie, 3, 7, 14, 30, 60 oder 90 Tage.")
    settings = save_console_settings({"trash_retention_days": days})
    return {"ok": True, "retention_days": int(settings.get("trash_retention_days", days))}

def cleanup_trash():
    trash_base = os.path.realpath(TRASH_DIR)
    makedirs_internal(trash_base, trash_base, exist_ok=True)
    if TRASH_RETENTION_DAYS <= 0:
        return 0
    cutoff = time.time() - (TRASH_RETENTION_DAYS * 86400)
    removed = 0
    for name in listdir_internal(trash_base, trash_base):
        path = assert_safe_internal_path(trash_base, os.path.join(trash_base, name))
        try:
            if getmtime_internal(trash_base, path) < cutoff:
                remove_safe_internal(trash_base, path)
                removed += 1
        except FileNotFoundError:
            continue
        except Exception as exc:
            append_console_note("Papierkorb-Bereinigung übersprungen: %s" % exc)
    return removed


def delete_or_trash_path(root_key, rel_path, permanent=False):
    full_path, rel_path = resolve_safe_path(root_key, rel_path)
    if rel_path == "/":
        raise ValueError("Der Wurzelordner kann nicht gelöscht werden.")
    if not path_exists_root(root_key, full_path):
        raise FileNotFoundError("Datei oder Ordner wurde nicht gefunden.")
    if root_key == "config" and rel_path.startswith("/.winomc"):
        raise ValueError("Interne WinoMC-Verzeichnisse können hier nicht gelöscht werden. Öffne bei Bedarf den Papierkorb direkt.")

    if permanent or root_key == "trash":
        remove_safe(root_key, full_path)
        meta_path = assert_safe_path(root_key, full_path + ".winomc-trash.json")
        if path_exists_root(root_key, meta_path):
            try:
                remove_safe(root_key, meta_path)
            except OSError as exc:
                log_warning("Papierkorb-Metadatei konnte nicht entfernt werden: %s" % exc)
        return {"ok": True, "permanent": True, "path": rel_path, "message": "Endgültig gelöscht: %s" % rel_path}

    cleanup_trash()
    trash_base = os.path.realpath(TRASH_DIR)
    makedirs_internal(trash_base, trash_base, exist_ok=True)
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    trash_name = safe_download_name("%s-%s-%s" % (timestamp, root_key, rel_path.replace("/", "__")), "winomc-trash")
    target_path = assert_safe_internal_path(trash_base, os.path.join(trash_base, trash_name))
    counter = 1
    while path_exists_internal(trash_base, target_path):
        target_path = assert_safe_internal_path(trash_base, os.path.join(trash_base, "%s-%s" % (trash_name, counter)))
        counter += 1
    move_safe_root_to_internal(root_key, full_path, trash_base, target_path)
    meta = {"original_root": root_key, "original_path": rel_path, "deleted_at": timestamp, "trash_name": os.path.basename(target_path)}
    try:
        with open_safe_internal(trash_base, target_path + ".winomc-trash.json", "w", encoding="utf-8") as handle:
            json.dump(meta, handle, ensure_ascii=False, indent=2)
    except Exception as exc:
        log_warning("Papierkorb-Metadaten konnten nicht geschrieben werden: %s" % exc)
    return {"ok": True, "permanent": False, "path": rel_path, "trash_path": target_path, "message": "In den Papierkorb verschoben: %s" % rel_path}



def restore_from_trash(trash_rel_path, overwrite=False, destination_root=None, destination_path=None):
    trash_path, trash_rel_path = resolve_safe_path("trash", trash_rel_path)
    if not path_exists_root("trash", trash_path):
        raise FileNotFoundError("Papierkorb-Eintrag wurde nicht gefunden.")
    if trash_rel_path == "/":
        raise ValueError("Der Papierkorb-Wurzelordner kann nicht wiederhergestellt werden.")

    meta_path = assert_safe_path("trash", trash_path + ".winomc-trash.json")
    if path_exists_root("trash", meta_path):
        with open_safe("trash", meta_path, "r", encoding="utf-8") as handle:
            meta = json.load(handle)
    else:
        meta = {"original_root": "config", "original_path": "/" + os.path.basename(trash_path)}

    target_root = str(destination_root or meta.get("original_root") or "config")
    target_rel = normalize_rel_path(str(destination_path or meta.get("original_path") or ("/" + os.path.basename(trash_path))))
    target_path, target_rel = resolve_safe_path(target_root, target_rel)

    if target_rel == "/":
        raise ValueError("Ein Papierkorb-Eintrag kann nicht direkt auf einen Wurzelordner wiederhergestellt werden.")

    parent = assert_safe_path(target_root, os.path.dirname(target_path))
    if not path_is_dir_root(target_root, parent):
        makedirs_root(target_root, parent, exist_ok=True)

    if path_exists_root(target_root, target_path):
        if not overwrite:
            raise FileExistsError("Ziel existiert bereits. Wiederherstellen mit Überschreiben bestätigen.")
        backup_path = make_file_backup(target_path, target_root, target_rel) if path_is_file_root(target_root, target_path) else None
        remove_safe(target_root, target_path)
    else:
        backup_path = None

    move_safe_internal_to_root(allowed_root_base("trash"), trash_path, target_root, target_path)
    if path_exists_root("trash", meta_path):
        try:
            remove_safe("trash", meta_path)
        except OSError as exc:
            log_warning("Papierkorb-Metadatei konnte nach Wiederherstellung nicht entfernt werden: %s" % exc)

    return {"ok": True, "root": target_root, "path": target_rel, "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Wiederhergestellt nach %s:%s" % (target_root, target_rel)}


def move_safe_root(root_key, source_path, target_path):
    safe_source = verify_root_path(root_key, source_path, require_exists=True, allow_missing=False)
    safe_target = verify_root_path(root_key, target_path, require_exists=False, allow_missing=True)
    parent = verify_root_path(root_key, os.path.dirname(safe_target.path), require_exists=True, allow_missing=False)
    if not parent.is_dir():
        raise FileNotFoundError("Zielordner existiert nicht.")
    if safe_target.lexists() and safe_target.is_link():
        raise ValueError("Verschieben auf einen symbolischen Link ist blockiert.")
    return safe_source.move_to(safe_target)


def move_path(root_key, source_rel_path, destination_rel_path, overwrite=False):
    root_key = str(root_key or "config")
    if root_key == "trash":
        raise ValueError("Papierkorb-Einträge bitte über Wiederherstellen oder Löschen verwalten.")
    source_path, source_rel = resolve_safe_path(root_key, source_rel_path)
    if source_rel == "/":
        raise ValueError("Der Wurzelordner kann nicht verschoben werden.")
    if not path_exists_root(root_key, source_path):
        raise FileNotFoundError("Quelle wurde nicht gefunden.")

    dest_path, dest_rel = resolve_safe_path(root_key, destination_rel_path)
    source_name = os.path.basename(source_rel.rstrip("/"))
    if path_exists_root(root_key, dest_path) and path_is_dir_root(root_key, dest_path):
        target_rel = normalize_rel_path(dest_rel.rstrip("/") + "/" + source_name)
        target_path, target_rel = resolve_safe_path(root_key, target_rel)
    else:
        target_path, target_rel = dest_path, dest_rel

    if target_rel == "/":
        raise ValueError("Ziel darf nicht der Wurzelordner sein.")
    if target_rel == source_rel:
        raise ValueError("Quelle und Ziel sind identisch.")
    if path_is_dir_root(root_key, source_path) and is_inside_base(source_path, target_path):
        raise ValueError("Ein Ordner kann nicht in sich selbst verschoben werden.")

    parent = assert_safe_path(root_key, os.path.dirname(target_path))
    if not path_is_dir_root(root_key, parent):
        raise FileNotFoundError("Zielordner existiert nicht.")

    backup_path = None
    if path_exists_root(root_key, target_path):
        if not overwrite:
            raise FileExistsError("Ziel existiert bereits. Verschieben mit Überschreiben bestätigen.")
        backup_path = make_file_backup(target_path, root_key, target_rel) if path_is_file_root(root_key, target_path) else None
        remove_safe(root_key, target_path)

    move_safe_root(root_key, source_path, target_path)
    return {
        "ok": True,
        "root": root_key,
        "source": source_rel,
        "path": target_rel,
        "backup_created": bool(backup_path),
        "backup_path": backup_path,
        "message": "Verschoben: %s → %s" % (source_rel, target_rel),
    }


def file_md5_hash(root_key, rel_path):
    full_path, rel_path = resolve_safe_path(root_key, rel_path)
    if not path_is_file_root(root_key, full_path):
        raise FileNotFoundError("MD5 kann nur für Dateien berechnet werden.")
    try:
        digest = hashlib.md5(usedforsecurity=False)
    except TypeError:
        digest = hashlib.md5()
    with open_safe(root_key, full_path, "rb") as handle:
        while True:
            chunk = handle.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)
    return {"ok": True, "root": root_key, "path": rel_path, "size": getsize_root(root_key, full_path), "md5": digest.hexdigest()}


def empty_trash():
    trash_base = os.path.realpath(TRASH_DIR)
    makedirs_internal(trash_base, trash_base, exist_ok=True)
    removed = 0
    for name in list(listdir_internal(trash_base, trash_base)):
        path = assert_safe_internal_path(trash_base, os.path.join(trash_base, name))
        try:
            remove_safe_internal(trash_base, path)
            removed += 1
        except FileNotFoundError:
            continue
    return {"ok": True, "removed": removed, "message": "Papierkorb geleert."}

def runtime_getsize(candidate_path):
    return verify_runtime_path(candidate_path, require_exists=True, allow_missing=False).getsize()


def runtime_path_exists(candidate_path):
    return verify_runtime_path(candidate_path, require_exists=False, allow_missing=True).exists()


def human_bytes(value):
    try:
        size = float(value)
    except (TypeError, ValueError):
        return "-"
    units = ["B", "KB", "MB", "GB", "TB"]
    index = 0
    while size >= 1024 and index < len(units) - 1:
        size /= 1024.0
        index += 1
    if index == 0:
        return "%d %s" % (int(size), units[index])
    return "%.1f %s" % (size, units[index])


def read_meminfo_metrics():
    metrics = {"available": None, "total": None, "used": None, "used_percent": None, "label": "-"}
    try:
        values = {}
        with open("/proc/meminfo", "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                if ":" not in line:
                    continue
                key, rest = line.split(":", 1)
                match = re.search(r"(\d+)", rest)
                if match:
                    values[key] = int(match.group(1)) * 1024
        total = values.get("MemTotal")
        available = values.get("MemAvailable")
        if total and available is not None:
            used = max(0, total - available)
            percent = round((used / total) * 100, 1) if total else None
            metrics.update({"available": available, "total": total, "used": used, "used_percent": percent, "label": "%s / %s" % (human_bytes(used), human_bytes(total))})
    except Exception as exc:
        metrics["error"] = str(exc)
    return metrics


def disk_usage_metrics():
    try:
        usage = shutil.disk_usage(allowed_root_base("config"))
        used = usage.total - usage.free
        percent = round((used / usage.total) * 100, 1) if usage.total else None
        return {"total": usage.total, "used": used, "free": usage.free, "used_percent": percent, "label": "%s frei" % human_bytes(usage.free)}
    except Exception as exc:
        return {"total": None, "used": None, "free": None, "used_percent": None, "label": "-", "error": str(exc)}


def loadavg_metrics():
    try:
        one, five, fifteen = os.getloadavg()
        return {"one": round(one, 2), "five": round(five, 2), "fifteen": round(fifteen, 2), "label": "%.2f / %.2f / %.2f" % (one, five, fifteen)}
    except Exception as exc:
        return {"one": None, "five": None, "fifteen": None, "label": "-", "error": str(exc)}


def tail_runtime_log_text(max_bytes=262144):
    try:
        log_path = verify_runtime_path(runtime_log_path(), require_exists=True, allow_missing=False)
        size = log_path.getsize()
        with log_path.open("rb") as handle:
            if size > max_bytes:
                handle.seek(size - max_bytes)
            data = handle.read(max_bytes)
        return data.decode("utf-8", errors="replace")
    except Exception:
        return ""


def player_metrics_from_log(max_players_env=""):
    result = {"online": None, "max": None, "label": "unbekannt", "source": "log"}
    try:
        if str(max_players_env or "").strip():
            result["max"] = int(str(max_players_env).strip())
    except ValueError:
        result["max"] = None
    text = tail_runtime_log_text()
    matches = list(re.finditer(r"There\s+are\s+(\d+)\s*/\s*(\d+)\s+players\s+online", text, re.IGNORECASE))
    if matches:
        match = matches[-1]
        result["online"] = int(match.group(1))
        result["max"] = int(match.group(2))
    if result["online"] is not None and result["max"] is not None:
        result["label"] = "%s / %s" % (result["online"], result["max"])
    elif result["max"] is not None:
        result["label"] = "? / %s" % result["max"]
    return result



def json_file(path, fallback):
    try:
        safe = verify_root_path("config", path, require_exists=True, allow_missing=False)
        if not safe.is_file():
            return fallback, "Datei ist kein reguläres File"
        with safe.open("r", encoding="utf-8", errors="replace") as handle:
            return json.load(handle), None
    except FileNotFoundError:
        return fallback, "Datei fehlt"
    except json.JSONDecodeError as exc:
        return fallback, "JSON ungültig: Zeile %s" % exc.lineno
    except Exception as exc:
        return fallback, str(exc)


def world_dir_path():
    level = os.environ.get("LEVEL_NAME", "world") or "world"
    return os.path.join(WORLDS_DIR, level)


def dir_size(path, max_entries=250000):
    total = 0
    count = 0
    skipped = 0
    try:
        base = verify_root_path("config", path, require_exists=False, allow_missing=True).path
        if not os.path.exists(base):
            return 0
        for root, dirs, files in os.walk(base):
            if count > max_entries:
                break
            for name in files:
                count += 1
                fp = os.path.join(root, name)
                try:
                    total += os.path.getsize(fp)
                except OSError:
                    skipped += 1
                    continue
        if skipped:
            log_warning("dir_size skipped %s unreadable or vanished files under %s" % (skipped, base))
    except Exception as exc:
        log_warning("dir_size failed for %s: %s" % (path, exc))
        return 0
    return total


def backup_manifest_path(name):
    safe_name = safe_download_name(name, "backup")
    return assert_safe_internal_path(BACKUP_DIR, os.path.join(BACKUP_DIR, safe_name + ".json"))


def list_backups():
    os.makedirs(BACKUP_DIR, exist_ok=True)
    backups = []
    for name in sorted(os.listdir(BACKUP_DIR), reverse=True):
        if not name.endswith(".json"):
            continue
        path = os.path.join(BACKUP_DIR, name)
        try:
            safe = verify_internal_path(BACKUP_DIR, path, require_exists=True, allow_missing=False)
            with safe.open("r", encoding="utf-8") as handle:
                meta = json.load(handle)
            archive = os.path.join(BACKUP_DIR, meta.get("archive", ""))
            size = os.path.getsize(archive) if meta.get("archive") and os.path.exists(archive) else 0
            meta["size"] = size
            meta["size_label"] = human_bytes(size)
            backups.append(meta)
        except Exception as exc:
            backups.append({"name": name, "type": "unknown", "created": "-", "status": "Fehler", "error": str(exc), "size_label": "-"})
    return backups


def prune_backups():
    keep = max(1, BACKUP_KEEP)
    backups = list_backups()
    for meta in backups[keep:]:
        try:
            for fn in (meta.get("archive"), meta.get("name") + ".json"):
                if not fn:
                    continue
                path = verify_internal_path(BACKUP_DIR, os.path.join(BACKUP_DIR, os.path.basename(fn)), require_exists=False, allow_missing=True)
                if path.exists():
                    path.remove()
        except Exception as exc:
            log_warning("Backup-Aufbewahrung konnte %s nicht löschen: %s" % (meta.get("name"), exc))


def create_framework_backup(kind="complete", reason="manual"):
    os.makedirs(BACKUP_DIR, exist_ok=True)
    kind = kind if kind in ("world", "config", "complete", "safety") else "complete"
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    level = os.environ.get("LEVEL_NAME", "world") or "world"
    name = safe_download_name("%s-%s-%s" % (timestamp, kind, level), "winomc-backup")
    archive_name = name + ".zip"
    archive_path = assert_safe_internal_path(BACKUP_DIR, os.path.join(BACKUP_DIR, archive_name))
    include = []
    if kind in ("world", "complete", "safety"):
        include.append((world_dir_path(), "worlds/" + level))
    if kind in ("config", "complete", "safety"):
        for rel in ("server.properties", "allowlist.json", "permissions.json", ".winomc/web_console_settings.json"):
            include.append((os.path.join(DATA_DIR, rel), rel))
    if kind in ("complete", "safety"):
        include.extend([(RESOURCE_PACKS_DIR, "resource_packs"), (BEHAVIOR_PACKS_DIR, "behavior_packs")])
    with zipfile.ZipFile(archive_path, "w", zipfile.ZIP_DEFLATED) as zf:
        manifest = {"name": name, "created": timestamp, "server_version": os.environ.get("VERSION", "LATEST"), "winomc_version": WINOMC_VERSION, "world": level, "type": kind, "reason": reason, "status": "OK"}
        zf.writestr("winomc-backup.json", json.dumps(manifest, ensure_ascii=False, indent=2))
        for src, arc in include:
            try:
                src = verify_root_path("config", src, require_exists=False, allow_missing=True).path
                if os.path.isdir(src):
                    for root, dirs, files in os.walk(src):
                        dirs[:] = [d for d in dirs if d not in (".git",)]
                        for fn in files:
                            fp = os.path.join(root, fn)
                            if os.path.islink(fp):
                                continue
                            zf.write(fp, posixpath.join(arc, os.path.relpath(fp, src).replace(os.sep, "/")))
                elif os.path.isfile(src):
                    zf.write(src, arc)
            except Exception as exc:
                zf.writestr("warnings/%s.txt" % safe_download_name(arc, "item"), str(exc))
    meta = {"name": name, "archive": archive_name, "created": timestamp, "server_version": os.environ.get("VERSION", "LATEST"), "winomc_version": WINOMC_VERSION, "world": level, "type": kind, "reason": reason, "status": "OK", "size": os.path.getsize(archive_path), "size_label": human_bytes(os.path.getsize(archive_path))}
    with open_safe_internal(BACKUP_DIR, backup_manifest_path(name), "w", encoding="utf-8") as handle:
        json.dump(meta, handle, ensure_ascii=False, indent=2)
    prune_backups()
    return meta


def diagnostics_payload():
    env = {k: os.environ.get(k, "") for k in ["SERVER_PORT", "SERVER_PORT_V6", "LEVEL_NAME", "SERVER_NAME", "ONLINE_MODE", "ALLOW_LIST"]}
    items = []
    def add(title, ok, message, repair=False):
        items.append({"title": title, "status": "OK" if ok else ("Reparierbar" if repair else "Warnung"), "severity": "OK" if ok else "warning", "message": message})
    add("Serverordner", os.path.isdir(DATA_DIR), DATA_DIR)
    add("Weltordner", os.path.isdir(world_dir_path()), "Welt: %s" % (env.get("LEVEL_NAME") or "world"), True)
    add("Schreibrechte", os.access(DATA_DIR, os.W_OK), "WinoMC kann /config schreiben." if os.access(DATA_DIR, os.W_OK) else "Keine Schreibrechte auf /config.")
    add("Speicherplatz", (disk_usage_metrics().get("free") or 0) > 512*1024*1024, disk_usage_metrics().get("label", "Nicht verfügbar"))
    props = os.path.join(DATA_DIR, "server.properties")
    add("server.properties", os.path.isfile(props), "Datei vorhanden." if os.path.isfile(props) else "Kann aus Add-on-Optionen neu geschrieben werden.", True)
    for port_key in ("SERVER_PORT", "SERVER_PORT_V6"):
        try:
            port = int(env.get(port_key) or 0); ok = 1 <= port <= 65535
        except ValueError: ok = False
        add(port_key, ok, "Port ist plausibel." if ok else "Port muss zwischen 1 und 65535 liegen.")
    allow, ae = json_file(os.path.join(DATA_DIR, "allowlist.json"), [])
    perms, pe = json_file(os.path.join(DATA_DIR, "permissions.json"), [])
    add("allowlist.json", ae is None and isinstance(allow, list), ae or "%s Einträge" % len(allow), True)
    add("permissions.json", pe is None and isinstance(perms, list), pe or "%s Einträge" % len(perms), True)
    add("Resource Packs", os.path.isdir(RESOURCE_PACKS_DIR), "Ordner vorhanden." if os.path.isdir(RESOURCE_PACKS_DIR) else "Ordner fehlt.", True)
    add("Behavior Packs", os.path.isdir(BEHAVIOR_PACKS_DIR), "Ordner vorhanden." if os.path.isdir(BEHAVIOR_PACKS_DIR) else "Ordner fehlt.", True)
    add("Konsole", runtime_path_exists(runtime_fifo_path()), "FIFO vorhanden." if runtime_path_exists(runtime_fifo_path()) else "Serverprozess/FIFO nicht erreichbar.")
    add("Logdatei", runtime_path_exists(runtime_log_path()), "Log lesbar." if runtime_path_exists(runtime_log_path()) else "Noch kein Log vorhanden.")
    add("Backups", bool(list_backups()), "Letztes Backup vorhanden." if list_backups() else "Noch kein WinoMC-Backup vorhanden.", True)
    world_safety = analyze_world_safety()
    add("Welt-Schutzstatus", world_safety.get("risk") == "green", "%s / Risiko %s" % (world_safety.get("mode"), world_safety.get("risk")), bool(world_safety.get("risk") != "green"))
    overall = "OK" if all(i["severity"] == "OK" for i in items) else "Warnung"
    return {"ok": True, "overall": overall, "items": items, "world_safety": world_safety}



BUILTIN_BEDROCK_PACK_NAMES = {"chemistry", "vanilla", "education", "default", "minecraft"}
BUILTIN_BEDROCK_PACK_PREFIXES = ("vanilla_", "experimental_")

def is_system_pack_path(path):
    parts = [str(part or "").strip().lower() for part in re.split(r"[\\/]+", str(path or "")) if str(part or "").strip()]
    for part in parts:
        if part in BUILTIN_BEDROCK_PACK_NAMES or any(part.startswith(prefix) for prefix in BUILTIN_BEDROCK_PACK_PREFIXES):
            return True
    return False

def is_builtin_bedrock_pack(pack):
    pack = pack or {}
    values = [pack.get("name"), pack.get("path"), pack.get("filename"), pack.get("manifest_path"), pack.get("uuid")]
    header = pack.get("header") if isinstance(pack.get("header"), dict) else {}
    values += [header.get("name"), header.get("description")]
    metadata = pack.get("metadata") if isinstance(pack.get("metadata"), dict) else {}
    values += [metadata.get("product_type"), metadata.get("pack_scope")]
    for value in values:
        text = str(value or "").strip().lower()
        if not text:
            continue
        base = os.path.basename(text.replace("\\", "/"))
        if base in BUILTIN_BEDROCK_PACK_NAMES or any(base.startswith(prefix) for prefix in BUILTIN_BEDROCK_PACK_PREFIXES):
            return True
        if is_system_pack_path(text):
            return True
    return False

def scan_packs(base_dir, pack_type):
    packs=[]; seen={}
    if not os.path.isdir(base_dir): return packs
    for name in sorted(os.listdir(base_dir)):
        pack_path=os.path.join(base_dir,name); manifest=os.path.join(pack_path,"manifest.json")
        if not os.path.isdir(pack_path): continue
        if is_system_pack_path(pack_path) or is_system_pack_path(name):
            continue
        data, err=json_file(manifest, {})
        header=data.get("header",{}) if isinstance(data,dict) else {}
        if is_builtin_bedrock_pack({"name": header.get("name") or name, "path": pack_path, "header": header, "metadata": data.get("metadata", {}) if isinstance(data, dict) else {}}):
            continue
        uuid=header.get("uuid",""); version=header.get("version",[])
        status="OK" if not err and uuid and version else "warning"
        desc=header.get("description","") or (err or "Manifest geprüft")
        if uuid and uuid in seen: status="warning"; desc="Doppelte UUID mit %s"%seen[uuid]
        if uuid: seen[uuid]=name
        packs.append({"name": header.get("name") or name, "path": name, "type": pack_type, "uuid": uuid, "version": ".".join(map(str,version)) if isinstance(version,list) else str(version), "description": desc, "status": status})
    return packs


def players_payload():
    allow, ae = json_file(os.path.join(DATA_DIR,"allowlist.json"), [])
    perms, pe = json_file(os.path.join(DATA_DIR,"permissions.json"), [])
    allow = allow if isinstance(allow, list) else []
    perms = perms if isinstance(perms, list) else []
    by = {}
    for a in allow:
        key = str(a.get("xuid") or a.get("name") or "")
        by.setdefault(key, {"name": a.get("name","-"), "xuid": a.get("xuid",""), "allowlisted": True, "role": "member", "issues": []})
    for p in perms:
        key = str(p.get("xuid") or p.get("permission") or len(by))
        row = by.setdefault(key, {"name": p.get("name","-"), "xuid": p.get("xuid",""), "allowlisted": False, "role": "member", "issues": []})
        row["role"] = p.get("permission", "member")
        if row["role"] == "operator" and not row["allowlisted"]:
            row["issues"].append("OP nicht auf Allowlist")
    warnings=[]
    if ae: warnings.append("allowlist.json: "+ae)
    if pe: warnings.append("permissions.json: "+pe)
    if parse_bool(os.environ.get("ALLOW_LIST"), False) and not allow: warnings.append("Allowlist ist aktiv, aber leer.")
    if not parse_bool(os.environ.get("ONLINE_MODE"), True): warnings.append("Online Mode ist deaktiviert und sollte nur bewusst genutzt werden.")
    return {"ok": True, "players": list(by.values()), "warnings": warnings}


