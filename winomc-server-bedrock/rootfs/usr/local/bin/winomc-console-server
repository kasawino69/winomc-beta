    function isIosSafariShell() {
      const ua = String(navigator.userAgent || '').toLowerCase();
      return /iphone|ipad|ipod/.test(ua) && /safari/.test(ua) && !/crios|fxios|edgios/.test(ua);
    }

    // Override mobile detection: a narrow desktop browser is still PC UX.
    isLikelyMobileViewport = function() {
      const width = Math.max(document.documentElement.clientWidth || 0, window.innerWidth || 0);
      const height = Math.max(document.documentElement.clientHeight || 0, window.innerHeight || 0);
      const coarsePointer = window.matchMedia && window.matchMedia('(pointer: coarse)').matches;
      const finePointer = window.matchMedia && (window.matchMedia('(pointer: fine)').matches || window.matchMedia('(any-pointer: fine)').matches);
      const touchPoints = Number(navigator.maxTouchPoints || navigator.msMaxTouchPoints || 0);
      const ua = String(navigator.userAgent || '').toLowerCase();
      const handheldUA = /iphone|ipod|android.*mobile|windows phone/.test(ua);
      const ipadLike = /ipad/.test(ua) || (navigator.platform === 'MacIntel' && touchPoints > 1 && coarsePointer);
      const portrait = height >= width;
      return handheldUA || (ipadLike && width <= 900) || (coarsePointer && !finePointer && touchPoints > 0 && portrait && width <= 980);
    };

    detectUxProfile = function() {
      return isLikelyMobileViewport() ? 'mobile' : 'desktop';
    };

    function cleanupLegacyNavigation() {
      document.querySelectorAll('[data-tab="desktop"], [data-tab="workbench"]').forEach(item => item.remove());
      document.querySelectorAll('nav .tab-button').forEach(item => {
        const label = (item.textContent || '').trim().toLowerCase();
        if (label.includes('desktop-modus')) item.remove();
        if (label.includes('pc-workbench') && item.id !== 'pcWorkbenchNav') item.remove();
      });
    }

    const baseUpdateUxProfileControl = updateUxProfileControl;
    updateUxProfileControl = function(preference, activeProfile) {
      baseUpdateUxProfileControl(preference, activeProfile);
      cleanupLegacyNavigation();
      document.body.classList.toggle('ios-browser-shell', isIosSafariShell());
      const mobile = activeProfile === 'mobile';
      if (desktopModeToggle) {
        desktopModeToggle.hidden = mobile;
        desktopModeToggle.disabled = mobile;
      }
      if (uxProfileSelect) {
        Array.from(uxProfileSelect.options).forEach(option => {
          if (option.value === 'desktop') {
            option.hidden = mobile;
            option.disabled = mobile;
          }
        });
      }
    };

    const baseSetConsoleMode = setConsoleMode;
    setConsoleMode = function(mode) {
      baseSetConsoleMode(mode || 'normal');
      document.body.classList.toggle('console-only-expand', mode === 'collapsed' || mode === 'hidden');
      if ((mode === 'collapsed' || mode === 'hidden') && consoleCollapse) consoleCollapse.textContent = 'Ausklappen';
    };

    enterDesktopModeFromUser = function() {
      if (isLikelyMobileViewport()) {
        localStorage.setItem(STORE_UX_PROFILE, 'auto');
        localStorage.setItem(STORE_DESKTOP_MODE, 'false');
        forceClassicShellAfterDesktop();
        applyAdaptiveUx();
        appendLine('[WinoMC UX] PC-Workbench ist auf MobilgerÃ¤ten bewusst deaktiviert.', 'error');
        return;
      }
      localStorage.setItem(STORE_UX_PROFILE, 'desktop');
      localStorage.setItem(STORE_DESKTOP_MODE, 'true');
      document.body.classList.remove('ux-auto', 'ux-mobile', 'ux-tablet');
      document.body.classList.add('ux-desktop');
      setDesktopMode(true, { adaptive: true, manual: true });
      updateUxProfileControl('desktop', 'desktop');
      requestAnimationFrame(() => {
        if (!document.body.classList.contains('desktop-mode')) setDesktopMode(true, { adaptive: true, manual: true });
        if (!document.querySelector('.tab-panel.desktop-open')) openDesktopWindow('overview');
        updateDesktopTaskbar();
      });
    };

    setUxProfile = function(profile) {
      const next = sanitizeUxProfile(profile);
      if (next === 'desktop' && isLikelyMobileViewport()) {
        localStorage.setItem(STORE_UX_PROFILE, 'auto');
        localStorage.setItem(STORE_DESKTOP_MODE, 'false');
        forceClassicShellAfterDesktop();
        applyAdaptiveUx();
        appendLine('[WinoMC UX] PC-Workbench ist auf MobilgerÃ¤ten nicht verfÃ¼gbar.', 'error');
        return;
      }
      localStorage.setItem(STORE_UX_PROFILE, next);
      if (next !== 'desktop') localStorage.setItem(STORE_DESKTOP_MODE, 'false');
      if (document.body.classList.contains('desktop-mode') && next !== 'desktop') forceClassicShellAfterDesktop();
      applyAdaptiveUx();
    };

    const baseActivateTab = activateTab;
    activateTab = function(tab) {
      if (tab === 'console' && !document.body.classList.contains('desktop-mode')) {
        baseActivateTab(tab);
        if (document.body.classList.contains('console-collapsed') || document.body.classList.contains('console-hidden')) setConsoleMode('normal');
        window.setTimeout(() => input?.focus({ preventScroll: true }), 80);
        return;
      }
      baseActivateTab(tab);
    };

    function createDashboardActionMenu(id, index) {
      const wrap = document.createElement('div');
      wrap.className = 'dashboard-action-menu-wrap';
      const toggle = document.createElement('button');
      toggle.type = 'button';
      toggle.className = 'dashboard-action-toggle soft';
      toggle.textContent = 'â‹¯';
      toggle.title = 'Kachel-Aktionen';
      const menu = document.createElement('div');
      menu.className = 'dashboard-action-menu';
      const up = document.createElement('button');
      up.type = 'button';
      up.textContent = 'Nach oben';
      up.disabled = index === 0;
      up.addEventListener('click', () => moveDashboardAction(index, -1));
      const down = document.createElement('button');
      down.type = 'button';
      down.textContent = 'Nach unten';
      down.disabled = index === dashboardActions.length - 1;
      down.addEventListener('click', () => moveDashboardAction(index, 1));
      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'danger';
      remove.textContent = 'Entfernen';
      remove.addEventListener('click', () => removeDashboardAction(id));
      menu.append(up, down, remove);
      toggle.addEventListener('click', event => {
        event.stopPropagation();
        document.querySelectorAll('.dashboard-action-menu-wrap.open').forEach(item => { if (item !== wrap) item.classList.remove('open'); });
        wrap.classList.toggle('open');
      });
      wrap.append(toggle, menu);
      return wrap;
    }

    function moveDashboardActionTo(from, to) {
      if (from === to || from < 0 || to < 0 || from >= dashboardActions.length || to >= dashboardActions.length) return;
      const [item] = dashboardActions.splice(from, 1);
      dashboardActions.splice(to, 0, item);
      saveDashboard();
      renderDashboard();
    }

    renderDashboard = function() {
      dashboardGrid.innerHTML = '';
      const columns = localStorage.getItem(STORE_COLUMNS) || 'auto';
      dashboardColumns.value = columns;
      dashboardGrid.classList.toggle('auto', columns === 'auto');
      if (columns === 'auto') dashboardGrid.style.removeProperty('--dashboard-columns');
      else dashboardGrid.style.setProperty('--dashboard-columns', columns);

      if (!dashboardActions.length) {
        const empty = document.createElement('div');
        empty.className = 'dashboard-empty';
        empty.textContent = 'Noch keine Kacheln ausgewÃ¤hlt. Suche oben nach einer Aktion und fÃ¼ge sie hinzu.';
        dashboardGrid.appendChild(empty);
      }

      dashboardActions.forEach((id, index) => {
        const action = ACTION_BY_ID[id];
        if (!action) return;
        const tile = document.createElement('article');
        tile.className = 'tile dashboard-tile';
        tile.draggable = !document.body.classList.contains('ux-mobile');
        tile.dataset.actionId = id;
        tile.dataset.index = String(index);
        tile.addEventListener('dragstart', event => {
          dashboardGrid.classList.add('drag-active');
          tile.classList.add('dragging');
          event.dataTransfer.effectAllowed = 'move';
          event.dataTransfer.setData('text/plain', String(index));
        });
        tile.addEventListener('dragend', () => {
          dashboardGrid.classList.remove('drag-active');
          document.querySelectorAll('.dashboard-tile.dragging,.dashboard-tile.drop-before,.dashboard-tile.drop-after').forEach(item => item.classList.remove('dragging','drop-before','drop-after'));
        });
        tile.addEventListener('dragover', event => {
          if (document.body.classList.contains('ux-mobile')) return;
          event.preventDefault();
          const rect = tile.getBoundingClientRect();
          const after = event.clientX > rect.left + rect.width / 2;
          tile.classList.toggle('drop-before', !after);
          tile.classList.toggle('drop-after', after);
        });
        tile.addEventListener('dragleave', () => tile.classList.remove('drop-before','drop-after'));
        tile.addEventListener('drop', event => {
          if (document.body.classList.contains('ux-mobile')) return;
          event.preventDefault();
          const from = Number(event.dataTransfer.getData('text/plain'));
          const rect = tile.getBoundingClientRect();
          const after = event.clientX > rect.left + rect.width / 2;
          let to = index + (after ? 1 : 0);
          if (from < to) to -= 1;
          to = clamp(to, 0, dashboardActions.length - 1);
          moveDashboardActionTo(from, to);
        });

        const top = document.createElement('div');
        top.className = 'tile-top';
        const text = document.createElement('div');
        const title = document.createElement('div');
        title.className = 'tile-title';
        title.textContent = action.label;
        const desc = document.createElement('div');
        desc.className = 'tile-desc';
        desc.textContent = action.description || '';
        text.append(title, desc);
        const meta = document.createElement('div');
        meta.style.display = 'grid';
        meta.style.gap = '6px';
        meta.style.justifyItems = 'end';
        const tag = document.createElement('span');
        tag.className = 'category-label';
        tag.textContent = action.category;
        meta.append(tag, createDashboardActionMenu(id, index));
        top.append(text, meta);
        const actionButton = createButtonForAction(action, action.template ? 'AusfÃ¼hrenâ€¦' : 'AusfÃ¼hren');
        actionButton.classList.add('tile-action-main');
        tile.append(top, actionButton);
        dashboardGrid.appendChild(tile);
      });
      renderActionPicker();
    };

    document.addEventListener('click', event => {
      if (!event.target.closest('.dashboard-action-menu-wrap')) {
        document.querySelectorAll('.dashboard-action-menu-wrap.open').forEach(item => item.classList.remove('open'));
      }
    });

    function commandMatches(item, term) {
      const hay = [item.cmd, item.title, item.group].join(' ').toLowerCase();
      return hay.includes(term.toLowerCase());
    }

    function initCommandAssistant() {
      if (!input || !form || document.getElementById('commandAssistant')) return;
      const assistant = document.createElement('div');
      assistant.id = 'commandAssistant';
      assistant.className = 'console-assistant';
      if (document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode')) assistant.classList.add('winomc-mobile-assistant');
      assistant.innerHTML = '<div class="console-assistant-title">Befehlshilfe</div><div class="command-suggestion-list" id="commandSuggestionList"></div>';
      document.body.appendChild(assistant);
      const list = assistant.querySelector('#commandSuggestionList');
      function hide() { assistant.classList.remove('open'); }
      function render() {
        const term = input.value.trim();
        if (!term || term.length < 1 || document.body.classList.contains('console-collapsed') || document.body.classList.contains('console-hidden')) { hide(); return; }
        const matches = BEDROCK_COMMAND_CATALOG.filter(item => commandMatches(item, term)).slice(0, 8);
        if (!matches.length) { hide(); return; }
        list.innerHTML = '';
        matches.forEach(item => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'command-suggestion';
          btn.innerHTML = '<span><code>' + escapeHtml(item.cmd) + '</code><small>' + escapeHtml(item.title) + '</small></span><span class="badge">' + escapeHtml(item.group) + '</span>';
          btn.addEventListener('pointerdown', event => {
            event.preventDefault();
            input.value = item.cmd;
            hide();
            input.focus({ preventScroll: true });
            input.setSelectionRange(input.value.length, input.value.length);
          });
          list.appendChild(btn);
        });
        assistant.classList.add('open');
      }
      input.addEventListener('input', render);
      input.addEventListener('focus', render);
      input.addEventListener('blur', () => window.setTimeout(hide, 180));
      form.addEventListener('submit', hide);
    }

    function enhanceConsolePanel() {
      const panel = document.querySelector('[data-panel="console"]');
      if (!panel || panel.dataset.enhanced === 'true') return;
      panel.dataset.enhanced = 'true';
      panel.innerHTML = '<div class="card console-center-card"><div class="card-header"><div><h2>Konsole & Befehlshilfe</h2><p>Die Live Console bleibt unten sichtbar. Diese Seite ist die Kommandozentrale mit Fokus, GrÃ¶ÃŸensteuerung und nicht stÃ¶renden VorschlÃ¤gen.</p></div><span class="badge">Live</span></div><div class="pill-group"><button data-console-size="compact">Kompakt</button><button data-console-size="normal">Normal</button><button data-console-size="large">GroÃŸ</button><button id="focusConsoleInputPanel" type="button">Eingabe fokussieren</button></div><div class="command-help-grid"><div class="command-help-card"><b>Intelligente Eingabe</b><p>Tippe unten einen Befehl oder Begriff. VorschlÃ¤ge erscheinen nur beim Schreiben und fÃ¼llen die Eingabe erst nach Antippen/Klick aus.</p><code>gamerule keepinventory true</code></div><div class="command-help-card"><b>Mobile freundlich</b><p>Kein Tab-Zwang: VorschlÃ¤ge funktionieren per Touch, Klick und Tastatur.</p><code>tp Spieler Ziel</code></div><div class="command-help-card"><b>Schnellbefehle</b><p>HÃ¤ufige Aktionen bleiben als sichere Buttons verfÃ¼gbar.</p><div class="pill-group"><button data-action-id="list">list</button><button data-action-id="say">say</button><button data-action-id="save-query">save query</button><button data-action-id="stop" class="danger">stop</button></div></div></div></div>';
