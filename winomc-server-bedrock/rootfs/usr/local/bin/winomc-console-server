      renderDashboard_16131();
      dashboardGrid.querySelectorAll('.dashboard-tile[data-action-id]').forEach(tile => {
        tile.dataset.dashboardActionId = tile.dataset.actionId || '';
        tile.removeAttribute('data-action-id');
