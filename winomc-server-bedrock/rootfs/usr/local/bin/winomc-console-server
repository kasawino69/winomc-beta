    const ACTION_BY_ID = Object.fromEntries(ACTIONS.map(action => [action.id, action]));
    const DEFAULT_DASHBOARD = ['list', 'say', 'time-day', 'weather-clear', 'save-query'];
    let history = JSON.parse(localStorage.getItem('winomcCommandHistory') || '[]');
    let historyIndex = history.length;
    let pendingTemplate = null;
    let dashboardActions = loadDashboard();
    let filesInitialized = false;
    let currentFileRoot = 'config';
    let currentFilePath = '/';
    let currentEditorFile = null;
    let webWriteLocked = localStorage.getItem(STORE_WEB_WRITE_LOCK) !== 'false';
    let trashRetentionDays = 7;
    let latestStatus = null;

    function appendLine(text, cls) { const div = document.createElement('div'); div.className = 'line' + (cls ? ' ' + cls : ''); div.textContent = text; const stick = log.scrollTop + log.clientHeight >= log.scrollHeight - 20; log.appendChild(div); while (log.children.length > 1600) log.removeChild(log.firstChild); if (stick) log.scrollTop = log.scrollHeight; }
    function saveHistory(command) { history = history.filter(item => item !== command); history.push(command); history = history.slice(-50); historyIndex = history.length; localStorage.setItem('winomcCommandHistory', JSON.stringify(history)); }
    async function sendCommand(command) { command = String(command || '').trim(); if (!command) return; appendLine('> ' + command, 'command'); saveHistory(command); input.value = ''; try { const endpoint = './api/command?command=' + encodeURIComponent(command); const res = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ command }) }); const data = await res.json(); if (!res.ok || !data.ok) appendLine('Fehler: ' + (data.error || res.statusText), 'error'); else appendLine('Befehl gesendet', 'ok'); } catch (err) { appendLine('Fehler beim Senden: ' + err.message, 'error'); } }
    function runAction(action) {
      if (!action) return;
      if (action.confirm && !window.confirm(action.confirm)) return;
      if (Array.isArray(action.fields) && action.fields.length) {
        runFieldAction(action);
        return;
      }
      if (action.template) { openPromptForAction(action); return; }
      sendCommand(action.command);
    }

    function runFieldAction(action) {
      const values = {};
      for (const field of action.fields) {
        let label = field.label || field.key || 'Wert';
        let hint = field.placeholder ? '\nBeispiel: ' + field.placeholder : '';
        let value = window.prompt(label + hint, field.default || '');
        if (value === null) return;
        value = String(value).trim();
        if (!value && !field.optional) {
          alert('Pflichtfeld fehlt: ' + label);
          return;
        }
        if (field.type === 'number' && value && !/^-?\d+(\.\d+)?$/.test(value)) {
          alert('Bitte eine Zahl eingeben: ' + label);
          return;
        }
        values[field.key] = value;
      }
      let command = action.template || '';
      Object.entries(values).forEach(([key, value]) => {
        command = command.replaceAll('{' + key + '}', value);
      });
      command = command.replace(/\s+/g, ' ').trim();
      if (!command) return;
      sendCommand(command);
    }

    function openPromptForAction(action) { pendingTemplate = action.template; modalTitle.textContent = action.promptTitle || action.label || 'Wert eingeben'; modalLabel.textContent = action.promptLabel || action.description || 'Bitte Wert eingeben.'; modalInput.value = ''; modalInput.placeholder = action.placeholder || ''; modalBackdrop.classList.add('open'); modalBackdrop.setAttribute('aria-hidden', 'false'); setTimeout(() => modalInput.focus(), 0); }
    function closePrompt() { modalBackdrop.classList.remove('open'); modalBackdrop.setAttribute('aria-hidden', 'true'); pendingTemplate = null; }
    function sendPromptValue() { const value = modalInput.value.trim(); if (!value || !pendingTemplate) return; const command = pendingTemplate.replaceAll('{value}', value); closePrompt(); sendCommand(command); }
    function loadDashboard() { try { const saved = JSON.parse(localStorage.getItem(STORE_DASHBOARD) || 'null'); if (Array.isArray(saved) && saved.length) return saved.filter(id => ACTION_BY_ID[id]); } catch (_) {} return [...DEFAULT_DASHBOARD]; }
    function saveDashboard() { localStorage.setItem(STORE_DASHBOARD, JSON.stringify(dashboardActions)); }
    function createButtonForAction(action, label) { const button = document.createElement('button'); button.type = 'button'; button.textContent = label || action.label; if (action.variant) button.classList.add(action.variant); button.addEventListener('click', () => runAction(action)); return button; }
    function renderDashboard() {
      dashboardGrid.innerHTML = '';
      const columns = localStorage.getItem(STORE_COLUMNS) || 'auto';
      dashboardColumns.value = columns;
      dashboardGrid.classList.toggle('auto', columns === 'auto');
      if (columns === 'auto') dashboardGrid.style.removeProperty('--dashboard-columns');
      else dashboardGrid.style.setProperty('--dashboard-columns', columns);

      if (!dashboardActions.length) {
        const empty = document.createElement('div');
        empty.className = 'dashboard-empty';
        empty.textContent = 'Noch keine Kacheln ausgewÃ¤hlt. Suche oben nach einer Aktion und fÃ¼ge sie hinzu.';
        dashboardGrid.appendChild(empty);
      }

      dashboardActions.forEach((id, index) => {
        const action = ACTION_BY_ID[id];
        if (!action) return;
        const tile = document.createElement('article');
        tile.className = 'tile dashboard-tile';
        const top = document.createElement('div');
        top.className = 'tile-top';
        const text = document.createElement('div');
        const title = document.createElement('div');
        title.className = 'tile-title';
        title.textContent = action.label;
        const desc = document.createElement('div');
        desc.className = 'tile-desc';
        desc.textContent = action.description || '';
        text.append(title, desc);
        const tag = document.createElement('span');
        tag.className = 'category-label';
        tag.textContent = action.category;
        top.append(text, tag);
        const actionButton = createButtonForAction(action, action.template ? 'AusfÃ¼hrenâ€¦' : 'AusfÃ¼hren');
        actionButton.classList.add('tile-action-main');
        const controls = document.createElement('div');
        controls.className = 'tile-actions';
        const up = document.createElement('button');
        up.type = 'button';
        up.textContent = 'â†‘';
        up.title = 'Nach oben';
        up.disabled = index === 0;
        up.addEventListener('click', () => moveDashboardAction(index, -1));
        const down = document.createElement('button');
        down.type = 'button';
        down.textContent = 'â†“';
        down.title = 'Nach unten';
        down.disabled = index === dashboardActions.length - 1;
        down.addEventListener('click', () => moveDashboardAction(index, 1));
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.textContent = 'Entfernen';
        remove.className = 'ghost';
        remove.addEventListener('click', () => removeDashboardAction(id));
        controls.append(up, down, remove);
        tile.append(top, actionButton, controls);
        dashboardGrid.appendChild(tile);
      });
      renderActionPicker();
    }

    function getDashboardAvailableActions() {
      const term = String(dashboardActionSearch?.value || '').trim().toLowerCase();
      return ACTIONS
        .filter(action => !dashboardActions.includes(action.id))
        .filter(action => !term || [action.label, action.description, action.category, action.id].join(' ').toLowerCase().includes(term))
        .sort((a, b) => (a.category + a.label).localeCompare(b.category + b.label));
    }

    function renderActionPicker() {
      if (!dashboardActionSelect || !actionPicker) return;
      const available = getDashboardAvailableActions();
      dashboardActionSelect.innerHTML = '';

      if (!available.length) {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = dashboardActionSearch?.value ? 'Keine passende Aktion gefunden' : 'Alle Aktionen sind bereits im Dashboard';
        dashboardActionSelect.appendChild(option);
        if (dashboardAddSelected) dashboardAddSelected.disabled = true;
        actionPicker.textContent = option.textContent;
        return;
      }

      let currentCategory = '';
      available.forEach(action => {
        if (action.category !== currentCategory) {
          currentCategory = action.category;
          const group = document.createElement('option');
          group.disabled = true;
          group.textContent = 'â”€â”€ ' + currentCategory + ' â”€â”€';
          dashboardActionSelect.appendChild(group);
        }
        const option = document.createElement('option');
        option.value = action.id;
        option.textContent = action.label + (action.variant === 'danger' ? '  Â· Kritisch' : '');
        dashboardActionSelect.appendChild(option);
      });

      const first = available[0];
      dashboardActionSelect.value = first.id;
      if (dashboardAddSelected) dashboardAddSelected.disabled = false;
      updateDashboardActionPreview();
    }

    function updateDashboardActionPreview() {
      if (!dashboardActionSelect || !actionPicker) return;
      const action = ACTION_BY_ID[dashboardActionSelect.value];
      if (!action) { actionPicker.textContent = 'Keine Aktion ausgewÃ¤hlt.'; return; }
      actionPicker.innerHTML = '<b>' + escapeHtml(action.label) + '</b><span>' + escapeHtml(action.category) + '</span><p>' + escapeHtml(action.description || '') + '</p>';
      actionPicker.classList.toggle('danger', action.variant === 'danger');
      actionPicker.classList.toggle('warning', action.variant === 'warning');
    }

    function addDashboardAction(id) { if (!ACTION_BY_ID[id] || dashboardActions.includes(id)) return; dashboardActions.push(id); saveDashboard(); renderDashboard(); }
    function removeDashboardAction(id) { dashboardActions = dashboardActions.filter(item => item !== id); saveDashboard(); renderDashboard(); }
    function moveDashboardAction(index, direction) { const next = index + direction; if (next < 0 || next >= dashboardActions.length) return; [dashboardActions[index], dashboardActions[next]] = [dashboardActions[next], dashboardActions[index]]; saveDashboard(); renderDashboard(); }

    function apiUrl(path, params = {}) { const query = new URLSearchParams(params); const suffix = query.toString() ? '?' + query.toString() : ''; return './' + path.replace(/^\/+/, '') + suffix; }
    const STARTUP_REQUEST_TIMEOUT_MS = 8000;
    const STARTUP_MAX_LOG_LINES = 600;
    const startupIntervals = new Map();
    let logSource = null;
    let renderedLogLines = 0;
    function setManagedInterval(key, fn, delay) { const existing = startupIntervals.get(key); if (existing) window.clearInterval(existing); const id = window.setInterval(fn, delay); startupIntervals.set(key, id); return id; }
    function showStartupError(message) { window.WinoMCBoot?.fail(message); const text = 'Startfehler: ' + message; statusEl.textContent = text; statusDot.classList.remove('ok'); const target = document.querySelector('[data-panel="overview"] .card') || document.querySelector('[data-panel="overview"]') || document.querySelector('main'); if (target && !document.getElementById('startupErrorBanner')) { const box = document.createElement('div'); box.id = 'startupErrorBanner'; box.className = 'info warn'; box.textContent = text + ' Â· Die OberflÃ¤che bleibt bedienbar; bitte Backend-Logs prÃ¼fen.'; target.prepend(box); } }
    async function fetchWithTimeout(url, options = {}, timeout = STARTUP_REQUEST_TIMEOUT_MS) { const controller = new AbortController(); const timer = window.setTimeout(() => controller.abort(), timeout); try { return await fetch(url, { ...options, signal: controller.signal }); } catch (err) { if (err.name === 'AbortError') throw new Error('ZeitÃ¼berschreitung beim Laden von ' + url); throw err; } finally { window.clearTimeout(timer); } }
    async function readJsonResponse(res) { let data = {}; try { data = await res.json(); } catch (_) { throw new Error('UngÃ¼ltige API-Antwort (' + res.status + ')'); } if (!res.ok || !data.ok) throw new Error(data.error || res.statusText || ('HTTP ' + res.status)); return data; }
    async function fetchJson(path, params = {}) { return readJsonResponse(await fetchWithTimeout(apiUrl(path, params), { cache: 'no-store' })); }
    async function postJson(path, payload = {}) { return readJsonResponse(await fetchWithTimeout('./' + path.replace(/^\/+/, ''), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })); }
    function setFilesStatus(text, variant) { if (!filesStatus) return; filesStatus.textContent = text; filesStatus.classList.toggle('warn', variant === 'warn'); }

    function applyWebWriteLock() {
      localStorage.setItem(STORE_WEB_WRITE_LOCK, String(webWriteLocked));
      document.cookie = 'winomc_web_protection=' + (webWriteLocked ? '1' : '0') + '; Path=/; SameSite=Lax';
      document.body.classList.toggle('web-write-locked', webWriteLocked);
      if (fileWriteLockToggle) {
        fileWriteLockToggle.textContent = webWriteLocked ? 'ðŸ”’ Web-Schutz: an' : 'ðŸ”“ Web-Schutz: aus';
        fileWriteLockToggle.classList.toggle('warning', webWriteLocked);
        fileWriteLockToggle.classList.toggle('primary', !webWriteLocked);
        fileWriteLockToggle.title = webWriteLocked
          ? 'Download, ZIP-Download, Ã„nderungen, Upload, Entpacken, LÃ¶schen und Wiederherstellen sind nur in der WeboberflÃ¤che gesperrt. Der Minecraft Server kann weiterhin schreiben.'
          : 'WeboberflÃ¤che ist entsperrt. Downloads und Dateiaktionen sind mÃ¶glich.';
      }
      if (fileDropZone) {
        fileDropZone.classList.toggle('locked', webWriteLocked);
        fileDropZone.textContent = webWriteLocked ? 'Web-Schutz aktiv: Upload ist gesperrt' : 'Dateien hierher ziehen oder klicken zum Hochladen';
        if (fileUploadInput && !fileDropZone.contains(fileUploadInput)) fileDropZone.appendChild(fileUploadInput);
      }
      document.querySelectorAll('[data-write-action], [data-download-action]').forEach(button => {
        button.disabled = webWriteLocked;
        button.title = webWriteLocked ? 'Web-Schutz aktiv: erst entsperren.' : '';
      });
      if (currentEditorFile && currentEditorFile.root !== 'trash') setEditorPreviewMode(webWriteLocked, webWriteLocked ? 'Web-Schutz aktiv: Vorschau. Zum Speichern oben entsperren.' : '');
    }

    async function syncWebProtectionFromServer() {
      try {
        const data = await fetchJson('/api/web-protection');
        webWriteLocked = Boolean(data.enabled);
        applyWebWriteLock();
      } catch (err) {
        appendLine('[Webschutz] Serverstatus konnte nicht geladen werden: ' + err.message, 'error');
        applyWebWriteLock();
      }
    }

    async function setWebProtectionOnServer(enabled) {
      const data = await postJson('/api/web-protection', { enabled: Boolean(enabled) });
      webWriteLocked = Boolean(data.enabled);
      applyWebWriteLock();
      return data;
    }

    function ensureWriteAllowed(actionLabel = 'Diese Aktion') {
      if (!webWriteLocked) return true;
      alert(actionLabel + ' ist durch den Web-Schutz gesperrt.\n\nDas betrifft nur diese WeboberflÃ¤che. Der Minecraft Server selbst kann seine Dateien weiterhin schreiben.');
      return false;
    }

    function ensureDownloadAllowed(actionLabel = 'Download') {
      if (!webWriteLocked) return true;
      alert(actionLabel + ' ist durch den Web-Schutz gesperrt.\n\nZum Herunterladen bitte den Web-Schutz in der Dateiansicht entsperren.');
      return false;
    }

    async function loadTrashSettings() {
      try {
        const data = await fetchJson('/api/files/trash/settings');
        trashRetentionDays = Number(data.retention_days ?? 7);
        if (trashRetentionSelect) trashRetentionSelect.value = String(trashRetentionDays);
      } catch (err) {
        appendLine('[WinoMC Dateien] Papierkorb-Einstellungen konnten nicht geladen werden: ' + err.message, 'error');
      }
    }

    async function saveTrashSettings(days) {
      try {
        const data = await postJson('/api/files/trash/settings', { retention_days: Number(days) });
        trashRetentionDays = Number(data.retention_days ?? days);
        if (trashRetentionSelect) trashRetentionSelect.value = String(trashRetentionDays);
        appendLine('[WinoMC Dateien] Papierkorb-Aufbewahrung gesetzt: ' + (trashRetentionDays === 0 ? 'nie automatisch' : trashRetentionDays + ' Tage'), 'ok');
      } catch (err) {
        alert(err.message);
      }
    }
    function formatBytes(value) { const bytes = Number(value || 0); if (bytes < 1024) return bytes + ' B'; if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'; if (bytes < 1024 * 1024 * 1024) return (bytes / 1024 / 1024).toFixed(1) + ' MB'; return (bytes / 1024 / 1024 / 1024).toFixed(1) + ' GB'; }
    function formatUnixTime(value) { if (!value) return '-'; return new Date(Number(value) * 1000).toLocaleString(); }
    function normalizeUiPath(path) { path = String(path || '/').replaceAll('\\', '/'); if (!path.startsWith('/')) path = '/' + path; path = path.replace(/\/+/g, '/'); return path || '/'; }
    function parentUiPath(path) { path = normalizeUiPath(path); if (path === '/') return '/'; const parts = path.split('/').filter(Boolean); parts.pop(); return '/' + parts.join('/'); }
    function escapeHtml(value) { return String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;'); }
    function closeFileActionMenus(exceptMenu = null) {
      document.querySelectorAll('.file-row-actions.open').forEach(menu => {
        if (menu !== exceptMenu) menu.classList.remove('open');
      });
    }

    function compactFileRowActions(actions) {
      if (!actions || actions.dataset.compacted === 'true') return;
      const buttons = Array.from(actions.children).filter(child => child.tagName === 'BUTTON');
      if (!buttons.length) return;
      actions.dataset.compacted = 'true';
      const toggle = document.createElement('button');
      toggle.type = 'button';
      toggle.className = 'file-action-toggle soft';
      toggle.textContent = 'Aktionen â–¾';
      toggle.setAttribute('aria-haspopup', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      const menu = document.createElement('div');
      menu.className = 'file-action-menu';
      buttons.forEach(button => {
        button.addEventListener('click', () => window.setTimeout(() => closeFileActionMenus(), 0));
        menu.appendChild(button);
      });
      actions.innerHTML = '';
      actions.append(toggle, menu);
    }

    function activateTab(tab) { if (document.body.classList.contains('desktop-mode')) { openDesktopWindow(tab); return; } document.body.classList.toggle('hide-hero', tab !== 'overview'); document.querySelectorAll('[data-tab]').forEach(item => item.classList.toggle('active', item.dataset.tab === tab)); document.querySelectorAll('[data-panel]').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab)); if (document.body.classList.contains('sidebar-collapsed')) requestAnimationFrame(scrollActiveSidebarIconIntoView); if (tab === 'files') initFileManager(); if (tab === 'overview' || tab === 'network') loadStatus(); if (tab === 'backups') loadBackups2(); if (tab === 'diagnostics') loadDiagnostics2(); if (tab === 'players') loadPlayers2(); if (tab === 'packs') { loadTransfer2(); loadPacks2(); } if (tab === 'transfer') loadTransfer2(); if (tab === 'updates') loadUpdates2(); if (tab === 'firststart') loadProfiles2(); }
    function openRoot(root, path = '/') { activateTab('files'); setTimeout(async () => { await initFileManager(); currentFileRoot = root; fileRootSelect.value = root; await loadFileList(path); }, 0); }

    async function loadStatus() { try { window.WinoMCBoot?.step('Status API wird geladen'); const data = await fetchJson('/api/status'); window.WinoMCBoot?.step('Status API erreicht'); latestStatus = data; data.env = data.env || {}; document.getElementById('statServerName').textContent = data.env.SERVER_NAME || '-'; document.getElementById('statLevelName').textContent = 'Welt: ' + (data.env.LEVEL_NAME || '-'); document.getElementById('statVersion').textContent = data.env.VERSION || '-'; document.getElementById('statRuntime').textContent = 'Runtime: native Â· BDS Auto Update: ' + (data.env.BDS_AUTO_UPDATE || '-'); document.getElementById('statPorts').textContent = (data.env.SERVER_PORT || '-') + ' / ' + (data.env.SERVER_PORT_V6 || '-'); document.getElementById('statLan').textContent = 'LAN: ' + (data.env.ENABLE_LAN_VISIBILITY || '-'); document.getElementById('statFifo').textContent = data.fifo_exists ? 'Console FIFO vorhanden' : 'Console FIFO fehlt'; document.getElementById('statLog').textContent = data.log_exists ? 'Logdatei vorhanden' : 'Logdatei fehlt'; document.getElementById('networkIpv4').textContent = 'SERVER_PORT=' + (data.env.SERVER_PORT || '-'); document.getElementById('networkIpv6').textContent = 'SERVER_PORT_V6=' + (data.env.SERVER_PORT_V6 || '-') + ' Â· ENABLE_BDS_V6BIND_FIX=' + (data.env.ENABLE_BDS_V6BIND_FIX || '-'); document.getElementById('networkLan').textContent = 'ENABLE_LAN_VISIBILITY=' + (data.env.ENABLE_LAN_VISIBILITY || '-'); const set=(id,v)=>{const e=document.getElementById(id); if(e) e.textContent=v||'Nicht verfÃ¼gbar'}; set('statPlayers', data.metrics?.players?.label); set('statMemory', data.metrics?.memory?.label); set('statDisk', data.metrics?.disk?.label); set('statWinoVersion', data.winomc_version || '2.0.0'); set('statHealth', 'Health: ' + (data.health?.overall || 'Nicht verfÃ¼gbar')); set('statLastBackup', data.backup?.latest?.name || 'Kein Backup'); set('statProtection', 'Online: '+(data.env.ONLINE_MODE||'-')+' Â· Allowlist: '+(data.env.ALLOW_LIST||'-')); } catch (err) { appendLine('[WinoMC Status] ' + err.message, 'error'); } }

    async function initFileManager() { if (filesInitialized) { await loadFileList(); return; } filesInitialized = true; try { setFilesStatus('Lade Bereiche...', 'warn'); const data = await fetchJson('/api/files/roots'); fileRootSelect.innerHTML = ''; data.roots.forEach(root => { const option = document.createElement('option'); option.value = root.key; option.textContent = root.label + (root.exists ? '' : ' (fehlt)'); option.disabled = !root.exists || !root.readable; fileRootSelect.appendChild(option); }); const firstEnabled = [...fileRootSelect.options].find(option => !option.disabled); if (![...fileRootSelect.options].some(option => option.value === currentFileRoot && !option.disabled)) currentFileRoot = firstEnabled ? firstEnabled.value : 'config'; fileRootSelect.value = currentFileRoot; await loadTrashSettings(); await syncWebProtectionFromServer(); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    async function loadFileList(path) { if (path !== undefined) currentFilePath = normalizeUiPath(path); currentFileRoot = fileRootSelect.value || currentFileRoot; try { setFilesStatus('Lade...', 'warn'); updatePathDisplay(); const data = await fetchJson('/api/files/list', { root: currentFileRoot, path: currentFilePath }); currentFilePath = data.path || '/'; fileParent.disabled = currentFilePath === '/'; updatePathDisplay(); renderFileEntries(data.entries || []); setFilesStatus('Bereit', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    function updatePathDisplay() { const full = currentFileRoot + ':' + currentFilePath; fileCurrentPath.textContent = full; filePathInput.value = currentFilePath; fileBreadcrumb.innerHTML = ''; const rootButton = document.createElement('button'); rootButton.type = 'button'; rootButton.textContent = currentFileRoot + ':/'; rootButton.addEventListener('click', () => loadFileList('/')); fileBreadcrumb.appendChild(rootButton); let current = ''; currentFilePath.split('/').filter(Boolean).forEach(part => { current += '/' + part; const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = part; const target = current; btn.addEventListener('click', () => loadFileList(target)); fileBreadcrumb.appendChild(btn); }); }
    function renderFileEntries(entries) {
      const inTrash = currentFileRoot === 'trash';
      document.body.classList.toggle('trash-open', inTrash);
      if (fileEmptyTrash) fileEmptyTrash.style.display = inTrash ? '' : 'none';
      if (!entries.length) {
        fileTableBody.innerHTML = '<tr><td colspan="5">Dieser Ordner ist leer.</td></tr>';
        applyWebWriteLock();
        return;
      }
      fileTableBody.innerHTML = '';

      entries.forEach(entry => {
        const tr = document.createElement('tr');
        tr.dataset.path = entry.path;
        tr.dataset.type = entry.type;
        if (!inTrash && entry.path !== '/') {
          tr.draggable = true;
          tr.addEventListener('dragstart', event => {
            tr.classList.add('dragging');
            event.dataTransfer.effectAllowed = 'move';
            event.dataTransfer.setData('application/x-winomc-file', JSON.stringify({ root: currentFileRoot, path: entry.path, name: entry.name, type: entry.type }));
            event.dataTransfer.setData('text/plain', entry.path);
          });
          tr.addEventListener('dragend', () => tr.classList.remove('dragging'));
        }
        if (!inTrash && entry.type === 'directory') {
          tr.addEventListener('dragover', event => {
            if (!hasInternalFileDrag(event)) return;
            event.preventDefault();
            event.dataTransfer.dropEffect = 'move';
            tr.classList.add('drop-target');
          });
          tr.addEventListener('dragleave', () => tr.classList.remove('drop-target'));
          tr.addEventListener('drop', event => {
            if (!hasInternalFileDrag(event)) return;
            event.preventDefault();
            tr.classList.remove('drop-target');
            const item = readInternalDrag(event);
            if (!item) return;
            moveFileEntry(item.path, item.name || item.path, item.type || 'file', entry.path, false, true);
          });
        }

        const nameTd = document.createElement('td');
        const nameButton = document.createElement('button');
        nameButton.type = 'button';
        nameButton.className = 'file-name-button';
        nameButton.textContent = (entry.type === 'directory' ? 'ðŸ“ ' : 'ðŸ“„ ') + entry.name;
        nameButton.addEventListener('click', () => entry.type === 'directory' ? loadFileList(entry.path) : openFileInEditor(entry.path));
        nameTd.appendChild(nameButton);

        const typeTd = document.createElement('td');
        typeTd.textContent = entry.type === 'directory' ? 'Ordner' : 'Datei';
        const sizeTd = document.createElement('td');
        sizeTd.textContent = entry.type === 'directory' ? '-' : formatBytes(entry.size);
        const modifiedTd = document.createElement('td');
        modifiedTd.textContent = inTrash && entry.original_path ? ('GelÃ¶scht: ' + (entry.deleted_at || '-') + ' Â· Quelle: ' + entry.original_root + ':' + entry.original_path) : formatUnixTime(entry.modified);
        const actionsTd = document.createElement('td');
        const actions = document.createElement('div');
        actions.className = 'file-row-actions';

        if (entry.type === 'directory') {
          const open = document.createElement('button');
          open.type = 'button';
          open.textContent = 'Ã–ffnen';
          open.addEventListener('click', () => loadFileList(entry.path));
          const zip = document.createElement('button');
          zip.type = 'button';
          zip.textContent = 'ZIP';
          zip.dataset.downloadAction = 'true';
          zip.addEventListener('click', () => downloadZip(entry.path));
          const exportZip = document.createElement('button');
          exportZip.type = 'button';
          exportZip.textContent = 'Export';
          exportZip.dataset.writeAction = 'true';
          exportZip.addEventListener('click', () => saveZipToExport(entry.path));
          actions.append(open, zip, exportZip);
        } else {
          const download = document.createElement('button');
          download.type = 'button';
          download.textContent = 'Download';
          download.dataset.downloadAction = 'true';
          download.addEventListener('click', () => downloadFile(entry.path));
          const edit = document.createElement('button');
          edit.type = 'button';
          edit.textContent = inTrash ? 'Vorschau' : 'Editor';
          edit.addEventListener('click', () => openFileInEditor(entry.path));
          const hash = document.createElement('button');
          hash.type = 'button';
          hash.textContent = 'MD5';
          hash.className = 'hash-button';
          hash.title = 'MD5-Hash dieser Datei berechnen';
          hash.addEventListener('click', () => checkFileMd5(entry.path, entry.name));
          actions.append(download, edit, hash);
          if (['.zip', '.mcpack', '.mcaddon', '.mcworld', '.mctemplate'].some(ext => entry.name.toLowerCase().endsWith(ext))) {
            const unzip = document.createElement('button');
            unzip.type = 'button';
            unzip.textContent = 'Entpacken';
            unzip.dataset.writeAction = 'true';
            unzip.addEventListener('click', () => unzipFile(entry.path));
            actions.appendChild(unzip);
          }
        }

        if (!inTrash && entry.path !== '/') {
          const move = document.createElement('button');
          move.type = 'button';
          move.textContent = 'Verschieben';
          move.className = 'move-button';
          move.dataset.writeAction = 'true';
          move.title = 'Datei oder Ordner verschieben';
          move.addEventListener('click', () => moveFileEntryPrompt(entry.path, entry.name, entry.type));
          actions.appendChild(move);
        }

        if (inTrash && entry.path !== '/') {
          const restore = document.createElement('button');
          restore.type = 'button';
          restore.textContent = 'Wiederherstellen';
          restore.className = 'primary';
          restore.dataset.writeAction = 'true';
          restore.title = entry.original_path ? ('ZurÃ¼ck nach ' + entry.original_root + ':' + entry.original_path) : 'Aus Papierkorb wiederherstellen';
          restore.addEventListener('click', () => restoreFileEntry(entry.path, entry.name));
          actions.appendChild(restore);
        }

        if (entry.path !== '/') {
          const del = document.createElement('button');
          del.type = 'button';
          del.textContent = inTrash ? 'EndgÃ¼ltig' : 'LÃ¶schen';
          del.className = 'danger';
          del.dataset.writeAction = 'true';
          del.addEventListener('click', () => deleteFileEntry(entry.path, entry.name, inTrash));
          actions.appendChild(del);
        }

        compactFileRowActions(actions);
        actionsTd.appendChild(actions);
        nameTd.dataset.label = 'Name';
        typeTd.dataset.label = 'Typ';
        sizeTd.dataset.label = 'GrÃ¶ÃŸe';
        modifiedTd.dataset.label = 'GeÃ¤ndert';
        actionsTd.dataset.label = 'Aktionen';
        tr.append(nameTd, typeTd, sizeTd, modifiedTd, actionsTd);
        fileTableBody.appendChild(tr);
      });
      applyWebWriteLock();
    }

    function hasInternalFileDrag(event) {
      return event.dataTransfer && Array.from(event.dataTransfer.types || []).includes('application/x-winomc-file');
    }

    function readInternalDrag(event) {
      try {
        const raw = event.dataTransfer.getData('application/x-winomc-file');
        if (!raw) return null;
        const data = JSON.parse(raw);
        if (!data || data.root !== currentFileRoot || !data.path) return null;
        return data;
      } catch (err) {
        appendLine('[WinoMC Dateien] Drag & Drop konnte nicht gelesen werden: ' + err.message, 'error');
        return null;
      }
    }

    function downloadFile(path) {
      if (!ensureDownloadAllowed('Download')) return;
      window.location.href = apiUrl('/api/files/download', { root: currentFileRoot, path });
    }
    function downloadZip(path) {
      if (!ensureDownloadAllowed('ZIP-Download')) return;
      window.location.href = apiUrl('/api/files/zip', { root: currentFileRoot, path });
    }
    async function saveZipToExport(path) { if (!ensureWriteAllowed('ZIP nach Export speichern')) return; try { setFilesStatus('Erstelle ZIP...', 'warn'); const data = await postJson('/api/files/zip', { root: currentFileRoot, paths: [path], save_to_export: true }); appendLine('[WinoMC Dateien] ZIP exportiert: ' + data.filename, 'ok'); setFilesStatus('ZIP exportiert', ''); if (currentFileRoot === 'export') await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] ZIP-Fehler: ' + err.message, 'error'); alert(err.message); } }

    async function checkFileMd5(path, name) {
      try {
        setFilesStatus('Berechne MD5...', 'warn');
        const data = await fetchJson('/api/files/md5', { root: currentFileRoot, path });
        const message = 'MD5 fÃ¼r â€ž' + (name || data.path) + 'â€œ:\n\n' + data.md5 + '\n\nGrÃ¶ÃŸe: ' + formatBytes(data.size);
        setFilesStatus('MD5 berechnet', '');
        appendLine('[WinoMC Dateien] MD5 ' + data.path + ': ' + data.md5, 'ok');
        if (navigator.clipboard && navigator.clipboard.writeText) {
          try { await navigator.clipboard.writeText(data.md5); } catch (_) {}
        }
        alert(message + '\n\nDer Hash wurde, sofern vom Browser erlaubt, in die Zwischenablage kopiert.');
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] MD5 fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    function moveFileEntryPrompt(path, name, type) {
      if (!ensureWriteAllowed('Verschieben')) return;
      const defaultTarget = currentFilePath === '/' ? '/' + name : currentFilePath.replace(/\/$/, '') + '/' + name;
      const destination = window.prompt('Zielpfad oder Zielordner eingeben:', defaultTarget);
      if (destination === null) return;
      moveFileEntry(path, name, type, destination, false, false);
    }

    async function moveFileEntry(path, name, type, destination, overwrite = false, fromDragDrop = false) {
      if (!ensureWriteAllowed('Verschieben')) return;
      if (!destination) return;
      if (!fromDragDrop && !overwrite && !window.confirm('â€ž' + name + 'â€œ nach â€ž' + destination + 'â€œ verschieben?')) return;
      try {
        setFilesStatus('Verschiebe...', 'warn');
        const data = await postJson('/api/files/move', { root: currentFileRoot, source: path, destination, overwrite: Boolean(overwrite) });
        appendLine('[WinoMC Dateien] ' + (data.message || ('Verschoben: ' + data.source + ' â†’ ' + data.path)), 'ok');
        setFilesStatus('Verschoben', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        const message = String(err.message || '');
        if (!overwrite && message.includes('Ziel existiert bereits') && window.confirm('Ziel existiert bereits. Ãœberschreiben und verschieben?')) {
          await moveFileEntry(path, name, type, destination, true, false);
          return;
        }
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Verschieben fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }
    function openEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.add('editor-open');
      editorPanel.classList.remove('editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      if (fileCloseEditor) fileCloseEditor.textContent = 'SchlieÃŸen';
      if (document.body.classList.contains('ux-mobile') && !document.body.classList.contains('console-collapsed')) setConsoleMode('collapsed');
      window.setTimeout(() => fileEditor?.focus({ preventScroll: true }), 80);
    }

    function closeEditorOverlay() {
      if (!editorPanel) return;
      editorPanel.classList.remove('editor-open', 'editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
    }

    function setEditorPreviewMode(previewOnly, note = '') {
      if (editorPanel) editorPanel.classList.toggle('preview-only', !!previewOnly);
      if (fileEditor) fileEditor.readOnly = !!previewOnly;
      if (fileSave) fileSave.hidden = !!previewOnly;
      if (fileCloseEditor) fileCloseEditor.textContent = 'SchlieÃŸen';
      if (editorFullscreen) editorFullscreen.textContent = 'Vollbild';
      if (editorReadonlyNote) {
        editorReadonlyNote.hidden = !previewOnly;
        editorReadonlyNote.textContent = note || 'SchreibgeschÃ¼tzte Vorschau. Zum Bearbeiten Datei aus dem Papierkorb wiederherstellen oder Web-Schutz entsperren.';
      }
    }

    async function openFileInEditor(path) {
      try {
        setFilesStatus(currentFileRoot === 'trash' ? 'Ã–ffne Vorschau...' : 'Ã–ffne Datei...', 'warn');
        const data = await fetchJson('/api/files/read', { root: currentFileRoot, path });
        const previewOnly = data.root === 'trash' || webWriteLocked;
        currentEditorFile = previewOnly ? null : { root: data.root, path: data.path };
        editorPath.textContent = data.root + ':' + data.path;
        editorMeta.textContent = formatBytes(data.size) + ' Â· geÃ¤ndert: ' + formatUnixTime(data.modified) + (data.json ? ' Â· JSON-PrÃ¼fung aktiv' : '') + (previewOnly ? ' Â· Papierkorb-Vorschau, nicht schreibbar' : '');
        fileEditor.value = data.content || '';
        setEditorPreviewMode(previewOnly, data.root === 'trash' ? 'Papierkorb-Vorschau: Wiederherstellen, um die Datei wieder bearbeitbar zu machen.' : (webWriteLocked ? 'Web-Schutz aktiv: Diese Datei wird nur als Vorschau geÃ¶ffnet.' : ''));
        openEditorOverlay();
        setFilesStatus(previewOnly ? 'Vorschau geÃ¶ffnet' : 'Datei geÃ¶ffnet', '');
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Editor-Fehler: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function saveEditorFile() { if (!ensureWriteAllowed('Speichern')) return;
      if (currentFileRoot === 'trash') { alert('Papierkorb-Dateien sind nur als Vorschau geÃ¶ffnet. Bitte zuerst wiederherstellen.'); return; }
      if (!currentEditorFile) { alert('Keine Datei geÃ¶ffnet.'); return; }
      try {
        setFilesStatus('Speichere...', 'warn');
        const data = await postJson('/api/files/write', { root: currentEditorFile.root, path: currentEditorFile.path, content: fileEditor.value });
        appendLine('[WinoMC Dateien] Datei gespeichert: ' + currentEditorFile.path, 'ok');
        if (data.backup_created) appendLine('[WinoMC Dateien] Backup erstellt: ' + data.backup_path, 'ok');
        setFilesStatus('Gespeichert', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Speichern fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    function clearEditor() { currentEditorFile = null; editorPath.textContent = 'Keine Datei geÃ¶ffnet'; editorMeta.textContent = 'Bereit'; fileEditor.value = ''; setEditorPreviewMode(false); closeEditorOverlay(); }
    async function uploadFiles(files) { if (!ensureWriteAllowed('Upload')) return; files = Array.from(files || []); if (!files.length) return; for (const file of files) { try { setFilesStatus('Upload: ' + file.name, 'warn'); let data; try { data = await uploadFileBinary(file); } catch (binaryErr) { if (file.size > MAX_JSON_UPLOAD_SIZE) throw binaryErr; appendLine('[WinoMC Dateien] Binary Upload fehlgeschlagen, nutze JSON-Fallback: ' + binaryErr.message, 'error'); data = await uploadFileJson(file); } appendLine('[WinoMC Dateien] Hochgeladen: ' + data.path, 'ok'); } catch (err) { appendLine('[WinoMC Dateien] Upload fehlgeschlagen: ' + file.name + ' Â· ' + err.message, 'error'); alert('Upload fehlgeschlagen: ' + file.name + '\n\n' + err.message); } } setFilesStatus('Upload fertig', ''); await loadFileList(currentFilePath); }
    async function uploadFileBinary(file) { const res = await fetch(apiUrl('/api/files/upload', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: 'false' }), { method: 'POST', headers: { 'Content-Type': 'application/octet-stream', 'X-WinoMC-Upload-Size': String(file.size), 'X-WinoMC-Filename': encodeURIComponent(file.name) }, body: file }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    function readFileAsBase64(file) { return new Promise((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result || '').split(',', 2)[1] || ''); reader.onerror = () => reject(reader.error || new Error('Datei konnte nicht gelesen werden.')); reader.readAsDataURL(file); }); }
    async function uploadFileJson(file) { const base64 = await readFileAsBase64(file); return postJson('/api/files/upload-json', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: false, content_base64: base64 }); }
    async function unzipFile(path) { if (!ensureWriteAllowed('Entpacken')) return; const destination = window.prompt('In welchen Ordner entpacken?', currentFilePath || '/'); if (destination === null) return; const overwrite = window.confirm('Vorhandene Dateien Ã¼berschreiben?'); try { setFilesStatus('Entpacke ZIP...', 'warn'); const data = await postJson('/api/files/unzip', { root: currentFileRoot, path, destination, overwrite }); appendLine('[WinoMC Dateien] Entpackt: ' + data.files + ' Dateien, ' + data.directories + ' Ordner', 'ok'); setFilesStatus('ZIP entpackt', ''); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Entpacken fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }
