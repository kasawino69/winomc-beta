def ensure_instance_layout(config):
    iid = validate_instance_id(config["id"])
    base = instance_path(iid)
    os.makedirs(base, exist_ok=True)
    for dirname in INSTANCE_DIRS:
        os.makedirs(os.path.join(base, dirname), exist_ok=True)
    for filename, default in (("allowlist.json", []), ("permissions.json", [])):
        path = os.path.join(base, filename)
        if not os.path.exists(path):
            write_json_file(path, default)
    with open(os.path.join(base, "server.properties"), "w", encoding="utf-8") as handle:
        handle.write(render_server_properties(config))
    write_json_file(os.path.join(base, "instance.json"), config)
    return config


def load_instance(instance_id, include_health=True):
    path = instance_path(instance_id, "instance.json")
    data = read_json_file(path, None)

    if not data:
        raise FileNotFoundError("Instanz nicht gefunden: %s" % instance_id)

    data.setdefault("id", validate_instance_id(instance_id))
    ensure_instance_automation(data)
    data["status"] = runtime_status(data["id"])

    if include_health:
        data["health"] = validate_instance_config(data)

    return data


def list_instances():
    os.makedirs(INSTANCES_DIR, exist_ok=True)
    items = []

    for name in sorted(os.listdir(INSTANCES_DIR)):
        try:
            path = instance_path(name, "instance.json")

            if os.path.isfile(path):
                inst = load_instance(name, include_health=False)
                status = inst.get("status") or {}
                state = status.get("state", "stopped")

                health = {"ok": True, "errors": [], "warnings": []}

                if state in ("crashed", "broken", "unknown"):
                    health = {
                        "ok": False,
                        "errors": ["Runtime-Status: %s" % state],
                        "warnings": [],
                    }

                items.append({
                    k: inst.get(k)
                    for k in ("id", "name", "engine", "profile", "created_at", "updated_at")
                } | {
                    "bedrock": inst.get("bedrock", {}),
                    "automation": inst.get("automation", normalize_instance_automation({})),
                    "status": status,
                    "health": health,
                })

        except Exception as exc:
            items.append({
                "id": name,
                "name": name,
                "broken": True,
                "error": str(exc),
                "status": {"state": "broken"},
                "health": {"ok": False, "errors": [str(exc)], "warnings": []},
            })

    return items

def used_instance_ports(exclude=None):
    ports = set()
    for inst in list_instances():
        if inst.get("id") == exclude or inst.get("broken"):
            continue
        b = inst.get("bedrock", {})
        for key in ("server_port", "server_port_v6"):
            try: ports.add(int(b.get(key)))
            except Exception: pass
    return ports

def next_free_instance_port():
    used = used_instance_ports()
    port = 19132
    while port in used or (port + 1) in used:
        port += 10
    return port

def validate_instance_config(config):
    errors, warnings = [], []
    try: iid = validate_instance_id(config.get("id")); instance_path(iid)
    except Exception as exc: errors.append(str(exc)); iid = None
    if config.get("engine") != "bedrock": errors.append("In 2.1b ist nur die Bedrock-Engine aktiv.")
    b = config.get("bedrock", {})
    ports = []
    for key in ("server_port", "server_port_v6"):
        try:
            port = int(b.get(key));
            if not (1 <= port <= 65535): errors.append("%s liegt auÃŸerhalb des gÃ¼ltigen Portbereichs." % key)
            ports.append(port)
        except Exception: errors.append("%s muss ein Port sein." % key)
    if len(set(ports)) != len(ports): errors.append("IPv4- und IPv6-Port dÃ¼rfen nicht identisch sein.")
    conflicts = used_instance_ports(exclude=iid)
    for port in ports:
        if port in conflicts: errors.append("Port %s wird bereits von einer anderen Instanz verwendet." % port)
    return {"ok": not errors, "errors": errors, "warnings": warnings}


def create_instance(payload):
    payload = payload or {}
    iid = validate_instance_id(payload.get("id") or payload.get("name") or "server")

    if os.path.exists(instance_path(iid, "instance.json")):
        raise ValueError("Instanz existiert bereits: %s" % iid)

    config = default_instance_config(
        iid,
        payload.get("name"),
        payload.get("profile", "vanilla-survival"),
        payload.get("server_port"),
    )

    config["bedrock"].update(payload.get("bedrock", {}))
    config["automation"] = normalize_instance_automation(payload.get("automation", {}))

    health = validate_instance_config(config)

    if not health["ok"]:
        raise ValueError("; ".join(health["errors"]))

    return ensure_instance_layout(config)


def update_instance(instance_id, payload):
    payload = payload or {}
    current = load_instance(instance_id)

    if "name" in payload:
        current["name"] = str(payload["name"])

    if "profile" in payload:
        current["profile"] = str(payload["profile"])

    if "bedrock" in payload and isinstance(payload["bedrock"], dict):
        current.setdefault("bedrock", {}).update(payload["bedrock"])

    if "automation" in payload and isinstance(payload["automation"], dict):
        current["automation"] = normalize_instance_automation(payload["automation"])
    else:
        ensure_instance_automation(current)

    current["updated_at"] = manager_now()

    health = validate_instance_config(current)

    if not health["ok"]:
        raise ValueError("; ".join(health["errors"]))

    return ensure_instance_layout(current)

def delete_instance(instance_id):
    stop_instance(instance_id)
    trash = os.path.join(MANAGER_STATE_DIR, "deleted", validate_instance_id(instance_id) + "-" + str(int(time.time())))
    os.makedirs(os.path.dirname(trash), exist_ok=True)
    shutil.move(instance_path(instance_id), trash)
    return {"ok": True, "deleted": instance_id, "moved_to": trash}

def runtime_state_path(instance_id): return instance_path(instance_id, "runtime", "state.json")
def runtime_workdir(instance_id): return instance_path(instance_id, "runtime", "bedrock")
def runtime_log_path_instance(instance_id): return instance_path(instance_id, "logs", "latest.log")
def runtime_history_path(instance_id): return instance_path(instance_id, "logs", "commands.log")

def detect_bds_runtime():
    candidates = []
    for directory in BDS_CANDIDATE_DIRS:
        exe = os.path.join(directory, "bedrock_server")
        candidates.append({"path": directory, "bedrock_server": exe, "exists": os.path.isfile(exe), "executable": os.path.isfile(exe) and os.access(exe, os.X_OK)})
    for candidate in candidates:
        if candidate["executable"]:
            candidate["ok"] = True
            return candidate
    error = "Keine ausfÃ¼hrbare Bedrock Dedicated Server Runtime gefunden. Erwartet wird bedrock_server in WINOMC_BDS_SHARED_DIR oder im bestehenden /config-BDS-Bestand."
    return {"ok": False, "error": error, "candidates": candidates}

def validate_bds_runtime_or_raise(instance_id=None):
    runtime = detect_bds_runtime()
    if not runtime.get("ok"):
        existing = [c for c in runtime.get("candidates", []) if c.get("exists")]
        code = "bedrock_not_executable" if existing else "bedrock_missing"
        raise WinoMCRuntimeError(code, runtime.get("error"), instance_id=instance_id, component="shared-runtime", suggested_action="Installiere oder aktualisiere Bedrock Dedicated Server in der gemeinsamen WinoMC Runtime.", details={"candidates": runtime.get("candidates", [])})
    shared_dir = runtime["path"]
    if not os.access(shared_dir, os.R_OK | os.X_OK):
        raise WinoMCRuntimeError("shared_runtime_unreadable", "Die gemeinsame Bedrock-Runtime ist nicht lesbar.", instance_id=instance_id, component="shared-runtime", details={"path": shared_dir})
    return runtime

def can_bind_udp(port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.bind(("0.0.0.0", int(port)))
        return True
    except OSError:
        return False
    finally:
        sock.close()

def validate_instance_start_or_raise(inst):
    iid = validate_instance_id(inst.get("id"))
    health = validate_instance_config(inst)
    if not health.get("ok"):
        raise WinoMCRuntimeError("invalid_instance_config", "Instanzkonfiguration ist ungÃ¼ltig.", instance_id=iid, component="instance-config", suggested_action="PrÃ¼fe Ports, Engine und Pfade der Instanz.", details=health)
    runtime = validate_bds_runtime_or_raise(iid)
    ensure_instance_layout(inst)
    for path_name in ("worlds", "resource_packs", "behavior_packs", "logs", "runtime"):
        path = instance_path(iid, path_name)
        if not os.path.isdir(path) or not os.access(path, os.W_OK):
            raise WinoMCRuntimeError("instance_path_not_writable", "Instanzpfad ist nicht beschreibbar: %s" % path_name, instance_id=iid, component="instance-paths", details={"path": path})
    for filename in ("server.properties", "allowlist.json", "permissions.json"):
        path = instance_path(iid, filename)
        if not os.path.isfile(path) or not os.access(path, os.W_OK):
            raise WinoMCRuntimeError("instance_file_not_writable", "Instanzdatei ist nicht beschreibbar: %s" % filename, instance_id=iid, component="instance-files", details={"path": path})
    b = inst.get("bedrock", {})
    for key in ("server_port", "server_port_v6"):
        port = int(b.get(key))
        if not can_bind_udp(port):
            # If this exact instance is already running, start_instance will return before this check. Otherwise fail clearly.
            raise WinoMCRuntimeError("port_unavailable", "Port %s ist auf dem Host nicht frei." % port, instance_id=iid, component="network", suggested_action="WÃ¤hle einen freien Bedrock-Port fÃ¼r diese Instanz.", details={"port": port, "field": key})
    return {"runtime": runtime, "health": health}


def safe_remove_runtime_path(path):
    if os.path.islink(path) or os.path.isfile(path):
        try:
            os.unlink(path)
        except FileNotFoundError:
            pass
    elif os.path.isdir(path):
        shutil.rmtree(path)

def safe_symlink_or_copy(source, target):
    if os.path.lexists(target):
        return
    if os.path.isdir(source):
        try:
            os.symlink(source, target, target_is_directory=True)
        except OSError:
            shutil.copytree(source, target, dirs_exist_ok=True)
    else:
        try:
            os.symlink(source, target)
        except OSError:
            os.makedirs(os.path.dirname(target), exist_ok=True)
            shutil.copy2(source, target)

def link_or_copy_children(source_dir, target_dir, prefer_existing=True):
    if not os.path.isdir(source_dir):
        return []

    os.makedirs(target_dir, exist_ok=True)
    linked = []

    for name in sorted(os.listdir(source_dir)):
        if name in (".", ".."):
            continue

        source = os.path.join(source_dir, name)
        target = os.path.join(target_dir, name)

        if os.path.lexists(target):
            if prefer_existing:
                continue
            safe_remove_runtime_path(target)

        if os.path.isfile(source) or os.path.isdir(source):
            safe_symlink_or_copy(source, target)
            linked.append(name)

    return linked

def prepare_instance_pack_dir(shared_dir, instance_dir, workdir, name):
    target = os.path.join(workdir, name)

    # Older 2.1b runtime layouts could leave resource_packs/behavior_packs
    # as direct symlinks to the instance pack dirs.
    # That hides Bedrock's shared Vanilla/system packs.
    if os.path.lexists(target):
        safe_remove_runtime_path(target)

    os.makedirs(target, exist_ok=True)

    # First expose Bedrock's shared Vanilla/system packs.
    linked_shared = link_or_copy_children(
        os.path.join(shared_dir, name),
        target,
        prefer_existing=True,
    )

    # Then expose per-instance user packs.
    linked_instance = link_or_copy_children(
        instance_dir,
        target,
        prefer_existing=True,
    )

    return {
        "shared": linked_shared,
        "instance": linked_instance,
        "path": target,
    }

def workdir_has_vanilla_resource_pack(workdir):
    pack_dir = os.path.join(workdir, "resource_packs")

    if not os.path.isdir(pack_dir):
        return False

    try:
        names = [name.lower() for name in os.listdir(pack_dir)]
    except OSError:
        return False

    return any(
        name == "vanilla" or name.startswith("vanilla_") or name.startswith("vanilla.")
        for name in names
    )

def prepare_instance_runtime(inst):
    iid = validate_instance_id(inst["id"])
    ensure_instance_layout(inst)

    runtime = validate_bds_runtime_or_raise(iid)
    workdir = runtime_workdir(iid)

    os.makedirs(workdir, exist_ok=True)

    shared_dir = runtime["path"]

    writable_links = {
        "worlds": instance_path(iid, "worlds"),
        "server.properties": instance_path(iid, "server.properties"),
        "allowlist.json": instance_path(iid, "allowlist.json"),
        "permissions.json": instance_path(iid, "permissions.json"),
    }

    for name, source in writable_links.items():
        target = os.path.join(workdir, name)

        if os.path.lexists(target):
            if os.path.islink(target) or os.path.isfile(target):
                safe_remove_runtime_path(target)
            elif os.path.isdir(target) and name != "worlds":
                safe_remove_runtime_path(target)

        if not os.path.lexists(target):
            safe_symlink_or_copy(source, target)

    # Pack directories are special:
    # Bedrock needs its shared Vanilla/system packs from the BDS runtime,
    # while WinoMC still needs per-instance user packs.
    # Therefore build a merged directory for each instance runtime.
    pack_links = {
        "resource_packs": prepare_instance_pack_dir(
            shared_dir,
            instance_path(iid, "resource_packs"),
            workdir,
            "resource_packs",
        ),
        "behavior_packs": prepare_instance_pack_dir(
            shared_dir,
            instance_path(iid, "behavior_packs"),
            workdir,
            "behavior_packs",
        ),
    }

    for name in os.listdir(shared_dir):
        source = os.path.join(shared_dir, name)

        if name in writable_links or name in pack_links:
            continue

        if name.startswith("world") or name in ("server.properties", "allowlist.json", "permissions.json"):
            continue

        if name == "instances":
            continue

        if os.path.isfile(source) or os.path.isdir(source):
            safe_symlink_or_copy(source, os.path.join(workdir, name))

    if not workdir_has_vanilla_resource_pack(workdir):
        raise WinoMCRuntimeError(
            "vanilla_resource_pack_missing",
            "Die Vanilla Resource Packs sind im Instanz-Workdir nicht sichtbar.",
            instance_id=iid,
            component="shared-runtime",
            suggested_action="Prüfe, ob die Bedrock-Runtime unter /config vollständige resource_packs enthält. Danach Add-on neu bauen und Instanz erneut starten.",
            details={
                "workdir": workdir,
                "resource_packs": os.path.join(workdir, "resource_packs"),
                "shared_resource_packs": os.path.join(shared_dir, "resource_packs"),
                "instance_resource_packs": instance_path(iid, "resource_packs"),
                "pack_links": pack_links,
            },
        )

    return {
        "runtime": runtime,
        "workdir": workdir,
        "pack_links": pack_links,
    }

def process_cwd(pid):
    try:
        return os.path.realpath(os.readlink("/proc/%s/cwd" % int(pid)))
    except Exception:
        return ""

def process_cmdline(pid):
    try:
        with open("/proc/%s/cmdline" % int(pid), "rb") as handle:
            return handle.read().replace(b"\x00", b" ").decode("utf-8", errors="replace")
    except Exception:
        return ""

def pid_matches_instance(instance_id, pid):
    if not pid:
        return False
    workdir = os.path.realpath(runtime_workdir(instance_id))
    cwd = process_cwd(pid)
    cmdline = process_cmdline(pid)
    return bool(cwd and cwd == workdir and "bedrock_server" in cmdline)

def reconcile_instance_runtime(instance_id):
    iid = validate_instance_id(instance_id)
    state = read_json_file(runtime_state_path(iid), {"state": "stopped"})
    pid = state.get("pid")
    if not pid:
        if state.get("state") in ("starting", "running", "stopping"):
            state.update({"state": "unknown", "reconciled_at": manager_now(), "recovery_note": "Runtime-State enthielt keinen PID."})
            write_runtime_state(iid, state)
        return state
    try:
        os.kill(int(pid), 0)
    except ProcessLookupError:
        next_state = "stopped" if state.get("last_action") == "stop" or state.get("state") == "stopping" else "crashed"
        state.update({"state": next_state, "pid": None, "reconciled_at": manager_now(), "recovery_note": "Gespeicherter PID existiert nicht mehr."})
        write_runtime_state(iid, state)
        return state
    except PermissionError:
        state.update({"state": "unknown", "reconciled_at": manager_now(), "recovery_note": "Gespeicherter PID ist nicht prÃ¼fbar."})
        write_runtime_state(iid, state)
        return state
    if not pid_matches_instance(iid, pid):
        state.update({"state": "unknown", "pid": None, "reconciled_at": manager_now(), "recovery_note": "PID gehÃ¶rt nicht eindeutig zu dieser Bedrock-Instanz; er wurde verworfen."})
        write_runtime_state(iid, state)
        return state
    state.update({"state": "running", "reconciled_at": manager_now(), "recovered_without_stdin": True, "recovery_note": "Prozess lÃ¤uft noch, aber die Manager-STDIN-Verbindung muss durch Neustart der Instanz erneuert werden."})
    write_runtime_state(iid, state)
    return state

def reconcile_all_instances():
    results = []
    os.makedirs(INSTANCES_DIR, exist_ok=True)
    for name in sorted(os.listdir(INSTANCES_DIR)):
        if os.path.isfile(instance_path(name, "instance.json")):
            try:
                results.append({"id": name, "state": reconcile_instance_runtime(name)})
            except Exception as exc:
                results.append({"id": name, "error": str(exc)})
    return results


def runtime_status(instance_id):
    iid = validate_instance_id(instance_id)
    state = read_json_file(runtime_state_path(iid), {"state": "stopped"})
    pid = state.get("pid")

    with PROCESS_LOCK:
        proc = PROCESS_HANDLES.get(iid)

    if proc is not None:
        rc = proc.poll()

        if rc is None:
            state["pid"] = proc.pid

            if state.get("state") not in ("starting", "stopping"):
                state["state"] = "running"

            write_runtime_state(iid, state)
            return state

        state.update({
            "state": "stopped" if state.get("last_action") == "stop" else "crashed",
            "exit_code": rc,
            "pid": None,
            "exited_at": state.get("exited_at") or manager_now(),
        })

        write_runtime_state(iid, state)

        with PROCESS_LOCK:
            PROCESS_HANDLES.pop(iid, None)

        return state

    if pid:
        state = reconcile_instance_runtime(iid)

    return state

def write_runtime_state(instance_id, payload):
    payload["updated_at"] = manager_now(); write_json_file(runtime_state_path(instance_id), payload); return payload

def monitor_instance_process(instance_id, proc):
    rc = proc.wait()
    with PROCESS_LOCK:
        current = PROCESS_HANDLES.get(validate_instance_id(instance_id))
        if current is proc:
            PROCESS_HANDLES.pop(validate_instance_id(instance_id), None)
    state = read_json_file(runtime_state_path(instance_id), {})
    next_state = "stopped" if state.get("state") == "stopping" or state.get("last_action") == "stop" else "crashed"
    state.update({"state": next_state, "pid": None, "exit_code": rc, "exited_at": manager_now()})
    write_runtime_state(instance_id, state)

def bedrock_environment(inst, prepared):
    b = inst.get("bedrock", {})
    env = os.environ.copy()
    env.update({
        "EULA": "TRUE",
        "SERVER_DATA_DIR": prepared["workdir"],
        "LD_LIBRARY_PATH": prepared["workdir"] + (":" + env.get("LD_LIBRARY_PATH", "") if env.get("LD_LIBRARY_PATH") else ""),
        "VERSION": str(b.get("version", "LATEST")),
        "SERVER_NAME": str(b.get("server_name", inst.get("name", inst["id"]))),
        "LEVEL_NAME": str(b.get("level_name", "world")),
        "SERVER_PORT": str(int(b.get("server_port", 19132))),
        "SERVER_PORT_V6": str(int(b.get("server_port_v6", 19133))),
        "ENABLE_BDS_V6BIND_FIX": str(bool(b.get("enable_v6bind_fix", False))).lower(),
        "USE_BOX64": str(os.environ.get("USE_BOX64", "true")),
    })
    return env


def start_instance(instance_id):
    iid = validate_instance_id(instance_id)
    inst = load_instance(iid)

    status = runtime_status(iid)

    if status.get("state") in ("running", "starting"):
        return {
            "ok": True,
            "status": status,
            "message": "Instanz läuft bereits oder startet.",
        }

    validate_instance_start_or_raise(inst)
    prepared = prepare_instance_runtime(inst)

    started_at = manager_now()

    write_runtime_state(iid, {
        "state": "starting",
        "pid": None,
        "last_action": "start",
        "started_at": started_at,
        "workdir": prepared["workdir"],
        "runtime": prepared["runtime"],
        "pack_links": prepared.get("pack_links", {}),
    })

    log_path = runtime_log_path_instance(iid)
    os.makedirs(os.path.dirname(log_path), exist_ok=True)

    log_handle = open(log_path, "ab", buffering=0)
    log_handle.write(("\n[%s] WinoMC startet Bedrock-Instanz %s\n" % (started_at, iid)).encode("utf-8"))
    log_handle.write(("[%s] Runtime-Workdir: %s\n" % (started_at, prepared["workdir"])).encode("utf-8"))

    command = [os.path.join(prepared["workdir"], "bedrock_server")]
    runtime_arch = os.uname().machine

    if (
        runtime_arch in ("aarch64", "arm64")
        and str(os.environ.get("USE_BOX64", "true")).lower() in ("true", "1", "yes", "on")
        and shutil.which("box64")
    ):
        command = ["box64", command[0]]

    proc = subprocess.Popen(
        command,
        cwd=prepared["workdir"],
        stdin=subprocess.PIPE,
        stdout=log_handle,
        stderr=subprocess.STDOUT,
        env=bedrock_environment(inst, prepared),
        start_new_session=True,
    )

    with PROCESS_LOCK:
        PROCESS_HANDLES[iid] = proc

    state = write_runtime_state(iid, {
        "state": "starting",
        "pid": proc.pid,
        "last_action": "start",
        "started_at": started_at,
        "workdir": prepared["workdir"],
        "log": log_path,
        "runtime": prepared["runtime"],
        "pack_links": prepared.get("pack_links", {}),
    })

    threading.Thread(
        target=monitor_instance_process,
        args=(iid, proc),
        daemon=True,
    ).start()

    grace = float(os.environ.get("WINOMC_INSTANCE_START_GRACE_SECONDS", "3"))
    time.sleep(max(0.1, min(grace, 10.0)))

    rc = proc.poll()

    if rc is not None:
        with PROCESS_LOCK:
            PROCESS_HANDLES.pop(iid, None)

        state = write_runtime_state(iid, {
            "state": "crashed",
            "pid": None,
            "exit_code": rc,
            "last_action": "start",
            "started_at": started_at,
            "exited_at": manager_now(),
            "workdir": prepared["workdir"],
            "log": log_path,
            "runtime": prepared["runtime"],
            "pack_links": prepared.get("pack_links", {}),
        })

        return {
            "ok": False,
            "status": state,
            "message": "Bedrock-Instanz wurde gestartet, aber früh wieder beendet.",
        }

    state = write_runtime_state(iid, {
        "state": "running",
        "pid": proc.pid,
        "last_action": "start",
        "started_at": started_at,
        "workdir": prepared["workdir"],
        "log": log_path,
        "runtime": prepared["runtime"],
        "pack_links": prepared.get("pack_links", {}),
    })

    return {
        "ok": True,
        "status": state,
        "message": "Bedrock-Instanz wurde gestartet.",
    }

def stop_instance(instance_id):
    iid = validate_instance_id(instance_id)
    status = runtime_status(iid)
    pid = status.get("pid")
    write_runtime_state(iid, dict(status, state="stopping", last_action="stop", stopping_at=manager_now()))
    try:
        with open(runtime_log_path_instance(iid), "ab", buffering=0) as log_handle:
            log_handle.write(("[%s] WinoMC stoppt Bedrock-Instanz %s kontrolliert\n" % (manager_now(), iid)).encode("utf-8"))
    except Exception:
        pass
    with PROCESS_LOCK:
        proc = PROCESS_HANDLES.get(iid)
    if proc is not None and proc.poll() is None:
        try:
            proc.stdin.write(b"stop\n"); proc.stdin.flush()
        except Exception:
            pass
        try:
            proc.wait(timeout=25)
        except subprocess.TimeoutExpired:
            try: os.killpg(proc.pid, signal.SIGTERM)
            except Exception: proc.terminate()
            try: proc.wait(timeout=10)
            except subprocess.TimeoutExpired: proc.kill()
        return {"ok": True, "status": runtime_status(iid), "message": "Instanz wurde gestoppt."}
    if pid:
        try:
            os.kill(int(pid), signal.SIGTERM)
            time.sleep(2)
        except ProcessLookupError:
            pass
        except Exception as exc:
            raise RuntimeError("Instanz konnte nicht gestoppt werden: %s" % exc)
    state = write_runtime_state(iid, {"state": "stopped", "pid": None, "last_action": "stop", "stopped_at": manager_now()})
    return {"ok": True, "status": state}

def restart_instance(instance_id):
    stop_instance(instance_id); return start_instance(instance_id)

def instance_console(instance_id, limit=200):
    log_path = instance_path(instance_id, "logs", "latest.log")
    lines = []
    if os.path.exists(log_path):
        with open(log_path, "r", encoding="utf-8", errors="replace") as handle: lines = list(deque(handle, maxlen=int(limit)))
    return {"ok": True, "instance_id": instance_id, "lines": [line.rstrip("\n") for line in lines]}

def send_instance_command(instance_id, command):
    iid = validate_instance_id(instance_id)
    command = sanitize_command(command)
    history_path = runtime_history_path(iid)
    os.makedirs(os.path.dirname(history_path), exist_ok=True)
    with open(history_path, "a", encoding="utf-8") as handle: handle.write("%s > %s\n" % (manager_now(), command))
    with PROCESS_LOCK:
        proc = PROCESS_HANDLES.get(iid)
    if proc is None or proc.poll() is not None or proc.stdin is None:
        raise RuntimeError("Instanzkonsole ist nicht verbunden. Starte die Instanz in diesem Manager-Prozess neu, bevor Befehle gesendet werden.")
    try:
        proc.stdin.write((command + "\n").encode("utf-8")); proc.stdin.flush()
    except Exception as exc:
        raise RuntimeError("Befehl konnte nicht an Instanz %s gesendet werden: %s" % (iid, exc))
    return {"ok": True, "instance_id": iid, "command": command, "queued": False}

def instance_backup(instance_id, backup_type="manual"):
    inst = load_instance(instance_id)
    stamp = time.strftime("%Y%m%d-%H%M%S", time.gmtime())
    target_dir = instance_path(instance_id, "backups")
    os.makedirs(target_dir, exist_ok=True)
    name = "%s-%s.zip" % (instance_id, stamp)
    target = os.path.join(target_dir, name)
    metadata = {"instance_id": instance_id, "instance_name": inst.get("name"), "created_at": manager_now(), "bedrock_version": inst.get("bedrock", {}).get("version", "LATEST"), "world_name": inst.get("bedrock", {}).get("level_name", "world"), "backup_type": backup_type}
    with zipfile.ZipFile(target, "w", zipfile.ZIP_DEFLATED) as zf:
        zf.writestr("backup-metadata.json", json.dumps(metadata, ensure_ascii=False, indent=2))
        for filename in ("instance.json", "server.properties", "allowlist.json", "permissions.json"):
            fp = instance_path(instance_id, filename)
            if os.path.exists(fp): zf.write(fp, filename)
    return {"ok": True, "backup": {"name": name, "path": target, "metadata": metadata, "size": os.path.getsize(target)}}

def manager_payload():
    return {"ok": True, "version": MANAGER_VERSION, "winomc_version": WINOMC_VERSION, "log_level": LOG_LEVEL, "instances_dir": INSTANCES_DIR, "import_dir": IMPORT_DIR, "export_dir": EXPORT_DIR, "profiles": list(BEDROCK_PROFILES.values()), "instances": list_instances()}

def default_console_instance_id():
    running = []
    for inst in list_instances():
        if inst.get("broken"):
            continue
        iid = inst.get("id")
        if not iid:
            continue
        state = ((inst.get("status") or {}).get("state") or "").lower()
        if state in ("running", "starting"):
            running.append(iid)
    if len(running) == 1:
        return running[0]
    if running:
        return running[0]
    return None
