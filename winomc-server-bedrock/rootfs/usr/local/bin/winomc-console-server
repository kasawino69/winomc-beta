    /* v1.6.14 UX and metrics controllers */
    const STORE_CONSOLE_BEFORE_FULLSCREEN_1614 = 'winomcConsoleBeforeFullscreenV1614';

    function updateServerOverviewMetrics(data) {
      const metrics = data && data.metrics ? data.metrics : {};
      const players = metrics.players || {};
      const memory = metrics.memory || {};
      const disk = metrics.disk || {};
      const loadavg = metrics.loadavg || {};
      const playersEl = document.getElementById('statPlayers');
      const playersHint = document.getElementById('statPlayersHint');
      const memoryEl = document.getElementById('statMemory');
      const memoryHint = document.getElementById('statMemoryHint');
      const diskEl = document.getElementById('statDisk');
      const diskHint = document.getElementById('statDiskHint');
      if (playersEl) playersEl.textContent = players.label || '-';
      if (playersHint) playersHint.textContent = players.online == null ? 'Noch kein aktueller list-Output im Log. â€žSpieler anzeigenâ€œ aktualisiert die Anzeige.' : 'Online-Spieler laut letztem Server-list-Output.';
      if (memoryEl) memoryEl.textContent = memory.label || '-';
      if (memoryHint) memoryHint.textContent = memory.used_percent != null ? ('RAM belegt: ' + memory.used_percent + '% Â· Load: ' + (loadavg.label || '-')) : 'RAM-Daten nicht verfÃ¼gbar.';
      if (diskEl) diskEl.textContent = disk.label || '-';
