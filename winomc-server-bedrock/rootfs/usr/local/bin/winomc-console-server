    const ACTION_BY_ID = Object.fromEntries(ACTIONS.map(action => [action.id, action]));
    const DEFAULT_DASHBOARD = ['list', 'say', 'time-day', 'weather-clear', 'coordinates-on', 'keepinventory-on', 'sleep-50', 'difficulty-normal', 'stop'];
    let history = JSON.parse(localStorage.getItem('winomcCommandHistory') || '[]');
    let historyIndex = history.length;
    let pendingTemplate = null;
    let dashboardActions = loadDashboard();
    let filesInitialized = false;
    let currentFileRoot = 'config';
    let currentFilePath = '/';
    let currentEditorFile = null;
    let latestStatus = null;

    function appendLine(text, cls) { const div = document.createElement('div'); div.className = 'line' + (cls ? ' ' + cls : ''); div.textContent = text; const stick = log.scrollTop + log.clientHeight >= log.scrollHeight - 20; log.appendChild(div); while (log.children.length > 1600) log.removeChild(log.firstChild); if (stick) log.scrollTop = log.scrollHeight; }
    function saveHistory(command) { history = history.filter(item => item !== command); history.push(command); history = history.slice(-50); historyIndex = history.length; localStorage.setItem('winomcCommandHistory', JSON.stringify(history)); }
    async function sendCommand(command) { command = String(command || '').trim(); if (!command) return; appendLine('> ' + command, 'command'); saveHistory(command); input.value = ''; try { const endpoint = './api/command?command=' + encodeURIComponent(command); const res = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ command }) }); const data = await res.json(); if (!res.ok || !data.ok) appendLine('Fehler: ' + (data.error || res.statusText), 'error'); else appendLine('Befehl gesendet', 'ok'); } catch (err) { appendLine('Fehler beim Senden: ' + err.message, 'error'); } }
    function runAction(action) { if (!action) return; if (action.confirm && !window.confirm(action.confirm)) return; if (action.template) { openPromptForAction(action); return; } sendCommand(action.command); }
    function openPromptForAction(action) { pendingTemplate = action.template; modalTitle.textContent = action.promptTitle || action.label || 'Wert eingeben'; modalLabel.textContent = action.promptLabel || action.description || 'Bitte Wert eingeben.'; modalInput.value = ''; modalInput.placeholder = action.placeholder || ''; modalBackdrop.classList.add('open'); modalBackdrop.setAttribute('aria-hidden', 'false'); setTimeout(() => modalInput.focus(), 0); }
    function closePrompt() { modalBackdrop.classList.remove('open'); modalBackdrop.setAttribute('aria-hidden', 'true'); pendingTemplate = null; }
    function sendPromptValue() { const value = modalInput.value.trim(); if (!value || !pendingTemplate) return; const command = pendingTemplate.replaceAll('{value}', value); closePrompt(); sendCommand(command); }
    function loadDashboard() { try { const saved = JSON.parse(localStorage.getItem(STORE_DASHBOARD) || 'null'); if (Array.isArray(saved) && saved.length) return saved.filter(id => ACTION_BY_ID[id]); } catch (_) {} return [...DEFAULT_DASHBOARD]; }
    function saveDashboard() { localStorage.setItem(STORE_DASHBOARD, JSON.stringify(dashboardActions)); }
    function createButtonForAction(action, label) { const button = document.createElement('button'); button.type = 'button'; button.textContent = label || action.label; if (action.variant) button.classList.add(action.variant); button.addEventListener('click', () => runAction(action)); return button; }
    function renderDashboard() { dashboardGrid.innerHTML = ''; const columns = localStorage.getItem(STORE_COLUMNS) || 'auto'; dashboardColumns.value = columns; dashboardGrid.classList.toggle('auto', columns === 'auto'); if (columns === 'auto') dashboardGrid.style.removeProperty('--dashboard-columns'); else dashboardGrid.style.setProperty('--dashboard-columns', columns); dashboardActions.forEach((id, index) => { const action = ACTION_BY_ID[id]; if (!action) return; const tile = document.createElement('article'); tile.className = 'tile'; const top = document.createElement('div'); top.className = 'tile-top'; const text = document.createElement('div'); const title = document.createElement('div'); title.className = 'tile-title'; title.textContent = action.label; const desc = document.createElement('div'); desc.className = 'tile-desc'; desc.textContent = action.description || ''; text.append(title, desc); const tag = document.createElement('span'); tag.className = 'category-label'; tag.textContent = action.category; top.append(text, tag); const actionButton = createButtonForAction(action, action.template ? 'Ausführen…' : 'Ausführen'); const controls = document.createElement('div'); controls.className = 'tile-actions'; const up = document.createElement('button'); up.type = 'button'; up.textContent = '↑'; up.disabled = index === 0; up.addEventListener('click', () => moveDashboardAction(index, -1)); const down = document.createElement('button'); down.type = 'button'; down.textContent = '↓'; down.disabled = index === dashboardActions.length - 1; down.addEventListener('click', () => moveDashboardAction(index, 1)); const remove = document.createElement('button'); remove.type = 'button'; remove.textContent = 'Entfernen'; remove.className = 'ghost'; remove.addEventListener('click', () => removeDashboardAction(id)); controls.append(up, down, remove); tile.append(top, actionButton, controls); dashboardGrid.appendChild(tile); }); renderActionPicker(); }
    function renderActionPicker() { actionPicker.innerHTML = ''; ACTIONS.forEach(action => { const item = document.createElement('div'); item.className = 'picker-item'; const meta = document.createElement('div'); meta.className = 'picker-meta'; const title = document.createElement('strong'); title.textContent = action.label; const cat = document.createElement('span'); cat.className = 'category-label'; cat.textContent = action.category; meta.append(title, cat); const desc = document.createElement('div'); desc.className = 'tile-desc'; desc.textContent = action.description || ''; const add = document.createElement('button'); add.type = 'button'; add.textContent = dashboardActions.includes(action.id) ? 'Bereits im Dashboard' : 'Hinzufügen'; add.disabled = dashboardActions.includes(action.id); add.addEventListener('click', () => addDashboardAction(action.id)); item.append(meta, desc, add); actionPicker.appendChild(item); }); }
    function addDashboardAction(id) { if (!ACTION_BY_ID[id] || dashboardActions.includes(id)) return; dashboardActions.push(id); saveDashboard(); renderDashboard(); }
    function removeDashboardAction(id) { dashboardActions = dashboardActions.filter(item => item !== id); saveDashboard(); renderDashboard(); }
    function moveDashboardAction(index, direction) { const next = index + direction; if (next < 0 || next >= dashboardActions.length) return; [dashboardActions[index], dashboardActions[next]] = [dashboardActions[next], dashboardActions[index]]; saveDashboard(); renderDashboard(); }

    function apiUrl(path, params = {}) { const query = new URLSearchParams(params); const suffix = query.toString() ? '?' + query.toString() : ''; return './' + path.replace(/^\/+/, '') + suffix; }
    async function fetchJson(path, params = {}) { const res = await fetch(apiUrl(path, params), { cache: 'no-store' }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    async function postJson(path, payload = {}) { const res = await fetch('./' + path.replace(/^\/+/, ''), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    function setFilesStatus(text, variant) { filesStatus.textContent = text; filesStatus.classList.toggle('warn', variant === 'warn'); }
    function formatBytes(value) { const bytes = Number(value || 0); if (bytes < 1024) return bytes + ' B'; if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'; if (bytes < 1024 * 1024 * 1024) return (bytes / 1024 / 1024).toFixed(1) + ' MB'; return (bytes / 1024 / 1024 / 1024).toFixed(1) + ' GB'; }
    function formatUnixTime(value) { if (!value) return '-'; return new Date(Number(value) * 1000).toLocaleString(); }
    function normalizeUiPath(path) { path = String(path || '/').replaceAll('\\', '/'); if (!path.startsWith('/')) path = '/' + path; path = path.replace(/\/+/g, '/'); return path || '/'; }
    function parentUiPath(path) { path = normalizeUiPath(path); if (path === '/') return '/'; const parts = path.split('/').filter(Boolean); parts.pop(); return '/' + parts.join('/'); }
    function escapeHtml(value) { return String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;'); }
    function activateTab(tab) { if (document.body.classList.contains('desktop-mode')) { openDesktopWindow(tab); return; } document.querySelectorAll('[data-tab]').forEach(item => item.classList.toggle('active', item.dataset.tab === tab)); document.querySelectorAll('[data-panel]').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab)); if (tab === 'files') initFileManager(); if (tab === 'overview' || tab === 'network') loadStatus(); }
    function openRoot(root, path = '/') { activateTab('files'); setTimeout(async () => { await initFileManager(); currentFileRoot = root; fileRootSelect.value = root; await loadFileList(path); }, 0); }

    async function loadStatus() { try { const data = await fetchJson('/api/status'); latestStatus = data; document.getElementById('statServerName').textContent = data.env.SERVER_NAME || '-'; document.getElementById('statLevelName').textContent = 'Welt: ' + (data.env.LEVEL_NAME || '-'); document.getElementById('statVersion').textContent = data.env.VERSION || '-'; document.getElementById('statRuntime').textContent = 'Runtime: native · BDS Auto Update: ' + (data.env.BDS_AUTO_UPDATE || '-'); document.getElementById('statPorts').textContent = (data.env.SERVER_PORT || '-') + ' / ' + (data.env.SERVER_PORT_V6 || '-'); document.getElementById('statLan').textContent = 'LAN: ' + (data.env.ENABLE_LAN_VISIBILITY || '-'); document.getElementById('statFifo').textContent = data.fifo_exists ? 'Console FIFO vorhanden' : 'Console FIFO fehlt'; document.getElementById('statLog').textContent = data.log_exists ? 'Logdatei vorhanden' : 'Logdatei fehlt'; document.getElementById('networkIpv4').textContent = 'SERVER_PORT=' + (data.env.SERVER_PORT || '-'); document.getElementById('networkIpv6').textContent = 'SERVER_PORT_V6=' + (data.env.SERVER_PORT_V6 || '-') + ' · ENABLE_BDS_V6BIND_FIX=' + (data.env.ENABLE_BDS_V6BIND_FIX || '-'); document.getElementById('networkLan').textContent = 'ENABLE_LAN_VISIBILITY=' + (data.env.ENABLE_LAN_VISIBILITY || '-'); } catch (err) { appendLine('[WinoMC Status] ' + err.message, 'error'); } }

    async function initFileManager() { if (filesInitialized) { await loadFileList(); return; } filesInitialized = true; try { setFilesStatus('Lade Bereiche...', 'warn'); const data = await fetchJson('/api/files/roots'); fileRootSelect.innerHTML = ''; data.roots.forEach(root => { const option = document.createElement('option'); option.value = root.key; option.textContent = root.label + (root.exists ? '' : ' (fehlt)'); option.disabled = !root.exists || !root.readable; fileRootSelect.appendChild(option); }); const firstEnabled = [...fileRootSelect.options].find(option => !option.disabled); if (![...fileRootSelect.options].some(option => option.value === currentFileRoot && !option.disabled)) currentFileRoot = firstEnabled ? firstEnabled.value : 'config'; fileRootSelect.value = currentFileRoot; await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    async function loadFileList(path) { if (path !== undefined) currentFilePath = normalizeUiPath(path); currentFileRoot = fileRootSelect.value || currentFileRoot; try { setFilesStatus('Lade...', 'warn'); updatePathDisplay(); const data = await fetchJson('/api/files/list', { root: currentFileRoot, path: currentFilePath }); currentFilePath = data.path || '/'; fileParent.disabled = currentFilePath === '/'; updatePathDisplay(); renderFileEntries(data.entries || []); setFilesStatus('Bereit', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    function updatePathDisplay() { const full = currentFileRoot + ':' + currentFilePath; fileCurrentPath.textContent = full; filePathInput.value = currentFilePath; fileBreadcrumb.innerHTML = ''; const rootButton = document.createElement('button'); rootButton.type = 'button'; rootButton.textContent = currentFileRoot + ':/'; rootButton.addEventListener('click', () => loadFileList('/')); fileBreadcrumb.appendChild(rootButton); let current = ''; currentFilePath.split('/').filter(Boolean).forEach(part => { current += '/' + part; const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = part; const target = current; btn.addEventListener('click', () => loadFileList(target)); fileBreadcrumb.appendChild(btn); }); }
    function renderFileEntries(entries) { if (!entries.length) { fileTableBody.innerHTML = '<tr><td colspan="5">Dieser Ordner ist leer.</td></tr>'; return; } fileTableBody.innerHTML = ''; entries.forEach(entry => { const tr = document.createElement('tr'); const nameTd = document.createElement('td'); const nameButton = document.createElement('button'); nameButton.type = 'button'; nameButton.className = 'file-name-button'; nameButton.textContent = (entry.type === 'directory' ? '📁 ' : '📄 ') + entry.name; nameButton.addEventListener('click', () => entry.type === 'directory' ? loadFileList(entry.path) : openFileInEditor(entry.path)); nameTd.appendChild(nameButton); const typeTd = document.createElement('td'); typeTd.textContent = entry.type === 'directory' ? 'Ordner' : 'Datei'; const sizeTd = document.createElement('td'); sizeTd.textContent = entry.type === 'directory' ? '-' : formatBytes(entry.size); const modifiedTd = document.createElement('td'); modifiedTd.textContent = formatUnixTime(entry.modified); const actionsTd = document.createElement('td'); const actions = document.createElement('div'); actions.className = 'file-row-actions'; if (entry.type === 'directory') { const open = document.createElement('button'); open.type = 'button'; open.textContent = 'Öffnen'; open.addEventListener('click', () => loadFileList(entry.path)); const zip = document.createElement('button'); zip.type = 'button'; zip.textContent = 'ZIP'; zip.addEventListener('click', () => downloadZip(entry.path)); const exportZip = document.createElement('button'); exportZip.type = 'button'; exportZip.textContent = 'Export'; exportZip.addEventListener('click', () => saveZipToExport(entry.path)); actions.append(open, zip, exportZip); } else { const download = document.createElement('button'); download.type = 'button'; download.textContent = 'Download'; download.addEventListener('click', () => downloadFile(entry.path)); const edit = document.createElement('button'); edit.type = 'button'; edit.textContent = 'Editor'; edit.addEventListener('click', () => openFileInEditor(entry.path)); actions.append(download, edit); if (['.zip', '.mcpack', '.mcaddon', '.mcworld', '.mctemplate'].some(ext => entry.name.toLowerCase().endsWith(ext))) { const unzip = document.createElement('button'); unzip.type = 'button'; unzip.textContent = 'Entpacken'; unzip.addEventListener('click', () => unzipFile(entry.path)); actions.appendChild(unzip); } } actionsTd.appendChild(actions); tr.append(nameTd, typeTd, sizeTd, modifiedTd, actionsTd); fileTableBody.appendChild(tr); }); }
    function downloadFile(path) { window.location.href = apiUrl('/api/files/download', { root: currentFileRoot, path }); }
    function downloadZip(path) { window.location.href = apiUrl('/api/files/zip', { root: currentFileRoot, path }); }
    async function saveZipToExport(path) { try { setFilesStatus('Erstelle ZIP...', 'warn'); const data = await postJson('/api/files/zip', { root: currentFileRoot, paths: [path], save_to_export: true }); appendLine('[WinoMC Dateien] ZIP exportiert: ' + data.filename, 'ok'); setFilesStatus('ZIP exportiert', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] ZIP-Fehler: ' + err.message, 'error'); alert(err.message); } }
    async function openFileInEditor(path) { try { setFilesStatus('Öffne Datei...', 'warn'); const data = await fetchJson('/api/files/read', { root: currentFileRoot, path }); currentEditorFile = { root: data.root, path: data.path }; editorPath.textContent = data.root + ':' + data.path; editorMeta.textContent = formatBytes(data.size) + ' · geändert: ' + formatUnixTime(data.modified) + (data.json ? ' · JSON-Prüfung aktiv' : ''); fileEditor.value = data.content || ''; setFilesStatus('Datei geöffnet', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Editor-Fehler: ' + err.message, 'error'); alert(err.message); } }
    async function saveEditorFile() { if (!currentEditorFile) { alert('Keine Datei geöffnet.'); return; } try { setFilesStatus('Speichere...', 'warn'); const data = await postJson('/api/files/write', { root: currentEditorFile.root, path: currentEditorFile.path, content: fileEditor.value }); appendLine('[WinoMC Dateien] Datei gespeichert: ' + currentEditorFile.path, 'ok'); if (data.backup_created) appendLine('[WinoMC Dateien] Backup erstellt: ' + data.backup_path, 'ok'); setFilesStatus('Gespeichert', ''); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Speichern fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }
    function clearEditor() { currentEditorFile = null; editorPath.textContent = 'Keine Datei geöffnet'; editorMeta.textContent = 'Bereit'; fileEditor.value = ''; }
    async function uploadFiles(files) { files = Array.from(files || []); if (!files.length) return; for (const file of files) { try { setFilesStatus('Upload: ' + file.name, 'warn'); let data; try { data = await uploadFileBinary(file); } catch (binaryErr) { if (file.size > MAX_JSON_UPLOAD_SIZE) throw binaryErr; appendLine('[WinoMC Dateien] Binary Upload fehlgeschlagen, nutze JSON-Fallback: ' + binaryErr.message, 'error'); data = await uploadFileJson(file); } appendLine('[WinoMC Dateien] Hochgeladen: ' + data.path, 'ok'); } catch (err) { appendLine('[WinoMC Dateien] Upload fehlgeschlagen: ' + file.name + ' · ' + err.message, 'error'); alert('Upload fehlgeschlagen: ' + file.name + '\n\n' + err.message); } } setFilesStatus('Upload fertig', ''); await loadFileList(currentFilePath); }
    async function uploadFileBinary(file) { const res = await fetch(apiUrl('/api/files/upload', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: 'false' }), { method: 'POST', headers: { 'Content-Type': 'application/octet-stream', 'X-WinoMC-Upload-Size': String(file.size), 'X-WinoMC-Filename': encodeURIComponent(file.name) }, body: file }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    function readFileAsBase64(file) { return new Promise((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result || '').split(',', 2)[1] || ''); reader.onerror = () => reject(reader.error || new Error('Datei konnte nicht gelesen werden.')); reader.readAsDataURL(file); }); }
    async function uploadFileJson(file) { const base64 = await readFileAsBase64(file); return postJson('/api/files/upload-json', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: false, content_base64: base64 }); }
    async function unzipFile(path) { const destination = window.prompt('In welchen Ordner entpacken?', currentFilePath || '/'); if (destination === null) return; const overwrite = window.confirm('Vorhandene Dateien überschreiben?'); try { setFilesStatus('Entpacke ZIP...', 'warn'); const data = await postJson('/api/files/unzip', { root: currentFileRoot, path, destination, overwrite }); appendLine('[WinoMC Dateien] Entpackt: ' + data.files + ' Dateien, ' + data.directories + ' Ordner', 'ok'); setFilesStatus('ZIP entpackt', ''); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Entpacken fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }
    async function runSafeWorldExport() { const defaultWorld = latestStatus && latestStatus.env && latestStatus.env.LEVEL_NAME ? '/' + latestStatus.env.LEVEL_NAME : '/world'; const worldPath = window.prompt('Welche Welt sicher exportieren?', defaultWorld); if (!worldPath) return; if (!window.confirm('Sicheren Welt-Export starten?\n\nAblauf: save hold → save query → ZIP → save resume')) return; try { setFilesStatus('Welt-Export läuft...', 'warn'); const data = await postJson('/api/worlds/export-safe', { path: worldPath, save_to_export: true }); appendLine('[WinoMC Dateien] Sicherer Welt-Export erstellt: ' + data.filename, 'ok'); setFilesStatus('Welt exportiert', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Welt-Export fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }

    form.addEventListener('submit', event => { event.preventDefault(); sendCommand(input.value); });
    document.addEventListener('click', event => { const actionBtn = event.target.closest('[data-action-id]'); if (actionBtn) { runAction(ACTION_BY_ID[actionBtn.dataset.actionId]); return; } const jump = event.target.closest('[data-jump-tab]'); if (jump) { activateTab(jump.dataset.jumpTab); return; } const openRootBtn = event.target.closest('[data-open-root]'); if (openRootBtn) { openRoot(openRootBtn.dataset.openRoot, '/'); return; } });
    document.querySelectorAll('[data-tab]').forEach(button => button.addEventListener('click', () => activateTab(button.dataset.tab)));
    document.querySelectorAll('[data-console-size]').forEach(button => button.addEventListener('click', () => applyConsoleSize(button.dataset.consoleSize)));
    sidebarToggle.addEventListener('click', toggleSidebar);
    resetWorkbenchLayout.addEventListener('click', resetWorkbench);
    consoleCollapse.addEventListener('click', () => setConsoleMode(document.body.classList.contains('console-collapsed') ? 'normal' : 'collapsed'));
    consoleMaximize.addEventListener('click', () => setConsoleMode(document.body.classList.contains('console-maximized') ? 'normal' : 'maximized'));
