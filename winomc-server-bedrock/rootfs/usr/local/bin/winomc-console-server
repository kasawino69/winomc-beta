      { id: 'save-hold', category: 'Experten', label: 'Backup: speichern pausieren', description: 'Pausiert Welt-Schreibvorgänge für Datei-Backups.', command: 'save hold', variant: 'warning', confirm: 'Speichern wirklich pausieren? Danach save resume ausführen.' },
      { id: 'save-query', category: 'Experten', label: 'Backup: Status prüfen', description: 'Fragt den Backup-/Speicherstatus ab.', command: 'save query' },
      { id: 'save-resume', category: 'Experten', label: 'Backup: speichern fortsetzen', description: 'Setzt normales Speichern nach save hold fort.', command: 'save resume', variant: 'primary' }
