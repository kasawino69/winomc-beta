    def do_PATCH(self):
        if self._forbidden_if_needed():
            return
        path = urlparse(self.path).path
        m = re.match(r"^/api/instances/([^/]+)$", path)
        if m:
            try:
                self.require_web_write_allowed("Instanz bearbeiten")
                self._send_json(200, {"ok": True, "instance": update_instance(m.group(1), self._read_json_payload())})
            except Exception as exc:
                self._send_json(400, runtime_error_payload(exc, m.group(1) if m else None, component="instance-manager"))
            return
        self.send_error(404)

    def do_DELETE(self):
        if self._forbidden_if_needed():
            return
        path = urlparse(self.path).path
        m = re.match(r"^/api/instances/([^/]+)$", path)
        if m:
            try:
                self.require_web_write_allowed("Instanz lÃ¶schen")
                self._send_json(200, delete_instance(m.group(1)))
            except Exception as exc:
                self._send_json(400, runtime_error_payload(exc, m.group(1) if m else None, component="instance-manager"))
            return
        self.send_error(404)

    def do_POST(self):
        if self._forbidden_if_needed():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        if path.endswith("/api/instances") or path == "/api/instances":
            try:
                self.require_web_write_allowed("Instanz erstellen")
                self._send_json(200, {"ok": True, "instance": create_instance(self._read_json_payload())})
            except Exception as exc:
                self._send_json(400, runtime_error_payload(exc, component="instance-manager"))
            return
        m = re.match(r"^/api/instances/([^/]+)/(start|stop|restart|command|backup)$", path)
        if m:
            try:
                iid, action = m.group(1), m.group(2)
                payload = self._read_json_payload() if action in ("command", "backup") else {}
                if action == "start": result = start_instance(iid)
                elif action == "stop": result = stop_instance(iid)
                elif action == "restart": result = restart_instance(iid)
                elif action == "command": result = send_instance_command(iid, payload.get("command", ""))
                else: result = instance_backup(iid, str(payload.get("type", "manual")))
                self._send_json(200, result)
            except Exception as exc:
                self._send_json(400, runtime_error_payload(exc, iid if 'iid' in locals() else None))
            return
        if path.endswith("/api/command") or path == "/api/command":
            try:
                command = sanitize_command(self._extract_command())
                routed_iid = default_console_instance_id()
                if routed_iid:
                    result = send_instance_command(routed_iid, command)
                    self._send_json(200, dict(result, routed_from="legacy-api-command", instance_id=routed_iid))
                else:
                    write_command(command)
                    self._send_json(200, {"ok": True, "command": command, "routed_from": "legacy-api-command", "target": "legacy-fifo"})
