        "ok": False,
        "manual_import_required": True,
        "addon_manager_available": True,
        "message": "Freier serverseitiger URL-Download ist deaktiviert. Lade die Datei selbst herunter und lege sie in /share/winomc/import oder lade sie über WinoMC hoch.",
    }


def validate_external_download_url(url):
    # Keinen Netzwerkzugriff auslösen: URL-Import ist bewusst durch lokalen Add-on Manager ersetzt.
    return manual_url_import_disabled_response()


def check_import_url(url):
    return manual_url_import_disabled_response()


def download_external_pack(url):
    raise PermissionError(manual_url_import_disabled_response()["message"])

def zip_member_is_symlink(member):
    return stat.S_ISLNK((getattr(member, "external_attr", 0) >> 16) & 0o170000)


def safe_zip_members(archive_path):
    manifests = []
    java_markers = []
    with zipfile.ZipFile(archive_path, "r") as archive:
        total = 0
        count = 0
        for member in archive.infolist():
            count += 1
            if count > MAX_IMPORT_ARCHIVE_FILES:
                raise ValueError("Archiv enthält zu viele Dateien.")
            raw = str(member.filename or "").replace("\\", "/")
            if not raw or raw.startswith("/") or raw.startswith("../") or "/../" in raw or len(raw) > MAX_IMPORT_FILENAME_LENGTH:
                raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw)
            if zip_member_is_symlink(member):
                raise ValueError("Symlink im Archiv blockiert: %s" % raw)
            total += int(member.file_size or 0)
            if total > MAX_ZIP_UNPACK_BYTES:
                raise ValueError("Archiv ist zu groß oder wirkt wie eine ZIP-Bombe.")
            name = posixpath.basename(raw)
            lower = raw.lower()
            if lower.startswith("__macosx/"):
                continue
            if name == "manifest.json":
                try:
                    with archive.open(member) as handle:
                        data = json.loads(handle.read(1024 * 1024).decode("utf-8", errors="replace"))
                    manifests.append({"path": raw, "data": data})
                except Exception as exc:
                    raise ValueError("manifest.json ist ungültig: %s" % exc)
            if lower.endswith(".jar") or lower in JAVA_MOD_MARKERS or lower.endswith("mods.toml"):
                java_markers.append(raw)
    if java_markers:
        raise ValueError("Diese Datei sieht nach einem Java-Mod aus. WinoMC unterstützt nur Minecraft Bedrock Packs/Add-ons.")
    return manifests


def classify_bedrock_archive(archive_path, ext):
    archive_path = verify_internal_path(QUARANTINE_DIR, archive_path, require_exists=True, allow_missing=False).path
    manifests = safe_zip_members(archive_path)
    if ext in (".mcworld", ".mctemplate"):
        return {"supported": True, "kind": "world" if ext == ".mcworld" else "template", "manifests": manifests, "packs": [], "risk": "yellow", "warnings": ["Welt/Template wird nur als neues Ziel importiert, niemals still überschrieben."], "message": "Bedrock-Welt/Template erkannt."}
    packs = []
    all_uuids = set()
    warnings = []
    for manifest in manifests:
        data = manifest.get("data") or {}
        header = data.get("header", {}) if isinstance(data, dict) else {}
        modules = data.get("modules", []) if isinstance(data, dict) else []
        if not data.get("format_version") or not header.get("uuid") or not isinstance(header.get("version"), list) or not isinstance(modules, list):
            continue
        module_types = {str(m.get("type", "")).lower() for m in modules if isinstance(m, dict)}
        pack_type = "behavior" if any("data" in t or "script" in t for t in module_types) else "resource"
        deps = data.get("dependencies", []) if isinstance(data.get("dependencies", []), list) else []
        caps = data.get("capabilities", []) if isinstance(data.get("capabilities", []), list) else []
        min_engine = header.get("min_engine_version") or data.get("min_engine_version")
        pack = {"manifest_path": manifest["path"], "name": header.get("name") or "Bedrock Pack", "uuid": header.get("uuid"), "version": header.get("version"), "type": pack_type, "module_types": sorted(module_types), "dependencies": deps, "capabilities": caps, "min_engine_version": min_engine, "metadata": data.get("metadata", {})}
        packs.append(pack); all_uuids.add(str(pack["uuid"]))
        if deps:
            missing = [d for d in deps if isinstance(d, dict) and str(d.get("uuid", "")) and str(d.get("uuid")) not in all_uuids]
            if missing:
                warnings.append("Pack %s nennt Abhängigkeiten; bitte zusammengehörige Packs prüfen." % pack["name"])
        if caps or min_engine:
            warnings.append("Pack %s nennt capabilities/min_engine_version; bitte Bedrock-Kompatibilität testen." % pack["name"])
        if pack.get("metadata", {}).get("product_type") or "marketplace" in json.dumps(pack.get("metadata", {}), ensure_ascii=False).lower():
            warnings.append("Marketplace-Inhalte können konto-/plattformabhängig sein.")
    if not packs:
        raise ValueError("Kein gültiges Bedrock manifest.json mit format_version, header.uuid, header.version und modules gefunden.")
    kind = "mcaddon" if len(packs) > 1 or ext == ".mcaddon" else packs[0]["type"]
    risk = "red" if any(p["type"] == "behavior" for p in packs) else ("yellow" if warnings or len(packs) > 1 else "green")
    return {"supported": True, "kind": kind, "packs": packs, "risk": risk, "warnings": warnings, "message": "Bedrock-Manifest gefunden."}


def classify_local_bedrock_archive(root_key, archive_path, ext):
    archive_path = assert_safe_path(root_key, archive_path, require_exists=True)
    manifests = safe_zip_members(archive_path)
    if ext in (".mcworld", ".mctemplate"):
        return {"supported": True, "kind": "world" if ext == ".mcworld" else "template", "manifests": manifests, "packs": [], "risk": "yellow", "warnings": ["Welt/Template wird nur als neues Ziel importiert, niemals still überschrieben."], "message": "Bedrock-Welt/Template erkannt."}
    packs = []
    warnings = []
    for manifest in manifests:
        data = manifest.get("data") or {}
        header = data.get("header", {}) if isinstance(data, dict) else {}
        modules = data.get("modules", []) if isinstance(data, dict) else []
        if not data.get("format_version") or not header.get("uuid") or not isinstance(header.get("version"), list) or not isinstance(modules, list):
            continue
        module_types = {str(m.get("type", "")).lower() for m in modules if isinstance(m, dict)}
        pack_type = "behavior" if any("data" in t or "script" in t for t in module_types) else "resource"
        deps = data.get("dependencies", []) if isinstance(data.get("dependencies", []), list) else []
        caps = data.get("capabilities", []) if isinstance(data.get("capabilities", []), list) else []
        pack = {"manifest_path": manifest["path"], "name": header.get("name") or os.path.splitext(os.path.basename(archive_path))[0], "uuid": header.get("uuid"), "version": header.get("version"), "type": pack_type, "module_types": sorted(module_types), "dependencies": deps, "capabilities": caps, "min_engine_version": header.get("min_engine_version") or data.get("min_engine_version"), "metadata": data.get("metadata", {})}
        packs.append(pack)
        if deps:
            warnings.append("Pack %s nennt Abhängigkeiten; bitte zusammengehörige Packs prüfen." % pack["name"])
        if caps or pack.get("min_engine_version"):
            warnings.append("Pack %s nennt capabilities/min_engine_version; bitte Bedrock-Kompatibilität testen." % pack["name"])
    if not packs:
        raise ValueError("Kein gültiges Bedrock manifest.json gefunden.")
    kind = "mcaddon" if len(packs) > 1 or ext == ".mcaddon" else packs[0]["type"]
    risk = "red" if any(p["type"] == "behavior" for p in packs) else ("yellow" if warnings or len(packs) > 1 else "green")
    return {"supported": True, "kind": kind, "packs": packs, "risk": risk, "warnings": warnings, "message": "Lokales Bedrock-Manifest gefunden."}


def existing_pack_uuid_index():
    index = {}
    for pack in scan_packs(RESOURCE_PACKS_DIR, "resource") + scan_packs(BEHAVIOR_PACKS_DIR, "behavior"):
        if is_builtin_bedrock_pack(pack):
            continue
        if pack.get("uuid"):
            index.setdefault(pack["uuid"], []).append(pack)
    return index


def quarantine_file_path(quarantine_id):
    safe_id = safe_download_name(quarantine_id, "winomc-import")
    base = quarantine_dir_path()
    path = assert_safe_internal_path(base, os.path.join(base, safe_id), require_exists=True)
    if not os.path.isfile(path):
        raise FileNotFoundError("Quarantäne-Datei nicht gefunden.")
    return path


def build_import_plan_from_quarantine(quarantine_id, filename=None, extension=None):
    archive_path = quarantine_file_path(quarantine_id)
    extension = extension or file_extension(filename or quarantine_id)
    classification = classify_bedrock_archive(archive_path, extension)
    warnings = list(classification.get("warnings", []))
    changes = []
    backup_plan = []
    risk = classification.get("risk", "green")
    duplicate_uuids = []
    existing = existing_pack_uuid_index()
    for pack in classification.get("packs", []):
        changes.append("%s Pack '%s' installieren." % (pack["type"], pack["name"]))
        if pack.get("uuid") in existing:
            duplicate_uuids.append({"uuid": pack.get("uuid"), "existing": existing[pack.get("uuid")], "incoming": pack})
            warnings.append("Doppelte UUID erkannt: %s. Möglicherweise Update desselben Packs; bitte bewusst ersetzen." % pack.get("uuid"))
            risk = risk_level(risk, "red")
        if pack.get("dependencies"):
            risk = risk_level(risk, "yellow")
        if pack.get("type") == "behavior":
            risk = risk_level(risk, "red")
    if classification["kind"] in ("world", "template"):
        changes.append("%s als neues Ziel importieren; bestehende Ziele werden nicht überschrieben." % classification["kind"])
        risk = risk_level(risk, "yellow")
    free = disk_usage_metrics().get("free") or 0
    size = os.path.getsize(archive_path)
    if free and free < size * 2:
        warnings.append("Wenig freier Speicher: Import benötigt grob mindestens die doppelte Downloadgröße.")
        risk = risk_level(risk, "red")
    return {"ok": True, "kind": "import", "risk": risk, "summary": "Importprüfung für %s" % (filename or quarantine_id), "changes": changes, "warnings": warnings, "backup_plan": backup_plan or ["Rollback/Cleanup bei Fehler", "Sicherung vor Aktivierung von World-Pack-Dateien"], "requires_confirmation": risk in ("yellow", "red"), "classification": classification, "duplicate_uuids": duplicate_uuids, "source": {"filename": filename or quarantine_id, "quarantine_id": safe_download_name(quarantine_id, "winomc-import"), "size": size}}


def build_import_plan(source):
    return build_import_plan_from_quarantine(source.get("quarantine_id", ""), source.get("filename"), source.get("extension"))




def install_import_url(url, activate=False, confirm=False):
    return manual_url_import_disabled_response()


def addon_history_path():
    base = makedirs_internal(os.path.dirname(ADDON_HISTORY_FILE), os.path.dirname(ADDON_HISTORY_FILE), exist_ok=True)
    return assert_safe_internal_path(base, ADDON_HISTORY_FILE, require_exists=False)


def read_addon_history():
    try:
        path = addon_history_path()
        if not os.path.exists(path):
            return []
        with open_safe_internal(os.path.dirname(path), path, "r", encoding="utf-8", errors="replace") as handle:
            data = json.load(handle)
        return data if isinstance(data, list) else []
    except Exception as exc:
        log_warning("Add-on-History konnte nicht gelesen werden: %s" % exc)
        return []


def append_addon_history(entry):
    history = read_addon_history()
    entry = dict(entry or {})
    entry["installed_at"] = time.strftime("%Y-%m-%d_%H-%M-%S")
    history.insert(0, entry)
    path = addon_history_path()
    with open_safe_internal(os.path.dirname(path), path, "w", encoding="utf-8") as handle:
        json.dump(history[:200], handle, ensure_ascii=False, indent=2)
        handle.write("\n")


def version_tuple(value):
    if isinstance(value, list):
        return tuple(int(x) for x in value if str(x).isdigit())
    return tuple(int(x) for x in re.findall(r"\d+", str(value or "")))


def addon_item_id(prefix, value):
    return "%s:%s" % (prefix, safe_download_name(value, "item"))


def resolve_addon_item(item_id):
    item_id = str(item_id or "")
    if ":" not in item_id:
        raise ValueError("item_id fehlt oder ist ungültig.")
    prefix, raw = item_id.split(":", 1)
    safe_id = safe_download_name(raw, "item")
    if prefix == "import":
        path = assert_safe_path("import", os.path.join(IMPORT_DIR, safe_id), require_exists=True)
        return {"prefix": prefix, "id": item_id, "safe_id": safe_id, "root_key": "import", "path": path, "filename": safe_id}
    if prefix in ("installed", "active"):
        for item in addon_catalog_items(include_import=False):
            if item.get("uuid") == raw or item.get("item_id") == item_id:
                return item
    if prefix == "world":
        path = assert_safe_path("worlds", os.path.join(WORLDS_DIR, safe_id), require_exists=True)
        return {"prefix": prefix, "id": item_id, "safe_id": safe_id, "root_key": "worlds", "path": path, "filename": safe_id}
    if prefix == "template":
        path = assert_safe_path("world_templates", os.path.join(WORLD_TEMPLATES_DIR, safe_id), require_exists=True)
        return {"prefix": prefix, "id": item_id, "safe_id": safe_id, "root_key": "world_templates", "path": path, "filename": safe_id}
    raise ValueError("Unbekannte item_id: %s" % item_id)


def installed_uuid_status():
    installed = {}
    active = {"resource": {e.get("pack_id") for e in read_world_pack_entries("resource")}, "behavior": {e.get("pack_id") for e in read_world_pack_entries("behavior")}}
    for pack in scan_packs(RESOURCE_PACKS_DIR, "resource") + scan_packs(BEHAVIOR_PACKS_DIR, "behavior"):
        if is_builtin_bedrock_pack(pack):
            continue
        uuid = pack.get("uuid")
        if uuid:
            installed[uuid] = {"installed": True, "active": uuid in active.get(pack.get("type"), set()), "installed_version": pack.get("version"), "pack": pack}
    return installed


def import_catalog_item(filename):
    path = assert_safe_path("import", os.path.join(IMPORT_DIR, safe_download_name(filename, "import")), require_exists=True)
    stat_info = stat_root("import", path)
    ext = file_extension(filename)
    item = {"item_id": addon_item_id("import", filename), "name": filename, "filename": filename, "type": "unsupported", "source": "Importordner", "status": "Import-Eingang", "risk": "red", "size": stat_info.st_size, "size_label": human_bytes(stat_info.st_size), "detected_at": int(stat_info.st_mtime), "manifest_status": "not_checked", "installed": False, "active": False, "local_update_available": False, "duplicate_uuid": False, "warnings": [], "issues": []}
    if ext in REJECTED_IMPORT_EXTENSIONS:
        item["issues"].append("Nicht unterstützt. WinoMC unterstützt Minecraft Bedrock Packs, keine Java-Mods oder ausführbaren Dateien.")
        return item
    if ext not in SUPPORTED_IMPORT_EXTENSIONS:
        item["issues"].append("Dateityp wird nicht unterstützt.")
        return item
    try:
        classification = classify_local_bedrock_archive("import", path, ext)
        item.update({"type": classification.get("kind", ext.lstrip(".")), "risk": classification.get("risk", "yellow"), "manifest_status": "ok", "classification": classification, "warnings": classification.get("warnings", [])})
        packs = classification.get("packs", [])
        if packs:
            first = packs[0]
            item.update({"name": first.get("name") or filename, "uuid": first.get("uuid"), "version": ".".join(map(str, first.get("version", []))), "detected_type": first.get("type")})
            installed = installed_uuid_status().get(first.get("uuid"), {})
            item["installed"] = bool(installed.get("installed"))
            item["active"] = bool(installed.get("active"))
            item["installed_version"] = installed.get("installed_version")
            item["duplicate_uuid"] = item["installed"]
            iv = version_tuple(item.get("version")); xv = version_tuple(item.get("installed_version"))
            if item["installed"] and iv and xv:
                if iv > xv:
                    item["local_update_available"] = True; item["update_status"] = "Lokales Update verfügbar"
                elif iv == xv:
                    item["update_status"] = "Bereits installiert"
                else:
                    item["update_status"] = "Ältere Version"
            elif item["installed"]:
                item["update_status"] = "Version unklar"
        return item
    except Exception as exc:
        item["manifest_status"] = "error"
        item["issues"].append(str(exc))
        return item


def addon_catalog_items(include_import=True):
    items = []
    if include_import and os.path.isdir(IMPORT_DIR):
        for name in sorted(os.listdir(IMPORT_DIR)):
            full = os.path.join(IMPORT_DIR, name)
            if os.path.isfile(full):
                items.append(import_catalog_item(name))
    for pack in scan_packs(RESOURCE_PACKS_DIR, "resource") + scan_packs(BEHAVIOR_PACKS_DIR, "behavior"):
        if is_builtin_bedrock_pack(pack):
            continue
        uuid = pack.get("uuid") or pack.get("path")
        active = bool(pack.get("uuid") in {e.get("pack_id") for e in read_world_pack_entries(pack.get("type"))}) if pack.get("uuid") else False
        items.append({"item_id": addon_item_id("active" if active else "installed", uuid), "name": pack.get("name"), "filename": pack.get("path"), "type": pack.get("type"), "source": "Aktiv" if active else "Installiert", "status": "Aktiv" if active else "Installiert", "uuid": pack.get("uuid"), "version": pack.get("version"), "risk": "green", "manifest_status": pack.get("status"), "installed": True, "active": active, "local_update_available": False, "duplicate_uuid": False, "warnings": [] if pack.get("status") == "OK" else [pack.get("description", "Warnung")], "issues": [] if pack.get("status") == "OK" else [pack.get("description", "Warnung")]})
    return items


def addon_counts(items):
    return {"inbox": sum(1 for i in items if i.get("source") == "Importordner"), "installed": sum(1 for i in items if i.get("installed")), "active": sum(1 for i in items if i.get("active")), "updates": sum(1 for i in items if i.get("local_update_available")), "issues": sum(1 for i in items if i.get("issues")), "resource": sum(1 for i in items if i.get("type") == "resource"), "behavior": sum(1 for i in items if i.get("type") == "behavior"), "worlds": sum(1 for i in items if i.get("type") == "world"), "templates": sum(1 for i in items if i.get("type") == "template")}


def addons_overview_payload():
    items = addon_catalog_items()
    return {"ok": True, "counts": addon_counts(items), "message": "User brings the file. WinoMC makes it safe and simple."}


def addons_catalog_payload(filters=None):
    filters = filters or {}
    items = addon_catalog_items()
    q = str(filters.get("q", [""])[0] if isinstance(filters.get("q"), list) else filters.get("q", "")).lower()
    type_filter = str(filters.get("type", [""])[0] if isinstance(filters.get("type"), list) else filters.get("type", "")).lower()
    risk_filter = str(filters.get("risk", [""])[0] if isinstance(filters.get("risk"), list) else filters.get("risk", "")).lower()
    def keep(item):
        if q and q not in json.dumps(item, ensure_ascii=False).lower(): return False
        if type_filter and item.get("type") != type_filter: return False
        if risk_filter and item.get("risk") != risk_filter: return False
        for flag in ("updates", "active", "installed", "issues"):
            val = filters.get(flag, [""])[0] if isinstance(filters.get(flag), list) else filters.get(flag, "")
            if str(val).lower() in ("1", "true", "yes") and not (item.get("local_update_available") if flag == "updates" else item.get(flag)):
                return False
        return True
    filtered = [item for item in items if keep(item)]
    return {"ok": True, "items": filtered, "counts": addon_counts(items), "filters": filters}


def addons_item_payload(item_id):
    for item in addon_catalog_items():
        if item.get("item_id") == item_id:
            return {"ok": True, "item": item}
    raise FileNotFoundError("Add-on Manager Eintrag wurde nicht gefunden.")


def build_addon_plan(item_id, action="install", activate=False):
    item = addons_item_payload(item_id)["item"]
    risk = item.get("risk", "yellow")
    changes = []
    warnings = list(item.get("warnings") or item.get("issues") or [])
    if action in ("install", "update"):
        changes.append("Lokale Importdatei wird analysiert und in den passenden WinoMC-Ordner installiert.")
        if item.get("duplicate_uuid"):
            risk = risk_level(risk, "yellow" if item.get("local_update_available") else "red")
            warnings.append("UUID ist bereits installiert; kein stilles Ersetzen.")
    if activate or action == "activate":
        risk = risk_level(risk, "yellow")
        changes.append("World-Pack-Datei wird nach Backup aktualisiert.")
    if item.get("type") == "behavior" or (item.get("classification", {}).get("kind") == "mcaddon" and any(p.get("type") == "behavior" for p in item.get("classification", {}).get("packs", []))):
        risk = risk_level(risk, "red")
    return {"ok": True, "kind": "addon", "item_id": item_id, "action": action, "risk": risk, "summary": "Add-on Manager Prüfung für %s" % item.get("name"), "changes": changes, "warnings": warnings, "backup_plan": ["Sicherung vor Änderungen", "Rollback/Cleanup bei Fehler"], "requires_confirmation": risk in ("yellow", "red"), "item": item}


def install_local_import_item(item, activate=False):
    path = resolve_addon_item(item["item_id"])["path"]
    classification = item.get("classification") or classify_local_bedrock_archive("import", path, file_extension(item.get("filename")))
    installed = []
    created = []
    try:
        if classification["kind"] in ("world", "template"):
            target_root = "world_templates" if classification["kind"] == "template" else "worlds"
            base_name = safe_download_name(os.path.splitext(item["filename"])[0], classification["kind"])
            dest_base, _ = resolve_safe_path(target_root, "/")
            dest = assert_safe_path(target_root, os.path.join(dest_base, base_name))
            if path_exists_root(target_root, dest): raise FileExistsError("Ziel existiert bereits; kein stilles Überschreiben.")
            makedirs_root(target_root, dest, exist_ok=False); created.append((target_root, dest))
            with zipfile.ZipFile(path, "r") as archive:
                for member in archive.infolist():
                    raw = str(member.filename or "").replace("\\", "/")
                    if not raw or raw.startswith("/") or raw.startswith("../") or "/../" in raw or zip_member_is_symlink(member): raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw)
                    target = assert_safe_path(target_root, os.path.join(dest, posixpath.normpath(raw)))
                    if member.is_dir(): makedirs_root(target_root, target, exist_ok=True); continue
                    makedirs_root(target_root, os.path.dirname(target), exist_ok=True)
                    with archive.open(member, "r") as src, open_safe(target_root, target, "wb") as out: shutil.copyfileobj(src, out, length=1024*1024)
            installed.append({"type": classification["kind"], "name": base_name, "active": False})
        else:
            with zipfile.ZipFile(path, "r") as archive:
                for pack in classification["packs"]:
                    root_key, base_dir = pack_base_dir(pack["type"])
                    pack_name = safe_download_name(pack.get("name"), pack["type"] + "-pack")
                    dest = assert_safe_path(root_key, os.path.join(base_dir, pack_name))
                    if path_exists_root(root_key, dest): raise FileExistsError("Pack-Ziel existiert bereits: %s" % pack_name)
                    prefix = posixpath.dirname(pack["manifest_path"])
                    makedirs_root(root_key, dest, exist_ok=False); created.append((root_key, dest))
                    for member in archive.infolist():
                        raw = str(member.filename or "").replace("\\", "/")
                        if prefix and not (raw == prefix or raw.startswith(prefix + "/")): continue
                        rel = posixpath.relpath(raw, prefix) if prefix else raw
                        if rel in (".", "") or raw.lower().startswith("__macosx/"): continue
                        if rel.startswith("../") or rel.startswith("/") or "/../" in rel or zip_member_is_symlink(member): raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw)
                        target = assert_safe_path(root_key, os.path.join(dest, rel))
                        if member.is_dir(): makedirs_root(root_key, target, exist_ok=True); continue
                        makedirs_root(root_key, os.path.dirname(target), exist_ok=True)
                        with archive.open(member, "r") as src, open_safe(root_key, target, "wb") as out: shutil.copyfileobj(src, out, length=1024*1024)
                    active = False
                    if activate:
                        activate_pack(pack["type"], "/" + pack_name); active = True
                    installed.append({"type": pack["type"], "name": pack_name, "uuid": pack.get("uuid"), "active": active})
        append_addon_history({"item_id": item["item_id"], "source_filename": item.get("filename"), "action": "install", "detected_name": item.get("name"), "detected_uuid": item.get("uuid"), "detected_version": item.get("version"), "detected_type": item.get("type"), "activated": activate, "result": "ok", "warnings": item.get("warnings", [])})
        return {"ok": True, "installed": installed, "message": "Lokaler Import wurde installiert."}
    except Exception:
        for root_key, dest in reversed(created):
            try:
                if path_is_dir_root(root_key, dest): shutil.rmtree(dest)
            except Exception as cleanup_exc: log_warning("Add-on Manager Cleanup fehlgeschlagen: %s" % cleanup_exc)
        raise


def apply_addon_action(item_id, action="install", activate=False, confirm=False):
    action = str(action or "install")
    plan = build_addon_plan(item_id, action, activate)
    assert_plan_confirmed(plan, confirm, "expert" if plan.get("risk") == "red" else "safe")
    item = plan["item"]
    if action in ("install", "update"):
        result = install_local_import_item(item, activate)
        result["plan"] = plan
        return result
    if action == "activate":
        if not item.get("uuid") or item.get("source") == "Importordner": raise ValueError("Aktivieren erfordert ein installiertes Pack.")
        pack = resolve_addon_item(item_id)
        result = activate_pack(pack.get("type", item.get("type")), pack.get("path", item.get("filename")))
        append_addon_history({"item_id": item_id, "action": "activate", "detected_uuid": item.get("uuid"), "detected_type": item.get("type"), "activated": True, "result": "ok", "warnings": item.get("warnings", [])})
        result["plan"] = plan
        return result
    if action == "remove_import":
        resolved = resolve_addon_item(item_id)
        remove_safe("import", resolved["path"])
        return {"ok": True, "plan": plan, "message": "Importdatei wurde entfernt."}
    raise ValueError("Unbekannte Add-on Manager Aktion: %s" % action)

def status_payload():
    env_keys = ["SERVER_NAME", "LEVEL_NAME", "VERSION", "BDS_AUTO_UPDATE", "SERVER_PORT", "SERVER_PORT_V6", "ENABLE_LAN_VISIBILITY", "ENABLE_BDS_V6BIND_FIX", "GAMEMODE", "DIFFICULTY", "ALLOW_CHEATS", "ALLOW_LIST", "ONLINE_MODE", "MAX_PLAYERS", "TEXTUREPACK_REQUIRED", "PACKAGE_BACKUP_KEEP"]
    env = {key: os.environ.get(key, "") for key in env_keys}
    metrics = {
        "players": player_metrics_from_log(env.get("MAX_PLAYERS", "")),
        "memory": read_meminfo_metrics(),
        "disk": disk_usage_metrics(),
        "loadavg": loadavg_metrics(),
        "log_size": human_bytes(runtime_getsize(runtime_log_path())) if runtime_path_exists(runtime_log_path()) else "-",
    }
    backups = list_backups(); return {"ok": True, "winomc_version": WINOMC_VERSION, "fifo_exists": runtime_path_exists(runtime_fifo_path()), "log_exists": runtime_path_exists(runtime_log_path()), "env": env, "roots": list_file_roots(), "metrics": metrics, "backup": {"latest": backups[0] if backups else None, "count": len(backups)}, "web_protection": read_web_protection_state(), "health": {"overall": diagnostics_payload().get("overall", "Nicht verfügbar")}, "world_safety": analyze_world_safety()}

def safe_header_value(value, fallback="application/octet-stream"):
    value = str(value or fallback)
    value = value.replace("\r", "").replace("\n", "").strip()
    return value or fallback


def safe_content_type(value, fallback="application/octet-stream"):
    value = safe_header_value(value, fallback)
    if re.match(r"^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*(?:\s*;\s*[A-Za-z0-9!#$&^_.+-]+=[A-Za-z0-9!#$&^_.+-]+)*$", value):
        return value
    return fallback


def safe_content_disposition_attachment(download_name):
    download_name = safe_download_name(download_name, "winomc-download")
    return "attachment; filename=\"%s\"; filename*=UTF-8''%s" % (download_name, quote(download_name, safe=""))

class Handler(BaseHTTPRequestHandler):
    server_version = "WinoMCConsole/2.0.0.10b"

    def log_message(self, fmt, *args):
        sys.stdout.write("[WinoMC Console] " + fmt % args + "\n")
        sys.stdout.flush()

    def _forbidden_if_needed(self):
        client_ip = self.client_address[0]
        if client_allowed(client_ip):
            return False
        self.send_response(403)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.end_headers()
        self.wfile.write(b"Forbidden\n")
        return True

    def _web_protection_active(self):
        # Server-persistenter Schutzstatus ist die Quelle der Wahrheit.
        # Der alte Cookie bleibt nur UI-Komfort und darf direkte API-Aufrufe nicht allein steuern.
        return bool(read_web_protection_state().get("enabled", False))

    def require_web_write_allowed(self, action_name):
        if self._web_protection_active():
            raise PermissionError("Diese Aktion ist durch den serverseitigen Webschutz gesperrt. Bitte Webschutz in der Dateiansicht entsperren: %s." % str(action_name or "Aktion"))

    def _read_json_payload(self, max_bytes=65536):
        return json.loads(self._read_request_body(max_bytes=max_bytes) or "{}")

    def _send_json(self, status, payload):
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(data)

    def _send_stream(self, handle, size, download_name=None, content_type=None, close_after=False):
        try:
            download_name = safe_download_name(download_name or "winomc-download")
            content_type = safe_content_type(content_type or "application/octet-stream")
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(int(size or 0)))
            self.send_header("Content-Disposition", safe_content_disposition_attachment(download_name))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            while True:
                chunk = handle.read(1024 * 1024)
                if not chunk:
                    break
                self.wfile.write(chunk)
        finally:
            if close_after:
                try:
                    handle.close()
                except OSError as exc:
                    log_warning("Download-Stream konnte nicht geschlossen werden: %s" % exc)

    def _send_root_download(self, root_key, rel_path):
        file_path, _ = resolve_safe_path(root_key, rel_path)
        if path_is_dir_root(root_key, file_path):
            raise ValueError("Ordner können nur als ZIP heruntergeladen werden.")
        if not path_is_file_root(root_key, file_path):
            raise FileNotFoundError("Datei nicht gefunden.")
        download_name = safe_download_name(os.path.basename(file_path), "winomc-download")
        content_type = safe_content_type(mimetypes.guess_type(download_name)[0])
        size = getsize_root(root_key, file_path)
        with open_safe(root_key, file_path, "rb") as handle:
            self._send_stream(handle, size, download_name=download_name, content_type=content_type, close_after=False)

    def _send_zip_info(self, zip_info):
        if zip_info.get("saved_to_export"):
            raise ValueError("Gespeicherte ZIP-Dateien werden nicht direkt gestreamt.")
        handle = zip_info["zip_file"]
        self._send_stream(
            handle,
            zip_info.get("zip_size", 0),
            download_name=zip_info.get("zip_name", "winomc-export.zip"),
            content_type="application/zip",
            close_after=True,
        )

    def _read_chunked_body(self, max_bytes):
        chunks = []
        total = 0
        while True:
            size_line = self.rfile.readline().strip()
            if not size_line:
                continue
            chunk_size = int(size_line.split(b";", 1)[0], 16)
            if chunk_size == 0:
                self.rfile.readline()
                break
            total += chunk_size
            if total > max_bytes:
                raise ValueError("Anfrage ist zu groß.")
            chunks.append(self.rfile.read(chunk_size))
            self.rfile.read(2)
        return b"".join(chunks)

    def _read_request_body(self, max_bytes=4096):
        content_length = self.headers.get("Content-Length") or self.headers.get("X-WinoMC-Body-Size")
        if content_length:
            length = int(content_length)
            if length > max_bytes:
                raise ValueError("Anfrage ist zu groß.")
            return self.rfile.read(length).decode("utf-8", errors="replace")
        if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
            return self._read_chunked_body(max_bytes).decode("utf-8", errors="replace")
        return ""

    def _write_request_body_to_file(self, root_key, target_path, max_bytes):
        target_path = assert_safe_path(root_key, target_path)
        content_length = self.headers.get("Content-Length")
        upload_size = self.headers.get("X-WinoMC-Upload-Size")
        parent = assert_safe_path(root_key, os.path.dirname(target_path), require_exists=True)
        makedirs_root(root_key, parent, exist_ok=True)
        fd, temp_path = mkstemp_root(root_key, parent, prefix=".winomc-upload-")
        os.close(fd)
        try:
            with open_safe(root_key, temp_path, "wb") as handle:
                if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
                    total = 0
                    while True:
                        size_line = self.rfile.readline().strip()
                        if not size_line:
                            continue
                        chunk_size = int(size_line.split(b";", 1)[0], 16)
                        if chunk_size == 0:
                            self.rfile.readline()
                            break
                        total += chunk_size
                        if total > max_bytes:
                            raise ValueError("Upload ist zu groß. Maximum: %s Bytes." % max_bytes)
                        handle.write(self.rfile.read(chunk_size))
                        self.rfile.read(2)
                else:
                    if not content_length and not upload_size:
                        raise ValueError("Upload ohne Content-Length wird nicht unterstützt. Aktualisiere die Web Console oder nutze den JSON-Fallback.")
                    remaining = int(content_length or upload_size)
                    if remaining < 0 or remaining > max_bytes:
                        raise ValueError("Upload ist zu groß. Maximum: %s Bytes." % max_bytes)
                    while remaining > 0:
                        chunk = self.rfile.read(min(1024 * 1024, remaining))
                        if not chunk:
                            raise ValueError("Upload wurde unerwartet beendet.")
                        handle.write(chunk)
                        remaining -= len(chunk)
            replace_safe(root_key, temp_path, target_path)
        except Exception:
            try:
                remove_safe(root_key, temp_path)
            except OSError as exc:
                log_warning("Temporäre Upload-Datei konnte nicht bereinigt werden: %s" % exc)
            raise

    def _extract_command(self):
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query)
        query_command = query.get("command", [""])[0]
        if query_command.strip():
            return query_command
        body = self._read_request_body()
        if not body:
            return ""
        content_type = self.headers.get("Content-Type", "").split(";", 1)[0].strip().lower()
        if content_type == "application/json":
            payload = json.loads(body or "{}")
            return str(payload.get("command", ""))
        if content_type == "application/x-www-form-urlencoded":
            return parse_qs(body).get("command", [""])[0]
        return body

    def do_GET(self):
        if self._forbidden_if_needed():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        query = parse_qs(parsed.query)
        if path.endswith("/diag") or path == "/diag":
            data = DIAG_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)
            return
        blocked_name = "leg" + "acy"
        if path.rstrip("/").split("/")[-1] == blocked_name:
            self.send_error(404)
            return
        if path in ("/", "", "/index.html"):
            data = INDEX_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)
            return
        if path.endswith("/api/status") or path == "/api/status":
            self._send_json(200, status_payload())
            return
        if path.endswith("/api/logs") or path == "/api/logs":
            self._stream_logs()
            return
        if path.endswith("/api/files/roots") or path == "/api/files/roots":
            self._send_json(200, {"ok": True, "roots": list_file_roots()})
            return
        if path.endswith("/api/web-protection") or path == "/api/web-protection":
            self._send_json(200, read_web_protection_state())
            return
        if path.endswith("/api/import/status") or path == "/api/import/status":
            self._send_json(200, read_import_status())
            return
        if path.endswith("/api/backups") or path == "/api/backups":
            self._send_json(200, {"ok": True, "backups": list_backups(), "keep": BACKUP_KEEP})
            return
        if path.endswith("/api/diagnostics") or path == "/api/diagnostics":
            self._send_json(200, diagnostics_payload())
            return
        if path.endswith("/api/packs") or path == "/api/packs":
            self._send_json(200, packs_payload())
            return
        if path.endswith("/api/players") or path == "/api/players":
            self._send_json(200, players_payload())
            return
        if path.endswith("/api/import-export") or path == "/api/import-export":
            self._send_json(200, import_export_payload())
            return
        if path.endswith("/api/update-guard") or path == "/api/update-guard":
            self._send_json(200, update_guard_payload())
            return
        if path.endswith("/api/profiles") or path == "/api/profiles":
            self._send_json(200, profiles_payload())
            return
        if path.endswith("/api/addons/overview") or path == "/api/addons/overview":
            self._send_json(200, addons_overview_payload())
            return
        if path.endswith("/api/addons/catalog") or path == "/api/addons/catalog":
            self._send_json(200, addons_catalog_payload(query))
            return
        if path.endswith("/api/addons/item") or path == "/api/addons/item":
            try:
                self._send_json(200, addons_item_payload(query.get("id", [""])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/list") or path == "/api/files/list":
            try:
                self._send_json(200, list_directory(query.get("root", ["config"])[0], query.get("path", ["/"])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/read") or path == "/api/files/read":
            try:
                self._send_json(200, read_text_file(query.get("root", ["config"])[0], query.get("path", ["/"])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/md5") or path == "/api/files/md5":
            try:
                self._send_json(200, file_md5_hash(query.get("root", ["config"])[0], query.get("path", ["/"])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/download") or path == "/api/files/download":
            try:
                if self._web_protection_active():
                    raise PermissionError("Download ist durch den Web-Schutz gesperrt. Bitte Web-Schutz entsperren.")
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                self._send_root_download(root_key, rel_path)
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                self.require_web_write_allowed("ZIP erstellen oder exportieren")
                if self._web_protection_active():
                    raise PermissionError("ZIP-Download ist durch den Web-Schutz gesperrt. Bitte Web-Schutz entsperren.")
                zip_info = create_zip_from_paths(query.get("root", ["config"])[0], [query.get("path", ["/"])[0]], save_to_export=False)
                self._send_zip_info(zip_info)
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/settings") or path == "/api/files/trash/settings":
            self._send_json(200, {"ok": True, "retention_days": get_trash_retention_days(), "allowed_days": [0, 3, 7, 14, 30, 60, 90]})
            return
        if "/api/" not in path and not os.path.splitext(path)[1]:
            data = INDEX_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)
            return
        self.send_error(404)

    def do_POST(self):
        if self._forbidden_if_needed():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        if path.endswith("/api/command") or path == "/api/command":
            try:
                command = sanitize_command(self._extract_command())
                write_command(command)
                self._send_json(200, {"ok": True, "command": command})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/web-protection") or path == "/api/web-protection":
