    const ACTION_BY_ID = Object.fromEntries(ACTIONS.map(action => [action.id, action]));
    const DEFAULT_DASHBOARD = ['list', 'say', 'time-day', 'weather-clear', 'coordinates-on', 'keepinventory-on', 'sleep-50', 'difficulty-normal', 'stop'];

    let history = JSON.parse(localStorage.getItem('winomcCommandHistory') || '[]');
    let historyIndex = history.length;
    let pendingTemplate = null;
    let dashboardActions = loadDashboard();
    let filesInitialized = false;
    let currentFileRoot = 'config';
    let currentFilePath = '/';
    let currentEditorFile = null;

    function appendLine(text, cls) {
      const div = document.createElement('div');
      div.className = 'line' + (cls ? ' ' + cls : '');
      div.textContent = text;
      const stick = log.scrollTop + log.clientHeight >= log.scrollHeight - 20;
      log.appendChild(div);
      while (log.children.length > 1600) log.removeChild(log.firstChild);
      if (stick) log.scrollTop = log.scrollHeight;
    }

    function saveHistory(command) {
      history = history.filter(item => item !== command);
      history.push(command);
      history = history.slice(-50);
      historyIndex = history.length;
      localStorage.setItem('winomcCommandHistory', JSON.stringify(history));
    }

    async function sendCommand(command) {
      command = String(command || '').trim();
      if (!command) return;
      appendLine('> ' + command, 'command');
      saveHistory(command);
      input.value = '';

      try {
        const endpoint = './api/command?command=' + encodeURIComponent(command);
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ command })
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          appendLine('Fehler: ' + (data.error || res.statusText), 'error');
        } else {
          appendLine('Befehl gesendet', 'ok');
        }
      } catch (err) {
        appendLine('Fehler beim Senden: ' + err.message, 'error');
      }
    }

    function runAction(action) {
      if (!action) return;
      if (action.confirm && !window.confirm(action.confirm)) return;
      if (action.template) {
        openPromptForAction(action);
        return;
      }
      sendCommand(action.command);
    }

    function openPromptForAction(action) {
      pendingTemplate = action.template;
      modalTitle.textContent = action.promptTitle || action.label || 'Wert eingeben';
      modalLabel.textContent = action.promptLabel || action.description || 'Bitte Wert eingeben.';
      modalInput.value = '';
      modalInput.placeholder = action.placeholder || '';
      modalBackdrop.classList.add('open');
      modalBackdrop.setAttribute('aria-hidden', 'false');
      setTimeout(() => modalInput.focus(), 0);
    }

    function closePrompt() {
      modalBackdrop.classList.remove('open');
      modalBackdrop.setAttribute('aria-hidden', 'true');
      pendingTemplate = null;
    }

    function sendPromptValue() {
      const value = modalInput.value.trim();
      if (!value || !pendingTemplate) return;
      const command = pendingTemplate.replaceAll('{value}', value);
      closePrompt();
      sendCommand(command);
    }

    function loadDashboard() {
      try {
        const saved = JSON.parse(localStorage.getItem(STORE_DASHBOARD) || 'null');
        if (Array.isArray(saved) && saved.length) {
          return saved.filter(id => ACTION_BY_ID[id]);
        }
      } catch (_) {}
      return [...DEFAULT_DASHBOARD];
    }

    function saveDashboard() {
      localStorage.setItem(STORE_DASHBOARD, JSON.stringify(dashboardActions));
    }

    function createButtonForAction(action, label) {
      const button = document.createElement('button');
      button.type = 'button';
      button.textContent = label || action.label;
      if (action.variant) button.classList.add(action.variant);
      button.addEventListener('click', () => runAction(action));
      return button;
    }

    function renderDashboard() {
      dashboardGrid.innerHTML = '';
      const columns = localStorage.getItem(STORE_COLUMNS) || 'auto';
      dashboardColumns.value = columns;
      dashboardGrid.classList.toggle('auto', columns === 'auto');
      if (columns === 'auto') {
        dashboardGrid.style.removeProperty('--dashboard-columns');
      } else {
        dashboardGrid.style.setProperty('--dashboard-columns', columns);
      }

      dashboardActions.forEach((id, index) => {
        const action = ACTION_BY_ID[id];
        if (!action) return;
        const tile = document.createElement('article');
        tile.className = 'tile';

        const top = document.createElement('div');
        top.className = 'tile-top';
        const text = document.createElement('div');
        const title = document.createElement('div');
        title.className = 'tile-title';
        title.textContent = action.label;
        const desc = document.createElement('div');
        desc.className = 'tile-desc';
        desc.textContent = action.description || '';
        text.appendChild(title);
        text.appendChild(desc);
        const tag = document.createElement('span');
        tag.className = 'category-label';
        tag.textContent = action.category;
        top.appendChild(text);
        top.appendChild(tag);

        const actionButton = createButtonForAction(action, action.template ? 'Ausführen…' : 'Ausführen');
        actionButton.classList.add('tile-action-main');

        const controls = document.createElement('div');
        controls.className = 'tile-actions';
        const up = document.createElement('button');
        up.type = 'button';
        up.textContent = '↑';
        up.title = 'Nach oben';
        up.disabled = index === 0;
        up.addEventListener('click', () => moveDashboardAction(index, -1));
        const down = document.createElement('button');
        down.type = 'button';
        down.textContent = '↓';
        down.title = 'Nach unten';
        down.disabled = index === dashboardActions.length - 1;
        down.addEventListener('click', () => moveDashboardAction(index, 1));
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.textContent = 'Entfernen';
        remove.className = 'ghost';
        remove.addEventListener('click', () => removeDashboardAction(id));
        controls.append(up, down, remove);

        tile.append(top, actionButton, controls);
        dashboardGrid.appendChild(tile);
      });

      renderActionPicker();
    }

    function renderActionPicker() {
      actionPicker.innerHTML = '';
      ACTIONS.forEach(action => {
        const item = document.createElement('div');
        item.className = 'picker-item';
        const meta = document.createElement('div');
        meta.className = 'picker-meta';
        const title = document.createElement('strong');
        title.textContent = action.label;
        const cat = document.createElement('span');
        cat.className = 'category-label';
        cat.textContent = action.category;
        meta.append(title, cat);
        const desc = document.createElement('div');
        desc.className = 'tile-desc';
        desc.textContent = action.description || '';
        const add = document.createElement('button');
        add.type = 'button';
        add.textContent = dashboardActions.includes(action.id) ? 'Bereits im Dashboard' : 'Hinzufügen';
        add.disabled = dashboardActions.includes(action.id);
        add.addEventListener('click', () => addDashboardAction(action.id));
        item.append(meta, desc, add);
        actionPicker.appendChild(item);
      });
    }

    function addDashboardAction(id) {
      if (!ACTION_BY_ID[id] || dashboardActions.includes(id)) return;
      dashboardActions.push(id);
      saveDashboard();
      renderDashboard();
    }

    function removeDashboardAction(id) {
      dashboardActions = dashboardActions.filter(item => item !== id);
      saveDashboard();
      renderDashboard();
    }

    function moveDashboardAction(index, direction) {
      const next = index + direction;
      if (next < 0 || next >= dashboardActions.length) return;
      [dashboardActions[index], dashboardActions[next]] = [dashboardActions[next], dashboardActions[index]];
      saveDashboard();
      renderDashboard();
    }

    function applyConsoleSize(size) {
      document.body.classList.toggle('console-compact', size === 'compact');
      document.body.classList.toggle('console-large', size === 'large');
      localStorage.setItem(STORE_CONSOLE_SIZE, size);
    }

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      sendCommand(input.value);
    });

    document.addEventListener('click', event => {
      const button = event.target.closest('[data-action-id]');
      if (!button) return;
      runAction(ACTION_BY_ID[button.dataset.actionId]);
    });

    document.querySelectorAll('[data-tab]').forEach(button => {
      button.addEventListener('click', () => {
        const tab = button.dataset.tab;
        document.querySelectorAll('[data-tab]').forEach(item => item.classList.toggle('active', item === button));
        document.querySelectorAll('[data-panel]').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab));

        if (tab === 'files') {
          initFileManager();
        }
      });
    });

    dashboardColumns.addEventListener('change', () => {
      localStorage.setItem(STORE_COLUMNS, dashboardColumns.value);
      renderDashboard();
    });

    resetDashboard.addEventListener('click', () => {
      dashboardActions = [...DEFAULT_DASHBOARD];
      saveDashboard();
      renderDashboard();
    });

    document.querySelectorAll('[data-console-size]').forEach(button => {
      button.addEventListener('click', () => applyConsoleSize(button.dataset.consoleSize));
    });

    clearLog.addEventListener('click', () => {
      log.innerHTML = '';
      appendLine('[WinoMC Console] Anzeige geleert. Der echte Server-Log bleibt erhalten.', 'ok');
    });

    fileRootSelect.addEventListener('change', () => {
      currentFileRoot = fileRootSelect.value;
      currentFilePath = '/';
      clearEditor();
      loadFileList('/');
    });

    fileRefresh.addEventListener('click', () => loadFileList(currentFilePath));

    fileParent.addEventListener('click', () => {
      loadFileList(parentUiPath(currentFilePath));
    });

    fileZipCurrent.addEventListener('click', () => {
      downloadZip(currentFilePath);
    });

    fileZipExportCurrent.addEventListener('click', () => {
      saveZipToExport(currentFilePath);
    });

    safeWorldExport.addEventListener('click', runSafeWorldExport);

    fileSave.addEventListener('click', saveEditorFile);
    fileCloseEditor.addEventListener('click', clearEditor);

    fileDropZone.addEventListener('click', () => fileUploadInput.click());

    fileUploadInput.addEventListener('change', () => {
      uploadFiles(fileUploadInput.files);
      fileUploadInput.value = '';
    });

    fileDropZone.addEventListener('dragover', event => {
      event.preventDefault();
      fileDropZone.classList.add('dragover');
    });

    fileDropZone.addEventListener('dragleave', () => {
      fileDropZone.classList.remove('dragover');
    });

    fileDropZone.addEventListener('drop', event => {
      event.preventDefault();
      fileDropZone.classList.remove('dragover');
      uploadFiles(event.dataTransfer.files);
    });
    
    modalCancel.addEventListener('click', closePrompt);
    modalSend.addEventListener('click', sendPromptValue);
    modalBackdrop.addEventListener('click', (event) => {
      if (event.target === modalBackdrop) closePrompt();
    });
    modalInput.addEventListener('keydown', event => {
      if (event.key === 'Enter') sendPromptValue();
      if (event.key === 'Escape') closePrompt();
    });

    input.addEventListener('keydown', event => {
      if (event.key === 'ArrowUp') {
        if (historyIndex > 0) historyIndex--;
        input.value = history[historyIndex] || input.value;
        event.preventDefault();
      }
      if (event.key === 'ArrowDown') {
        if (historyIndex < history.length) historyIndex++;
        input.value = history[historyIndex] || '';
        event.preventDefault();
      }
    });

    function apiUrl(path, params = {}) {
      const query = new URLSearchParams(params);
      const suffix = query.toString() ? '?' + query.toString() : '';
      return './' + path.replace(/^\/+/, '') + suffix;
    }

    async function fetchJson(path, params = {}) {
      const res = await fetch(apiUrl(path, params), { cache: 'no-store' });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || res.statusText);
      return data;
    }

    async function postJson(path, payload = {}) {
      const res = await fetch('./' + path.replace(/^\/+/, ''), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || res.statusText);
      return data;
    }

    function setFilesStatus(text, variant) {
      filesStatus.textContent = text;
      filesStatus.classList.toggle('warn', variant === 'warn');
    }

    function formatBytes(value) {
      const bytes = Number(value || 0);
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      if (bytes < 1024 * 1024 * 1024) return (bytes / 1024 / 1024).toFixed(1) + ' MB';
      return (bytes / 1024 / 1024 / 1024).toFixed(1) + ' GB';
    }

    function formatUnixTime(value) {
      if (!value) return '-';
      return new Date(Number(value) * 1000).toLocaleString();
    }

    function normalizeUiPath(path) {
      path = String(path || '/').replaceAll('\\', '/');
      if (!path.startsWith('/')) path = '/' + path;
      path = path.replace(/\/+/g, '/');
      return path || '/';
    }

    function parentUiPath(path) {
      path = normalizeUiPath(path);
      if (path === '/') return '/';
      const parts = path.split('/').filter(Boolean);
      parts.pop();
      return '/' + parts.join('/');
    }

    async function initFileManager() {
      if (filesInitialized) {
        await loadFileList();
        return;
      }

      filesInitialized = true;

      try {
        setFilesStatus('Lade Bereiche...', 'warn');
        const data = await fetchJson('/api/files/roots');

        fileRootSelect.innerHTML = '';
        data.roots.forEach(root => {
          const option = document.createElement('option');
          option.value = root.key;
          option.textContent = root.label + (root.exists ? '' : ' (fehlt)');
          option.disabled = !root.exists || !root.readable;
          fileRootSelect.appendChild(option);
        });

        if ([...fileRootSelect.options].some(option => option.value === currentFileRoot && !option.disabled)) {
          fileRootSelect.value = currentFileRoot;
        } else {
          const firstEnabled = [...fileRootSelect.options].find(option => !option.disabled);
          currentFileRoot = firstEnabled ? firstEnabled.value : 'config';
          fileRootSelect.value = currentFileRoot;
        }

        await loadFileList();
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>';
      }
    }

    async function loadFileList(path) {
      if (path !== undefined) currentFilePath = normalizeUiPath(path);
      currentFileRoot = fileRootSelect.value || currentFileRoot;

      try {
        setFilesStatus('Lade...', 'warn');
        fileCurrentPath.textContent = currentFileRoot + ':' + currentFilePath;

        const data = await fetchJson('/api/files/list', {
          root: currentFileRoot,
          path: currentFilePath
        });

        currentFilePath = data.path || '/';
        fileCurrentPath.textContent = currentFileRoot + ':' + currentFilePath;
        fileParent.disabled = currentFilePath === '/';

        renderFileEntries(data.entries || []);
        setFilesStatus('Bereit', '');
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>';
      }
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function renderFileEntries(entries) {
      if (!entries.length) {
        fileTableBody.innerHTML = '<tr><td colspan="5">Dieser Ordner ist leer.</td></tr>';
        return;
      }

      fileTableBody.innerHTML = '';

      entries.forEach(entry => {
        const tr = document.createElement('tr');

        const nameTd = document.createElement('td');
        const nameButton = document.createElement('button');
        nameButton.type = 'button';
        nameButton.className = 'file-name-button';
        nameButton.textContent = (entry.type === 'directory' ? '📁 ' : '📄 ') + entry.name;
        nameButton.addEventListener('click', () => {
          if (entry.type === 'directory') {
            loadFileList(entry.path);
          } else {
            openFileInEditor(entry.path);
          }
        });
        nameTd.appendChild(nameButton);

        const typeTd = document.createElement('td');
        typeTd.textContent = entry.type === 'directory' ? 'Ordner' : 'Datei';

        const sizeTd = document.createElement('td');
        sizeTd.textContent = entry.type === 'directory' ? '-' : formatBytes(entry.size);

        const modifiedTd = document.createElement('td');
        modifiedTd.textContent = formatUnixTime(entry.modified);

        const actionsTd = document.createElement('td');
        const actions = document.createElement('div');
        actions.className = 'file-row-actions';

        if (entry.type === 'directory') {
          const open = document.createElement('button');
          open.type = 'button';
          open.textContent = 'Öffnen';
          open.addEventListener('click', () => loadFileList(entry.path));
          actions.appendChild(open);

          const zip = document.createElement('button');
          zip.type = 'button';
          zip.textContent = 'ZIP';
          zip.addEventListener('click', () => downloadZip(entry.path));
          actions.appendChild(zip);
        } else {
          const download = document.createElement('button');
          download.type = 'button';
          download.textContent = 'Download';
          download.addEventListener('click', () => downloadFile(entry.path));
          actions.appendChild(download);

          const edit = document.createElement('button');
          edit.type = 'button';
          edit.textContent = 'Editor';
          edit.addEventListener('click', () => openFileInEditor(entry.path));
          actions.appendChild(edit);

          if (entry.name.toLowerCase().endsWith('.zip')) {
            const unzip = document.createElement('button');
            unzip.type = 'button';
            unzip.textContent = 'Entpacken';
            unzip.addEventListener('click', () => unzipFile(entry.path));
            actions.appendChild(unzip);
          }
        }

        actionsTd.appendChild(actions);
        tr.append(nameTd, typeTd, sizeTd, modifiedTd, actionsTd);
        fileTableBody.appendChild(tr);
      });
    }

    function downloadFile(path) {
      window.location.href = apiUrl('/api/files/download', {
        root: currentFileRoot,
        path
      });
    }

    function downloadZip(path) {
      window.location.href = apiUrl('/api/files/zip', {
        root: currentFileRoot,
        path
      });
    }

    async function saveZipToExport(path) {
      try {
        setFilesStatus('Erstelle ZIP...', 'warn');
        const data = await postJson('/api/files/zip', {
          root: currentFileRoot,
          paths: [path],
          save_to_export: true
        });
        appendLine('[WinoMC Dateien] ZIP exportiert: ' + data.filename, 'ok');
        setFilesStatus('ZIP exportiert', '');
        await loadFileList();
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] ZIP-Fehler: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function openFileInEditor(path) {
      try {
        setFilesStatus('Öffne Datei...', 'warn');
        const data = await fetchJson('/api/files/read', {
          root: currentFileRoot,
          path
        });

        currentEditorFile = {
          root: data.root,
          path: data.path
        };

        editorPath.textContent = data.root + ':' + data.path;
        editorMeta.textContent = formatBytes(data.size) + ' · geändert: ' + formatUnixTime(data.modified) + (data.json ? ' · JSON-Prüfung aktiv' : '');
        fileEditor.value = data.content || '';
        setFilesStatus('Datei geöffnet', '');
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Editor-Fehler: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function saveEditorFile() {
      if (!currentEditorFile) {
        alert('Keine Datei geöffnet.');
        return;
      }

      try {
        setFilesStatus('Speichere...', 'warn');
        const data = await postJson('/api/files/write', {
          root: currentEditorFile.root,
          path: currentEditorFile.path,
          content: fileEditor.value
        });

        appendLine('[WinoMC Dateien] Datei gespeichert: ' + currentEditorFile.path, 'ok');

        if (data.backup_created) {
          appendLine('[WinoMC Dateien] Backup erstellt: ' + data.backup_path, 'ok');
        }

        setFilesStatus('Gespeichert', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Speichern fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    function clearEditor() {
      currentEditorFile = null;
      editorPath.textContent = 'Keine Datei geöffnet';
      editorMeta.textContent = 'Bereit';
      fileEditor.value = '';
    }

    async function uploadFiles(files) {
      files = Array.from(files || []);
      if (!files.length) return;

      for (const file of files) {
        try {
          setFilesStatus('Upload: ' + file.name, 'warn');

          const res = await fetch(apiUrl('/api/files/upload', {
            root: currentFileRoot,
            path: currentFilePath,
            filename: file.name,
            overwrite: 'false'
          }), {
            method: 'POST',
            headers: { 'Content-Type': 'application/octet-stream' },
            body: file
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            throw new Error(data.error || res.statusText);
          }

          appendLine('[WinoMC Dateien] Hochgeladen: ' + data.path, 'ok');
        } catch (err) {
          appendLine('[WinoMC Dateien] Upload fehlgeschlagen: ' + file.name + ' · ' + err.message, 'error');
          alert('Upload fehlgeschlagen: ' + file.name + '\n\n' + err.message);
        }
      }

      setFilesStatus('Upload fertig', '');
      await loadFileList(currentFilePath);
    }

    async function unzipFile(path) {
      const destination = window.prompt('In welchen Ordner entpacken?', currentFilePath || '/');
      if (destination === null) return;

      const overwrite = window.confirm('Vorhandene Dateien überschreiben?');

      try {
        setFilesStatus('Entpacke ZIP...', 'warn');
        const data = await postJson('/api/files/unzip', {
          root: currentFileRoot,
          path,
          destination,
          overwrite
        });

        appendLine('[WinoMC Dateien] ZIP entpackt: ' + data.files + ' Dateien', 'ok');
        setFilesStatus('ZIP entpackt', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Entpacken fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function runSafeWorldExport() {
      const worldPath = window.prompt('Welche Welt sicher exportieren?', '/world');
      if (!worldPath) return;

      if (!window.confirm('Sicheren Welt-Export starten?\n\nAblauf: save hold → save query → ZIP → save resume')) {
        return;
      }

      try {
        setFilesStatus('Welt-Export läuft...', 'warn');
        const data = await postJson('/api/worlds/export-safe', {
          path: worldPath,
          save_to_export: true
        });

        appendLine('[WinoMC Dateien] Sicherer Welt-Export erstellt: ' + data.filename, 'ok');
        setFilesStatus('Welt exportiert', '');

        if (currentFileRoot === 'export') {
          await loadFileList('/');
        }
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Welt-Export fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    function connectLogs() {
      const source = new EventSource('./api/logs');
      source.onopen = () => {
        statusEl.textContent = 'Live verbunden';
        statusDot.classList.add('ok');
      };
      source.onmessage = event => {
        try {
          const data = JSON.parse(event.data);
          if (data.line) appendLine(data.line);
        } catch (_) {}
      };
      source.onerror = () => {
        statusEl.textContent = 'Verbindung wird neu aufgebaut...';
        statusDot.classList.remove('ok');
      };
    }

    applyConsoleSize(localStorage.getItem(STORE_CONSOLE_SIZE) || 'normal');
    renderDashboard();
    connectLogs();
  </script>
</body>
</html>
"""


def client_allowed(client_ip: str) -> bool:
    if not ALLOWED_PROXIES:
        return True
    return client_ip in ALLOWED_PROXIES


def read_recent_lines(path: str, limit: int):
    lines = deque(maxlen=max(1, limit))
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                lines.append(line.rstrip("\n"))
    except FileNotFoundError:
        return []
    return list(lines)


def sanitize_command(command: str) -> str:
    command = command.replace("\x00", "").strip()
    if command.startswith("/"):
        command = command[1:].strip()
    command = "".join(ch for ch in command if ch == "\t" or ord(ch) >= 32)
    if len(command) > MAX_COMMAND_LENGTH:
        raise ValueError(f"Befehl ist zu lang. Maximum: {MAX_COMMAND_LENGTH} Zeichen.")
    if not command:
        raise ValueError("Leerer Befehl.")
    return command


def write_command(command: str):
    if not os.path.exists(FIFO_PATH):
        raise RuntimeError("Console FIFO existiert noch nicht. Läuft der Bedrock Server bereits?")
    if not os.path.exists(LOG_PATH):
        open(LOG_PATH, "a", encoding="utf-8").close()

    fd = os.open(FIFO_PATH, os.O_WRONLY | os.O_NONBLOCK)
    try:
        os.write(fd, (command + "\n").encode("utf-8"))
    finally:
        os.close(fd)

    with open(LOG_PATH, "a", encoding="utf-8", errors="replace") as log_handle:
        log_handle.write(f"[WinoMC Console] > {command}\n")


class Handler(BaseHTTPRequestHandler):
    server_version = "WinoMCConsole/1.0"

    def log_message(self, fmt, *args):
        sys.stdout.write("[WinoMC Console] " + fmt % args + "\n")
        sys.stdout.flush()

    def _forbidden_if_needed(self) -> bool:
        client_ip = self.client_address[0]
        if client_allowed(client_ip):
            return False
        self.send_response(403)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.end_headers()
        self.wfile.write(b"Forbidden\n")
        return True

    def _send_json(self, status: int, payload: dict):
        data = json.dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _send_file(self, file_path: str, download_name: str | None = None, content_type: str | None = None, cleanup: bool = False):
        try:
            if not os.path.isfile(file_path):
                raise FileNotFoundError("Datei nicht gefunden.")

            download_name = safe_download_name(download_name or os.path.basename(file_path))
            content_type = content_type or mimetypes.guess_type(file_path)[0] or "application/octet-stream"
            size = os.path.getsize(file_path)

            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(size))
            self.send_header(
                "Content-Disposition",
                f"attachment; filename=\"{download_name}\"; filename*=UTF-8''{quote(download_name)}",
            )
            self.send_header("Cache-Control", "no-store")
            self.end_headers()

            with open(file_path, "rb") as handle:
                while True:
                    chunk = handle.read(1024 * 1024)
                    if not chunk:
                        break
                    self.wfile.write(chunk)

        finally:
            if cleanup:
                try:
                    os.remove(file_path)
                except OSError:
                    pass

    def _read_request_body(self, max_bytes: int = 4096) -> str:
        """Read a small request body.

        Home-Assistant-Ingress may proxy POST requests without a normal
        Content-Length header. The UI therefore also sends the command as
        query parameter, but this keeps JSON/form/plain-text bodies working.
        """
        content_length = self.headers.get("Content-Length")
        if content_length:
            length = int(content_length)
            if length > max_bytes:
                raise ValueError("Anfrage ist zu groß.")
            return self.rfile.read(length).decode("utf-8", errors="replace")

        if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
            chunks = []
            total = 0
            while True:
                size_line = self.rfile.readline().strip()
                if not size_line:
                    continue
                chunk_size = int(size_line.split(b";", 1)[0], 16)
                if chunk_size == 0:
                    self.rfile.readline()
                    break
                total += chunk_size
                if total > max_bytes:
                    raise ValueError("Anfrage ist zu groß.")
                chunks.append(self.rfile.read(chunk_size))
                self.rfile.read(2)
            return b"".join(chunks).decode("utf-8", errors="replace")

        return ""

    def _write_request_body_to_file(self, target_path: str, max_bytes: int):
        content_length = self.headers.get("Content-Length")

        if not content_length:
            raise ValueError("Upload ohne Content-Length wird nicht unterstützt.")

        try:
            remaining = int(content_length)
        except ValueError:
            raise ValueError("Ungültige Upload-Größe.")

        if remaining < 0:
            raise ValueError("Ungültige Upload-Größe.")

        if remaining > max_bytes:
            raise ValueError(f"Upload ist zu groß. Maximum: {max_bytes} Bytes.")

        parent = os.path.dirname(target_path)
        os.makedirs(parent, exist_ok=True)

        fd, temp_path = tempfile.mkstemp(prefix=".winomc-upload-", dir=parent)
        os.close(fd)

        try:
            with open(temp_path, "wb") as handle:
                while remaining > 0:
                    chunk = self.rfile.read(min(1024 * 1024, remaining))

                    if not chunk:
                        raise ValueError("Upload wurde unerwartet beendet.")

                    handle.write(chunk)
                    remaining -= len(chunk)

            os.replace(temp_path, target_path)

        except Exception:
            try:
                os.remove(temp_path)
            except OSError:
                pass
            raise

    def _extract_command(self) -> str:
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query)
        query_command = query.get("command", [""])[0]
        if query_command.strip():
            return query_command

        body = self._read_request_body()
        if not body:
            return ""

        content_type = self.headers.get("Content-Type", "").split(";", 1)[0].strip().lower()
        if content_type == "application/json":
            payload = json.loads(body or "{}")
            return str(payload.get("command", ""))
        if content_type == "application/x-www-form-urlencoded":
            return parse_qs(body).get("command", [""])[0]
        return body

    def do_GET(self):
        if self._forbidden_if_needed():
            return

        parsed = urlparse(self.path)
        path = parsed.path
        query = parse_qs(parsed.query)

        if path in ("/", "", "/index.html"):
            data = INDEX_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)
            return

        if path.endswith("/api/status") or path == "/api/status":
            self._send_json(200, {
                "ok": True,
                "fifo_exists": os.path.exists(FIFO_PATH),
                "log_exists": os.path.exists(LOG_PATH),
            })
            return

        if path.endswith("/api/logs") or path == "/api/logs":
            self._stream_logs()
            return

        if path.endswith("/api/files/roots") or path == "/api/files/roots":
            self._send_json(200, {
                "ok": True,
                "roots": list_file_roots(),
            })
            return

        if path.endswith("/api/files/list") or path == "/api/files/list":
            try:
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                self._send_json(200, list_directory(root_key, rel_path))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/read") or path == "/api/files/read":
            try:
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                self._send_json(200, read_text_file(root_key, rel_path))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/download") or path == "/api/files/download":
            try:
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                file_path, normalized_rel_path = resolve_safe_path(root_key, rel_path)

                if os.path.isdir(file_path):
                    raise ValueError("Ordner können nur als ZIP heruntergeladen werden.")

                download_name = os.path.basename(file_path)
                self._send_file(file_path, download_name=download_name)
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                zip_info = create_zip_from_paths(root_key, [rel_path], save_to_export=False)
                self._send_file(
                    zip_info["zip_path"],
                    download_name=zip_info["zip_name"],
                    content_type="application/zip",
                    cleanup=zip_info["cleanup"],
                )
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        self.send_error(404)

    def do_POST(self):
        if self._forbidden_if_needed():
            return

        parsed = urlparse(self.path)
        path = parsed.path

        if path.endswith("/api/command") or path == "/api/command":
            try:
                command = sanitize_command(self._extract_command())
                write_command(command)
                self._send_json(200, {"ok": True, "command": command})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/upload") or path == "/api/files/upload":
            try:
                query = parse_qs(parsed.query)

                root_key = query.get("root", ["import"])[0]
                dir_rel_path = query.get("path", ["/"])[0]
                filename = query.get("filename", ["upload.bin"])[0]
                overwrite = parse_bool(query.get("overwrite", ["false"])[0], default=False)

                target_path, target_rel_path = prepare_upload_target(
                    root_key,
                    dir_rel_path,
                    filename,
                    overwrite=overwrite,
                )

                backup_path = None
                if os.path.exists(target_path):
                    backup_path = make_file_backup(target_path, root_key, target_rel_path)

                self._write_request_body_to_file(target_path, MAX_UPLOAD_BYTES)

                self._send_json(200, {
                    "ok": True,
                    "root": root_key,
                    "path": target_rel_path,
                    "filename": os.path.basename(target_path),
                    "backup_created": bool(backup_path),
                    "backup_path": backup_path,
                    "message": "Datei hochgeladen.",
                })
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/write") or path == "/api/files/write":
            try:
                body = self._read_request_body(max_bytes=MAX_TEXT_FILE_BYTES + 65536)
                payload = json.loads(body or "{}")

                root_key = str(payload.get("root", "config"))
                rel_path = str(payload.get("path", "/"))
                content = str(payload.get("content", ""))

                self._send_json(200, write_text_file(root_key, rel_path, content))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/unzip") or path == "/api/files/unzip":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")

                root_key = str(payload.get("root", "import"))
                archive_path = str(payload.get("path", "/"))
                destination = str(payload.get("destination", "/"))
                overwrite = bool(payload.get("overwrite", False))

                self._send_json(200, extract_zip_file(
                    root_key,
                    archive_path,
                    destination_rel_path=destination,
                    overwrite=overwrite,
                ))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/worlds/export-safe") or path == "/api/worlds/export-safe":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")

                world_path = str(payload.get("path", "/world"))
                save_to_export = bool(payload.get("save_to_export", True))

                zip_info = create_safe_world_export(world_path, save_to_export=save_to_export)

                if save_to_export:
                    self._send_json(200, {
                        "ok": True,
                        "saved_to_export": True,
                        "root": "export",
                        "path": zip_info["export_path"],
                        "filename": zip_info["zip_name"],
                        "message": "Sicherer Welt-Export wurde nach /share/winomc/export gespeichert.",
                    })
                    return

                self._send_file(
                    zip_info["zip_path"],
                    download_name=zip_info["zip_name"],
                    content_type="application/zip",
                    cleanup=zip_info["cleanup"],
                )
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")

                root_key = str(payload.get("root", "config"))
                rel_paths = payload.get("paths")

                if not isinstance(rel_paths, list) or not rel_paths:
                    rel_paths = [str(payload.get("path", "/"))]

                rel_paths = [str(item) for item in rel_paths]
                save_to_export = bool(payload.get("save_to_export", False))

                zip_info = create_zip_from_paths(root_key, rel_paths, save_to_export=save_to_export)

                if save_to_export:
                    self._send_json(200, {
                        "ok": True,
                        "saved_to_export": True,
                        "root": "export",
                        "path": zip_info["export_path"],
                        "filename": zip_info["zip_name"],
                    })
                    return

                self._send_file(
                    zip_info["zip_path"],
                    download_name=zip_info["zip_name"],
                    content_type="application/zip",
                    cleanup=zip_info["cleanup"],
                )
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return

        self.send_error(404)

    def _sse_send(self, payload: dict):
        data = json.dumps(payload, ensure_ascii=False)
        self.wfile.write(f"data: {data}\n\n".encode("utf-8"))
        self.wfile.flush()

    def _stream_logs(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()

        for line in read_recent_lines(LOG_PATH, HISTORY_LIMIT):
            self._sse_send({"line": line})

        position = 0
        try:
            position = os.path.getsize(LOG_PATH)
        except OSError:
            position = 0

        last_heartbeat = time.time()
        while True:
            try:
                size = os.path.getsize(LOG_PATH)
                if size < position:
                    position = 0

                if size > position:
                    with open(LOG_PATH, "r", encoding="utf-8", errors="replace") as handle:
                        handle.seek(position)
                        for line in handle:
                            self._sse_send({"line": line.rstrip("\n")})
                        position = handle.tell()

                if time.time() - last_heartbeat > 15:
                    self.wfile.write(b": heartbeat\n\n")
                    self.wfile.flush()
                    last_heartbeat = time.time()

                time.sleep(0.5)
            except (BrokenPipeError, ConnectionResetError):
                break
            except Exception as exc:
                try:
                    self._sse_send({"line": f"[WinoMC Console] Log Stream Fehler: {exc}"})
                except Exception:
                    break
                time.sleep(1)


def main():
    os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
    open(LOG_PATH, "a", encoding="utf-8").close()

    httpd = ThreadingHTTPServer((HOST, PORT), Handler)

    def shutdown(_signum, _frame):
        httpd.shutdown()

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    print(f"[WinoMC Console] Web console listening on {HOST}:{PORT}", flush=True)
    httpd.serve_forever(poll_interval=0.5)


if __name__ == "__main__":
    main()
