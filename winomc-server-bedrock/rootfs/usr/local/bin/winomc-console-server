    window.__commandSuggestionSelecting = false;
    form?.addEventListener('submit', event => {
      if (window.__commandSuggestionSelecting) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
    }, true);

    function fillCommandFromSuggestion(command) {
      window.__commandSuggestionSelecting = true;
      input.value = String(command || '').replace(/^\//, '');
      input.focus({ preventScroll: true });
      const pos = input.value.length;
      try { input.setSelectionRange(pos, pos); } catch (_) {}
      window.setTimeout(() => { window.__commandSuggestionSelecting = false; }, 650);
    }

    initCommandAssistant = function() {
      if (!input || !form) return;
      document.getElementById('commandAssistant')?.remove();
      const assistant = document.createElement('div');
      assistant.id = 'commandAssistant';
      assistant.className = 'console-assistant';
      assistant.innerHTML = '<div class="console-assistant-title">Befehlshilfe <span class="badge">Ãœbernehmen, nicht senden</span></div><div class="command-suggestion-list" id="commandSuggestionList"></div>';
      document.body.appendChild(assistant);
      const list = assistant.querySelector('#commandSuggestionList');
      function hide() { assistant.classList.remove('open'); }
      function score(item, term) {
        const needle = term.toLowerCase().replace(/^\//, '');
        const cmd = String(item.cmd || '').toLowerCase();
        const title = String(item.title || '').toLowerCase();
        const group = String(item.group || '').toLowerCase();
        if (cmd === needle) return 0;
        if (cmd.startsWith(needle)) return 1;
        if (cmd.includes(' ' + needle) || cmd.includes(needle)) return 2;
        if (title.includes(needle)) return 3;
        if (group.includes(needle)) return 4;
        return 99;
      }
      function commandMatchesFull(item, term) {
        const hay = [item.cmd, item.title, item.group].join(' ').toLowerCase();
        return hay.includes(term.toLowerCase().replace(/^\//, ''));
      }
      function render() {
        const term = input.value.trim();
        if (!term || term.length < 1 || document.body.classList.contains('console-collapsed') || document.body.classList.contains('console-hidden')) { hide(); return; }
        const matches = BEDROCK_COMMAND_CATALOG
          .filter(item => commandMatchesFull(item, term))
          .sort((a,b) => score(a, term) - score(b, term) || String(a.cmd).localeCompare(String(b.cmd)))
          .slice(0, 12);
        if (!matches.length) { hide(); return; }
        list.innerHTML = '';
        matches.forEach(item => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'command-suggestion' + (item.template ? ' is-template' : '');
          btn.setAttribute('aria-label', 'Befehl Ã¼bernehmen: ' + item.cmd);
          btn.innerHTML = '<span><code>' + escapeHtml(item.cmd) + '</code><small>' + escapeHtml(item.title) + '</small></span><button type="button" class="command-insert-button primary">EinfÃ¼gen</button>';
          let touchStartY = 0;
          btn.addEventListener('touchstart', event => { touchStartY = event.touches?.[0]?.clientY || 0; }, { passive: true });
          const apply = event => {
            event.preventDefault();
            event.stopPropagation();
            fillCommandFromSuggestion(item.cmd);
            hide();
          };
          btn.querySelector('.command-insert-button')?.addEventListener('click', apply);
          btn.addEventListener('click', event => { if (!event.target.closest('.command-insert-button')) apply(event); });
          btn.addEventListener('touchend', event => { const endY = event.changedTouches?.[0]?.clientY || touchStartY; if (Math.abs(endY - touchStartY) > 10) return; if (!event.target.closest('.command-insert-button')) apply(event); }, { passive: false });
          list.appendChild(btn);
        });
        assistant.classList.add('open');
      }
      input.addEventListener('input', render);
      input.addEventListener('focus', render);
      input.addEventListener('blur', () => window.setTimeout(() => { if (!window.__commandSuggestionSelecting) hide(); }, 240));
    };

