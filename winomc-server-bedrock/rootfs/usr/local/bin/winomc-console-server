  <script data-version="2.0.0.10b">
  (() => {
    'use strict';
    const VERSION = '2.0.0.10b';
    const MAX_LOG_LINES = 400;
    const state = { safe: new URLSearchParams(location.search).get('safe') === '1', active: 'overview', api: null, es: null, logBuffer: [], logFlush: 0, modules: new Map(), errors: [], logRetry: 0, logReconnectTimer: null, filePath: '/' };
    const $ = (sel, root=document) => root.querySelector(sel);
    const esc = value => String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
    function bootStep(text, level='ok') { const list = $('#bootSteps'); if (list) list.insertAdjacentHTML('beforeend', `<li class="wmc-${level}">${esc(new Date().toLocaleTimeString())} · ${esc(text)}</li>`); }
    function showError(scope, err) { const message = err && (err.message || String(err)) || 'Unbekannter Fehler'; state.errors.push({scope,message}); const box = $('#globalErrors'); if (box) { box.hidden = false; box.insertAdjacentHTML('beforeend', `<div><b>${esc(scope)}:</b> ${esc(message)}</div>`); } const safeScope = String(scope).replace(/[^a-z0-9_-]/gi, ''); const target = document.querySelector(`[data-module-error="${safeScope}"]`); if (target) target.insertAdjacentHTML('afterbegin', `<div class="wmc-card wmc-error"><b>${esc(scope)} Fehler</b><p>${esc(message)}</p></div>`); bootStep(`${scope}: ${message}`, 'bad'); }
    function guarded(name, fn) { try { const result = fn(); if (result && typeof result.catch === 'function') result.catch(err => showError(name, err)); return result; } catch (err) { showError(name, err); return null; } }
    window.addEventListener('error', ev => showError('JavaScript', ev.message || ev.error));
    window.addEventListener('unhandledrejection', ev => showError('Promise', ev.reason));
    function apiUrl(path, params = {}) { const q = new URLSearchParams(params); return './' + String(path).replace(/^\/+/, '') + (q.toString() ? '?' + q.toString() : ''); }
    function renderBaseShell() {
      document.body.className = state.safe ? 'wmc-safe wmc-classic' : 'wmc-classic';
      document.body.innerHTML = `
        <header class="wmc-header"><div><div class="wmc-title">WinoMC Console</div><div class="wmc-muted">Beta ${VERSION} · robuste Webconsole-App-Shell</div></div><div class="wmc-actions"><button id="reloadBtn">Neu laden</button><a class="wmc-btn" href="./diag">Diagnose</a><a class="wmc-btn warn" href="./?safe=1">Safe Mode</a><button id="classicBtn">PC klassisch</button><button id="mobileBtn">Mobile</button><button id="desktopBtn">Desktop</button></div></header>
        <div class="wmc-layout"><nav class="wmc-nav" aria-label="WinoMC Navigation" id="nav"></nav><main class="wmc-main">
          ${state.safe ? '<section class="wmc-card wmc-warn"><b>Safe Mode aktiv</b><p>Desktop, Explorer, Profile, Add-on Manager, Webschutz, Live-Log-SSE und Polling sind deaktiviert. Nur Shell und ein manueller Status-Test laufen.</p></section>' : ''}
          <section class="wmc-card"><h2>Boot-Diagnose</h2><ol id="bootSteps"><li>HTML geladen</li><li>CSS geladen</li><li>JavaScript gestartet</li><li>App-Shell gerendert</li></ol><div id="globalErrors" class="wmc-card wmc-error" hidden><b>Fehlerbereich</b></div></section>
          <section id="panel-overview" class="wmc-panel active" data-panel="overview"><h2>Übersicht / Serverstatus</h2><div id="statusArea" data-module-error="status"><div class="wmc-card">Status wird asynchron geladen...</div></div></section>
          <section id="panel-console" class="wmc-panel" data-panel="console"><h2>Live-Konsole</h2><div id="consoleArea" data-module-error="console"></div></section>
          <section id="panel-files" class="wmc-panel" data-panel="files"><h2>Dateien / Explorer</h2><div id="filesArea" data-module-error="files"><div class="wmc-card">Dateimodul wird erst beim Öffnen geladen.</div></div></section>
          <section id="panel-profiles" class="wmc-panel" data-panel="profiles"><h2>Erststart / Profile</h2><div id="profilesArea" data-module-error="profiles"><div class="wmc-card">Profile werden erst beim Öffnen geladen.</div></div></section>
          <section id="panel-addons" class="wmc-panel" data-panel="addons"><h2>Add-on Manager</h2><div id="addonsArea" data-module-error="addons"><div class="wmc-card">Add-on Manager wird erst beim Öffnen geladen.</div></div></section>
          <section id="panel-webprotection" class="wmc-panel" data-panel="webprotection"><h2>Webschutz</h2><div id="webProtectionArea" data-module-error="webprotection"><div class="wmc-card">Webschutz wird erst beim Öffnen geladen.</div></div></section>
          <section id="panel-diagnostics" class="wmc-panel" data-panel="diagnostics"><h2>Diagnose</h2><div id="diagnosticsArea"></div></section>
        </main></div>`;
      bootStep('Navigation wird sichtbar');
    }
    function initApiClient() {
      state.api = {
        url: apiUrl,
        async request(path, options = {}, timeout = 8000) {
          const controller = new AbortController();
          const timer = setTimeout(() => controller.abort(), timeout);
          try {
            const res = await fetch(apiUrl(path, options.params || {}), { cache:'no-store', ...options, signal: controller.signal });
            const text = await res.text();
            let data = {};
            try { data = text ? JSON.parse(text) : {}; } catch { throw new Error(`Ungültige JSON-Antwort von ${path}: HTTP ${res.status}`); }
            if (!res.ok || data.ok === false) throw new Error(data.error || res.statusText || `HTTP ${res.status}`);
            return data;
          } catch (err) {
            if (err.name === 'AbortError') throw new Error(`Zeitüberschreitung bei ${path}`);
            throw err;
          } finally { clearTimeout(timer); }
        },
        get(path, params, timeout) { return this.request(path, { params }, timeout); },
        post(path, payload, timeout) { return this.request(path, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload || {}) }, timeout); }
      };
      bootStep('API-Client bereit');
    }
    function initNavigation() {
      const items = [['overview','Übersicht'],['console','Live-Konsole'],['files','Dateien'],['profiles','Profile'],['addons','Add-ons'],['webprotection','Webschutz'],['diagnostics','Diagnose']];
      const nav = $('#nav');
      nav.innerHTML = items.map(([id,label]) => `<button data-nav="${id}" class="${id==='overview'?'active':''}">${label}</button>`).join('');
      nav.addEventListener('click', ev => { const btn = ev.target.closest('[data-nav]'); if (btn) activatePanel(btn.dataset.nav); });
      $('#reloadBtn').onclick = () => location.reload(); $('#classicBtn').onclick = () => initClassicMode(); $('#mobileBtn').onclick = () => initMobileMode(); $('#desktopBtn').onclick = () => guarded('desktop', initDesktopMode);
    }
    function activatePanel(id) {
      state.active = id;
      document.querySelectorAll('[data-nav]').forEach(b => b.classList.toggle('active', b.dataset.nav === id));
      document.querySelectorAll('[data-panel]').forEach(p => p.classList.toggle('active', p.dataset.panel === id));
      if (id === 'files' && !state.safe) guarded('files', initFilesPanel);
      if (id === 'profiles' && !state.safe) guarded('profiles', initProfilesPanel);
      if (id === 'addons' && !state.safe) guarded('addons', initAddonManagerPanel);
      if (id === 'webprotection' && !state.safe) guarded('webprotection', initWebProtectionPanel);
      if (id === 'diagnostics') renderDiagnosticsPanel();
    }
    async function initStatusPanel() {
      const target = $('#statusArea');
      target.innerHTML = `<div class="wmc-card">Status wird geladen...</div>`;
      const data = await state.api.get('/api/status', {}, 9000);
      const env = data.env || {}; const m = data.metrics || {};
      target.innerHTML = `<div class="wmc-grid"><div class="wmc-kpi">Server<b>${esc(env.SERVER_NAME || '-')}</b><span class="wmc-muted">Welt: ${esc(env.LEVEL_NAME || '-')}</span></div><div class="wmc-kpi">Spieler<b>${esc(m.players?.label || 'Nicht verfügbar')}</b><span class="wmc-muted">Health: ${esc(data.health?.overall || '-')}</span></div><div class="wmc-kpi">Speicher<b>${esc(m.memory?.label || '-')}</b><span class="wmc-muted">Disk: ${esc(m.disk?.label || '-')}</span></div></div><div class="wmc-card"><b>Ports</b><p>${esc(env.SERVER_PORT || '-')} / ${esc(env.SERVER_PORT_V6 || '-')}</p><p>WinoMC ${esc(data.winomc_version || VERSION)} · FIFO ${data.fifo_exists ? 'OK' : 'fehlt'} · Log ${data.log_exists ? 'OK' : 'fehlt'}</p></div>`;
      bootStep('Status API erreicht');
    }
    function initConsolePanel() {
      const target = $('#consoleArea');
      if (state.safe) {
        target.innerHTML = `<div class="wmc-card wmc-warn"><b>Live-Konsole im Safe Mode deaktiviert</b><p>Keine Befehle, kein EventSource und kein automatisches Polling. Nutze den normalen Modus, wenn die Shell stabil sichtbar ist.</p></div><div id="logBox" class="wmc-log" aria-live="polite">[WinoMC] Safe Mode: Live-Log-SSE deaktiviert.\n</div>`;
        return;
      }
      target.innerHTML = `<div class="wmc-row"><input id="commandInput" placeholder="Bedrock-Befehl, z. B. list oder say Hallo"><button class="primary" id="sendCommandBtn">Senden</button><button id="connectLogBtn">Live-Log verbinden</button></div><p id="consoleStatus" class="wmc-muted">Konsole sichtbar. Live-Log startet nach der UI.</p><div id="logBox" class="wmc-log" aria-live="polite">[WinoMC] Konsole bereit. Live-Log ist nicht Voraussetzung für den Start.\n</div>`;
      $('#sendCommandBtn').onclick = () => sendCommand(); $('#commandInput').addEventListener('keydown', ev => { if (ev.key === 'Enter') sendCommand(); }); $('#connectLogBtn').onclick = () => connectLogs(true);
      setTimeout(() => guarded('console', () => connectLogs(false)), 700);
    }
    async function sendCommand() { const input = $('#commandInput'); const command = input.value.trim(); if (!command) return; appendLog('> ' + command); input.value=''; try { await state.api.post('/api/command', {command}, 8000); appendLog('[WinoMC] Befehl gesendet.'); } catch (err) { appendLog('[Fehler] ' + err.message); showError('console', err); } }
    function appendLog(line) { state.logBuffer.push(String(line)); if (!state.logFlush) state.logFlush = requestAnimationFrame(flushLog); }
    function flushLog() { state.logFlush = 0; const box = $('#logBox'); if (!box) return; const lines = (box.textContent ? box.textContent.split('\n').filter(Boolean) : []).concat(state.logBuffer.splice(0)).slice(-MAX_LOG_LINES); box.textContent = lines.join('\n') + '\n'; box.scrollTop = box.scrollHeight; }
    function connectLogs(manual) {
      if (!window.EventSource) { $('#consoleStatus').textContent = 'EventSource wird nicht unterstützt.'; return; }
      if (state.es) { try { state.es.close(); } catch {} state.es = null; }
      $('#consoleStatus').textContent = 'Live-Log verbindet...';
      const es = new EventSource(apiUrl('/api/logs')); state.es = es;
      es.onopen = () => { state.logRetry = 0; $('#consoleStatus').textContent = 'Live-Log verbunden.'; bootStep('Live-Log verbunden'); };
      es.onmessage = ev => { try { const data = JSON.parse(ev.data); if (data.line) appendLog(data.line); } catch {} };
      es.onerror = () => { $('#consoleStatus').textContent = 'Live-Log wartet oder ist getrennt. UI bleibt bedienbar.'; try { es.close(); } catch {} state.es = null; if (manual) showError('console', new Error('Live-Log-Verbindung fehlgeschlagen')); if (!state.safe) { const delay = Math.min(30000, 1000 * Math.pow(2, state.logRetry++)); clearTimeout(state.logReconnectTimer); state.logReconnectTimer = setTimeout(() => guarded('console', () => connectLogs(false)), delay); } };
    }
    function initMobileMode() { document.body.classList.remove('wmc-classic','wmc-desktop'); document.body.classList.add('wmc-mobile'); bootStep('Mobile-Modus aktiv'); }
    function initClassicMode() { document.body.classList.remove('wmc-mobile','wmc-desktop'); document.body.classList.add('wmc-classic'); bootStep('PC-Classic-Modus aktiv'); }
    function initDesktopMode() { if (state.safe) throw new Error('Desktop-Modus ist im Safe Mode deaktiviert.'); document.body.classList.remove('wmc-mobile','wmc-classic'); document.body.classList.add('wmc-desktop'); bootStep('Desktop-Modus isoliert aktiviert'); }
    async function initFilesPanel() { if (state.modules.get('files')) return; state.modules.set('files', true); const area = $('#filesArea'); area.innerHTML = '<div class="wmc-card">Dateibereiche werden geladen...</div>'; const data = await state.api.get('/api/files/roots', {}, 8000); area.innerHTML = `<div class="wmc-row"><select id="fileRoot">${(data.roots||[]).map(r=>`<option value="${esc(r.key)}" ${(!r.exists||!r.readable)?'disabled':''}>${esc(r.label)}${r.exists?'':' (fehlt)'}</option>`).join('')}</select><input id="filePath" value="/"><button id="fileOpen">Öffnen</button><a id="fileZip" class="wmc-btn" href="#">Export ZIP</a></div><div class="wmc-row"><input id="fileUploadInput" type="file"><button id="fileUploadBtn">Upload</button><span id="fileStatus" class="wmc-muted"></span></div><div id="fileList" class="wmc-card">Bereit.</div>`; $('#fileOpen').onclick = () => loadFiles($('#filePath').value || '/'); $('#fileRoot').onchange = () => loadFiles('/'); $('#fileUploadBtn').onclick = () => uploadFile(); await loadFiles('/'); }
