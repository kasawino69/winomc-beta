            try:
                payload = self._read_json_payload()
                self._send_json(200, build_addon_plan(str(payload.get("item_id", "")), str(payload.get("action", "install")), bool(payload.get("activate", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/addons/apply") or path == "/api/addons/apply":
