    function applyConsoleSize16142(size) {
      const requested = String(size || 'normal');
      if (requested === 'fullscreen') {
        toggleConsoleFullscreen16142();
        return;
      }
      if (document.body.classList.contains('console-maximized')) {
        // A direct size button exits fullscreen into the explicitly requested size.
        setConsoleMode(requested === 'large' ? 'large' : requested);
        requestAnimationFrame(updateConsoleLabels16142);
        return;
      }
      if (requested === 'compact') setConsoleMode('compact');
      else if (requested === 'large') setConsoleMode('large');
      else if (requested === 'normal') setConsoleMode('normal');
      else setConsoleMode(requested);
      requestAnimationFrame(updateConsoleLabels16142);
    }

    document.addEventListener('click', event => {
