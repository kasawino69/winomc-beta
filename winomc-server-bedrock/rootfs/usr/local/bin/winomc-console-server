    /* v1.6.14.3 focused hardening layer
       The earlier mobile console fixes introduced valid UX ideas, but mobile
       browsers still exposed the drag handle in some collapsed states and the
       editor backdrop could let touches reach the page behind it. This final
       layer is deliberately narrow and only hardens those known states. */
    (function hardenUx16143() {
      const VERSION_16143 = '1.6.14.3';
      const fullscreenStore = 'winomc.console.beforeFullscreen.1.6.14.3';

      function mobileShell() {
        return document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode');
      }

      function modeName() {
        if (document.body.classList.contains('console-collapsed')) return 'collapsed';
        if (document.body.classList.contains('console-hidden')) return 'hidden';
        if (document.body.classList.contains('console-maximized')) return 'maximized';
        if (document.body.classList.contains('console-compact')) return 'compact';
        if (document.body.classList.contains('console-large')) return 'large';
        return 'normal';
      }

      function forceHideMobileResizeHandle() {
        if (!consoleResizeHandle) return;
        if (mobileShell()) {
          consoleResizeHandle.hidden = true;
          consoleResizeHandle.setAttribute('aria-hidden', 'true');
          consoleResizeHandle.style.display = 'none';
          consoleResizeHandle.style.pointerEvents = 'none';
          consoleResizeHandle.style.visibility = 'hidden';
          consoleResizeHandle.style.height = '0px';
        } else {
          consoleResizeHandle.hidden = false;
          consoleResizeHandle.removeAttribute('aria-hidden');
          consoleResizeHandle.style.removeProperty('display');
          consoleResizeHandle.style.removeProperty('pointer-events');
          consoleResizeHandle.style.removeProperty('visibility');
          consoleResizeHandle.style.removeProperty('height');
        }
      }

      function syncCollapsedMobileConsole() {
        if (!mobileShell()) return;
        forceHideMobileResizeHandle();
        if (document.body.classList.contains('console-collapsed') || document.body.classList.contains('console-hidden')) {
          document.body.classList.remove('console-large', 'console-maximized', 'console-compact');
          if (consoleCollapse) consoleCollapse.textContent = 'Ausklappen';
        }
      }

      function updateFullscreenButtons() {
        const isFull = document.body.classList.contains('console-maximized');
        document.querySelectorAll('[data-console-size="fullscreen"]').forEach(button => {
          button.textContent = isFull ? 'Normal' : 'Vollbild';
          button.setAttribute('aria-pressed', isFull ? 'true' : 'false');
          button.setAttribute('aria-label', isFull ? 'Live Console zur vorherigen GrÃ¶ÃŸe zurÃ¼cksetzen' : 'Live Console im Vollbild Ã¶ffnen');
        });
        document.querySelectorAll('[data-console-size="large"]').forEach(button => {
          button.textContent = 'GroÃŸ';
          button.setAttribute('aria-pressed', document.body.classList.contains('console-large') ? 'true' : 'false');
        });
      }

      const previousSetConsoleMode = setConsoleMode;
      setConsoleMode = function(mode) {
        const requested = mode || 'normal';
        if (mobileShell() && (requested === 'collapsed' || requested === 'hidden')) {
          previousSetConsoleMode('collapsed');
        } else {
          previousSetConsoleMode(requested);
        }
        syncCollapsedMobileConsole();
        updateFullscreenButtons();
      };

      function applySize(size) {
        const requested = String(size || 'normal');
        if (requested === 'fullscreen') {
          if (document.body.classList.contains('console-maximized')) {
            const previous = localStorage.getItem(fullscreenStore) || 'normal';
            setConsoleMode(previous === 'maximized' || previous === 'fullscreen' ? 'normal' : previous);
          } else {
            const current = modeName();
            localStorage.setItem(fullscreenStore, current === 'maximized' ? 'normal' : current);
            setConsoleMode('maximized');
          }
          return;
        }
        if (requested === 'compact') setConsoleMode('compact');
        else if (requested === 'large') setConsoleMode('large');
        else if (requested === 'normal') setConsoleMode('normal');
        else if (requested === 'collapsed' || requested === 'hidden') setConsoleMode('collapsed');
      }

      document.addEventListener('click', event => {
        const button = event.target.closest?.('[data-console-size]');
        if (!button) return;
        if (!mobileShell()) return;
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
        applySize(button.dataset.consoleSize || 'normal');
      }, true);

      document.addEventListener('pointerdown', event => {
        if (mobileShell() && event.target === consoleResizeHandle) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          return;
        }
        const button = event.target.closest?.('[data-console-size]');
        if (!button) return;
        if (!mobileShell()) return;
        event.stopPropagation();
      }, true);


      const editorModalBackdrop16143 = document.getElementById('editorModalBackdrop');
      if (editorModalBackdrop16143) {
        ['pointerdown', 'touchstart', 'click', 'dblclick', 'contextmenu', 'wheel'].forEach(type => {
          editorModalBackdrop16143.addEventListener(type, event => {
            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();
          }, true);
        });
      }

      function editorOpen() {
        return !!(editorPanel && (editorPanel.classList.contains('editor-open') || editorPanel.classList.contains('editor-fullscreen')));
      }

      function syncEditorModalState() {
        document.body.classList.toggle('editor-modal-open', editorOpen());
      }

      const previousOpenEditorOverlay = openEditorOverlay;
      openEditorOverlay = function() {
        previousOpenEditorOverlay();
        syncEditorModalState();
      };

      const previousCloseEditorOverlay = closeEditorOverlay;
      closeEditorOverlay = function() {
        previousCloseEditorOverlay();
        syncEditorModalState();
      };

      function blockBackgroundWhileEditorOpen(event) {
        if (!mobileShell() || !editorOpen() || !editorPanel) return;
        if (editorPanel.contains(event.target)) return;
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
      }

      ['pointerdown', 'touchstart', 'click', 'dblclick', 'contextmenu', 'wheel'].forEach(type => {
        document.addEventListener(type, blockBackgroundWhileEditorOpen, true);
      });

      if (editorPanel) {
        new MutationObserver(syncEditorModalState).observe(editorPanel, { attributes: true, attributeFilter: ['class'] });
      }

      window.addEventListener('resize', () => {
        forceHideMobileResizeHandle();
        syncCollapsedMobileConsole();
      }, { passive: true });

      window.addEventListener('orientationchange', () => {
        window.setTimeout(() => {
          forceHideMobileResizeHandle();
          syncCollapsedMobileConsole();
        }, 250);
      }, { passive: true });

      forceHideMobileResizeHandle();
      syncCollapsedMobileConsole();
      syncEditorModalState();
      updateFullscreenButtons();
      console.info('[WinoMC UX] Mobile hardening loaded ' + VERSION_16143);
    })();



    /* v1.6.14.4 Desktop Workbench blocker hardening
       Only clears stale blocking layers in PC Workbench mode. It does not
       change window sizing, mobile behavior, file APIs, or console logic. */
    (function hardenDesktopWorkbenchBlockers16144() {
      const VERSION_16144 = '1.6.14.4';

      function desktopActive16144() {
        return document.body.classList.contains('desktop-mode');
      }

      function editorIsReallyOpen16144() {
        return !!(window.editorPanel && (editorPanel.classList.contains('editor-open') || editorPanel.classList.contains('editor-fullscreen')));
      }

      function clearDesktopWorkbenchBlockers16144() {
        if (!desktopActive16144()) return;

        // Classic card maximization uses body.has-maximized-card + ::after.
        // In the PC Workbench this state is stale and can create an invisible
        // click-blocking panel over the lower desktop area.
        document.body.classList.remove('has-maximized-card');
        document.querySelectorAll('.card.maximized').forEach(card => card.classList.remove('maximized'));

        // Non-open or minimized windows must never receive pointer events.
        document.querySelectorAll('.tab-panel').forEach(panel => {
          const open = panel.classList.contains('desktop-open') && !panel.classList.contains('desktop-minimized');
          if (open) {
            panel.style.removeProperty('pointer-events');
            panel.style.removeProperty('visibility');
          } else {
            panel.style.pointerEvents = 'none';
            panel.style.visibility = 'hidden';
          }
        });

        // The editor modal backdrop is valid only while the editor is really open.
        if (!editorIsReallyOpen16144()) {
          document.body.classList.remove('editor-modal-open');
          const editorBackdrop = document.getElementById('editorModalBackdrop');
          if (editorBackdrop) {
            editorBackdrop.setAttribute('aria-hidden', 'true');
            editorBackdrop.style.pointerEvents = 'none';
            editorBackdrop.style.display = 'none';
          }
        }
      }

      function wrapDesktopFunction16144(name, after) {
        try {
          const original = window[name] || globalThis[name];
          if (typeof original !== 'function' || original.__winomc16144Wrapped) return;
          const wrapped = function(...args) {
            const result = original.apply(this, args);
            window.requestAnimationFrame(after);
            return result;
          };
          wrapped.__winomc16144Wrapped = true;
          globalThis[name] = wrapped;
          try { window[name] = wrapped; } catch (_) {}
        } catch (_) {
          // Non-critical hardening hook. CSS still protects the workbench.
        }
      }

      wrapDesktopFunction16144('setDesktopMode', clearDesktopWorkbenchBlockers16144);
      wrapDesktopFunction16144('openDesktopWindow', clearDesktopWorkbenchBlockers16144);
      wrapDesktopFunction16144('updateDesktopTaskbar', clearDesktopWorkbenchBlockers16144);

      document.addEventListener('pointerdown', () => {
        if (desktopActive16144()) clearDesktopWorkbenchBlockers16144();
      }, true);

      window.addEventListener('resize', () => window.requestAnimationFrame(clearDesktopWorkbenchBlockers16144), { passive: true });
      window.addEventListener('orientationchange', () => window.setTimeout(clearDesktopWorkbenchBlockers16144, 150), { passive: true });

      window.requestAnimationFrame(clearDesktopWorkbenchBlockers16144);
      window.setTimeout(clearDesktopWorkbenchBlockers16144, 300);
      console.info('[WinoMC UX] Desktop Workbench blocker hardening loaded ' + VERSION_16144);
    })();



    /* v1.6.14.7 Desktop Workbench free-space hardening
       One-time cleanup for old localStorage window heights. Users can resize
       the file window afterwards; maximized windows are intentionally untouched. */
    (function hardenDesktopFilesFreeSpace16147() {
      const VERSION_16147 = '1.6.14.7';
      const MIGRATION_KEY_16147 = 'winomc.desktop.filesFreeSpaceMigrated.1.6.14.7';
      const MAX_FILES_HEIGHT_16147 = 540;

      function desktopFilesHardeningActive16147() {
        return document.body.classList.contains('ux-desktop') && document.body.classList.contains('desktop-mode');
      }

      function readDesktopPositions16147() {
        try {
          if (typeof desktopPositions === 'function') return desktopPositions() || {};
        } catch (_) {}
        try {
          return JSON.parse(localStorage.getItem(STORE_DESKTOP_POSITIONS) || '{}') || {};
        } catch (_) {
          return {};
        }
      }

      function writeDesktopPositions16147(positions) {
        try {
          localStorage.setItem(STORE_DESKTOP_POSITIONS, JSON.stringify(positions || {}));
        } catch (_) {}
      }

      function clampStoredFilesRect16147() {
        const positions = readDesktopPositions16147();
        const files = positions.files;
        if (!files) return;
        let changed = false;
        let storedHeight = parseFloat(files.height || '0');
        if (Number.isFinite(storedHeight) && storedHeight > MAX_FILES_HEIGHT_16147) {
          storedHeight = MAX_FILES_HEIGHT_16147;
          files.height = MAX_FILES_HEIGHT_16147 + 'px';
          changed = true;
        }
        const storedTop = parseFloat(files.top || '0');
        const taskbarLimit = Math.max(360, window.innerHeight - 58);
        if (Number.isFinite(storedTop) && Number.isFinite(storedHeight) && storedHeight > 0 && storedTop + storedHeight > taskbarLimit) {
          files.top = Math.max(8, taskbarLimit - storedHeight) + 'px';
          changed = true;
        }
        if (changed) writeDesktopPositions16147(positions);
      }

      function clampOpenFilesWindow16147() {
        if (!desktopFilesHardeningActive16147()) return;
        const panel = document.querySelector('.tab-panel[data-panel="files"].desktop-open:not(.desktop-minimized):not(.desktop-maximized)');
        if (!panel) return;
        let changed = false;
        let currentHeight = parseFloat(panel.style.height || '0') || panel.getBoundingClientRect().height;
        if (Number.isFinite(currentHeight) && currentHeight > MAX_FILES_HEIGHT_16147) {
          currentHeight = MAX_FILES_HEIGHT_16147;
          panel.style.height = MAX_FILES_HEIGHT_16147 + 'px';
          changed = true;
        }
        const rect = panel.getBoundingClientRect();
        const taskbarLimit = Math.max(360, window.innerHeight - 58);
        if (rect.bottom > taskbarLimit && rect.height > 0) {
          panel.style.top = Math.max(8, taskbarLimit - Math.min(rect.height, MAX_FILES_HEIGHT_16147)) + 'px';
          changed = true;
        }
        if (changed) {
          try {
            const res = await fetch(apiUrl(path, options.params || {}), { cache:'no-store', ...options, signal: controller.signal });
            const text = await res.text();
            let data = {};
            try { data = text ? JSON.parse(text) : {}; } catch { throw new Error(`UngÃ¼ltige JSON-Antwort von ${path}: HTTP ${res.status}`); }
            if (!res.ok || data.ok === false) throw new Error(data.error || res.statusText || `HTTP ${res.status}`);
            return data;
          } catch (err) {
            if (err.name === 'AbortError') throw new Error(`ZeitÃ¼berschreitung bei ${path}`);
            throw err;
          } finally { clearTimeout(timer); }
        },
        get(path, params, timeout) { return this.request(path, { params }, timeout); },
        post(path, payload, timeout) { return this.request(path, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload || {}) }, timeout); }
      };
      bootStep('API-Client bereit');
    }
