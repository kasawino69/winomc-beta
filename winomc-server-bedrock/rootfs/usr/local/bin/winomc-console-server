    const ACTION_BY_ID = Object.fromEntries(ACTIONS.map(action => [action.id, action]));
    const DEFAULT_DASHBOARD = ['list', 'say', 'time-day', 'weather-clear', 'save-query'];
    let history = JSON.parse(localStorage.getItem('winomcCommandHistory') || '[]');
    let historyIndex = history.length;
    let pendingTemplate = null;
    let dashboardActions = loadDashboard();
    let filesInitialized = false;
    let currentFileRoot = 'config';
    let currentFilePath = '/';
    let currentEditorFile = null;
    let webWriteLocked = localStorage.getItem(STORE_WEB_WRITE_LOCK) !== 'false';
    let trashRetentionDays = 7;
    let latestStatus = null;

    function appendLine(text, cls) { const div = document.createElement('div'); div.className = 'line' + (cls ? ' ' + cls : ''); div.textContent = text; const stick = log.scrollTop + log.clientHeight >= log.scrollHeight - 20; log.appendChild(div); while (log.children.length > 1600) log.removeChild(log.firstChild); if (stick) log.scrollTop = log.scrollHeight; }
    function saveHistory(command) { history = history.filter(item => item !== command); history.push(command); history = history.slice(-50); historyIndex = history.length; localStorage.setItem('winomcCommandHistory', JSON.stringify(history)); }
    async function sendCommand(command) { command = String(command || '').trim(); if (!command) return; appendLine('> ' + command, 'command'); saveHistory(command); input.value = ''; try { const endpoint = './api/command?command=' + encodeURIComponent(command); const res = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ command }) }); const data = await res.json(); if (!res.ok || !data.ok) appendLine('Fehler: ' + (data.error || res.statusText), 'error'); else appendLine('Befehl gesendet', 'ok'); } catch (err) { appendLine('Fehler beim Senden: ' + err.message, 'error'); } }
    function runAction(action) {
      if (!action) return;
      if (action.confirm && !window.confirm(action.confirm)) return;
      if (Array.isArray(action.fields) && action.fields.length) {
        runFieldAction(action);
        return;
      }
      if (action.template) { openPromptForAction(action); return; }
      sendCommand(action.command);
    }

    function runFieldAction(action) {
      const values = {};
      for (const field of action.fields) {
        let label = field.label || field.key || 'Wert';
        let hint = field.placeholder ? '\nBeispiel: ' + field.placeholder : '';
        let value = window.prompt(label + hint, field.default || '');
        if (value === null) return;
        value = String(value).trim();
        if (!value && !field.optional) {
          alert('Pflichtfeld fehlt: ' + label);
          return;
        }
        if (field.type === 'number' && value && !/^-?\d+(\.\d+)?$/.test(value)) {
          alert('Bitte eine Zahl eingeben: ' + label);
          return;
        }
        values[field.key] = value;
      }
      let command = action.template || '';
      Object.entries(values).forEach(([key, value]) => {
        command = command.replaceAll('{' + key + '}', value);
      });
      command = command.replace(/\s+/g, ' ').trim();
      if (!command) return;
      sendCommand(command);
    }

    function openPromptForAction(action) { pendingTemplate = action.template; modalTitle.textContent = action.promptTitle || action.label || 'Wert eingeben'; modalLabel.textContent = action.promptLabel || action.description || 'Bitte Wert eingeben.'; modalInput.value = ''; modalInput.placeholder = action.placeholder || ''; modalBackdrop.classList.add('open'); modalBackdrop.setAttribute('aria-hidden', 'false'); setTimeout(() => modalInput.focus(), 0); }
    function closePrompt() { modalBackdrop.classList.remove('open'); modalBackdrop.setAttribute('aria-hidden', 'true'); pendingTemplate = null; }
    function sendPromptValue() { const value = modalInput.value.trim(); if (!value || !pendingTemplate) return; const command = pendingTemplate.replaceAll('{value}', value); closePrompt(); sendCommand(command); }
    function loadDashboard() { try { const saved = JSON.parse(localStorage.getItem(STORE_DASHBOARD) || 'null'); if (Array.isArray(saved) && saved.length) return saved.filter(id => ACTION_BY_ID[id]); } catch (_) {} return [...DEFAULT_DASHBOARD]; }
    function saveDashboard() { localStorage.setItem(STORE_DASHBOARD, JSON.stringify(dashboardActions)); }
    function createButtonForAction(action, label) { const button = document.createElement('button'); button.type = 'button'; button.textContent = label || action.label; if (action.variant) button.classList.add(action.variant); button.addEventListener('click', () => runAction(action)); return button; }
    function renderDashboard() {
      dashboardGrid.innerHTML = '';
      const columns = localStorage.getItem(STORE_COLUMNS) || 'auto';
      dashboardColumns.value = columns;
      dashboardGrid.classList.toggle('auto', columns === 'auto');
      if (columns === 'auto') dashboardGrid.style.removeProperty('--dashboard-columns');
      else dashboardGrid.style.setProperty('--dashboard-columns', columns);

      if (!dashboardActions.length) {
        const empty = document.createElement('div');
        empty.className = 'dashboard-empty';
        empty.textContent = 'Noch keine Kacheln ausgewählt. Suche oben nach einer Aktion und füge sie hinzu.';
        dashboardGrid.appendChild(empty);
      }

      dashboardActions.forEach((id, index) => {
        const action = ACTION_BY_ID[id];
        if (!action) return;
        const tile = document.createElement('article');
        tile.className = 'tile dashboard-tile';
        const top = document.createElement('div');
        top.className = 'tile-top';
        const text = document.createElement('div');
        const title = document.createElement('div');
        title.className = 'tile-title';
        title.textContent = action.label;
        const desc = document.createElement('div');
        desc.className = 'tile-desc';
        desc.textContent = action.description || '';
        text.append(title, desc);
        const tag = document.createElement('span');
        tag.className = 'category-label';
        tag.textContent = action.category;
        top.append(text, tag);
        const actionButton = createButtonForAction(action, action.template ? 'Ausführen…' : 'Ausführen');
        actionButton.classList.add('tile-action-main');
        const controls = document.createElement('div');
        controls.className = 'tile-actions';
        const up = document.createElement('button');
        up.type = 'button';
        up.textContent = '↑';
        up.title = 'Nach oben';
        up.disabled = index === 0;
        up.addEventListener('click', () => moveDashboardAction(index, -1));
        const down = document.createElement('button');
        down.type = 'button';
        down.textContent = '↓';
        down.title = 'Nach unten';
        down.disabled = index === dashboardActions.length - 1;
        down.addEventListener('click', () => moveDashboardAction(index, 1));
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.textContent = 'Entfernen';
        remove.className = 'ghost';
        remove.addEventListener('click', () => removeDashboardAction(id));
        controls.append(up, down, remove);
        tile.append(top, actionButton, controls);
        dashboardGrid.appendChild(tile);
      });
      renderActionPicker();
    }

    function getDashboardAvailableActions() {
      const term = String(dashboardActionSearch?.value || '').trim().toLowerCase();
      return ACTIONS
        .filter(action => !dashboardActions.includes(action.id))
        .filter(action => !term || [action.label, action.description, action.category, action.id].join(' ').toLowerCase().includes(term))
        .sort((a, b) => (a.category + a.label).localeCompare(b.category + b.label));
    }

    function renderActionPicker() {
      if (!dashboardActionSelect || !actionPicker) return;
      const available = getDashboardAvailableActions();
      dashboardActionSelect.innerHTML = '';

      if (!available.length) {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = dashboardActionSearch?.value ? 'Keine passende Aktion gefunden' : 'Alle Aktionen sind bereits im Dashboard';
        dashboardActionSelect.appendChild(option);
        if (dashboardAddSelected) dashboardAddSelected.disabled = true;
        actionPicker.textContent = option.textContent;
        return;
      }

      let currentCategory = '';
      available.forEach(action => {
        if (action.category !== currentCategory) {
          currentCategory = action.category;
          const group = document.createElement('option');
          group.disabled = true;
          group.textContent = '── ' + currentCategory + ' ──';
          dashboardActionSelect.appendChild(group);
        }
        const option = document.createElement('option');
        option.value = action.id;
        option.textContent = action.label + (action.variant === 'danger' ? '  · Kritisch' : '');
        dashboardActionSelect.appendChild(option);
      });

      const first = available[0];
      dashboardActionSelect.value = first.id;
      if (dashboardAddSelected) dashboardAddSelected.disabled = false;
      updateDashboardActionPreview();
    }

    function updateDashboardActionPreview() {
      if (!dashboardActionSelect || !actionPicker) return;
      const action = ACTION_BY_ID[dashboardActionSelect.value];
      if (!action) { actionPicker.textContent = 'Keine Aktion ausgewählt.'; return; }
      actionPicker.innerHTML = '<b>' + escapeHtml(action.label) + '</b><span>' + escapeHtml(action.category) + '</span><p>' + escapeHtml(action.description || '') + '</p>';
      actionPicker.classList.toggle('danger', action.variant === 'danger');
      actionPicker.classList.toggle('warning', action.variant === 'warning');
    }

    function addDashboardAction(id) { if (!ACTION_BY_ID[id] || dashboardActions.includes(id)) return; dashboardActions.push(id); saveDashboard(); renderDashboard(); }
    function removeDashboardAction(id) { dashboardActions = dashboardActions.filter(item => item !== id); saveDashboard(); renderDashboard(); }
    function moveDashboardAction(index, direction) { const next = index + direction; if (next < 0 || next >= dashboardActions.length) return; [dashboardActions[index], dashboardActions[next]] = [dashboardActions[next], dashboardActions[index]]; saveDashboard(); renderDashboard(); }

    function apiUrl(path, params = {}) { const query = new URLSearchParams(params); const suffix = query.toString() ? '?' + query.toString() : ''; return './' + path.replace(/^\/+/, '') + suffix; }
    async function fetchJson(path, params = {}) { const res = await fetch(apiUrl(path, params), { cache: 'no-store' }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    async function postJson(path, payload = {}) { const res = await fetch('./' + path.replace(/^\/+/, ''), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    function setFilesStatus(text, variant) { filesStatus.textContent = text; filesStatus.classList.toggle('warn', variant === 'warn'); }

    function applyWebWriteLock() {
      localStorage.setItem(STORE_WEB_WRITE_LOCK, String(webWriteLocked));
      document.body.classList.toggle('web-write-locked', webWriteLocked);
      if (fileWriteLockToggle) {
        fileWriteLockToggle.textContent = webWriteLocked ? '🔒 Web-Schutz: an' : '🔓 Web-Schutz: aus';
        fileWriteLockToggle.classList.toggle('warning', webWriteLocked);
        fileWriteLockToggle.classList.toggle('primary', !webWriteLocked);
        fileWriteLockToggle.title = webWriteLocked
          ? 'Ändern, Löschen, Upload, Entpacken und Wiederherstellen sind nur in der Weboberfläche gesperrt. Der Minecraft Server kann weiterhin schreiben.'
          : 'Weboberfläche ist entsperrt. Änderungen, Uploads und Löschaktionen sind möglich.';
      }
      if (fileDropZone) {
        fileDropZone.classList.toggle('locked', webWriteLocked);
        fileDropZone.textContent = webWriteLocked ? 'Web-Schutz aktiv: Upload ist gesperrt' : 'Dateien hierher ziehen oder klicken zum Hochladen';
        if (fileUploadInput && !fileDropZone.contains(fileUploadInput)) fileDropZone.appendChild(fileUploadInput);
      }
      document.querySelectorAll('[data-write-action]').forEach(button => {
        button.disabled = webWriteLocked;
        button.title = webWriteLocked ? 'Web-Schutz aktiv: erst entsperren.' : '';
      });
      if (currentEditorFile && currentEditorFile.root !== 'trash') setEditorPreviewMode(webWriteLocked, webWriteLocked ? 'Web-Schutz aktiv: Vorschau. Zum Speichern oben entsperren.' : '');
    }

    function ensureWriteAllowed(actionLabel = 'Diese Aktion') {
      if (!webWriteLocked) return true;
      alert(actionLabel + ' ist durch den Web-Schutz gesperrt.\n\nDas betrifft nur diese Weboberfläche. Der Minecraft Server selbst kann seine Dateien weiterhin schreiben.');
      return false;
    }

    async function loadTrashSettings() {
      try {
        const data = await fetchJson('/api/files/trash/settings');
        trashRetentionDays = Number(data.retention_days ?? 7);
        if (trashRetentionSelect) trashRetentionSelect.value = String(trashRetentionDays);
      } catch (err) {
        appendLine('[WinoMC Dateien] Papierkorb-Einstellungen konnten nicht geladen werden: ' + err.message, 'error');
      }
    }

    async function saveTrashSettings(days) {
      try {
        const data = await postJson('/api/files/trash/settings', { retention_days: Number(days) });
        trashRetentionDays = Number(data.retention_days ?? days);
        if (trashRetentionSelect) trashRetentionSelect.value = String(trashRetentionDays);
        appendLine('[WinoMC Dateien] Papierkorb-Aufbewahrung gesetzt: ' + (trashRetentionDays === 0 ? 'nie automatisch' : trashRetentionDays + ' Tage'), 'ok');
      } catch (err) {
        alert(err.message);
      }
    }
    function formatBytes(value) { const bytes = Number(value || 0); if (bytes < 1024) return bytes + ' B'; if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'; if (bytes < 1024 * 1024 * 1024) return (bytes / 1024 / 1024).toFixed(1) + ' MB'; return (bytes / 1024 / 1024 / 1024).toFixed(1) + ' GB'; }
    function formatUnixTime(value) { if (!value) return '-'; return new Date(Number(value) * 1000).toLocaleString(); }
    function normalizeUiPath(path) { path = String(path || '/').replaceAll('\\', '/'); if (!path.startsWith('/')) path = '/' + path; path = path.replace(/\/+/g, '/'); return path || '/'; }
    function parentUiPath(path) { path = normalizeUiPath(path); if (path === '/') return '/'; const parts = path.split('/').filter(Boolean); parts.pop(); return '/' + parts.join('/'); }
    function escapeHtml(value) { return String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;'); }
    function activateTab(tab) { if (document.body.classList.contains('desktop-mode')) { openDesktopWindow(tab); return; } document.body.classList.toggle('hide-hero', tab !== 'overview'); document.querySelectorAll('[data-tab]').forEach(item => item.classList.toggle('active', item.dataset.tab === tab)); document.querySelectorAll('[data-panel]').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab)); if (document.body.classList.contains('sidebar-collapsed')) requestAnimationFrame(scrollActiveSidebarIconIntoView); if (tab === 'files') initFileManager(); if (tab === 'overview' || tab === 'network') loadStatus(); }
    function openRoot(root, path = '/') { activateTab('files'); setTimeout(async () => { await initFileManager(); currentFileRoot = root; fileRootSelect.value = root; await loadFileList(path); }, 0); }

    async function loadStatus() { try { const data = await fetchJson('/api/status'); latestStatus = data; document.getElementById('statServerName').textContent = data.env.SERVER_NAME || '-'; document.getElementById('statLevelName').textContent = 'Welt: ' + (data.env.LEVEL_NAME || '-'); document.getElementById('statVersion').textContent = data.env.VERSION || '-'; document.getElementById('statRuntime').textContent = 'Runtime: native · BDS Auto Update: ' + (data.env.BDS_AUTO_UPDATE || '-'); document.getElementById('statPorts').textContent = (data.env.SERVER_PORT || '-') + ' / ' + (data.env.SERVER_PORT_V6 || '-'); document.getElementById('statLan').textContent = 'LAN: ' + (data.env.ENABLE_LAN_VISIBILITY || '-'); document.getElementById('statFifo').textContent = data.fifo_exists ? 'Console FIFO vorhanden' : 'Console FIFO fehlt'; document.getElementById('statLog').textContent = data.log_exists ? 'Logdatei vorhanden' : 'Logdatei fehlt'; document.getElementById('networkIpv4').textContent = 'SERVER_PORT=' + (data.env.SERVER_PORT || '-'); document.getElementById('networkIpv6').textContent = 'SERVER_PORT_V6=' + (data.env.SERVER_PORT_V6 || '-') + ' · ENABLE_BDS_V6BIND_FIX=' + (data.env.ENABLE_BDS_V6BIND_FIX || '-'); document.getElementById('networkLan').textContent = 'ENABLE_LAN_VISIBILITY=' + (data.env.ENABLE_LAN_VISIBILITY || '-'); } catch (err) { appendLine('[WinoMC Status] ' + err.message, 'error'); } }

    async function initFileManager() { if (filesInitialized) { await loadFileList(); return; } filesInitialized = true; try { setFilesStatus('Lade Bereiche...', 'warn'); const data = await fetchJson('/api/files/roots'); fileRootSelect.innerHTML = ''; data.roots.forEach(root => { const option = document.createElement('option'); option.value = root.key; option.textContent = root.label + (root.exists ? '' : ' (fehlt)'); option.disabled = !root.exists || !root.readable; fileRootSelect.appendChild(option); }); const firstEnabled = [...fileRootSelect.options].find(option => !option.disabled); if (![...fileRootSelect.options].some(option => option.value === currentFileRoot && !option.disabled)) currentFileRoot = firstEnabled ? firstEnabled.value : 'config'; fileRootSelect.value = currentFileRoot; await loadTrashSettings(); applyWebWriteLock(); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    async function loadFileList(path) { if (path !== undefined) currentFilePath = normalizeUiPath(path); currentFileRoot = fileRootSelect.value || currentFileRoot; try { setFilesStatus('Lade...', 'warn'); updatePathDisplay(); const data = await fetchJson('/api/files/list', { root: currentFileRoot, path: currentFilePath }); currentFilePath = data.path || '/'; fileParent.disabled = currentFilePath === '/'; updatePathDisplay(); renderFileEntries(data.entries || []); setFilesStatus('Bereit', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); fileTableBody.innerHTML = '<tr><td colspan="5">Fehler: ' + escapeHtml(err.message) + '</td></tr>'; } }
    function updatePathDisplay() { const full = currentFileRoot + ':' + currentFilePath; fileCurrentPath.textContent = full; filePathInput.value = currentFilePath; fileBreadcrumb.innerHTML = ''; const rootButton = document.createElement('button'); rootButton.type = 'button'; rootButton.textContent = currentFileRoot + ':/'; rootButton.addEventListener('click', () => loadFileList('/')); fileBreadcrumb.appendChild(rootButton); let current = ''; currentFilePath.split('/').filter(Boolean).forEach(part => { current += '/' + part; const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = part; const target = current; btn.addEventListener('click', () => loadFileList(target)); fileBreadcrumb.appendChild(btn); }); }
    function renderFileEntries(entries) {
      const inTrash = currentFileRoot === 'trash';
      document.body.classList.toggle('trash-open', inTrash);
      if (fileEmptyTrash) fileEmptyTrash.style.display = inTrash ? '' : 'none';
      if (!entries.length) {
        fileTableBody.innerHTML = '<tr><td colspan="5">Dieser Ordner ist leer.</td></tr>';
        applyWebWriteLock();
        return;
      }
      fileTableBody.innerHTML = '';

      entries.forEach(entry => {
        const tr = document.createElement('tr');
        const nameTd = document.createElement('td');
        const nameButton = document.createElement('button');
        nameButton.type = 'button';
        nameButton.className = 'file-name-button';
        nameButton.textContent = (entry.type === 'directory' ? '📁 ' : '📄 ') + entry.name;
        nameButton.addEventListener('click', () => entry.type === 'directory' ? loadFileList(entry.path) : openFileInEditor(entry.path));
        nameTd.appendChild(nameButton);

        const typeTd = document.createElement('td');
        typeTd.textContent = entry.type === 'directory' ? 'Ordner' : 'Datei';
        const sizeTd = document.createElement('td');
        sizeTd.textContent = entry.type === 'directory' ? '-' : formatBytes(entry.size);
        const modifiedTd = document.createElement('td');
        modifiedTd.textContent = inTrash && entry.original_path ? ('Gelöscht: ' + (entry.deleted_at || '-') + ' · Quelle: ' + entry.original_root + ':' + entry.original_path) : formatUnixTime(entry.modified);
        const actionsTd = document.createElement('td');
        const actions = document.createElement('div');
        actions.className = 'file-row-actions';

        if (entry.type === 'directory') {
          const open = document.createElement('button');
          open.type = 'button';
          open.textContent = 'Öffnen';
          open.addEventListener('click', () => loadFileList(entry.path));
          const zip = document.createElement('button');
          zip.type = 'button';
          zip.textContent = 'ZIP';
          zip.addEventListener('click', () => downloadZip(entry.path));
          const exportZip = document.createElement('button');
          exportZip.type = 'button';
          exportZip.textContent = 'Export';
          exportZip.dataset.writeAction = 'true';
          exportZip.addEventListener('click', () => saveZipToExport(entry.path));
          actions.append(open, zip, exportZip);
        } else {
          const download = document.createElement('button');
          download.type = 'button';
          download.textContent = 'Download';
          download.addEventListener('click', () => downloadFile(entry.path));
          const edit = document.createElement('button');
          edit.type = 'button';
          edit.textContent = inTrash ? 'Vorschau' : 'Editor';
          edit.addEventListener('click', () => openFileInEditor(entry.path));
          actions.append(download, edit);
          if (['.zip', '.mcpack', '.mcaddon', '.mcworld', '.mctemplate'].some(ext => entry.name.toLowerCase().endsWith(ext))) {
            const unzip = document.createElement('button');
            unzip.type = 'button';
            unzip.textContent = 'Entpacken';
            unzip.dataset.writeAction = 'true';
            unzip.addEventListener('click', () => unzipFile(entry.path));
            actions.appendChild(unzip);
          }
        }

        if (inTrash && entry.path !== '/') {
          const restore = document.createElement('button');
          restore.type = 'button';
          restore.textContent = 'Wiederherstellen';
          restore.className = 'primary';
          restore.dataset.writeAction = 'true';
          restore.title = entry.original_path ? ('Zurück nach ' + entry.original_root + ':' + entry.original_path) : 'Aus Papierkorb wiederherstellen';
          restore.addEventListener('click', () => restoreFileEntry(entry.path, entry.name));
          actions.appendChild(restore);
        }

        if (entry.path !== '/') {
          const del = document.createElement('button');
          del.type = 'button';
          del.textContent = inTrash ? 'Endgültig' : 'Löschen';
          del.className = 'danger';
          del.dataset.writeAction = 'true';
          del.addEventListener('click', () => deleteFileEntry(entry.path, entry.name, inTrash));
          actions.appendChild(del);
        }

        actionsTd.appendChild(actions);
        tr.append(nameTd, typeTd, sizeTd, modifiedTd, actionsTd);
        fileTableBody.appendChild(tr);
      });
      applyWebWriteLock();
    }

    function downloadFile(path) { window.location.href = apiUrl('/api/files/download', { root: currentFileRoot, path }); }
    function downloadZip(path) { window.location.href = apiUrl('/api/files/zip', { root: currentFileRoot, path }); }
    async function saveZipToExport(path) { if (!ensureWriteAllowed('ZIP nach Export speichern')) return; try { setFilesStatus('Erstelle ZIP...', 'warn'); const data = await postJson('/api/files/zip', { root: currentFileRoot, paths: [path], save_to_export: true }); appendLine('[WinoMC Dateien] ZIP exportiert: ' + data.filename, 'ok'); setFilesStatus('ZIP exportiert', ''); if (currentFileRoot === 'export') await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] ZIP-Fehler: ' + err.message, 'error'); alert(err.message); } }
    function setEditorPreviewMode(previewOnly, note = '') {
      if (editorPanel) editorPanel.classList.toggle('preview-only', !!previewOnly);
      if (fileEditor) fileEditor.readOnly = !!previewOnly;
      if (fileSave) fileSave.hidden = !!previewOnly;
      if (fileCloseEditor) fileCloseEditor.textContent = previewOnly ? 'Vorschau leeren' : 'Editor leeren';
      if (editorFullscreen) editorFullscreen.textContent = previewOnly ? 'Vorschau Vollbild' : 'Editor Vollbild';
      if (editorReadonlyNote) {
        editorReadonlyNote.hidden = !previewOnly;
        editorReadonlyNote.textContent = note || 'Schreibgeschützte Vorschau. Zum Bearbeiten Datei aus dem Papierkorb wiederherstellen oder Web-Schutz entsperren.';
      }
    }

    async function openFileInEditor(path) {
      try {
        setFilesStatus(currentFileRoot === 'trash' ? 'Öffne Vorschau...' : 'Öffne Datei...', 'warn');
        const data = await fetchJson('/api/files/read', { root: currentFileRoot, path });
        const previewOnly = data.root === 'trash' || webWriteLocked;
        currentEditorFile = previewOnly ? null : { root: data.root, path: data.path };
        editorPath.textContent = data.root + ':' + data.path;
        editorMeta.textContent = formatBytes(data.size) + ' · geändert: ' + formatUnixTime(data.modified) + (data.json ? ' · JSON-Prüfung aktiv' : '') + (previewOnly ? ' · Papierkorb-Vorschau, nicht schreibbar' : '');
        fileEditor.value = data.content || '';
        setEditorPreviewMode(previewOnly, data.root === 'trash' ? 'Papierkorb-Vorschau: Wiederherstellen, um die Datei wieder bearbeitbar zu machen.' : (webWriteLocked ? 'Web-Schutz aktiv: Diese Datei wird nur als Vorschau geöffnet.' : ''));
        setFilesStatus(previewOnly ? 'Vorschau geöffnet' : 'Datei geöffnet', '');
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Editor-Fehler: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function saveEditorFile() { if (!ensureWriteAllowed('Speichern')) return;
      if (currentFileRoot === 'trash') { alert('Papierkorb-Dateien sind nur als Vorschau geöffnet. Bitte zuerst wiederherstellen.'); return; }
      if (!currentEditorFile) { alert('Keine Datei geöffnet.'); return; }
      try {
        setFilesStatus('Speichere...', 'warn');
        const data = await postJson('/api/files/write', { root: currentEditorFile.root, path: currentEditorFile.path, content: fileEditor.value });
        appendLine('[WinoMC Dateien] Datei gespeichert: ' + currentEditorFile.path, 'ok');
        if (data.backup_created) appendLine('[WinoMC Dateien] Backup erstellt: ' + data.backup_path, 'ok');
        setFilesStatus('Gespeichert', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Speichern fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    function clearEditor() { currentEditorFile = null; editorPath.textContent = 'Keine Datei geöffnet'; editorMeta.textContent = 'Bereit'; fileEditor.value = ''; setEditorPreviewMode(false); }
    async function uploadFiles(files) { if (!ensureWriteAllowed('Upload')) return; files = Array.from(files || []); if (!files.length) return; for (const file of files) { try { setFilesStatus('Upload: ' + file.name, 'warn'); let data; try { data = await uploadFileBinary(file); } catch (binaryErr) { if (file.size > MAX_JSON_UPLOAD_SIZE) throw binaryErr; appendLine('[WinoMC Dateien] Binary Upload fehlgeschlagen, nutze JSON-Fallback: ' + binaryErr.message, 'error'); data = await uploadFileJson(file); } appendLine('[WinoMC Dateien] Hochgeladen: ' + data.path, 'ok'); } catch (err) { appendLine('[WinoMC Dateien] Upload fehlgeschlagen: ' + file.name + ' · ' + err.message, 'error'); alert('Upload fehlgeschlagen: ' + file.name + '\n\n' + err.message); } } setFilesStatus('Upload fertig', ''); await loadFileList(currentFilePath); }
    async function uploadFileBinary(file) { const res = await fetch(apiUrl('/api/files/upload', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: 'false' }), { method: 'POST', headers: { 'Content-Type': 'application/octet-stream', 'X-WinoMC-Upload-Size': String(file.size), 'X-WinoMC-Filename': encodeURIComponent(file.name) }, body: file }); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.error || res.statusText); return data; }
    function readFileAsBase64(file) { return new Promise((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result || '').split(',', 2)[1] || ''); reader.onerror = () => reject(reader.error || new Error('Datei konnte nicht gelesen werden.')); reader.readAsDataURL(file); }); }
    async function uploadFileJson(file) { const base64 = await readFileAsBase64(file); return postJson('/api/files/upload-json', { root: currentFileRoot, path: currentFilePath, filename: file.name, overwrite: false, content_base64: base64 }); }
    async function unzipFile(path) { if (!ensureWriteAllowed('Entpacken')) return; const destination = window.prompt('In welchen Ordner entpacken?', currentFilePath || '/'); if (destination === null) return; const overwrite = window.confirm('Vorhandene Dateien überschreiben?'); try { setFilesStatus('Entpacke ZIP...', 'warn'); const data = await postJson('/api/files/unzip', { root: currentFileRoot, path, destination, overwrite }); appendLine('[WinoMC Dateien] Entpackt: ' + data.files + ' Dateien, ' + data.directories + ' Ordner', 'ok'); setFilesStatus('ZIP entpackt', ''); await loadFileList(currentFilePath); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Entpacken fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }
    async function deleteFileEntry(path, name, permanent) { if (!ensureWriteAllowed(permanent ? 'Endgültig löschen' : 'Löschen')) return;
      const label = permanent ? 'endgültig löschen' : 'in den Papierkorb verschieben';
      if (!window.confirm('„' + name + '“ wirklich ' + label + '?')) return;
      try {
        setFilesStatus('Lösche...', 'warn');
        const data = await postJson('/api/files/delete', { root: currentFileRoot, path, permanent: Boolean(permanent) });
        appendLine('[WinoMC Dateien] ' + (data.message || 'Gelöscht: ' + path), 'ok');
        setFilesStatus('Gelöscht', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Löschen fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function restoreFileEntry(path, name, overwrite = false) { if (!ensureWriteAllowed('Wiederherstellen')) return;
      if (!overwrite && !window.confirm('„' + name + '“ aus dem Papierkorb wiederherstellen?')) return;
      try {
        setFilesStatus('Stelle wieder her...', 'warn');
        const data = await postJson('/api/files/trash/restore', { path, overwrite: Boolean(overwrite) });
        appendLine('[WinoMC Dateien] ' + (data.message || 'Wiederhergestellt: ' + path), 'ok');
        setFilesStatus('Wiederhergestellt', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        const message = String(err.message || '');
        if (!overwrite && message.includes('Ziel existiert bereits') && window.confirm('Ziel existiert bereits. Überschreiben und wiederherstellen?')) {
          await restoreFileEntry(path, name, true);
          return;
        }
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Wiederherstellen fehlgeschlagen: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function emptyTrash() { if (!ensureWriteAllowed('Papierkorb leeren')) return;
      if (!window.confirm('Papierkorb wirklich endgültig leeren?')) return;
      try {
        setFilesStatus('Leere Papierkorb...', 'warn');
        const data = await postJson('/api/files/trash/empty', {});
        appendLine('[WinoMC Dateien] Papierkorb geleert: ' + data.removed + ' Einträge', 'ok');
        setFilesStatus('Papierkorb geleert', '');
        await loadFileList(currentFilePath);
      } catch (err) {
        setFilesStatus('Fehler', 'warn');
        appendLine('[WinoMC Dateien] Papierkorb konnte nicht geleert werden: ' + err.message, 'error');
        alert(err.message);
      }
    }

    async function runSafeWorldExport() { if (!ensureWriteAllowed('Sicherer Welt-Export')) return; const defaultWorld = latestStatus && latestStatus.env && latestStatus.env.LEVEL_NAME ? '/' + latestStatus.env.LEVEL_NAME : '/world'; const worldPath = window.prompt('Welche Welt sicher exportieren?', defaultWorld); if (!worldPath) return; if (!window.confirm('Sicheren Welt-Export starten?\n\nAblauf: save hold → save query → ZIP → save resume')) return; try { setFilesStatus('Welt-Export läuft...', 'warn'); const data = await postJson('/api/worlds/export-safe', { path: worldPath, save_to_export: true }); appendLine('[WinoMC Dateien] Sicherer Welt-Export erstellt: ' + data.filename, 'ok'); setFilesStatus('Welt exportiert', ''); } catch (err) { setFilesStatus('Fehler', 'warn'); appendLine('[WinoMC Dateien] Welt-Export fehlgeschlagen: ' + err.message, 'error'); alert(err.message); } }

    form.addEventListener('submit', event => { event.preventDefault(); sendCommand(input.value); });
    document.addEventListener('click', event => { const actionBtn = event.target.closest('[data-action-id]'); if (actionBtn) { runAction(ACTION_BY_ID[actionBtn.dataset.actionId]); return; } const jump = event.target.closest('[data-jump-tab]'); if (jump) { activateTab(jump.dataset.jumpTab); return; } const openRootBtn = event.target.closest('[data-open-root]'); if (openRootBtn) { openRoot(openRootBtn.dataset.openRoot, '/'); return; } });
    document.querySelectorAll('[data-tab]').forEach(button => button.addEventListener('click', () => activateTab(button.dataset.tab)));
    document.querySelectorAll('[data-console-size]').forEach(button => button.addEventListener('click', () => applyConsoleSize(button.dataset.consoleSize)));
    sidebarToggle.addEventListener('click', toggleSidebar);
    resetWorkbenchLayout.addEventListener('click', resetWorkbench);
    if (consoleCollapse) consoleCollapse.addEventListener('click', () => setConsoleMode(document.body.classList.contains('console-collapsed') ? 'normal' : 'collapsed'));
    if (consoleDesktopClose) consoleDesktopClose.addEventListener('click', () => minimizeDesktopWindow('console'));
    if (consoleMinimize) consoleMinimize.addEventListener('click', () => minimizeDesktopWindow('console'));
    if (consoleMaximize) consoleMaximize.addEventListener('click', () => setConsoleMode(document.body.classList.contains('console-maximized') ? 'normal' : 'maximized'));
    editorFullscreen.addEventListener('click', toggleEditorFullscreen);
    editorWrapToggle.addEventListener('click', toggleEditorWrap);
    editorFontPlus.addEventListener('click', () => changeEditorFont(1));
    editorFontMinus.addEventListener('click', () => changeEditorFont(-1));
    dashboardColumns.addEventListener('change', () => { localStorage.setItem(STORE_COLUMNS, dashboardColumns.value); renderDashboard(); });
    resetDashboard.addEventListener('click', () => { dashboardActions = [...DEFAULT_DASHBOARD]; saveDashboard(); renderDashboard(); });
    if (dashboardActionSearch) dashboardActionSearch.addEventListener('input', renderActionPicker);
    if (dashboardActionSelect) dashboardActionSelect.addEventListener('change', updateDashboardActionPreview);
    if (dashboardAddSelected) dashboardAddSelected.addEventListener('click', () => { if (dashboardActionSelect && dashboardActionSelect.value) addDashboardAction(dashboardActionSelect.value); });
    clearLog.addEventListener('click', () => { log.innerHTML = ''; appendLine('[WinoMC Console] Anzeige geleert. Der echte Server-Log bleibt erhalten.', 'ok'); });
    focusConsoleInput.addEventListener('click', () => input.focus());
    modalCancel.addEventListener('click', closePrompt); modalSend.addEventListener('click', sendPromptValue); modalBackdrop.addEventListener('click', event => { if (event.target === modalBackdrop) closePrompt(); }); modalInput.addEventListener('keydown', event => { if (event.key === 'Enter') sendPromptValue(); if (event.key === 'Escape') closePrompt(); });
    input.addEventListener('keydown', event => { if (event.key === 'ArrowUp') { if (historyIndex > 0) historyIndex--; input.value = history[historyIndex] || input.value; event.preventDefault(); } if (event.key === 'ArrowDown') { if (historyIndex < history.length) historyIndex++; input.value = history[historyIndex] || ''; event.preventDefault(); } });
    fileRootSelect.addEventListener('change', () => { currentFileRoot = fileRootSelect.value; currentFilePath = '/'; clearEditor(); loadFileList('/'); });
    fileOpenPath.addEventListener('click', () => loadFileList(filePathInput.value));
    filePathInput.addEventListener('keydown', event => { if (event.key === 'Enter') loadFileList(filePathInput.value); });
    fileRefresh.addEventListener('click', () => loadFileList(currentFilePath));
    if (fileRefreshExplorer) fileRefreshExplorer.addEventListener('click', () => loadFileList(currentFilePath));
    if (fileOpenTrash) fileOpenTrash.addEventListener('click', () => openRoot('trash', '/'));
    if (fileOpenTrashExplorer) fileOpenTrashExplorer.addEventListener('click', () => openRoot('trash', '/'));
    if (fileEmptyTrash) { fileEmptyTrash.dataset.writeAction = 'true'; fileEmptyTrash.addEventListener('click', emptyTrash); }
    if (fileWriteLockToggle) fileWriteLockToggle.addEventListener('click', () => { webWriteLocked = !webWriteLocked; applyWebWriteLock(); });
    if (trashRetentionSelect) trashRetentionSelect.addEventListener('change', () => saveTrashSettings(trashRetentionSelect.value));
    fileParent.addEventListener('click', () => loadFileList(parentUiPath(currentFilePath)));
    fileZipCurrent.addEventListener('click', () => downloadZip(currentFilePath));
    fileZipExportCurrent.addEventListener('click', () => saveZipToExport(currentFilePath));
    safeWorldExport.addEventListener('click', runSafeWorldExport); backupSafeWorldExport.addEventListener('click', runSafeWorldExport);
    fileSave.addEventListener('click', saveEditorFile); fileCloseEditor.addEventListener('click', clearEditor);
    fileDropZone.addEventListener('click', () => { if (ensureWriteAllowed('Upload')) fileUploadInput.click(); });
    fileUploadInput.addEventListener('change', () => { uploadFiles(fileUploadInput.files); fileUploadInput.value = ''; });
    fileDropZone.addEventListener('dragover', event => { event.preventDefault(); fileDropZone.classList.add('dragover'); });
    fileDropZone.addEventListener('dragleave', () => fileDropZone.classList.remove('dragover'));
    fileDropZone.addEventListener('drop', event => { event.preventDefault(); fileDropZone.classList.remove('dragover'); uploadFiles(event.dataTransfer.files); });


    function clamp(value, min, max) { return Math.min(max, Math.max(min, value)); }
    function getStoredJson(key, fallback) { try { const value = JSON.parse(localStorage.getItem(key) || 'null'); return value ?? fallback; } catch (_) { return fallback; } }
    function setRootVar(name, value) { document.documentElement.style.setProperty(name, value); }

    function applySidebarState() {
      const collapsed = localStorage.getItem(STORE_SIDEBAR_COLLAPSED) === 'true';
      document.body.classList.toggle('sidebar-collapsed', collapsed);
      if (collapsed) requestAnimationFrame(scrollActiveSidebarIconIntoView);
    }

    function scrollActiveSidebarIconIntoView() {
      const nav = document.querySelector('nav[aria-label="WinoMC Menü"]');
      const active = nav && nav.querySelector('.tab-button.active');
      if (!nav || !active || !document.body.classList.contains('sidebar-collapsed')) return;
      const navRect = nav.getBoundingClientRect();
      const activeRect = active.getBoundingClientRect();
      if (activeRect.top < navRect.top + 8 || activeRect.bottom > navRect.bottom - 8) {
        active.scrollIntoView({ block: 'nearest', inline: 'nearest' });
      }
    }

    function toggleSidebar() {
      const next = !(localStorage.getItem(STORE_SIDEBAR_COLLAPSED) === 'true');
      localStorage.setItem(STORE_SIDEBAR_COLLAPSED, String(next));
      applySidebarState();
    }

    function isDesktopModeActive() {
      return document.body.classList.contains('desktop-mode');
    }

    function setConsoleMode(mode) {
      document.body.classList.remove('console-collapsed', 'console-hidden', 'console-maximized', 'console-compact', 'console-large');
      if (mode === 'collapsed') document.body.classList.add('console-collapsed');
      if (mode === 'hidden') document.body.classList.add('console-hidden');
      if (mode === 'maximized') document.body.classList.add('console-maximized');
      if (mode === 'compact') document.body.classList.add('console-compact');
      if (mode === 'large') document.body.classList.add('console-large');
      localStorage.setItem(STORE_CONSOLE_SIZE, mode);

      if (mode === 'normal') {
        const stored = Number(localStorage.getItem(STORE_CONSOLE_HEIGHT) || 330);
        if (!isDesktopModeActive()) {
          setRootVar('--console-height', clamp(stored, 180, Math.round(window.innerHeight * 0.82)) + 'px');
        }
      } else if (mode === 'compact' || mode === 'large') {
        if (!isDesktopModeActive()) document.documentElement.style.removeProperty('--console-height');
      }

      if (consoleCollapse) consoleCollapse.textContent = mode === 'collapsed' ? 'Ausklappen' : 'Einklappen';
      if (consoleMaximize) consoleMaximize.textContent = document.body.classList.contains('desktop-mode') ? (mode === 'maximized' ? '❐' : '□') : (mode === 'maximized' ? 'Normal' : 'Max');
      if (consoleMinimize) consoleMinimize.textContent = document.body.classList.contains('desktop-mode') ? '–' : (mode === 'hidden' ? 'Einblenden' : 'Minimieren');
      updateDesktopTaskbar();
    }

    function applyConsoleSize(size) {
      setConsoleMode(size || 'normal');
    }

    function readDesktopConsoleRect() {
      return getStoredJson(STORE_DESKTOP_CONSOLE_RECT, null);
    }

    function saveDesktopConsoleRect() {
      if (!consoleDock || !isDesktopModeActive() || document.body.classList.contains('console-maximized') || document.body.classList.contains('console-hidden')) return;
      const rect = consoleDock.getBoundingClientRect();
      const data = {
        left: Math.round(rect.left),
        top: Math.round(rect.top),
        width: Math.round(rect.width),
        height: Math.round(rect.height)
      };
      localStorage.setItem(STORE_DESKTOP_CONSOLE_RECT, JSON.stringify(data));
      applyDesktopConsoleRect(data);
    }

    function applyDesktopConsoleRect(rect) {
      if (!rect) return;
      const safeWidth = clamp(Number(rect.width) || 760, Math.min(420, window.innerWidth - 18), Math.max(320, window.innerWidth - 18));
      const safeHeight = clamp(Number(rect.height) || 320, 86, Math.max(180, window.innerHeight - 72));
      const safeLeft = clamp(Number(rect.left) || 18, 8, Math.max(8, window.innerWidth - safeWidth - 8));
      const safeTop = clamp(Number(rect.top) || 80, 8, Math.max(8, window.innerHeight - safeHeight - 58));
      setRootVar('--desktop-console-left', safeLeft + 'px');
      setRootVar('--desktop-console-top', safeTop + 'px');
      setRootVar('--desktop-console-right', 'auto');
      setRootVar('--desktop-console-bottom', 'auto');
      setRootVar('--desktop-console-width', safeWidth + 'px');
      setRootVar('--desktop-console-height', safeHeight + 'px');
    }

    function ensureDesktopConsoleRect() {
      if (!consoleDock || !isDesktopModeActive() || isDesktopMobile()) return;
      const saved = readDesktopConsoleRect();
      if (saved) {
        applyDesktopConsoleRect(saved);
        return;
      }
      const width = Math.min(820, Math.max(520, window.innerWidth * 0.48));
      const height = Math.min(420, Math.max(280, window.innerHeight * 0.42));
      applyDesktopConsoleRect({
        left: window.innerWidth - width - 18,
        top: window.innerHeight - height - 58,
        width,
        height
      });
    }

    function bringConsoleToFront() {
      if (!consoleDock) return;
      desktopZ += 1;
      consoleDock.style.zIndex = String(desktopZ + 50);
      document.querySelectorAll('.desktop-task-button').forEach(btn => btn.classList.toggle('active', btn.dataset.windowId === 'console'));
    }

    function initConsoleResize() {
      if (!consoleResizeHandle) return;
      let startY = 0;
      let startHeight = 0;
      let startTop = 0;
      const onMove = event => {
        if (isDesktopModeActive() && !isDesktopMobile()) {
          const minHeight = 86;
          const maxHeight = Math.max(180, window.innerHeight - 72);
          const delta = event.clientY - startY;
          const nextHeight = clamp(startHeight - delta, minHeight, maxHeight);
          const nextTop = clamp(startTop + delta, 8, window.innerHeight - nextHeight - 58);
          const rect = consoleDock.getBoundingClientRect();
          applyDesktopConsoleRect({ left: rect.left, top: nextTop, width: rect.width, height: nextHeight });
          document.body.classList.remove('console-collapsed', 'console-hidden', 'console-maximized', 'console-compact', 'console-large');
          localStorage.setItem(STORE_CONSOLE_SIZE, 'normal');
          return;
        }
        const maxHeight = Math.round(window.innerHeight * 0.86);
        const minHeight = window.innerWidth <= 720 ? 170 : 190;
        const nextHeight = clamp(startHeight + (startY - event.clientY), minHeight, maxHeight);
        document.body.classList.remove('console-collapsed', 'console-hidden', 'console-maximized', 'console-compact', 'console-large');
        setRootVar('--console-height', nextHeight + 'px');
        localStorage.setItem(STORE_CONSOLE_HEIGHT, String(nextHeight));
        localStorage.setItem(STORE_CONSOLE_SIZE, 'normal');
      };
      const onUp = () => {
        consoleResizeHandle.classList.remove('dragging');
        consoleDock?.classList.remove('desktop-console-resizing');
        saveDesktopConsoleRect();
        window.removeEventListener('pointermove', onMove);
        window.removeEventListener('pointerup', onUp);
      };
      consoleResizeHandle.addEventListener('pointerdown', event => {
        event.preventDefault();
        startY = event.clientY;
        startHeight = consoleDock ? consoleDock.getBoundingClientRect().height : 330;
        startTop = consoleDock ? consoleDock.getBoundingClientRect().top : 0;
        consoleResizeHandle.classList.add('dragging');
        if (isDesktopModeActive()) {
          bringConsoleToFront();
          consoleDock?.classList.add('desktop-console-resizing');
        }
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
      });
    }

    function initDesktopConsoleWindow() {
      if (!consoleDock || !consoleHead) return;
      consoleHead.addEventListener('pointerdown', event => {
        if (!isDesktopModeActive() || isDesktopMobile()) return;
        if (event.target.closest('button, input, select, textarea')) return;
        if (document.body.classList.contains('console-maximized')) return;
        event.preventDefault();
        bringConsoleToFront();
        const startX = event.clientX;
        const startY = event.clientY;
        const rect = consoleDock.getBoundingClientRect();
        consoleDock.classList.add('desktop-console-dragging');
        const onMove = moveEvent => {
          const nextLeft = clamp(rect.left + moveEvent.clientX - startX, 8, window.innerWidth - rect.width - 8);
          const nextTop = clamp(rect.top + moveEvent.clientY - startY, 8, window.innerHeight - rect.height - 58);
          applyDesktopConsoleRect({ left: nextLeft, top: nextTop, width: rect.width, height: rect.height });
        };
        const onUp = () => {
          consoleDock.classList.remove('desktop-console-dragging');
          saveDesktopConsoleRect();
          window.removeEventListener('pointermove', onMove);
          window.removeEventListener('pointerup', onUp);
        };
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
      });

      if ('ResizeObserver' in window) {
        let timer = null;
        const observer = new ResizeObserver(() => {
          if (!isDesktopModeActive() || isDesktopMobile() || document.body.classList.contains('console-maximized')) return;
          clearTimeout(timer);
          timer = setTimeout(saveDesktopConsoleRect, 250);
        });
        observer.observe(consoleDock);
      }

      consoleDock.addEventListener('pointerdown', () => {
        if (isDesktopModeActive()) bringConsoleToFront();
      });
    }

    function initFileSplitResize() {
      const stored = localStorage.getItem(STORE_FILES_SPLIT);
      if (stored) setRootVar('--files-left-width', stored + '%');
      if (!filesSplitHandle || !fileManagerGrid) return;
      let rect = null;
      const onMove = event => {
        if (window.innerWidth <= 1050 || !rect) return;
        const percent = clamp(((event.clientX - rect.left) / rect.width) * 100, 30, 72);
        setRootVar('--files-left-width', percent.toFixed(1) + '%');
        localStorage.setItem(STORE_FILES_SPLIT, percent.toFixed(1));
      };
      const onUp = () => {
        filesSplitHandle.classList.remove('dragging');
        window.removeEventListener('pointermove', onMove);
        window.removeEventListener('pointerup', onUp);
      };
      filesSplitHandle.addEventListener('pointerdown', event => {
        if (window.innerWidth <= 1050) return;
        event.preventDefault();
        rect = fileManagerGrid.getBoundingClientRect();
        filesSplitHandle.classList.add('dragging');
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
      });
    }

    function applyEditorPrefs() {
      const font = Number(localStorage.getItem(STORE_EDITOR_FONT) || 13);
      fileEditor.style.fontSize = clamp(font, 11, 22) + 'px';
      const wrap = localStorage.getItem(STORE_EDITOR_WRAP) !== 'off';
      fileEditor.classList.toggle('nowrap', !wrap);
      fileEditor.setAttribute('wrap', wrap ? 'soft' : 'off');
      if (editorWrapToggle) editorWrapToggle.textContent = wrap ? 'Umbruch aus' : 'Umbruch an';
    }

    function changeEditorFont(delta) {
      const current = Number(localStorage.getItem(STORE_EDITOR_FONT) || 13);
      localStorage.setItem(STORE_EDITOR_FONT, String(clamp(current + delta, 11, 22)));
      applyEditorPrefs();
    }

    function toggleEditorWrap() {
      const wrap = localStorage.getItem(STORE_EDITOR_WRAP) !== 'off';
      localStorage.setItem(STORE_EDITOR_WRAP, wrap ? 'off' : 'on');
      applyEditorPrefs();
    }

    function toggleEditorFullscreen() {
      editorPanel.classList.toggle('editor-fullscreen');
      if (editorFullscreen) editorFullscreen.textContent = editorPanel.classList.contains('editor-fullscreen') ? 'Vollbild schließen' : 'Editor Vollbild';
    }

    function cardIdFor(card, index) {
      if (card.dataset.cardId) return card.dataset.cardId;
      const heading = card.querySelector('h2, h3');
      const base = (heading ? heading.textContent : 'card-' + index).toLowerCase().replace(/[^a-z0-9äöüß]+/g, '-').replace(/^-+|-+$/g, '');
      card.dataset.cardId = base || ('card-' + index);
      return card.dataset.cardId;
    }

    function initCardChrome() {
      // v1.5.4 fix: the old dynamic card chrome added window buttons to every
      // classic dashboard card and could permanently hide content via localStorage.
      // Keep cards visible by default and only add safe module controls to explicitly
      // marked file-manager cards. Desktop windows themselves still use their own bar.
      localStorage.removeItem(STORE_HIDDEN_CARDS);
      document.body.classList.remove('has-maximized-card');
      document.querySelectorAll('.card').forEach(card => {
        card.style.display = '';
        card.classList.remove('maximized');
        const existing = card.querySelector(':scope > .card-header .card-tools');
        if (existing) existing.remove();
      });

      document.querySelectorAll('.card[data-card-id="files-explorer"], .card[data-card-id="files-editor"]').forEach(card => {
        const header = card.querySelector(':scope > .card-header');
        if (!header || header.querySelector('.card-tools')) return;
        const tools = document.createElement('div');
        tools.className = 'card-tools';

        const collapse = document.createElement('button');
        collapse.type = 'button';
        collapse.title = 'Modul einklappen';
        collapse.textContent = '–';
        collapse.addEventListener('click', event => {
          event.stopPropagation();
          card.classList.toggle('collapsed');
          collapse.textContent = card.classList.contains('collapsed') ? '+' : '–';
        });

        const maximize = document.createElement('button');
        maximize.type = 'button';
        maximize.title = 'Modul maximieren';
        maximize.textContent = '□';
        maximize.addEventListener('click', event => {
          event.stopPropagation();
          if (!document.body.classList.contains('desktop-mode')) return;
          const active = card.classList.toggle('maximized');
          document.body.classList.toggle('has-maximized-card', active);
          maximize.textContent = active ? '❐' : '□';
        });

        tools.append(collapse, maximize);
        header.appendChild(tools);
      });
    }

    function resetWorkbench() {
      ['winomcConsoleHeightV1','winomcConsoleSizeV1','winomcSidebarCollapsedV1','winomcFilesSplitV1','winomcHiddenCardsV1','winomcEditorFontV1','winomcEditorWrapV1','winomcDesktopModeV1','winomcDesktopWindowsV1','winomcDesktopPositionsV1','winomcDesktopConsoleRectV1'].forEach(key => localStorage.removeItem(key));
      document.documentElement.style.removeProperty('--console-height');
      document.documentElement.style.removeProperty('--files-left-width');
      document.body.classList.remove('sidebar-collapsed', 'console-collapsed', 'console-hidden', 'console-maximized', 'console-compact', 'console-large', 'has-maximized-card', 'desktop-mode');
      document.querySelectorAll('.card').forEach(card => { card.style.display = ''; card.classList.remove('collapsed', 'maximized'); }); document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('desktop-open', 'desktop-minimized', 'desktop-maximized'));
      applyConsoleSize('normal');
      applyEditorPrefs();
      alert('Workbench-Layout zurückgesetzt.');
    }



    const DESKTOP_MODULES = [
      { id: 'overview', title: 'Übersicht', icon: '🏠' },
      { id: 'dashboard', title: 'Mein Dashboard', icon: '🧩' },
      { id: 'console', title: 'Konsole', icon: '💻' },
      { id: 'server', title: 'Server', icon: '🌍' },
      { id: 'packs', title: 'Packs & Add-ons', icon: '📦' },
      { id: 'backups', title: 'Backups', icon: '💾' },
      { id: 'network', title: 'Netzwerk', icon: '🛜' },
      { id: 'files', title: 'Dateien', icon: '📁' },
      { id: 'expert', title: 'Experten', icon: '🧰' }
    ];
    const DESKTOP_BY_ID = Object.fromEntries(DESKTOP_MODULES.map(item => [item.id, item]));
    let desktopZ = 100;

    function isDesktopMobile() {
      return window.matchMedia('(max-width: 850px)').matches;
    }

    function desktopOpenIds() {
      return getStoredJson(STORE_DESKTOP_WINDOWS, ['overview']);
    }

    function saveDesktopOpenIds(ids) {
      localStorage.setItem(STORE_DESKTOP_WINDOWS, JSON.stringify([...new Set(ids)]));
    }

    function desktopPositions() {
      return getStoredJson(STORE_DESKTOP_POSITIONS, {});
    }

    function saveDesktopPosition(id, panel) {
      if (!id || isDesktopMobile() || panel.classList.contains('desktop-maximized')) return;
      const positions = desktopPositions();
      positions[id] = {
        left: panel.style.left,
        top: panel.style.top,
        width: panel.style.width,
        height: panel.style.height
      };
      localStorage.setItem(STORE_DESKTOP_POSITIONS, JSON.stringify(positions));
    }

    function desktopDefaultRect(id) {
      const index = DESKTOP_MODULES.findIndex(item => item.id === id);
      const offset = Math.max(0, index) * 26;
      const width = Math.min(980, Math.max(560, window.innerWidth - 240));
      const height = Math.min(660, Math.max(360, window.innerHeight - 160));
      return {
        left: 140 + offset + 'px',
        top: 68 + offset + 'px',
        width: width + 'px',
        height: height + 'px'
      };
    }

    function ensureDesktopWindowBar(panel, id) {
      if (!panel || panel.querySelector(':scope > .desktop-window-bar')) return;
      const meta = DESKTOP_BY_ID[id] || { title: id, icon: '🪟' };
      const bar = document.createElement('div');
      bar.className = 'desktop-window-bar';
      bar.innerHTML = '<div class="desktop-window-title"><span>' + meta.icon + '</span><span>' + escapeHtml(meta.title) + '</span></div><div class="desktop-window-actions"><button type="button" data-window-action="minimize" title="Minimieren">–</button><button type="button" data-window-action="maximize" title="Maximieren">□</button><button type="button" data-window-action="close" title="Schließen">×</button></div>';
      panel.prepend(bar);

      bar.addEventListener('pointerdown', event => {
        if (event.target.closest('button') || isDesktopMobile() || panel.classList.contains('desktop-maximized')) return;
        event.preventDefault();
        bringDesktopWindowToFront(id);
        const startX = event.clientX;
        const startY = event.clientY;
        const rect = panel.getBoundingClientRect();
        const onMove = moveEvent => {
          const nextLeft = clamp(rect.left + moveEvent.clientX - startX, 6, window.innerWidth - 120);
          const nextTop = clamp(rect.top + moveEvent.clientY - startY, 6, window.innerHeight - 110);
          panel.style.left = nextLeft + 'px';
          panel.style.top = nextTop + 'px';
        };
        const onUp = () => {
          window.removeEventListener('pointermove', onMove);
          window.removeEventListener('pointerup', onUp);
          saveDesktopPosition(id, panel);
        };
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
      });

      bar.querySelector('[data-window-action="minimize"]').addEventListener('click', () => minimizeDesktopWindow(id));
      bar.querySelector('[data-window-action="maximize"]').addEventListener('click', () => toggleDesktopMaximize(id));
      bar.querySelector('[data-window-action="close"]').addEventListener('click', () => closeDesktopWindow(id));
    }

    function bringDesktopWindowToFront(id) {
      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel) return;
      desktopZ += 1;
      panel.style.zIndex = String(desktopZ);
      document.querySelectorAll('.desktop-task-button').forEach(btn => btn.classList.toggle('active', btn.dataset.windowId === id));
    }

    function openDesktopWindow(id) {
      if (id === 'console') {
        setConsoleMode('normal');
        ensureDesktopConsoleRect();
        bringConsoleToFront();
        const ids = desktopOpenIds();
        if (!ids.includes('console')) ids.push('console');
        saveDesktopOpenIds(ids);
        updateDesktopTaskbar();
        setTimeout(() => input?.focus(), 0);
        return;
      }

      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel) return;

      if (isDesktopMobile()) {
        document.querySelectorAll('.tab-panel.desktop-open').forEach(item => {
          if (item !== panel) item.classList.remove('desktop-open', 'desktop-minimized');
        });
      }

      ensureDesktopWindowBar(panel, id);
      panel.classList.add('desktop-open');
      panel.classList.remove('desktop-minimized');

      if (!isDesktopMobile() && !panel.dataset.desktopPlaced) {
        const positions = desktopPositions();
        const rect = positions[id] || desktopDefaultRect(id);
        panel.style.left = rect.left;
        panel.style.top = rect.top;
        panel.style.width = rect.width;
        panel.style.height = rect.height;
        panel.dataset.desktopPlaced = 'true';
      }

      const ids = desktopOpenIds();
      if (!ids.includes(id)) ids.push(id);
      saveDesktopOpenIds(ids);

      if (id === 'files') initFileManager();
      if (id === 'overview' || id === 'network') loadStatus();
      bringDesktopWindowToFront(id);
      updateDesktopTaskbar();
    }

    function minimizeDesktopWindow(id) {
      if (id === 'console') {
        if (!isDesktopModeActive()) {
          setConsoleMode('collapsed');
        } else {
          setConsoleMode('hidden');
          const ids = desktopOpenIds();
          if (!ids.includes('console')) ids.push('console');
          saveDesktopOpenIds(ids);
          updateDesktopTaskbar();
        }
        return;
      }
      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel) return;
      panel.classList.add('desktop-minimized');
      updateDesktopTaskbar();
    }

    function restoreDesktopWindow(id) {
      if (id === 'console') {
        openDesktopWindow('console');
        return;
      }
      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel || !panel.classList.contains('desktop-open')) {
        openDesktopWindow(id);
        return;
      }
      panel.classList.remove('desktop-minimized');
      bringDesktopWindowToFront(id);
      updateDesktopTaskbar();
    }

    function closeDesktopWindow(id) {
      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel) return;
      panel.classList.remove('desktop-open', 'desktop-minimized', 'desktop-maximized');
      saveDesktopOpenIds(desktopOpenIds().filter(item => item !== id));
      updateDesktopTaskbar();
    }

    function toggleDesktopMaximize(id) {
      if (id === 'console') {
        setConsoleMode(document.body.classList.contains('console-maximized') ? 'normal' : 'maximized');
        if (!document.body.classList.contains('console-maximized')) ensureDesktopConsoleRect();
        bringConsoleToFront();
        return;
      }
      const panel = document.querySelector('[data-panel="' + id + '"]');
      if (!panel) return;
      if (!panel.classList.contains('desktop-maximized')) saveDesktopPosition(id, panel);
      panel.classList.toggle('desktop-maximized');
      const button = panel.querySelector('[data-window-action="maximize"]');
      if (button) button.textContent = panel.classList.contains('desktop-maximized') ? '❐' : '□';
      bringDesktopWindowToFront(id);
    }

    function updateDesktopTaskbar() {
      if (!desktopTaskButtons) return;
      desktopTaskButtons.innerHTML = '';
      desktopOpenIds().forEach(id => {
        if (id === 'console') {
          const meta = DESKTOP_BY_ID[id] || { title: 'Konsole', icon: '💻' };
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'desktop-task-button';
          btn.dataset.windowId = id;
          btn.textContent = meta.icon + ' ' + meta.title;
          btn.classList.toggle('active', !document.body.classList.contains('console-hidden'));
          btn.addEventListener('click', () => {
            if (document.body.classList.contains('console-hidden')) restoreDesktopWindow('console');
            else minimizeDesktopWindow('console');
          });
          desktopTaskButtons.appendChild(btn);
          return;
        }
        const panel = document.querySelector('[data-panel="' + id + '"]');
        if (!panel || !panel.classList.contains('desktop-open')) return;
        const meta = DESKTOP_BY_ID[id] || { title: id, icon: '🪟' };
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'desktop-task-button';
        btn.dataset.windowId = id;
        btn.textContent = meta.icon + ' ' + meta.title;
        btn.addEventListener('click', () => {
          if (panel.classList.contains('desktop-minimized')) restoreDesktopWindow(id);
          else minimizeDesktopWindow(id);
        });
        desktopTaskButtons.appendChild(btn);
      });
    }

    function renderDesktopStartMenu() {
      if (!desktopStartMenu) return;
      desktopStartMenu.innerHTML = '';
      DESKTOP_MODULES.forEach(meta => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.innerHTML = '<span>' + meta.icon + '</span><span>' + escapeHtml(meta.title) + '</span>';
        btn.addEventListener('click', () => {
          desktopStartMenu.classList.remove('open');
          openDesktopWindow(meta.id);
        });
        desktopStartMenu.appendChild(btn);
      });
      const divider = document.createElement('div');
      divider.style.height = '1px';
      divider.style.background = 'rgba(148,163,184,.18)';
      divider.style.margin = '6px 0';
      desktopStartMenu.appendChild(divider);
      const classic = document.createElement('button');
      classic.type = 'button';
      classic.innerHTML = '<span>↩</span><span>Klassische Ansicht</span>';
      classic.addEventListener('click', () => setDesktopMode(false));
      desktopStartMenu.appendChild(classic);
    }

    function setDesktopMode(enabled) {
      document.body.classList.toggle('desktop-mode', enabled);
      localStorage.setItem(STORE_DESKTOP_MODE, enabled ? 'true' : 'false');
      if (desktopModeToggle) desktopModeToggle.textContent = enabled ? 'Klassische Ansicht' : 'Desktop-Modus';
      setConsoleMode(localStorage.getItem(STORE_CONSOLE_SIZE) || 'normal');
      if (enabled) {
        renderDesktopStartMenu();
        ensureDesktopConsoleRect();
        const ids = desktopOpenIds();
        if (!ids.length) ids.push('overview');
        ids.forEach(openDesktopWindow);
        if (!document.querySelector('.tab-panel.desktop-open')) openDesktopWindow('overview');
        updateDesktopClock();
      } else {
        desktopStartMenu?.classList.remove('open');
        document.body.classList.remove('has-maximized-card');
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('desktop-open', 'desktop-minimized', 'desktop-maximized'));
        document.querySelectorAll('.card').forEach(card => card.classList.remove('maximized'));
        if (document.body.classList.contains('console-hidden')) setConsoleMode('normal');
        updateDesktopTaskbar();
      }
    }

    function toggleDesktopMode() {
      setDesktopMode(!document.body.classList.contains('desktop-mode'));
    }

    function updateDesktopClock() {
      if (!desktopClock) return;
      desktopClock.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function initDesktopWorkbench() {
      renderDesktopStartMenu();
      document.querySelectorAll('[data-open-window]').forEach(button => button.addEventListener('click', () => openDesktopWindow(button.dataset.openWindow)));
      if (desktopModeToggle) desktopModeToggle.addEventListener('click', toggleDesktopMode);
      if (desktopExitButton) desktopExitButton.addEventListener('click', () => setDesktopMode(false));
      if (desktopStartButton) desktopStartButton.addEventListener('click', () => desktopStartMenu.classList.toggle('open'));
      document.addEventListener('click', event => {
        if (!event.target.closest('.desktop-start-wrap')) desktopStartMenu?.classList.remove('open');
      });
      document.querySelectorAll('.tab-panel').forEach(panel => {
        panel.addEventListener('pointerdown', () => {
          if (document.body.classList.contains('desktop-mode')) bringDesktopWindowToFront(panel.dataset.panel);
        });
      });
      setInterval(updateDesktopClock, 15000);
      updateDesktopClock();
      if (localStorage.getItem(STORE_DESKTOP_MODE) === 'true') setDesktopMode(true);
    }

    function connectLogs() { const source = new EventSource('./api/logs'); source.onopen = () => { statusEl.textContent = 'Live verbunden'; statusDot.classList.add('ok'); }; source.onmessage = event => { try { const data = JSON.parse(event.data); if (data.line) appendLine(data.line); } catch (_) {} }; source.onerror = () => { statusEl.textContent = 'Verbindung wird neu aufgebaut...'; statusDot.classList.remove('ok'); }; }
    applySidebarState(); applyConsoleSize(localStorage.getItem(STORE_CONSOLE_SIZE) || 'normal'); applyEditorPrefs(); initConsoleResize();
    initDesktopConsoleWindow(); initFileSplitResize(); initCardChrome(); initDesktopWorkbench(); renderDashboard(); connectLogs(); loadStatus();
  </script>
</body>
</html>
"""


def ensure_directories():
    for path in (DATA_DIR, WORLDS_DIR, RESOURCE_PACKS_DIR, BEHAVIOR_PACKS_DIR, WORLD_TEMPLATES_DIR, IMPORT_DIR, EXPORT_DIR, FILE_BACKUP_DIR, TRASH_DIR):
        try:
            os.makedirs(path, exist_ok=True)
        except Exception:
            pass


def client_allowed(client_ip):
    if not ALLOWED_PROXIES:
        return True
    return client_ip in ALLOWED_PROXIES


def read_recent_lines(path, limit):
    lines = deque(maxlen=max(1, limit))
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                lines.append(line.rstrip("\n"))
    except FileNotFoundError:
        return []
    return list(lines)


def sanitize_command(command):
    command = str(command or "").replace("\x00", "").strip()
    if command.startswith("/"):
        command = command[1:].strip()
    command = "".join(ch for ch in command if ch == "\t" or ord(ch) >= 32)
    if len(command) > MAX_COMMAND_LENGTH:
        raise ValueError("Befehl ist zu lang. Maximum: %s Zeichen." % MAX_COMMAND_LENGTH)
    if not command:
        raise ValueError("Leerer Befehl.")
    return command


def write_command(command):
    if not os.path.exists(FIFO_PATH):
        raise RuntimeError("Console FIFO existiert noch nicht. Läuft der Bedrock Server bereits?")
    if not os.path.exists(LOG_PATH):
        open(LOG_PATH, "a", encoding="utf-8").close()
    fd = os.open(FIFO_PATH, os.O_WRONLY | os.O_NONBLOCK)
    try:
        os.write(fd, (command + "\n").encode("utf-8"))
    finally:
        os.close(fd)
    append_console_note("> " + command)


def append_console_note(message):
    try:
        with open(LOG_PATH, "a", encoding="utf-8", errors="replace") as log_handle:
            log_handle.write("[WinoMC Console] %s\n" % message)
    except Exception:
        pass


def normalize_rel_path(rel_path):
    rel_path = unquote(str(rel_path or "/")).replace("\\", "/").replace("\x00", "")
    rel_path = posixpath.normpath("/" + rel_path.lstrip("/"))
    if rel_path == "/.":
        rel_path = "/"
    return rel_path


def is_inside_base(base_path, candidate_path):
    base_path = os.path.realpath(base_path)
    candidate_path = os.path.realpath(candidate_path)
    return candidate_path == base_path or candidate_path.startswith(base_path + os.sep)


def resolve_safe_path(root_key, rel_path="/"):
    if root_key not in FILE_ROOTS:
        raise ValueError("Unbekannter Dateibereich.")
    rel_path = normalize_rel_path(rel_path)
    base_path = os.path.realpath(FILE_ROOTS[root_key]["path"])
    candidate_path = os.path.realpath(os.path.join(base_path, rel_path.lstrip("/")))
    if not is_inside_base(base_path, candidate_path):
        raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
    return candidate_path, rel_path


def safe_download_name(name, fallback="winomc-download"):
    name = str(name or fallback).strip()
    name = re.sub(r"[^A-Za-z0-9._-]+", "_", name)
    name = name.strip("._-")
    return name or fallback


def parse_bool(value, default=False):
    if value is None:
        return default
    return str(value).strip().lower() in ("1", "true", "yes", "on", "ja")


def file_extension(path):
    return os.path.splitext(str(path or ""))[1].lower()


def is_editable_text_file(path):
    name = os.path.basename(path).lower()
    ext = file_extension(path)
    if ext in EDITABLE_TEXT_EXTENSIONS:
        return True
    return name in {
        "server.properties", "allowlist.json", "permissions.json", "valid_known_packs.json",
        "world_resource_packs.json", "world_behavior_packs.json", "manifest.json"
    }


def validate_json_if_needed(path, content):
    if file_extension(path) not in JSON_EXTENSIONS:
        return
    try:
        json.loads(content or "")
    except json.JSONDecodeError as exc:
        raise ValueError("JSON ist ungültig: Zeile %s, Spalte %s: %s" % (exc.lineno, exc.colno, exc.msg))


def make_file_backup(file_path, root_key, rel_path):
    if not os.path.exists(file_path) or not os.path.isfile(file_path):
        return None
    os.makedirs(FILE_BACKUP_DIR, exist_ok=True)
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    rel_name = normalize_rel_path(rel_path).replace("/", "__")
    backup_name = safe_download_name("%s-%s-%s" % (timestamp, root_key, rel_name), "winomc-file-backup")
    backup_path = os.path.join(FILE_BACKUP_DIR, backup_name)
    if os.path.exists(backup_path):
        backup_path += ".bak"
    shutil.copy2(file_path, backup_path)
    return backup_path


def list_file_roots():
    cleanup_trash()
    roots = []
    for key, info in FILE_ROOTS.items():
        path = os.path.realpath(info["path"])
        roots.append({"key": key, "label": info["label"], "description": info.get("description", ""), "path": path, "exists": os.path.exists(path), "readable": os.path.isdir(path) and os.access(path, os.R_OK)})
    return roots


def list_directory(root_key, rel_path="/"):
    full_path, rel_path = resolve_safe_path(root_key, rel_path)
    if not os.path.exists(full_path):
        raise FileNotFoundError("Pfad existiert nicht.")
    if not os.path.isdir(full_path):
        raise ValueError("Pfad ist kein Ordner.")
    root_base = os.path.realpath(FILE_ROOTS[root_key]["path"])
    entries = []
    for name in sorted(os.listdir(full_path), key=lambda item: item.lower()):
        if root_key == "trash" and name.endswith(".winomc-trash.json"):
            continue
        child_path = os.path.join(full_path, name)
        if os.path.islink(child_path):
            continue
        if not is_inside_base(root_base, child_path):
            continue
        try:
            stat = os.stat(child_path)
        except OSError:
            continue
        is_dir = os.path.isdir(child_path)
        child_rel_path = normalize_rel_path(posixpath.join(rel_path, name))
        entry = {"name": name, "path": child_rel_path, "type": "directory" if is_dir else "file", "size": stat.st_size, "modified": int(stat.st_mtime), "downloadable": not is_dir, "zipable": True, "editable": (not is_dir and is_editable_text_file(child_path)), "extractable": (not is_dir and file_extension(child_path) in ZIP_EXTENSIONS)}
        if root_key == "trash":
            meta_path = child_path + ".winomc-trash.json"
            try:
                with open(meta_path, "r", encoding="utf-8") as handle:
                    meta = json.load(handle)
                entry["trash_meta"] = meta
                entry["original_root"] = meta.get("original_root", "")
                entry["original_path"] = meta.get("original_path", "")
                entry["deleted_at"] = meta.get("deleted_at", "")
            except Exception:
                entry["trash_meta"] = None
        entries.append(entry)
    entries.sort(key=lambda item: (item["type"] != "directory", item["name"].lower()))
    parent = None if rel_path == "/" else normalize_rel_path(posixpath.dirname(rel_path))
    return {"ok": True, "root": root_key, "path": rel_path, "parent": parent, "entries": entries}


def read_text_file(root_key, rel_path):
    file_path, rel_path = resolve_safe_path(root_key, rel_path)
    if not os.path.exists(file_path):
        raise FileNotFoundError("Datei existiert nicht.")
    if not os.path.isfile(file_path):
        raise ValueError("Nur Dateien können im Editor geöffnet werden.")
    if not is_editable_text_file(file_path):
        raise ValueError("Dieser Dateityp ist nicht für den Texteditor freigegeben.")
    size = os.path.getsize(file_path)
    if size > MAX_TEXT_FILE_BYTES:
        raise ValueError("Datei ist zu groß für den Editor. Maximum: %s Bytes." % MAX_TEXT_FILE_BYTES)
    with open(file_path, "r", encoding="utf-8", errors="replace") as handle:
        content = handle.read()
    stat = os.stat(file_path)
    return {"ok": True, "root": root_key, "path": rel_path, "name": os.path.basename(file_path), "size": stat.st_size, "modified": int(stat.st_mtime), "editable": True, "json": file_extension(file_path) in JSON_EXTENSIONS, "content": content}


def write_text_file(root_key, rel_path, content):
    if root_key == "trash":
        raise ValueError("Papierkorb-Dateien sind nur als Vorschau geöffnet. Bitte zuerst wiederherstellen.")
    file_path, rel_path = resolve_safe_path(root_key, rel_path)
    if os.path.isdir(file_path):
        raise ValueError("Ordner können nicht als Datei gespeichert werden.")
    parent = os.path.dirname(file_path)
    if not os.path.isdir(parent):
        raise FileNotFoundError("Zielordner existiert nicht.")
    if not is_editable_text_file(file_path):
        raise ValueError("Dieser Dateityp ist nicht für den Texteditor freigegeben.")
    content = str(content or "")
    validate_json_if_needed(file_path, content)
    backup_path = make_file_backup(file_path, root_key, rel_path)
    fd, temp_path = tempfile.mkstemp(prefix=".winomc-edit-", dir=parent)
    os.close(fd)
    try:
        with open(temp_path, "w", encoding="utf-8", newline="") as handle:
            handle.write(content)
        os.replace(temp_path, file_path)
    except Exception:
        try:
            os.remove(temp_path)
        except OSError:
            pass
        raise
    return {"ok": True, "root": root_key, "path": rel_path, "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Datei gespeichert."}


def prepare_upload_target(root_key, dir_rel_path, filename, overwrite=False):
    dir_path, dir_rel_path = resolve_safe_path(root_key, dir_rel_path)
    if not os.path.exists(dir_path):
        raise FileNotFoundError("Upload-Zielordner existiert nicht.")
    if not os.path.isdir(dir_path):
        raise ValueError("Upload-Ziel ist kein Ordner.")
    filename = safe_download_name(unquote(filename or ""), "upload.bin")
    target_path = os.path.realpath(os.path.join(dir_path, filename))
    root_base = os.path.realpath(FILE_ROOTS[root_key]["path"])
    if not is_inside_base(root_base, target_path):
        raise ValueError("Upload-Ziel außerhalb des erlaubten Bereichs blockiert.")
    if os.path.exists(target_path) and not overwrite:
        raise FileExistsError("Datei existiert bereits. Überschreiben wurde nicht erlaubt.")
    target_rel_path = normalize_rel_path(posixpath.join(dir_rel_path, filename))
    return target_path, target_rel_path


def create_zip_from_paths(root_key, rel_paths, save_to_export=False):
    if not rel_paths:
        raise ValueError("Keine Dateien oder Ordner ausgewählt.")
    root_base = os.path.realpath(FILE_ROOTS[root_key]["path"])
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    zip_name = safe_download_name("winomc-%s-%s.zip" % (root_key, timestamp))
    if save_to_export:
        export_dir, _ = resolve_safe_path("export", "/")
        os.makedirs(export_dir, exist_ok=True)
        zip_path = os.path.join(export_dir, zip_name)
        cleanup = False
    else:
        fd, zip_path = tempfile.mkstemp(prefix="winomc-", suffix=".zip")
        os.close(fd)
        cleanup = True
    with zipfile.ZipFile(zip_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
        for rel_path in rel_paths:
            source_path, normalized_rel_path = resolve_safe_path(root_key, rel_path)
            if not os.path.exists(source_path):
                raise FileNotFoundError("Nicht gefunden: %s" % normalized_rel_path)
            if os.path.islink(source_path):
                continue
            if not is_inside_base(root_base, source_path):
                raise ValueError("Pfad außerhalb des erlaubten Bereichs blockiert.")
            source_name = safe_download_name(os.path.basename(source_path.rstrip(os.sep)) or FILE_ROOTS[root_key]["label"], "winomc-files")
            if os.path.isfile(source_path):
                archive.write(source_path, source_name)
                continue
            parent_path = os.path.dirname(source_path.rstrip(os.sep))
            for current_root, dirs, files in os.walk(source_path, followlinks=False):
                dirs[:] = [dirname for dirname in dirs if not os.path.islink(os.path.join(current_root, dirname)) and is_inside_base(root_base, os.path.join(current_root, dirname))]
                for filename in files:
                    file_path = os.path.join(current_root, filename)
                    if os.path.islink(file_path) or not is_inside_base(root_base, file_path):
                        continue
                    archive_name = os.path.relpath(file_path, parent_path)
                    archive.write(file_path, archive_name)
    return {"zip_path": zip_path, "zip_name": zip_name, "cleanup": cleanup, "saved_to_export": save_to_export, "export_path": normalize_rel_path("/" + zip_name) if save_to_export else None}


def extract_zip_file(root_key, archive_rel_path, destination_rel_path="/", overwrite=False):
    archive_path, archive_rel_path = resolve_safe_path(root_key, archive_rel_path)
    destination_path, destination_rel_path = resolve_safe_path(root_key, destination_rel_path)
    if not os.path.isfile(archive_path):
        raise FileNotFoundError("ZIP-Datei nicht gefunden.")
    if file_extension(archive_path) not in ZIP_EXTENSIONS:
        raise ValueError("Nur .zip, .mcpack, .mcaddon, .mcworld und .mctemplate können entpackt werden.")
    if not os.path.isdir(destination_path):
        raise ValueError("Ziel zum Entpacken ist kein Ordner.")
    root_base = os.path.realpath(FILE_ROOTS[root_key]["path"])
    extracted_files = 0
    extracted_dirs = 0
    total_size = 0
    with zipfile.ZipFile(archive_path, "r") as archive:
        for member in archive.infolist():
            total_size += int(member.file_size or 0)
            if total_size > MAX_ZIP_UNPACK_BYTES:
                raise ValueError("Archiv ist zu groß zum Entpacken.")
        for member in archive.infolist():
            raw_name = str(member.filename or "").replace("\\", "/")
            if not raw_name or raw_name.startswith("/") or raw_name.startswith("../") or "/../" in raw_name:
                raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw_name)
            normalized_name = posixpath.normpath(raw_name)
            if normalized_name in ("", ".") or normalized_name.startswith("../") or normalized_name == "..":
                raise ValueError("Unsicherer Archiv-Pfad blockiert: %s" % raw_name)
            target_path = os.path.realpath(os.path.join(destination_path, normalized_name))
            if not is_inside_base(destination_path, target_path) or not is_inside_base(root_base, target_path):
                raise ValueError("Archiv-Pfad außerhalb des erlaubten Bereichs blockiert: %s" % raw_name)
            if member.is_dir():
                os.makedirs(target_path, exist_ok=True)
                extracted_dirs += 1
                continue
            if os.path.exists(target_path) and not overwrite:
                raise FileExistsError("Datei existiert bereits: %s" % normalized_name)
            os.makedirs(os.path.dirname(target_path), exist_ok=True)
            with archive.open(member, "r") as source, open(target_path, "wb") as target:
                shutil.copyfileobj(source, target, length=1024 * 1024)
            extracted_files += 1
    return {"ok": True, "root": root_key, "archive": archive_rel_path, "destination": destination_rel_path, "files": extracted_files, "directories": extracted_dirs, "message": "Archiv wurde entpackt."}


def create_safe_world_export(world_rel_path="/world", save_to_export=True):
    world_rel_path = normalize_rel_path(world_rel_path)
    world_path, _ = resolve_safe_path("worlds", world_rel_path)
    if not os.path.isdir(world_path):
        raise FileNotFoundError("Weltordner wurde nicht gefunden.")
    hold_sent = False
    try:
        append_console_note("Sicherer Welt-Export gestartet.")
        write_command("save hold")
        hold_sent = True
        time.sleep(1.0)
        write_command("save query")
        time.sleep(2.0)
        zip_info = create_zip_from_paths("worlds", [world_rel_path], save_to_export=save_to_export)
        append_console_note("Sicherer Welt-Export wurde erstellt.")
        return zip_info
    finally:
        if hold_sent:
            try:
                write_command("save resume")
                append_console_note("save resume nach sicherem Welt-Export ausgeführt.")
            except Exception as exc:
                append_console_note("WARNUNG: save resume konnte nicht automatisch ausgeführt werden: %s" % exc)




def remove_path(path):
    if os.path.isdir(path) and not os.path.islink(path):
        shutil.rmtree(path)
    else:
        os.remove(path)



def load_console_settings():
    defaults = {"trash_retention_days": TRASH_RETENTION_DAYS}
    try:
        with open(CONSOLE_SETTINGS_FILE, "r", encoding="utf-8") as handle:
            data = json.load(handle)
        if not isinstance(data, dict):
            return defaults
        defaults.update(data)
    except FileNotFoundError:
        pass
    except Exception:
        pass
    return defaults


def save_console_settings(settings):
    os.makedirs(os.path.dirname(CONSOLE_SETTINGS_FILE), exist_ok=True)
    current = load_console_settings()
    current.update(settings)
    fd, temp_path = tempfile.mkstemp(prefix=".winomc-settings-", dir=os.path.dirname(CONSOLE_SETTINGS_FILE))
    os.close(fd)
    try:
        with open(temp_path, "w", encoding="utf-8") as handle:
            json.dump(current, handle, indent=2, ensure_ascii=False)
            handle.write("\n")
        os.replace(temp_path, CONSOLE_SETTINGS_FILE)
    except Exception:
        try:
            os.remove(temp_path)
        except OSError:
            pass
        raise
    return current


def get_trash_retention_days():
    try:
        value = int(load_console_settings().get("trash_retention_days", TRASH_RETENTION_DAYS))
    except Exception:
        value = TRASH_RETENTION_DAYS
    if value < 0:
        value = TRASH_RETENTION_DAYS
    return value


def set_trash_retention_days(days):
    days = int(days)
    allowed = {0, 3, 7, 14, 30, 60, 90}
    if days not in allowed:
        raise ValueError("Ungültige Papierkorb-Aufbewahrung. Erlaubt: nie, 3, 7, 14, 30, 60 oder 90 Tage.")
    settings = save_console_settings({"trash_retention_days": days})
    return {"ok": True, "retention_days": int(settings.get("trash_retention_days", days))}

def cleanup_trash():
    os.makedirs(TRASH_DIR, exist_ok=True)
    if TRASH_RETENTION_DAYS <= 0:
        return 0
    cutoff = time.time() - (TRASH_RETENTION_DAYS * 86400)
    removed = 0
    for name in os.listdir(TRASH_DIR):
        path = os.path.join(TRASH_DIR, name)
        try:
            if os.path.getmtime(path) < cutoff:
                remove_path(path)
                removed += 1
        except FileNotFoundError:
            pass
        except Exception as exc:
            append_console_note("Papierkorb-Bereinigung übersprungen: %s" % exc)
    return removed


def delete_or_trash_path(root_key, rel_path, permanent=False):
    full_path, rel_path = resolve_safe_path(root_key, rel_path)
    if rel_path == "/":
        raise ValueError("Der Wurzelordner kann nicht gelöscht werden.")
    if not os.path.exists(full_path):
        raise FileNotFoundError("Datei oder Ordner wurde nicht gefunden.")
    if root_key == "config" and rel_path.startswith("/.winomc"):
        raise ValueError("Interne WinoMC-Verzeichnisse können hier nicht gelöscht werden. Öffne bei Bedarf den Papierkorb direkt.")

    if permanent or root_key == "trash":
        remove_path(full_path)
        meta_path = full_path + ".winomc-trash.json"
        if os.path.exists(meta_path):
            try:
                os.remove(meta_path)
            except OSError:
                pass
        return {"ok": True, "permanent": True, "path": rel_path, "message": "Endgültig gelöscht: %s" % rel_path}

    cleanup_trash()
    os.makedirs(TRASH_DIR, exist_ok=True)
    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    trash_name = safe_download_name("%s-%s-%s" % (timestamp, root_key, rel_path.replace("/", "__")), "winomc-trash")
    target_path = os.path.join(TRASH_DIR, trash_name)
    counter = 1
    while os.path.exists(target_path):
        target_path = os.path.join(TRASH_DIR, "%s-%s" % (trash_name, counter))
        counter += 1
    shutil.move(full_path, target_path)
    meta = {"original_root": root_key, "original_path": rel_path, "deleted_at": timestamp, "trash_name": os.path.basename(target_path)}
    try:
        with open(target_path + ".winomc-trash.json", "w", encoding="utf-8") as handle:
            json.dump(meta, handle, ensure_ascii=False, indent=2)
    except Exception:
        pass
    return {"ok": True, "permanent": False, "path": rel_path, "trash_path": target_path, "message": "In den Papierkorb verschoben: %s" % rel_path}



def restore_from_trash(trash_rel_path, overwrite=False, destination_root=None, destination_path=None):
    trash_path, trash_rel_path = resolve_safe_path("trash", trash_rel_path)
    if not os.path.exists(trash_path):
        raise FileNotFoundError("Papierkorb-Eintrag wurde nicht gefunden.")
    if trash_rel_path == "/":
        raise ValueError("Der Papierkorb-Wurzelordner kann nicht wiederhergestellt werden.")

    meta_path = trash_path + ".winomc-trash.json"
    if os.path.exists(meta_path):
        with open(meta_path, "r", encoding="utf-8") as handle:
            meta = json.load(handle)
    else:
        meta = {"original_root": "config", "original_path": "/" + os.path.basename(trash_path)}

    target_root = str(destination_root or meta.get("original_root") or "config")
    target_rel = normalize_rel_path(str(destination_path or meta.get("original_path") or ("/" + os.path.basename(trash_path))))
    target_path, target_rel = resolve_safe_path(target_root, target_rel)

    if target_rel == "/":
        raise ValueError("Ein Papierkorb-Eintrag kann nicht direkt auf einen Wurzelordner wiederhergestellt werden.")

    parent = os.path.dirname(target_path)
    if not os.path.isdir(parent):
        os.makedirs(parent, exist_ok=True)

    if os.path.exists(target_path):
        if not overwrite:
            raise FileExistsError("Ziel existiert bereits. Wiederherstellen mit Überschreiben bestätigen.")
        backup_path = make_file_backup(target_path, target_root, target_rel) if os.path.isfile(target_path) else None
        remove_path(target_path)
    else:
        backup_path = None

    shutil.move(trash_path, target_path)
    if os.path.exists(meta_path):
        try:
            os.remove(meta_path)
        except OSError:
            pass

    return {"ok": True, "root": target_root, "path": target_rel, "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Wiederhergestellt nach %s:%s" % (target_root, target_rel)}

def empty_trash():
    os.makedirs(TRASH_DIR, exist_ok=True)
    removed = 0
    for name in list(os.listdir(TRASH_DIR)):
        path = os.path.join(TRASH_DIR, name)
        try:
            remove_path(path)
            removed += 1
        except FileNotFoundError:
            pass
    return {"ok": True, "removed": removed, "message": "Papierkorb geleert."}

def status_payload():
    env_keys = ["SERVER_NAME", "LEVEL_NAME", "VERSION", "BDS_AUTO_UPDATE", "SERVER_PORT", "SERVER_PORT_V6", "ENABLE_LAN_VISIBILITY", "ENABLE_BDS_V6BIND_FIX", "GAMEMODE", "DIFFICULTY", "ALLOW_CHEATS", "ALLOW_LIST", "MAX_PLAYERS", "TEXTUREPACK_REQUIRED", "PACKAGE_BACKUP_KEEP"]
    return {"ok": True, "fifo_exists": os.path.exists(FIFO_PATH), "log_exists": os.path.exists(LOG_PATH), "env": {key: os.environ.get(key, "") for key in env_keys}, "roots": list_file_roots()}


class Handler(BaseHTTPRequestHandler):
    server_version = "WinoMCConsole/1.5.5"

    def log_message(self, fmt, *args):
        sys.stdout.write("[WinoMC Console] " + fmt % args + "\n")
        sys.stdout.flush()

    def _forbidden_if_needed(self):
        client_ip = self.client_address[0]
        if client_allowed(client_ip):
            return False
        self.send_response(403)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.end_headers()
        self.wfile.write(b"Forbidden\n")
        return True

    def _send_json(self, status, payload):
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(data)

    def _send_file(self, file_path, download_name=None, content_type=None, cleanup=False):
        try:
            if not os.path.isfile(file_path):
                raise FileNotFoundError("Datei nicht gefunden.")
            download_name = safe_download_name(download_name or os.path.basename(file_path))
            content_type = content_type or mimetypes.guess_type(file_path)[0] or "application/octet-stream"
            size = os.path.getsize(file_path)
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(size))
            self.send_header("Content-Disposition", "attachment; filename=\"%s\"; filename*=UTF-8''%s" % (download_name, quote(download_name)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            with open(file_path, "rb") as handle:
                while True:
                    chunk = handle.read(1024 * 1024)
                    if not chunk:
                        break
                    self.wfile.write(chunk)
        finally:
            if cleanup:
                try:
                    os.remove(file_path)
                except OSError:
                    pass

    def _read_chunked_body(self, max_bytes):
        chunks = []
        total = 0
        while True:
            size_line = self.rfile.readline().strip()
            if not size_line:
                continue
            chunk_size = int(size_line.split(b";", 1)[0], 16)
            if chunk_size == 0:
                self.rfile.readline()
                break
            total += chunk_size
            if total > max_bytes:
                raise ValueError("Anfrage ist zu groß.")
            chunks.append(self.rfile.read(chunk_size))
            self.rfile.read(2)
        return b"".join(chunks)

    def _read_request_body(self, max_bytes=4096):
        content_length = self.headers.get("Content-Length") or self.headers.get("X-WinoMC-Body-Size")
        if content_length:
            length = int(content_length)
            if length > max_bytes:
                raise ValueError("Anfrage ist zu groß.")
            return self.rfile.read(length).decode("utf-8", errors="replace")
        if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
            return self._read_chunked_body(max_bytes).decode("utf-8", errors="replace")
        return ""

    def _write_request_body_to_file(self, target_path, max_bytes):
        content_length = self.headers.get("Content-Length")
        upload_size = self.headers.get("X-WinoMC-Upload-Size")
        parent = os.path.dirname(target_path)
        os.makedirs(parent, exist_ok=True)
        fd, temp_path = tempfile.mkstemp(prefix=".winomc-upload-", dir=parent)
        os.close(fd)
        try:
            with open(temp_path, "wb") as handle:
                if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
                    total = 0
                    while True:
                        size_line = self.rfile.readline().strip()
                        if not size_line:
                            continue
                        chunk_size = int(size_line.split(b";", 1)[0], 16)
                        if chunk_size == 0:
                            self.rfile.readline()
                            break
                        total += chunk_size
                        if total > max_bytes:
                            raise ValueError("Upload ist zu groß. Maximum: %s Bytes." % max_bytes)
                        handle.write(self.rfile.read(chunk_size))
                        self.rfile.read(2)
                else:
                    if not content_length and not upload_size:
                        raise ValueError("Upload ohne Content-Length wird nicht unterstützt. Aktualisiere die Web Console oder nutze den JSON-Fallback.")
                    remaining = int(content_length or upload_size)
                    if remaining < 0 or remaining > max_bytes:
                        raise ValueError("Upload ist zu groß. Maximum: %s Bytes." % max_bytes)
                    while remaining > 0:
                        chunk = self.rfile.read(min(1024 * 1024, remaining))
                        if not chunk:
                            raise ValueError("Upload wurde unerwartet beendet.")
                        handle.write(chunk)
                        remaining -= len(chunk)
            os.replace(temp_path, target_path)
        except Exception:
            try:
                os.remove(temp_path)
            except OSError:
                pass
            raise

    def _extract_command(self):
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query)
        query_command = query.get("command", [""])[0]
        if query_command.strip():
            return query_command
        body = self._read_request_body()
        if not body:
            return ""
        content_type = self.headers.get("Content-Type", "").split(";", 1)[0].strip().lower()
        if content_type == "application/json":
            payload = json.loads(body or "{}")
            return str(payload.get("command", ""))
        if content_type == "application/x-www-form-urlencoded":
            return parse_qs(body).get("command", [""])[0]
        return body

    def do_GET(self):
        if self._forbidden_if_needed():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        query = parse_qs(parsed.query)
        if path in ("/", "", "/index.html"):
            data = INDEX_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)
            return
        if path.endswith("/api/status") or path == "/api/status":
            self._send_json(200, status_payload())
            return
        if path.endswith("/api/logs") or path == "/api/logs":
            self._stream_logs()
            return
        if path.endswith("/api/files/roots") or path == "/api/files/roots":
            self._send_json(200, {"ok": True, "roots": list_file_roots()})
            return
        if path.endswith("/api/files/list") or path == "/api/files/list":
            try:
                self._send_json(200, list_directory(query.get("root", ["config"])[0], query.get("path", ["/"])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/read") or path == "/api/files/read":
            try:
                self._send_json(200, read_text_file(query.get("root", ["config"])[0], query.get("path", ["/"])[0]))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/download") or path == "/api/files/download":
            try:
                root_key = query.get("root", ["config"])[0]
                rel_path = query.get("path", ["/"])[0]
                file_path, _ = resolve_safe_path(root_key, rel_path)
                if os.path.isdir(file_path):
                    raise ValueError("Ordner können nur als ZIP heruntergeladen werden.")
                self._send_file(file_path, download_name=os.path.basename(file_path))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                zip_info = create_zip_from_paths(query.get("root", ["config"])[0], [query.get("path", ["/"])[0]], save_to_export=False)
                self._send_file(zip_info["zip_path"], download_name=zip_info["zip_name"], content_type="application/zip", cleanup=zip_info["cleanup"])
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/settings") or path == "/api/files/trash/settings":
            self._send_json(200, {"ok": True, "retention_days": get_trash_retention_days(), "allowed_days": [0, 3, 7, 14, 30, 60, 90]})
            return
        self.send_error(404)

    def do_POST(self):
        if self._forbidden_if_needed():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        if path.endswith("/api/command") or path == "/api/command":
            try:
                command = sanitize_command(self._extract_command())
                write_command(command)
                self._send_json(200, {"ok": True, "command": command})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/upload") or path == "/api/files/upload":
            try:
                query = parse_qs(parsed.query)
                root_key = query.get("root", ["import"])[0]
                dir_rel_path = query.get("path", ["/"])[0]
                filename = query.get("filename", [self.headers.get("X-WinoMC-Filename", "upload.bin")])[0]
                overwrite = parse_bool(query.get("overwrite", ["false"])[0], default=False)
                target_path, target_rel_path = prepare_upload_target(root_key, dir_rel_path, filename, overwrite=overwrite)
                backup_path = make_file_backup(target_path, root_key, target_rel_path) if os.path.exists(target_path) else None
                self._write_request_body_to_file(target_path, MAX_UPLOAD_BYTES)
                self._send_json(200, {"ok": True, "root": root_key, "path": target_rel_path, "filename": os.path.basename(target_path), "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Datei hochgeladen."})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/upload-json") or path == "/api/files/upload-json":
            try:
                body = self._read_request_body(max_bytes=MAX_JSON_UPLOAD_BYTES * 2)
                payload = json.loads(body or "{}")
                root_key = str(payload.get("root", "import"))
                dir_rel_path = str(payload.get("path", "/"))
                filename = str(payload.get("filename", "upload.bin"))
                overwrite = bool(payload.get("overwrite", False))
                content_base64 = str(payload.get("content_base64", ""))
                raw = base64.b64decode(content_base64.encode("ascii"), validate=True)
                if len(raw) > MAX_JSON_UPLOAD_BYTES:
                    raise ValueError("JSON-Upload ist zu groß.")
                target_path, target_rel_path = prepare_upload_target(root_key, dir_rel_path, filename, overwrite=overwrite)
                backup_path = make_file_backup(target_path, root_key, target_rel_path) if os.path.exists(target_path) else None
                with open(target_path, "wb") as handle:
                    handle.write(raw)
                self._send_json(200, {"ok": True, "root": root_key, "path": target_rel_path, "filename": os.path.basename(target_path), "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Datei hochgeladen."})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/write") or path == "/api/files/write":
            try:
                body = self._read_request_body(max_bytes=MAX_TEXT_FILE_BYTES + 65536)
                payload = json.loads(body or "{}")
                self._send_json(200, write_text_file(str(payload.get("root", "config")), str(payload.get("path", "/")), str(payload.get("content", ""))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                root_key = str(payload.get("root", "config"))
                rel_paths = payload.get("paths")
                if not isinstance(rel_paths, list) or not rel_paths:
                    rel_paths = [str(payload.get("path", "/"))]
                rel_paths = [str(item) for item in rel_paths]
                save_to_export = bool(payload.get("save_to_export", False))
                zip_info = create_zip_from_paths(root_key, rel_paths, save_to_export=save_to_export)
                if save_to_export:
                    self._send_json(200, {"ok": True, "saved_to_export": True, "root": "export", "path": zip_info["export_path"], "filename": zip_info["zip_name"]})
                    return
                self._send_file(zip_info["zip_path"], download_name=zip_info["zip_name"], content_type="application/zip", cleanup=zip_info["cleanup"])
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/unzip") or path == "/api/files/unzip":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, extract_zip_file(str(payload.get("root", "import")), str(payload.get("path", "/")), destination_rel_path=str(payload.get("destination", "/")), overwrite=bool(payload.get("overwrite", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/delete") or path == "/api/files/delete":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, delete_or_trash_path(str(payload.get("root", "config")), str(payload.get("path", "/")), permanent=bool(payload.get("permanent", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/restore") or path == "/api/files/trash/restore":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, restore_from_trash(
                    str(payload.get("path", "/")),
                    overwrite=bool(payload.get("overwrite", False)),
                    destination_root=payload.get("destination_root"),
                    destination_path=payload.get("destination_path"),
                ))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/settings") or path == "/api/files/trash/settings":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, set_trash_retention_days(payload.get("retention_days", TRASH_RETENTION_DAYS)))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/empty") or path == "/api/files/trash/empty":
            try:
                self._send_json(200, empty_trash())
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/worlds/export-safe") or path == "/api/worlds/export-safe":
            try:
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                zip_info = create_safe_world_export(str(payload.get("path", "/world")), save_to_export=bool(payload.get("save_to_export", True)))
                if zip_info["saved_to_export"]:
                    self._send_json(200, {"ok": True, "saved_to_export": True, "root": "export", "path": zip_info["export_path"], "filename": zip_info["zip_name"], "message": "Sicherer Welt-Export wurde nach /share/winomc/export gespeichert."})
                    return
                self._send_file(zip_info["zip_path"], download_name=zip_info["zip_name"], content_type="application/zip", cleanup=zip_info["cleanup"])
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        self.send_error(404)

    def _sse_send(self, payload):
        data = json.dumps(payload, ensure_ascii=False)
        self.wfile.write(("data: %s\n\n" % data).encode("utf-8"))
        self.wfile.flush()

    def _stream_logs(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()
        for line in read_recent_lines(LOG_PATH, HISTORY_LIMIT):
            self._sse_send({"line": line})
        try:
            position = os.path.getsize(LOG_PATH)
        except OSError:
            position = 0
        last_heartbeat = time.time()
        while True:
            try:
                size = os.path.getsize(LOG_PATH)
                if size < position:
                    position = 0
                if size > position:
                    with open(LOG_PATH, "r", encoding="utf-8", errors="replace") as handle:
                        handle.seek(position)
                        for line in handle:
                            self._sse_send({"line": line.rstrip("\n")})
                        position = handle.tell()
                if time.time() - last_heartbeat > 15:
                    self.wfile.write(b": heartbeat\n\n")
                    self.wfile.flush()
                    last_heartbeat = time.time()
                time.sleep(0.5)
            except (BrokenPipeError, ConnectionResetError):
                break
            except Exception as exc:
                try:
                    self._sse_send({"line": "[WinoMC Console] Log Stream Fehler: %s" % exc})
                except Exception:
                    break
                time.sleep(1)


def main():
    ensure_directories()
    os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
    open(LOG_PATH, "a", encoding="utf-8").close()
    httpd = ThreadingHTTPServer((HOST, PORT), Handler)

    def shutdown(_signum, _frame):
        httpd.shutdown()

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)
    print("[WinoMC Console] Web console listening on %s:%s" % (HOST, PORT), flush=True)
    httpd.serve_forever(poll_interval=0.5)


if __name__ == "__main__":
    main()
