def atomic_write_json_root(root_key, rel_path, data, backup=True):
    file_path, normalized_rel = resolve_safe_path(root_key, rel_path)
    parent = assert_safe_path(root_key, os.path.dirname(file_path), require_exists=True)
    if path_is_dir_root(root_key, file_path):
        raise ValueError("Ziel ist ein Ordner, keine JSON-Datei.")
    backup_path = make_file_backup(file_path, root_key, normalized_rel) if backup and path_exists_root(root_key, file_path) else None
    fd, temp_path = mkstemp_root(root_key, parent, prefix=".winomc-json-")
    os.close(fd)
    try:
        with open_safe(root_key, temp_path, "w", encoding="utf-8", newline="") as handle:
            json.dump(data, handle, ensure_ascii=False, indent=2)
            handle.write("\n")
        replace_safe(root_key, temp_path, file_path)
    except Exception:
        try:
            remove_safe(root_key, temp_path)
        except Exception as exc:
            log_warning("TemporÃ¤re JSON-Datei konnte nicht entfernt werden: %s" % exc)
        raise
    return {"path": normalized_rel, "backup_created": bool(backup_path), "backup_path": backup_path}


def world_pack_rel_path(pack_type):
    pack_type = str(pack_type or "resource").lower()
    if pack_type not in ("resource", "behavior"):
        raise ValueError("Pack-Typ muss resource oder behavior sein.")
    level = os.environ.get("LEVEL_NAME", "world") or "world"
    filename = "world_resource_packs.json" if pack_type == "resource" else "world_behavior_packs.json"
    return normalize_rel_path(posixpath.join("/worlds", level, filename))


def pack_base_dir(pack_type):
    pack_type = str(pack_type or "resource").lower()
    if pack_type == "resource":
        return "resource_packs", RESOURCE_PACKS_DIR
    if pack_type == "behavior":
        return "behavior_packs", BEHAVIOR_PACKS_DIR
    raise ValueError("Pack-Typ muss resource oder behavior sein.")


def read_pack_manifest(pack_type, pack_path):
    root_key, base_dir = pack_base_dir(pack_type)
    pack_path = safe_rel_parts(pack_path)
    if not pack_path:
        raise ValueError("Pack-Pfad fehlt.")
    pack_dir = os.path.join(base_dir, *pack_path)
    pack_dir = assert_safe_path(root_key, pack_dir, require_exists=True)
    if not path_is_dir_root(root_key, pack_dir):
        raise FileNotFoundError("Pack-Ordner wurde nicht gefunden.")
    manifest_path = os.path.join(pack_dir, "manifest.json")
    data, err = json_file(manifest_path, {})
    if err:
        raise ValueError("Pack-Manifest ist ungÃ¼ltig: %s" % err)
    header = data.get("header", {}) if isinstance(data, dict) else {}
    uuid = str(header.get("uuid", "")).strip()
    version = header.get("version")
    if not uuid or not isinstance(version, list) or not version:
        raise ValueError("Pack-Manifest braucht UUID und Version.")
    version = [int(v) for v in version]
    return {"pack_id": uuid, "version": version, "name": header.get("name") or os.path.basename(pack_dir), "path": "/" + "/".join(pack_path)}


def read_world_pack_entries(pack_type):
    rel = world_pack_rel_path(pack_type)
    path, _ = resolve_safe_path("config", rel)
    if not path_exists_root("config", path):
        return []
    data, err = json_file(path, [])
    if err:
        raise ValueError("Welt-Pack-Datei ist ungÃ¼ltig: %s" % err)
    if not isinstance(data, list):
        raise ValueError("Welt-Pack-Datei muss eine JSON-Liste sein.")
    clean = []
    for item in data:
        if not isinstance(item, dict):
            continue
        pack_id = str(item.get("pack_id") or "").strip()
        version = item.get("version")
        if pack_id and isinstance(version, list):
            clean.append({"pack_id": pack_id, "version": [int(v) for v in version]})
    return clean


def write_world_pack_entries(pack_type, entries):
    rel = world_pack_rel_path(pack_type)
    path, _ = resolve_safe_path("config", rel)
    parent = os.path.dirname(path)
    makedirs_root("config", parent, exist_ok=True)
    return atomic_write_json_root("config", rel, entries, backup=True)


def activate_pack(pack_type, pack_path):
    manifest = read_pack_manifest(pack_type, pack_path)
    entries = read_world_pack_entries(pack_type)
    entries = [entry for entry in entries if entry.get("pack_id") != manifest["pack_id"]]
    entries.append({"pack_id": manifest["pack_id"], "version": manifest["version"]})
    result = write_world_pack_entries(pack_type, entries)
    result.update({"ok": True, "pack": manifest, "entries": entries, "message": "Pack wurde fÃ¼r diese Welt aktiviert."})
    return result


def deactivate_pack(pack_type, uuid):
    uuid = str(uuid or "").strip()
    if not uuid:
        raise ValueError("UUID fehlt.")
    entries = read_world_pack_entries(pack_type)
    new_entries = [entry for entry in entries if entry.get("pack_id") != uuid]
    if len(new_entries) == len(entries):
        raise FileNotFoundError("Aktiver Pack-Eintrag wurde nicht gefunden.")
    result = write_world_pack_entries(pack_type, new_entries)
    result.update({"ok": True, "uuid": uuid, "entries": new_entries, "message": "Pack wurde fÃ¼r diese Welt deaktiviert."})
    return result


def packs_payload():
    resource = scan_packs(RESOURCE_PACKS_DIR, "resource")
    behavior = scan_packs(BEHAVIOR_PACKS_DIR, "behavior")
    active = {"resource": read_world_pack_entries("resource"), "behavior": read_world_pack_entries("behavior")}
    active_ids = {"resource": {e["pack_id"] for e in active["resource"]}, "behavior": {e["pack_id"] for e in active["behavior"]}}
    for pack in resource:
        pack["active"] = bool(pack.get("uuid") in active_ids["resource"])
    for pack in behavior:
        pack["active"] = bool(pack.get("uuid") in active_ids["behavior"])
    return {"ok": True, "resource_packs": resource, "behavior_packs": behavior, "active": active, "texturepack_required": parse_bool(os.environ.get("TEXTUREPACK_REQUIRED"), False)}


def normalize_role(role):
    role = str(role or "member").lower().strip()
    if role not in ("operator", "member", "visitor"):
        raise ValueError("Rolle muss operator, member oder visitor sein.")
    return role


def normalize_player_entry(item):
    if not isinstance(item, dict):
        raise ValueError("Spieler-Eintrag ist ungÃ¼ltig.")
    name = str(item.get("name") or "").strip()
    xuid = str(item.get("xuid") or "").strip()
    if not name and not xuid:
        raise ValueError("Spieler braucht mindestens Name oder XUID.")
    if xuid and not re.match(r"^[0-9]{5,32}$", xuid):
        raise ValueError("XUID sieht ungÃ¼ltig aus: %s" % xuid)
    return {"name": name, "xuid": xuid, "allowlisted": bool(item.get("allowlisted", True)), "role": normalize_role(item.get("role", "member"))}


def save_players(players):
    if not isinstance(players, list):
        raise ValueError("players muss eine Liste sein.")
    normalized = [normalize_player_entry(item) for item in players]
    seen = set()
    for player in normalized:
        key = player.get("xuid") or player.get("name")
        if key in seen:
            raise ValueError("Doppelter Spieler/XUID: %s" % key)
        seen.add(key)
    allowlist = []
    permissions = []
    for player in normalized:
        if player["allowlisted"]:
            entry = {"name": player["name"] or player["xuid"], "ignoresPlayerLimit": False}
            if player["xuid"]:
                entry["xuid"] = player["xuid"]
            allowlist.append(entry)
        if player["xuid"]:
            permissions.append({"permission": player["role"], "xuid": player["xuid"]})
    allow_result = atomic_write_json_root("config", "/allowlist.json", allowlist, backup=True)
    perm_result = atomic_write_json_root("config", "/permissions.json", permissions, backup=True)
    payload = players_payload()
    payload.update({"saved": True, "allowlist_result": allow_result, "permissions_result": perm_result, "message": "Spielerrechte wurden gespeichert."})
    return payload


def find_backup_meta(backup_name):
    safe_name = safe_download_name(backup_name, "")
    if not safe_name:
        raise ValueError("Backup-Name fehlt.")
    for meta in list_backups():
        if safe_name in (meta.get("name"), meta.get("archive"), os.path.basename(meta.get("archive", ""))):
            archive = os.path.join(BACKUP_DIR, meta.get("archive", ""))
            archive = verify_internal_path(BACKUP_DIR, archive, require_exists=True, allow_missing=False)
            return meta, archive.path
    candidate = verify_internal_path(BACKUP_DIR, os.path.join(BACKUP_DIR, safe_name), require_exists=True, allow_missing=False)
    if not candidate.is_file() or not safe_name.endswith(".zip"):
        raise FileNotFoundError("Backup wurde nicht gefunden.")
    return {"name": safe_name, "archive": safe_name, "type": "unknown"}, candidate.path



def backup_contains(archive_path):
    contains = {"worlds": False, "resource_packs": False, "behavior_packs": False, "world_resource_packs": False, "world_behavior_packs": False, "server_properties": False, "files": 0, "size": 0}
    with zipfile.ZipFile(archive_path, "r") as archive:
        for member in archive.infolist():
            raw = str(member.filename or "").replace("\\", "/")
            if not raw or raw == "winomc-backup.json" or raw.startswith("warnings/"):
                continue
            contains["files"] += 1
            contains["size"] += int(member.file_size or 0)
            if raw.startswith("worlds/"):
                contains["worlds"] = True
            if raw.startswith("resource_packs/"):
                contains["resource_packs"] = True
            if raw.startswith("behavior_packs/"):
                contains["behavior_packs"] = True
            if raw.endswith("world_resource_packs.json"):
                contains["world_resource_packs"] = True
            if raw.endswith("world_behavior_packs.json"):
                contains["world_behavior_packs"] = True
            if raw == "server.properties":
                contains["server_properties"] = True
    return contains


def build_restore_plan(backup_name, mode="complete"):
    mode = str(mode or "complete").lower()
    if mode not in ("config", "world", "complete"):
        raise ValueError("Restore-Modus muss config, world oder complete sein.")
    meta, archive_path = find_backup_meta(backup_name)
    contains = backup_contains(archive_path)
    world = analyze_world_safety()
    changes = []
    warnings = []
    if mode in ("world", "complete") and contains["worlds"]:
        changes.append("Weltdaten werden aus dem Backup wiederhergestellt.")
    if mode in ("config", "complete"):
        for key, label in (("server_properties", "server.properties"), ("world_resource_packs", "world_resource_packs.json"), ("world_behavior_packs", "world_behavior_packs.json")):
            if contains.get(key):
                changes.append("%s wird aus dem Backup wiederhergestellt." % label)
    if mode == "complete":
        if contains["resource_packs"]:
            changes.append("Resource-Pack-Ordner werden wiederhergestellt.")
        if contains["behavior_packs"]:
            changes.append("Behavior-Pack-Ordner werden wiederhergestellt.")
    risk = "yellow" if changes else "green"
    if world.get("risk") in ("yellow", "red") and (contains["world_resource_packs"] or contains["world_behavior_packs"] or contains["behavior_packs"]):
        risk = "red"
        warnings.append("Aktuelle Welt enthÃ¤lt Add-on-/Pack-Hinweise; Restore kann aktive Add-ons verÃ¤ndern.")
    free = disk_usage_metrics().get("free") or 0
    needed = int(contains.get("size") or 0) * 2
    if free and needed and free < needed:
        risk = risk_level(risk, "red")
        warnings.append("Wenig freier Speicher fÃ¼r Restore plus Safety-Backup.")
    return {"ok": True, "kind": "restore", "backup": meta, "mode": mode, "risk": risk, "summary": "Restore-Vorschau fÃ¼r %s" % meta.get("name", backup_name), "changes": changes, "warnings": warnings, "backup_plan": ["Safety-Backup vor Restore"], "will_restore": changes, "will_skip": [], "contains": contains, "world_safety": world, "requires_confirmation": requires_confirmation({"risk": risk})}


def restore_backup(backup_name, mode="complete", restart=False, confirm=False):
    plan = build_restore_plan(backup_name, mode)
    assert_plan_confirmed(plan, confirm)
    meta, archive_path = find_backup_meta(backup_name)
    safety = create_framework_backup("safety", "pre-restore")
    prefixes = []
    if mode in ("world", "complete"):
        prefixes.append("worlds/")
    if mode in ("config", "complete"):
        prefixes.extend(["server.properties", "allowlist.json", "permissions.json", ".winomc/"])
    if mode == "complete":
        prefixes.extend(["resource_packs/", "behavior_packs/"])
    restored = []
    skipped = []
    root_base = allowed_root_base("config")
    with zipfile.ZipFile(archive_path, "r") as archive:
        for member in archive.infolist():
            raw_name = str(member.filename or "").replace("\\", "/")
            if not raw_name or raw_name == "winomc-backup.json" or raw_name.startswith("warnings/"):
                continue
            normalized = posixpath.normpath(raw_name)
            if normalized.startswith("../") or normalized.startswith("/") or normalized == "..":
                raise ValueError("Unsicherer Backup-Pfad blockiert: %s" % raw_name)
            if member.is_dir() or zip_member_is_symlink(member):
                if zip_member_is_symlink(member):
                    raise ValueError("Symlink im Backup blockiert: %s" % raw_name)
            if not any(normalized == prefix or normalized.startswith(prefix) for prefix in prefixes):
                skipped.append(normalized)
                continue
            target = assert_safe_path("config", os.path.join(DATA_DIR, normalized))
            if not is_inside_base(root_base, target):
                raise ValueError("Restore-Ziel auÃŸerhalb von /config blockiert: %s" % raw_name)
            if member.is_dir():
                makedirs_root("config", target, exist_ok=True)
                continue
            if path_exists_root("config", target):
                make_file_backup(target, "config", "/" + normalized)
            makedirs_root("config", os.path.dirname(target), exist_ok=True)
            with archive.open(member, "r") as source, open_safe("config", target, "wb") as dest:
                shutil.copyfileobj(source, dest, length=1024 * 1024)
            restored.append(normalized)
    if restart:
        append_console_note("Restore abgeschlossen. Bitte Add-on/Server manuell neu starten, falls nÃ¶tig.")
    return {"ok": True, "backup": meta, "mode": mode, "plan": plan, "safety_backup": safety, "restored": restored, "skipped": skipped, "message": "Restore abgeschlossen. Bitte Serverzustand und Health prÃ¼fen."}

def delete_backup(backup_name):
    meta, archive_path = find_backup_meta(backup_name)
    removed = []
    for path in (archive_path, backup_manifest_path(meta.get("name", ""))):
        try:
            verified = verify_internal_path(BACKUP_DIR, path, require_exists=False, allow_missing=True)
            if verified.exists():
                verified.remove(); removed.append(os.path.basename(verified.path))
        except Exception as exc:
            log_warning("Backup-Datei konnte nicht gelÃ¶scht werden: %s" % exc)
    return {"ok": True, "removed": removed, "message": "Backup wurde gelÃ¶scht."}


def prepare_update(payload=None):
    payload = payload or {}
    warning = str(payload.get("warning", "")).strip()
    if warning:
        try:
            write_command("say " + warning)
        except Exception as exc:
            append_console_note("Spielerwarnung konnte nicht gesendet werden: %s" % exc)
    backup = create_framework_backup("complete", "pre-update")
    state_dir = makedirs_internal(os.path.join(DATA_DIR, ".winomc"), os.path.join(DATA_DIR, ".winomc"), exist_ok=True)
    state_path = assert_safe_internal_path(state_dir, os.path.join(state_dir, "update-prepared.json"))
    state = {"prepared_at": time.strftime("%Y-%m-%d_%H-%M-%S"), "backup": backup, "version": os.environ.get("VERSION", "LATEST"), "auto_update": os.environ.get("BDS_AUTO_UPDATE", ""), "message": "Update vorbereitet. Bitte Add-on neu starten, damit BDS_AUTO_UPDATE/VERSION greift."}
    with open_safe_internal(state_dir, state_path, "w", encoding="utf-8") as handle:
        json.dump(state, handle, ensure_ascii=False, indent=2)
    return {"ok": True, "state": state, "checks": update_guard_payload().get("checks", []), "message": state["message"]}


def prepare_profile(profile_id):
    profiles = profiles_payload().get("profiles", [])
    selected = None
    slug = str(profile_id or "").lower().replace(" ", "-")
    for profile in profiles:
        if slug in (profile["name"].lower().replace(" ", "-"), safe_download_name(profile["name"].lower(), "")):
            selected = profile
            break
    if not selected:
        raise FileNotFoundError("Profil wurde nicht gefunden.")
    create_framework_backup("config", "pre-profile-prepare")
    state_dir = makedirs_internal(os.path.join(DATA_DIR, ".winomc"), os.path.join(DATA_DIR, ".winomc"), exist_ok=True)
    state_path = assert_safe_internal_path(state_dir, os.path.join(state_dir, "prepared-profile.json"))
    state = {"prepared_at": time.strftime("%Y-%m-%d_%H-%M-%S"), "profile": selected, "applied": False, "message": "Profil vorbereitet. Werte bitte in Home Assistant prÃ¼fen und Ã¼bernehmen; Add-on-Optionen wurden nicht automatisch Ã¼berschrieben."}
    with open_safe_internal(state_dir, state_path, "w", encoding="utf-8") as handle:
        json.dump(state, handle, ensure_ascii=False, indent=2)
    return {"ok": True, "profile": selected, "state": state, "message": state["message"]}


def state_dir_path():
    return makedirs_internal(WINOMC_STATE_DIR, WINOMC_STATE_DIR, exist_ok=True)


def write_state_json(path, payload):
    base = state_dir_path()
    target = assert_safe_internal_path(base, path)
    with open_safe_internal(base, target, "w", encoding="utf-8") as handle:
        json.dump(payload, handle, ensure_ascii=False, indent=2)
        handle.write("\n")
    return target


def read_web_protection_state():
    default = {"ok": True, "enabled": False, "source": "default", "updated_at": None}
    try:
        base = state_dir_path()
        target = assert_safe_internal_path(base, WEB_PROTECTION_FILE, require_exists=False)
        if not os.path.exists(target):
            return default
        with open_safe_internal(base, target, "r", encoding="utf-8", errors="replace") as handle:
            data = json.load(handle)
        return {"ok": True, "enabled": bool(data.get("enabled", False)), "source": data.get("source", "server"), "updated_at": data.get("updated_at")}
    except Exception as exc:
        log_warning("Webschutz-Status konnte nicht gelesen werden: %s" % exc)
        return default


def set_web_protection_state(enabled, source="web-ui"):
    payload = {"enabled": bool(enabled), "updated_at": time.strftime("%Y-%m-%d_%H-%M-%S"), "source": safe_download_name(source, "web-ui")}
    write_state_json(WEB_PROTECTION_FILE, payload)
    payload["ok"] = True
    return payload


def write_import_status(status, message, extra=None):
    payload = {"ok": True, "status": status, "message": message, "updated_at": time.strftime("%Y-%m-%d_%H-%M-%S")}
    if isinstance(extra, dict):
        payload.update(extra)
    write_state_json(IMPORT_STATUS_FILE, payload)
    return payload


def read_import_status():
    try:
        base = state_dir_path()
        target = assert_safe_internal_path(base, IMPORT_STATUS_FILE, require_exists=False)
        if not os.path.exists(target):
            return {"ok": True, "status": "idle", "message": "Noch kein URL-Import ausgefÃ¼hrt."}
        with open_safe_internal(base, target, "r", encoding="utf-8", errors="replace") as handle:
            data = json.load(handle)
        data["ok"] = True
        return data
    except Exception as exc:
        return {"ok": False, "status": "error", "message": str(exc)}



def risk_level(*levels):
    order = {"green": 0, "yellow": 1, "red": 2}
    best = "green"
    for level in levels:
        if order.get(str(level or "green"), 0) > order[best]:
            best = str(level)
    return best


def requires_confirmation(plan):
    return str(plan.get("risk", "green")) in ("yellow", "red") or bool(plan.get("requires_confirmation", False))


def assert_plan_confirmed(plan, confirm=False, mode="safe"):
    if str(plan.get("risk")) == "red" and mode != "expert":
        raise PermissionError("Diese Aktion ist rot eingestuft und erfordert Expertenmodus mit bewusster BestÃ¤tigung.")
    if requires_confirmation(plan) and not bool(confirm):
        raise PermissionError("Aktion nicht ausgefÃ¼hrt: %s BestÃ¤tigung erforderlich." % plan.get("summary", "Safety Planner verlangt eine BestÃ¤tigung."))


def pack_manifest_signals(base_dir, label):
    signals = []
    if not os.path.isdir(base_dir):
        return signals
    for root, dirs, files in os.walk(base_dir):
        dirs[:] = [d for d in dirs if d not in ("__MACOSX", ".git")]
        if "manifest.json" not in files:
            continue
        data, err = json_file(os.path.join(root, "manifest.json"), {})
        rel = os.path.relpath(root, base_dir)
        if err:
            signals.append({"type": "manifest_invalid", "pack": rel, "message": "%s Manifest ungÃ¼ltig: %s" % (label, err)})
            continue
        modules = data.get("modules", []) if isinstance(data, dict) else []
        header = data.get("header", {}) if isinstance(data, dict) else {}
        module_types = [str(m.get("type", "")).lower() for m in modules if isinstance(m, dict)]
        for key in ("dependencies", "capabilities", "metadata"):
            if data.get(key):
                signals.append({"type": key, "pack": rel, "message": "%s enthÃ¤lt %s." % (rel, key)})
        if header.get("min_engine_version") or data.get("min_engine_version"):
            signals.append({"type": "min_engine_version", "pack": rel, "message": "%s nennt eine minimale Bedrock-Version." % rel})
        if any(t in ("data", "script", "client_data") or "script" in t for t in module_types):
            signals.append({"type": "behavior_or_script", "pack": rel, "message": "%s enthÃ¤lt Behavior-/Script-Module." % rel})
        elif "resources" in module_types:
            signals.append({"type": "resources", "pack": rel, "message": "%s enthÃ¤lt Resource-Module." % rel})
    return signals


def read_world_pack_file(pack_type):
    rel = world_pack_rel_path(pack_type)
    path, _ = resolve_safe_path("config", rel)
    if not path_exists_root("config", path):
        return {"exists": False, "valid": True, "entries": [], "error": None, "rel": rel}
    data, err = json_file(path, [])
    return {"exists": True, "valid": err is None and isinstance(data, list), "entries": data if isinstance(data, list) else [], "error": err, "rel": rel}


def analyze_world_safety():
    signals = []
    warnings = []
    mode = "vanilla"
    risk = "green"
    resource_file = read_world_pack_file("resource")
    behavior_file = read_world_pack_file("behavior")
    for label, info in (("world_resource_packs.json", resource_file), ("world_behavior_packs.json", behavior_file)):
        if info["exists"] and not info["valid"]:
            mode = "unknown"; risk = risk_level(risk, "red"); warnings.append("%s ist ungÃ¼ltig; automatische Reparatur wÃ¼rde Pack-Zustand verÃ¤ndern." % label)
        elif info["entries"]:
            signals.append({"type": "active_pack_file", "file": label, "count": len(info["entries"]), "message": "%s enthÃ¤lt aktive EintrÃ¤ge." % label})
            if label.startswith("world_behavior"):
                mode = "addons"; risk = risk_level(risk, "red")
            elif mode == "vanilla":
                mode = "resource_packs"; risk = risk_level(risk, "yellow")
    resource_signals = pack_manifest_signals(RESOURCE_PACKS_DIR, "Resource Pack")
    behavior_signals = pack_manifest_signals(BEHAVIOR_PACKS_DIR, "Behavior Pack")
    signals.extend(resource_signals + behavior_signals)
    if behavior_signals:
        mode = "addons"; risk = risk_level(risk, "red")
    elif resource_signals and mode == "vanilla":
        mode = "resource_packs"; risk = risk_level(risk, "yellow")
    world = world_dir_path()
    for marker in ("premium_cache", "valid_known_packs.json", "world_resource_pack_history.json"):
        if os.path.exists(os.path.join(world, marker)):
            mode = "marketplace_or_unknown"; risk = risk_level(risk, "yellow"); signals.append({"type": "marketplace_or_unknown", "message": "Marketplace/unklare Weltspur: %s" % marker})
    if mode == "addons":
        warnings.append("Add-ons erkannt: automatische Reparaturen werden nur nach BestÃ¤tigung ausgefÃ¼hrt.")
    return {"ok": True, "mode": mode, "risk": risk, "signals": signals, "warnings": warnings, "recommendation": "Analyze first. Explain risk. Backup. Confirm. Then act."}


def build_repair_plan(action):
    action = str(action or "").strip()
    world = analyze_world_safety()
    changes=[]; warnings=[]; backup_plan=[]; risk="green"
    if action in ("ensure_directories", "repair_all_safe"):
        changes.append("Fehlende Standardordner werden erstellt.")
    targets = []
    if action in ("repair_allowlist", "repair_all_safe"):
        targets.append(("/allowlist.json", "allowlist.json", False))
    if action in ("repair_permissions", "repair_all_safe"):
        targets.append(("/permissions.json", "permissions.json", False))
    if action in ("repair_world_resource_packs", "repair_pack_files", "repair_all_safe"):
        targets.append((world_pack_rel_path("resource"), "world_resource_packs.json", True))
    if action in ("repair_world_behavior_packs", "repair_pack_files", "repair_all_safe"):
        targets.append((world_pack_rel_path("behavior"), "world_behavior_packs.json", True))
    for rel,label,is_pack in targets:
        path,_ = resolve_safe_path("config", rel)
        if path_exists_root("config", path):
            data,err=json_file(path, [])
            if err is None and isinstance(data, list):
                changes.append("%s ist gÃ¼ltig und wird nicht ersetzt." % label)
                if data and is_pack:
                    warnings.append("%s enthÃ¤lt aktive Pack-EintrÃ¤ge und wird nicht geleert." % label)
                    risk = risk_level(risk, "red")
                continue
            backup_plan.append("Sicherungskopie von %s" % label)
            changes.append("UngÃ¼ltige %s kÃ¶nnte als leere Liste neu erzeugt werden." % label)
            risk = risk_level(risk, "red" if is_pack or world.get("risk") != "green" else "yellow")
        else:
            changes.append("Fehlende %s kÃ¶nnte als leere Liste erstellt werden." % label)
            if is_pack and world.get("risk") != "green":
                risk = risk_level(risk, "yellow"); warnings.append("Pack-/Add-on-Spuren gefunden; fehlende Pack-Datei wird nicht ohne BestÃ¤tigung erstellt.")
    if action in ("repair_pack_files", "repair_all_safe") and world.get("risk") == "red":
        risk = risk_level(risk, "red")
    return {"ok": True, "kind": "repair", "action": action, "risk": risk, "summary": "Reparaturplan fÃ¼r %s" % action, "changes": changes, "warnings": warnings, "backup_plan": backup_plan, "world_safety": world, "requires_confirmation": risk in ("yellow", "red")}


def repair_json_list(rel_path, label, confirm=False, mode="safe", plan=None):
    file_path, normalized = resolve_safe_path("config", rel_path)
    parent = os.path.dirname(file_path)
    makedirs_root("config", parent, exist_ok=True)
    is_pack_file = label in ("world_resource_packs.json", "world_behavior_packs.json")
    if path_exists_root("config", file_path):
        data, err = json_file(file_path, [])
        if err is None and isinstance(data, list):
            return {"action": label, "status": "skipped", "message": "%s ist bereits gÃ¼ltig und wurde nicht ersetzt." % label}
        if is_pack_file or (plan and plan.get("risk") == "red"):
            assert_plan_confirmed(plan or {"risk":"red","summary":label}, confirm, mode)
        backup_path = make_file_backup(file_path, "config", normalized) if path_is_file_root("config", file_path) else None
    else:
        if is_pack_file and plan and plan.get("risk") in ("yellow", "red"):
            assert_plan_confirmed(plan, confirm, mode)
        backup_path = None
    result = atomic_write_json_root("config", normalized, [], backup=False)
    return {"action": label, "status": "repaired", "message": "%s wurde als leere valide JSON-Liste geschrieben." % label, "backup_path": backup_path, "result": result}


def repair_diagnostics(action, confirm=False, mode="safe"):
    action = str(action or "").strip()
    mode = str(mode or "safe").lower()
    plan = build_repair_plan(action)
    if plan["risk"] == "red" or (plan["risk"] == "yellow" and action not in ("ensure_directories",)):
        assert_plan_confirmed(plan, confirm, mode)
    results = []
    if action in ("ensure_directories", "repair_all_safe"):
        ensure_directories(); state_dir_path(); results.append({"action": "ensure_directories", "status": "ok", "message": "Ordnerstruktur wurde geprÃ¼ft/erstellt."})
    if action in ("repair_allowlist", "repair_all_safe"):
        results.append(repair_json_list("/allowlist.json", "allowlist.json", confirm, mode, plan))
    if action in ("repair_permissions", "repair_all_safe"):
        results.append(repair_json_list("/permissions.json", "permissions.json", confirm, mode, plan))
    if action != "repair_all_safe":
        if action in ("repair_world_resource_packs", "repair_pack_files"):
            results.append(repair_json_list(world_pack_rel_path("resource"), "world_resource_packs.json", confirm, mode, plan))
        if action in ("repair_world_behavior_packs", "repair_pack_files"):
            results.append(repair_json_list(world_pack_rel_path("behavior"), "world_behavior_packs.json", confirm, mode, plan))
    if not results:
        raise ValueError("Unbekannte oder nicht sichere Reparaturaktion: %s" % action)
    return {"ok": True, "action": action, "plan": plan, "results": results, "message": "Reparatur abgeschlossen."}



