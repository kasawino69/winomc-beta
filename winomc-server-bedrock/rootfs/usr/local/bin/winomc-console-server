                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/upload-json") or path == "/api/files/upload-json":
            try:
                self.require_web_write_allowed("Datei hochladen")
                body = self._read_request_body(max_bytes=MAX_JSON_UPLOAD_BYTES * 2)
                payload = json.loads(body or "{}")
                root_key = str(payload.get("root", "import"))
                dir_rel_path = str(payload.get("path", "/"))
                filename = str(payload.get("filename", "upload.bin"))
                overwrite = bool(payload.get("overwrite", False))
                content_base64 = str(payload.get("content_base64", ""))
                raw = base64.b64decode(content_base64.encode("ascii"), validate=True)
                if len(raw) > MAX_JSON_UPLOAD_BYTES:
                    raise ValueError("JSON-Upload ist zu groÃŸ.")
                target_path, target_rel_path = prepare_upload_target(root_key, dir_rel_path, filename, overwrite=overwrite)
                backup_path = make_file_backup(target_path, root_key, target_rel_path) if path_exists_root(root_key, target_path) else None
                with open_safe(root_key, target_path, "wb") as handle:
                    handle.write(raw)
                self._send_json(200, {"ok": True, "root": root_key, "path": target_rel_path, "filename": os.path.basename(target_path), "backup_created": bool(backup_path), "backup_path": backup_path, "message": "Datei hochgeladen."})
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/write") or path == "/api/files/write":
            try:
                self.require_web_write_allowed("Datei speichern")
                body = self._read_request_body(max_bytes=MAX_TEXT_FILE_BYTES + 65536)
                payload = json.loads(body or "{}")
                self._send_json(200, write_text_file(str(payload.get("root", "config")), str(payload.get("path", "/")), str(payload.get("content", ""))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/zip") or path == "/api/files/zip":
            try:
                self.require_web_write_allowed("ZIP erstellen oder exportieren")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                root_key = str(payload.get("root", "config"))
                rel_paths = payload.get("paths")
                if not isinstance(rel_paths, list) or not rel_paths:
                    rel_paths = [str(payload.get("path", "/"))]
                rel_paths = [str(item) for item in rel_paths]
                save_to_export = bool(payload.get("save_to_export", False))
                zip_info = create_zip_from_paths(root_key, rel_paths, save_to_export=save_to_export)
                if save_to_export:
                    self._send_json(200, {"ok": True, "saved_to_export": True, "root": "export", "path": zip_info["export_path"], "filename": zip_info["zip_name"]})
                    return
                self._send_zip_info(zip_info)
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/unzip") or path == "/api/files/unzip":
            try:
                self.require_web_write_allowed("Archiv entpacken")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, extract_zip_file(str(payload.get("root", "import")), str(payload.get("path", "/")), destination_rel_path=str(payload.get("destination", "/")), overwrite=bool(payload.get("overwrite", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/delete") or path == "/api/files/delete":
            try:
                self.require_web_write_allowed("Datei lÃ¶schen")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, delete_or_trash_path(str(payload.get("root", "config")), str(payload.get("path", "/")), permanent=bool(payload.get("permanent", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/move") or path == "/api/files/move":
            try:
                self.require_web_write_allowed("Datei verschieben")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, move_path(str(payload.get("root", "config")), str(payload.get("source", "/")), str(payload.get("destination", "/")), overwrite=bool(payload.get("overwrite", False))))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/restore") or path == "/api/files/trash/restore":
            try:
                self.require_web_write_allowed("Papierkorb wiederherstellen")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, restore_from_trash(
                    str(payload.get("path", "/")),
                    overwrite=bool(payload.get("overwrite", False)),
                    destination_root=payload.get("destination_root"),
                    destination_path=payload.get("destination_path"),
                ))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/settings") or path == "/api/files/trash/settings":
            try:
                self.require_web_write_allowed("Papierkorb-Einstellung Ã¤ndern")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                self._send_json(200, set_trash_retention_days(payload.get("retention_days", TRASH_RETENTION_DAYS)))
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/files/trash/empty") or path == "/api/files/trash/empty":
            try:
                self.require_web_write_allowed("Papierkorb leeren")
                self._send_json(200, empty_trash())
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        if path.endswith("/api/worlds/export-safe") or path == "/api/worlds/export-safe":
            try:
                self.require_web_write_allowed("Welt exportieren")
                body = self._read_request_body(max_bytes=65536)
                payload = json.loads(body or "{}")
                zip_info = create_safe_world_export(str(payload.get("path", "/world")), save_to_export=bool(payload.get("save_to_export", True)))
                if zip_info["saved_to_export"]:
                    self._send_json(200, {"ok": True, "saved_to_export": True, "root": "export", "path": zip_info["export_path"], "filename": zip_info["zip_name"], "message": "Sicherer Welt-Export wurde nach /share/winomc/export gespeichert."})
                    return
                self._send_zip_info(zip_info)
            except Exception as exc:
                self._send_json(400, {"ok": False, "error": str(exc)})
            return
        self.send_error(404)

    def _sse_send(self, payload):
        data = json.dumps(payload, ensure_ascii=False)
        self.wfile.write(("data: %s\n\n" % data).encode("utf-8"))
        self.wfile.flush()

    def _stream_logs(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()
        for line in read_recent_lines(LOG_PATH, HISTORY_LIMIT):
            self._sse_send({"line": line})
        try:
            position = runtime_getsize(runtime_log_path())
        except OSError:
            position = 0
        last_heartbeat = time.time()
        while True:
            try:
                size = runtime_getsize(runtime_log_path())
                if size < position:
                    position = 0
                if size > position:
                    with open_runtime(runtime_log_path(), "r", encoding="utf-8", errors="replace") as handle:
                        handle.seek(position)
                        for line in handle:
                            self._sse_send({"line": line.rstrip("\n")})
                        position = handle.tell()
                if time.time() - last_heartbeat > 15:
                    self.wfile.write(b": heartbeat\n\n")
                    self.wfile.flush()
                    last_heartbeat = time.time()
                time.sleep(0.5)
            except (BrokenPipeError, ConnectionResetError):
                break
            except Exception as exc:
                try:
                    self._sse_send({"line": "[WinoMC Console] Log Stream Fehler: %s" % exc})
                except Exception:
                    break
                time.sleep(1)



WATCHDOG_THREAD_STARTED = False
WATCHDOG_LOCK = threading.Lock()

def automation_enabled(config, key):
    return bool((config.get("automation") or {}).get(key, False))

def manager_instance_configs():
    os.makedirs(INSTANCES_DIR, exist_ok=True)
    configs = []

    for name in sorted(os.listdir(INSTANCES_DIR)):
        try:
            path = instance_path(name, "instance.json")
            if os.path.isfile(path):
                configs.append(load_instance(name, include_health=False))
        except Exception as exc:
            print("[WinoMC Console] Automation scan skipped %s: %s" % (name, exc), flush=True)

    return configs

def autostart_instances():
    results = []

    for inst in manager_instance_configs():
        iid = inst.get("id")

        if not automation_enabled(inst, "autostart"):
            continue

        status = runtime_status(iid)
        state = status.get("state", "stopped")

        if state in ("running", "starting"):
            continue

        try:
            result = start_instance(iid)
            results.append({"id": iid, "action": "autostart", "ok": bool(result.get("ok")), "state": result.get("status", {}).get("state")})
        except Exception as exc:
            results.append({"id": iid, "action": "autostart", "ok": False, "error": str(exc)})

    return results

def watchdog_loop():
    interval = int(os.environ.get("WINOMC_WATCHDOG_INTERVAL_SECONDS", "15"))

    while True:
        time.sleep(max(5, interval))

        for inst in manager_instance_configs():
            iid = inst.get("id")

            if not automation_enabled(inst, "watchdog"):
                continue

            status = runtime_status(iid)
            state = status.get("state", "stopped")

            # Respect manual stop. Watchdog only repairs crashes/unknown states.
            if state not in ("crashed", "unknown"):
                continue

            try:
                print("[WinoMC Console] Watchdog startet Instanz %s nach Status %s neu." % (iid, state), flush=True)
                start_instance(iid)
            except Exception as exc:
                print("[WinoMC Console] Watchdog konnte Instanz %s nicht starten: %s" % (iid, exc), flush=True)

def start_watchdog_thread():
    global WATCHDOG_THREAD_STARTED

    with WATCHDOG_LOCK:
        if WATCHDOG_THREAD_STARTED:
            return

        WATCHDOG_THREAD_STARTED = True
        threading.Thread(target=watchdog_loop, daemon=True).start()

def main():
    ensure_directories()
    log_path = runtime_log_path()
    ensure_runtime_parent_dir(log_path)
    with open_runtime(log_path, "a", encoding="utf-8"):
        pass
    reconciliation = reconcile_all_instances()
    if reconciliation:
        print("[WinoMC Console] Runtime reconciliation: %s" % json.dumps(reconciliation, ensure_ascii=False), flush=True)
    autostart_results = autostart_instances()
    if autostart_results:
        print("[WinoMC Console] Autostart: %s" % json.dumps(autostart_results, ensure_ascii=False), flush=True)
    start_watchdog_thread()
    httpd = ThreadingHTTPServer((HOST, PORT), Handler)

    def shutdown(_signum, _frame):
        httpd.shutdown()

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)
    print("[WinoMC Console] Web console listening on %s:%s" % (HOST, PORT), flush=True)
    httpd.serve_forever(poll_interval=0.5)


if __name__ == "__main__":
    main()
