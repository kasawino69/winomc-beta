    /* v1.6.13.2: mobile console size buttons + editor visibility */
    function isMobileShell16132() {
      return document.body.classList.contains('ux-mobile') && !document.body.classList.contains('desktop-mode');
    }

    function refreshMobileConsoleLabels16132() {
      const mobile = isMobileShell16132();
      document.querySelectorAll('[data-console-size="large"]').forEach(button => {
        button.textContent = mobile ? 'Vollbild' : 'GroÃŸ';
        button.setAttribute('aria-label', mobile ? 'Live Console im Vollbild Ã¶ffnen' : 'Live Console groÃŸ anzeigen');
      });
      document.querySelectorAll('[data-console-size="compact"]').forEach(button => {
        button.setAttribute('aria-label', mobile ? 'Live Console kompakt mit Eingabe und drei Logzeilen anzeigen' : 'Live Console kompakt anzeigen');
      });
      document.querySelectorAll('[data-console-size="normal"]').forEach(button => {
        button.setAttribute('aria-label', mobile ? 'Live Console normal mit etwa zehn Logzeilen anzeigen' : 'Live Console normal anzeigen');
      });
    }

    const baseApplyConsoleSize16132 = applyConsoleSize;
    applyConsoleSize = function(size) {
      if (isMobileShell16132()) {
        if (size === 'large' || size === 'maximized') {
          setConsoleMode('maximized');
          refreshMobileConsoleLabels16132();
          return;
        }
        if (size === 'compact') {
          setConsoleMode('compact');
          refreshMobileConsoleLabels16132();
          return;
        }
        setConsoleMode('normal');
        refreshMobileConsoleLabels16132();
        return;
      }
      baseApplyConsoleSize16132(size || 'normal');
      refreshMobileConsoleLabels16132();
    };

    const baseSetConsoleMode16132 = setConsoleMode;
    setConsoleMode = function(mode) {
      baseSetConsoleMode16132(mode || 'normal');
      if (isMobileShell16132()) {
        document.documentElement.style.removeProperty('--console-height');
      }
      refreshMobileConsoleLabels16132();
    };

    const baseOpenEditorOverlay16132 = openEditorOverlay;
    openEditorOverlay = function() {
      baseOpenEditorOverlay16132();
      if (!editorPanel) return;
      editorPanel.classList.add('editor-open');
      if (isMobileShell16132()) {
        // The editor is a true mobile overlay; keep the console out of the way.
        setConsoleMode('collapsed');
      }
      requestAnimationFrame(() => {
        try {
          editorPanel.focus?.({ preventScroll: true });
          editorPanel.scrollIntoView?.({ block: 'center', inline: 'nearest' });
          if (!isMobileShell16132()) window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch (_) {}
      });
    };

