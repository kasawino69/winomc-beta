    function ensurePcWorkbenchNav() {
      const nav = document.querySelector('nav[aria-label="WinoMC MenÃ¼"]');
      if (!nav) return null;
      let button = document.getElementById('pcWorkbenchNav');
      if (!button) {
        button = document.createElement('button');
        button.type = 'button';
        button.id = 'pcWorkbenchNav';
        button.className = 'tab-button pc-workbench-nav';
        button.setAttribute('aria-label', 'PC-Workbench');
        button.innerHTML = '<span class="icon">ðŸ–¥ï¸</span> PC-Workbench';
        nav.appendChild(button);
      }
      button.hidden = isLikelyMobileViewport();
      button.disabled = isLikelyMobileViewport();
      button.onclick = event => {
        event.preventDefault();
        event.stopPropagation();
        enterDesktopModeFromUser();
      };
      return button;
    }

    const cleanupLegacyNavigation_16131 = cleanupLegacyNavigation;
