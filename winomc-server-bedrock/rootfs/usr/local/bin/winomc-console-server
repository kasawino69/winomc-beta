  <noscript><section class="winomc-boot-fallback"><div class="winomc-boot-box"><div class="winomc-boot-title">JavaScript ist deaktiviert.</div><p>Die WinoMC Console benÃ¶tigt JavaScript. Der statische Fallback bestÃ¤tigt, dass HTML sichtbar ausgeliefert wurde.</p></div></section></noscript>
  <script>
    (function () {
      function step(text) {
        var list = document.getElementById('bootSteps');
        if (!list) return;
        var item = document.createElement('li');
        item.textContent = text;
        list.appendChild(item);
      }
      function fail(message) {
        var box = document.getElementById('bootError');
        if (box) { box.hidden = false; box.textContent = 'Fehler: ' + message; }
        step('Fehler abgefangen');
      }
      window.WinoMCBoot = { step: step, fail: fail };
      document.documentElement.classList.add('winomc-html-loaded');
      step('JavaScript gestartet');
      window.addEventListener('error', function (event) { fail(event.message || 'Unbekannter JavaScript-Fehler'); });
      window.addEventListener('unhandledrejection', function (event) { var reason = event.reason; fail((reason && (reason.message || reason.toString())) || 'Unbehandelte Promise-Ablehnung'); });
    })();
  </script>
