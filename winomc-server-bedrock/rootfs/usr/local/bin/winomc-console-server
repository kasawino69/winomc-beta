      { id: 'op-add', category: 'Mehrspieler', label: 'OP geben', description: 'Gibt einem Spieler Operator-Rechte.', template: 'op {value}', promptTitle: 'Operator hinzufügen', promptLabel: 'Spielername', placeholder: 'PlayerName' },
