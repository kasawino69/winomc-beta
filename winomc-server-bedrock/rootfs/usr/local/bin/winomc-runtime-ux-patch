        ("WinoMC 2.0.0 Framework Workbench", "WinoMC 2.0.0.2b Framework Workbench"),
    ):
        text = text.replace(old, new)

    old_builtin = '''BUILTIN_BEDROCK_PACK_NAMES = {"chemistry", "vanilla", "education", "default", "minecraft"}
BUILTIN_BEDROCK_PACK_PREFIXES = ("vanilla_", "experimental_")

def is_system_pack_path(path):
    parts = [str(part or "").strip().lower() for part in re.split(r"[\\\\/]+", str(path or "")) if str(part or "").strip()]
    for part in parts:
        if part in BUILTIN_BEDROCK_PACK_NAMES or any(part.startswith(prefix) for prefix in BUILTIN_BEDROCK_PACK_PREFIXES):
            return True
    return False

def is_builtin_bedrock_pack(pack):
    pack = pack or {}
    values = [pack.get("name"), pack.get("path"), pack.get("filename"), pack.get("manifest_path"), pack.get("uuid")]
    header = pack.get("header") if isinstance(pack.get("header"), dict) else {}
    values += [header.get("name"), header.get("description")]
    metadata = pack.get("metadata") if isinstance(pack.get("metadata"), dict) else {}
    values += [metadata.get("product_type"), metadata.get("pack_scope")]
    for value in values:
        text = str(value or "").strip().lower()
        if not text:
            continue
        base = os.path.basename(text.replace("\\\\", "/"))
        if base in BUILTIN_BEDROCK_PACK_NAMES or any(base.startswith(prefix) for prefix in BUILTIN_BEDROCK_PACK_PREFIXES):
            return True
        if is_system_pack_path(text):
            return True
    return False
'''
    new_builtin = '''BUILTIN_BEDROCK_PACK_NAMES = {
    "chemistry", "vanilla", "education", "default", "minecraft",
    "resourcepack.editor.client.name", "resourcepack.editor.server.name",
    "server editor library", "@minecraft/server ts library", "@minecraft/server-ui ts library",
}
BUILTIN_BEDROCK_PACK_PREFIXES = ("vanilla_", "experimental_", "chemistry_", "resourcepack.editor.", "@minecraft/")
BUILTIN_BEDROCK_PACK_CONTAINS = (
    "resourcepack.editor.",
    "server editor library",
    "@minecraft/server",
    "@minecraft/server-ui",
)

def _is_builtin_pack_text(value):
    text = str(value or "").strip().lower()
    if not text:
        return False
    base = os.path.basename(text.replace("\\\\", "/"))
    candidates = {text, base}
    for candidate in candidates:
        if not candidate:
            continue
        if candidate in BUILTIN_BEDROCK_PACK_NAMES:
            return True
        if any(candidate.startswith(prefix) for prefix in BUILTIN_BEDROCK_PACK_PREFIXES):
            return True
        if any(marker in candidate for marker in BUILTIN_BEDROCK_PACK_CONTAINS):
            return True
    return False

def is_system_pack_path(path):
    parts = [str(part or "").strip().lower() for part in re.split(r"[\\\\/]+", str(path or "")) if str(part or "").strip()]
    for part in parts:
        if _is_builtin_pack_text(part):
            return True
    return False

def is_builtin_bedrock_pack(pack):
    pack = pack or {}
    values = [pack.get("name"), pack.get("path"), pack.get("filename"), pack.get("manifest_path"), pack.get("uuid")]
    header = pack.get("header") if isinstance(pack.get("header"), dict) else {}
    values += [header.get("name"), header.get("description")]
    metadata = pack.get("metadata") if isinstance(pack.get("metadata"), dict) else {}
    values += [metadata.get("product_type"), metadata.get("pack_scope")]
    for value in values:
        if _is_builtin_pack_text(value) or is_system_pack_path(value):
            return True
    return False
'''
    if old_builtin in text:
