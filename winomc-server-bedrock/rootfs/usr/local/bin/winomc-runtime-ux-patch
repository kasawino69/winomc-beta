      window.loadProfiles2 = async function loadProfiles2Clean() {
        try {
          const data = await fetchJson('/api/profiles');
          const target = document.getElementById('profilesGrid');
          if (!target) return;
          target.innerHTML = (data.profiles || []).map(profile =>
            '<article class="tile"><div class="tile-title">'+escapeHtml(profile.name)+'</div><div class="tile-desc">'+escapeHtml(profile.description)+'</div><pre>'+escapeHtml(JSON.stringify(profile.defaults, null, 2))+'</pre><button class="primary" data-profile-apply="'+escapeHtml(profile.name)+'">Profil anwenden</button></article>'
          ).join('');
        } catch (err) {
          appendLine('[Erststart] ' + err.message, 'error');
        }
      };

      document.addEventListener('click', async event => {
        const t = event.target.closest('button,[data-diagnostics-repair],[data-profile-apply],[data-player-remove]');
        if (!t) return;
        try {
          if (t.id === 'repairAllSafe2') {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            if (!confirm('Sichere Reparaturen ausführen?\n\nWinoMC erstellt fehlende Standardordner und korrigiert nur sichere Basisdateien.\n\nFortfahren?')) return;
            const result = await postJson('/api/diagnostics/repair', { action: 'repair_all_safe', mode: 'safe', confirm: true });
            alert(result.message || 'Reparatur abgeschlossen.');
            await window.loadDiagnostics2();
            return;
          }
          if (t.dataset.diagnosticsRepair) {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            const title = t.dataset.diagnosticsTitle || t.dataset.diagnosticsRepair;
            if (!confirm('Reparatur ausführen: ' + title + '\n\nDiese Aktion kann Dateien anlegen oder korrigieren. WinoMC nutzt die vorhandene Safety-/Backup-Logik und bricht ab, wenn der Web-Schutz Änderungen blockiert.\n\nFortfahren?')) return;
            const result = await postJson('/api/diagnostics/repair', { action: t.dataset.diagnosticsRepair, mode: 'safe', confirm: true });
            alert(result.message || 'Reparatur abgeschlossen.');
            await window.loadDiagnostics2();
            return;
          }
          if (t.id === 'playersAdd2') {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            window.collectPlayers2();
            window.winomcPlayers2 = Array.isArray(window.winomcPlayers2) ? window.winomcPlayers2 : [];
            window.winomcPlayers2.push({ name: '', xuid: '', allowlisted: true, role: 'member', issues: [] });
            const warnings = document.getElementById('playersWarnings');
            if (warnings) warnings.textContent = 'Neuer Spieler hinzugefügt. Bitte Gamertag/XUID eintragen und Speichern klicken.';
            renderPlayers2002();
            return;
          }
          if (t.dataset.playerRemove) {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            window.collectPlayers2();
            window.winomcPlayers2.splice(Number(t.dataset.playerRemove), 1);
            const warnings = document.getElementById('playersWarnings');
            if (warnings) warnings.textContent = 'Spieler entfernt. Bitte Speichern klicken.';
            renderPlayers2002();
            return;
          }
          if (t.id === 'playersSave2') {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            const result = await postJson('/api/players/save', { players: window.collectPlayers2() });
            const warnings = document.getElementById('playersWarnings');
            if (warnings) warnings.textContent = result.message || 'Spielerrechte wurden gespeichert.';
            await window.loadPlayers2();
            return;
          }
          if (t.dataset.profileApply) {
            event.preventDefault(); event.stopPropagation(); event.stopImmediatePropagation();
            const result = await postJson('/api/profiles/apply', { profile: t.dataset.profileApply });
            alert(result.message || 'Profil angewendet.');
            await window.loadProfiles2();
            return;
          }
        } catch (err) {
          alert(err.message);
          appendLine('[WinoMC 2.0.0.2b] ' + err.message, 'error');
        }
      }, true);

      cleanupTransferEntrypoints();
      window.addEventListener('load', cleanupTransferEntrypoints, { once: true });
      requestAnimationFrame(() => {
        cleanupTransferEntrypoints();
        ensurePlayerActions();
      });
    })();
'''
    if JS_MARKER not in text:
        text = text.replace("</script>", js_patch + "\n</script>", 1)

    if text != original:
        TARGET.write_text(text, encoding="utf-8")
        print("WinoMC 2.0.0.2b UI cleanup patch applied")
    else:
        print("WinoMC 2.0.0.2b UI cleanup patch already present")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
