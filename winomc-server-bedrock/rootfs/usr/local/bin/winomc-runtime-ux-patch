            + '</div></article>'
          ).join('') || '<article class="tile"><div class="tile-title">Noch keine Dateien im Import-Eingang.</div><div class="tile-desc">Lege lokale Bedrock-Pack-Dateien in /share/winomc/import ab oder nutze den Upload im Dateimanager.</div></article>';
