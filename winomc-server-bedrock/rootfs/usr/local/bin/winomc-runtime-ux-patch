#!/usr/bin/env python3
from pathlib import Path
import sys

TARGET = Path(sys.argv[1]) if len(sys.argv) > 1 else Path("/usr/local/bin/winomc-console-server")
VERSION = "2.0.0.2b"
CSS_MARKER = "v2.0.0.2b PC Workbench cleanup CSS"
JS_MARKER = "v2.0.0.2b PC Workbench cleanup JS"
BACKEND_MARKER = "v2.0.0.2b profile apply backend"


def replace_once(text, old, new):
    if old in text:
        return text.replace(old, new, 1)
    return text


def main():
    if not TARGET.exists():
        print("WinoMC UX patch skipped: %s not found" % TARGET)
        return 0

    text = TARGET.read_text(encoding="utf-8")
    original = text

    for old, new in (
        ('WINOMC_VERSION = os.environ.get("WINOMC_VERSION", "2.0.0")',
         'WINOMC_VERSION = os.environ.get("WINOMC_VERSION", "2.0.0.2b")'),
        ("<title>WinoMC 2.0.0 Framework Workbench</title>",
         "<title>WinoMC 2.0.0.2b Framework Workbench</title>"),
        ('<div class="card metric-card"><div class="stat-label">WinoMC</div><div class="stat-value" id="statWinoVersion">2.0.0</div>',
