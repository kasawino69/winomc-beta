            + '</tr>';
        }).join('');
        ensurePlayerActions();
      };

      window.collectPlayers2 = function collectPlayers2Clean() {
        document.querySelectorAll('[data-player-field]').forEach(el => {
          const i = Number(el.dataset.playerIndex);
          const f = el.dataset.playerField;
          if (!Array.isArray(window.winomcPlayers2) || !window.winomcPlayers2[i]) return;
          window.winomcPlayers2[i][f] = f === 'allowlisted' ? el.value === 'true' : el.value;
        });
