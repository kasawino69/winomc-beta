    "correct-player-movement", "chat-restriction", "disable-player-interaction",
    "disable-persona", "disable-custom-skins", "emit-server-telemetry",
]

def _profile_value_to_property(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    if value is None:
        return ""
    return str(value)

def _find_profile(profile_id):
    profiles = profiles_payload().get("profiles", [])
    slug = str(profile_id or "").lower().replace(" ", "-")
    for profile in profiles:
        name_slug = profile["name"].lower().replace(" ", "-")
        if slug in (name_slug, safe_download_name(profile["name"].lower(), "")):
            return profile
    raise FileNotFoundError("Profil wurde nicht gefunden.")

def _read_server_properties_for_profile():
    props = {}
    passthrough = []
    try:
        with open_safe_internal(DATA_DIR, SERVER_PROPERTIES_PATH, "r", encoding="utf-8") as handle:
            for raw_line in handle:
                line = raw_line.rstrip("\n")
                if not line or line.lstrip().startswith("#") or "=" not in line:
                    passthrough.append(line)
                    continue
                key, value = line.split("=", 1)
                key = key.strip()
                if key:
                    props[key] = value.strip()
                else:
                    passthrough.append(line)
    except FileNotFoundError:
        pass
    return props, passthrough

def apply_profile(profile_id):
    selected = _find_profile(profile_id)
    defaults = selected.get("defaults", {}) if isinstance(selected.get("defaults"), dict) else {}
    backup = create_framework_backup("config", "pre-profile-apply")
    props, passthrough = _read_server_properties_for_profile()
    changed = {}
    for option_key, property_key in PROFILE_PROPERTY_MAP.items():
        if option_key not in defaults:
            continue
        value = _profile_value_to_property(defaults.get(option_key))
        props[property_key] = value
        changed[property_key] = value
        os.environ[str(option_key)] = str(defaults.get(option_key))
    if not changed:
        raise ValueError("Profil enthält keine anwendbaren Servereigenschaften.")
    if defaults.get("ALLOW_LIST") is True and not os.path.exists(os.path.join(DATA_DIR, "allowlist.json")):
        atomic_write_json_root("config", "/allowlist.json", [], backup=False)
    lines = ["# WinoMC server.properties - durch Erststart-Profil aktualisiert"]
    emitted = set()
    for key in PROFILE_PROPERTY_ORDER:
        if key in props:
            lines.append("%s=%s" % (key, props[key]))
            emitted.add(key)
    for key in sorted(props):
        if key not in emitted:
            lines.append("%s=%s" % (key, props[key]))
            emitted.add(key)
    for line in passthrough:
        if line and line not in lines:
            lines.append(line)
    with open_safe_internal(DATA_DIR, SERVER_PROPERTIES_PATH, "w", encoding="utf-8", newline="\n") as handle:
        handle.write("\n".join(lines).rstrip() + "\n")
    state_dir = makedirs_internal(os.path.join(DATA_DIR, ".winomc"), os.path.join(DATA_DIR, ".winomc"), exist_ok=True)
    state_path = assert_safe_internal_path(state_dir, os.path.join(state_dir, "applied-profile.json"))
    state = {
        "applied_at": time.strftime("%Y-%m-%d_%H-%M-%S"),
        "profile": selected,
        "changed": changed,
        "backup": backup,
        "message": "Profil angewendet. Servereigenschaften wurden aktualisiert.",
    }
    with open_safe_internal(state_dir, state_path, "w", encoding="utf-8") as handle:
        json.dump(state, handle, ensure_ascii=False, indent=2)
        handle.write("\n")
    return {"ok": True, "profile": selected, "changed": changed, "backup": backup, "state": state, "message": state["message"]}
'''
    if BACKEND_MARKER not in text:
        text = text.replace("\n\ndef state_dir_path():", profile_backend + "\n\ndef state_dir_path():", 1)

    if "/api/profiles/apply" not in text:
