    new_behavior = '<div class="card"><div class="card-header"><div><h3>Behavior Packs & Add-ons</h3><p>Behavior Packs verändern Welt-Metadaten und sollten kontrolliert importiert werden.</p></div></div><div class="pill-group"><button data-open-root="behavior_packs">Behavior Packs öffnen</button><button data-open-root="worlds">Weltdateien öffnen</button><button data-open-root="import">Importordner anzeigen</button><button data-open-root="export">Exportordner anzeigen</button></div></div>'
