#!/bin/sh
set -eu

SERVER_DATA_DIR="${SERVER_DATA_DIR:-/config}"
PROPERTIES_FILE="${SERVER_DATA_DIR}/server.properties"

bool_lc() {
  case "${1:-false}" in
    true|TRUE|True|1|yes|YES|on|ON) echo "true" ;;
    *) echo "false" ;;
  esac
}

mkdir -p "${SERVER_DATA_DIR}"

cat > "${PROPERTIES_FILE}" <<EOF
server-name=${SERVER_NAME:-WinoMC Server}
gamemode=${GAMEMODE:-survival}
force-gamemode=$(bool_lc "${FORCE_GAMEMODE:-false}")
difficulty=${DIFFICULTY:-normal}
allow-cheats=$(bool_lc "${ALLOW_CHEATS:-false}")
max-players=${MAX_PLAYERS:-10}
online-mode=$(bool_lc "${ONLINE_MODE:-true}")
allow-list=$(bool_lc "${ALLOW_LIST:-false}")
server-port=${SERVER_PORT:-19132}
server-portv6=${SERVER_PORT_V6:-19133}
enable-lan-visibility=$(bool_lc "${ENABLE_LAN_VISIBILITY:-true}")
view-distance=${VIEW_DISTANCE:-10}
tick-distance=${TICK_DISTANCE:-4}
player-idle-timeout=${PLAYER_IDLE_TIMEOUT:-30}
max-threads=${MAX_THREADS:-2}
level-name=${LEVEL_NAME:-world}
level-seed=${LEVEL_SEED:-}
default-player-permission-level=${DEFAULT_PLAYER_PERMISSION_LEVEL:-member}
texturepack-required=$(bool_lc "${TEXTUREPACK_REQUIRED:-false}")
content-log-file-enabled=$(bool_lc "${CONTENT_LOG_FILE_ENABLED:-false}")
content-log-level=${CONTENT_LOG_LEVEL:-info}
content-log-console-output-enabled=$(bool_lc "${CONTENT_LOG_CONSOLE_OUTPUT_ENABLED:-false}")
server-authoritative-movement=${SERVER_AUTHORITATIVE_MOVEMENT:-server-auth}
server-authoritative-block-breaking=$(bool_lc "${SERVER_AUTHORITATIVE_BLOCK_BREAKING:-false}")
player-movement-score-threshold=${PLAYER_MOVEMENT_SCORE_THRESHOLD:-20}
player-movement-distance-threshold=${PLAYER_MOVEMENT_DISTANCE_THRESHOLD:-0.3}
player-movement-duration-threshold-in-ms=${PLAYER_MOVEMENT_DURATION_THRESHOLD_IN_MS:-500}
correct-player-movement=$(bool_lc "${CORRECT_PLAYER_MOVEMENT:-false}")
chat-restriction=${CHAT_RESTRICTION:-None}
disable-player-interaction=$(bool_lc "${DISABLE_PLAYER_INTERACTION:-false}")
disable-persona=$(bool_lc "${DISABLE_PERSONA:-false}")
disable-custom-skins=$(bool_lc "${DISABLE_CUSTOM_SKINS:-false}")
emit-server-telemetry=$(bool_lc "${EMIT_SERVER_TELEMETRY:-false}")
EOF

echo "WinoMC native server.properties written: ${PROPERTIES_FILE}"