#!/bin/sh
set -eu

SERVER_DATA_DIR="${SERVER_DATA_DIR:-/config}"
VERSION="${VERSION:-LATEST}"
BDS_DIRECT_DOWNLOAD_URL="${BDS_DIRECT_DOWNLOAD_URL:-${DIRECT_DOWNLOAD_URL:-}}"
BDS_AUTO_UPDATE="${BDS_AUTO_UPDATE:-true}"

DOWNLOAD_LINKS_URL="${DOWNLOAD_LINKS_URL:-https://net.web.minecraft-services.net/api/v1.0/download/links}"
DOWNLOAD_SECONDARY_LINKS_URL="${DOWNLOAD_SECONDARY_LINKS_URL:-https://net.web.minecraft-services.net/api/v1.0/download/links}"
PROCESSED_DOWNLOAD_LINKS_URL="${PROCESSED_DOWNLOAD_LINKS_URL:-https://raw.githubusercontent.com/kittizz/bedrock-server-downloads/refs/heads/main/bedrock-server-downloads.json}"
RESOLVE_XUID_API_URL="${RESOLVE_XUID_API_URL:-https://mcprofile.io/api/v1/bedrock/gamertag}"

BDS_STATE_DIR="${SERVER_DATA_DIR}/.winomc/bds"
BDS_VERSION_FILE="${BDS_STATE_DIR}/installed-version"
BDS_URL_FILE="${BDS_STATE_DIR}/installed-url"

mkdir -p "${SERVER_DATA_DIR}" "${BDS_STATE_DIR}"

is_true() {
  case "$(printf '%s' "${1:-false}" | tr '[:upper:]' '[:lower:]')" in
    true|on|1|yes) return 0 ;;
    *) return 1 ;;
  esac
}

version_upper() {
  printf '%s' "${1:-}" | tr '[:lower:]' '[:upper:]'
}

replace_version_in_url() {
  original_url="$1"
  new_version="$2"

  printf '%s' "${original_url}" \
    | sed -E "s/(bedrock-server-)[^/]+(\.zip)/\1${new_version}\2/"
}

version_from_existing() {
  if ls bedrock_server >/dev/null 2>&1; then
    echo "existing"
    return 0
  fi

  return 1
}

lookup_download_url_from_minecraft_services() {
  platform="$1"

  for api_url in "${DOWNLOAD_LINKS_URL}" "${DOWNLOAD_SECONDARY_LINKS_URL}"; do
    download_url="$(curl -fsSL -A "WinoMC Bedrock Runtime" "${api_url}" \
      | jq --arg platform "${platform}" -rR '
          try(fromjson) catch({})
          | .result.links // []
          | map(select(.downloadType == $platform))
          | if length > 0 then first.downloadUrl else empty end
        ' 2>/dev/null || true)"

    if [ -n "${download_url}" ] && [ "${download_url}" != "null" ]; then
      echo "${download_url}"
      return 0
    fi
  done

  return 1
}

lookup_download_url_from_processed_links() {
  platform="$1"

  case "${platform}" in
    serverBedrockPreviewLinux)
      type="preview"
      ;;
    *)
      type="release"
      ;;
  esac

  download_url="$(curl -fsSL -A "WinoMC Bedrock Runtime" "${PROCESSED_DOWNLOAD_LINKS_URL}" \
    | jq --arg type "${type}" -r '
        .[$type]
        | to_entries
        | sort_by(.key | split(".") | map(tonumber))
        | last
        | .value.linux.url // empty
      ' 2>/dev/null || true)"

  if [ -n "${download_url}" ] && [ "${download_url}" != "null" ]; then
    echo "${download_url}"
    return 0
  fi

  return 1
}

lookup_download_url() {
  platform="$1"

  if lookup_download_url_from_minecraft_services "${platform}"; then
    return 0
  fi

  echo "WARN: Minecraft Services lookup failed, trying processed fallback links" >&2

  if lookup_download_url_from_processed_links "${platform}"; then
    return 0
  fi

  return 1
}

extract_version_from_url() {
  url="$1"

  version="$(printf '%s' "${url}" \
    | sed -n 's#.*bedrock-server-\([0-9][0-9.]*\)\.zip.*#\1#p')"

  if [ -n "${version}" ]; then
    echo "${version}"
    return 0
  fi

  return 1
}

trim_value() {
  printf '%s' "${1:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

list_values() {
  printf '%s' "${1:-}" | tr '\n;|' ',,,'
}

json_array_from_lines() {
  file="$1"

  if [ -s "${file}" ]; then
    jq -s '.' "${file}"
  else
    printf '[]\n'
  fi
}

resolve_xuid() {
  value="$(trim_value "${1:-}")"

  if [ -z "${value}" ]; then
    return 1
  fi

  if printf '%s' "${value}" | grep -Eq '^[0-9]{15,}$'; then
    echo "${value}"
    return 0
  fi

  encoded="$(printf '%s' "${value}" | jq -sRr @uri)"
  xuid="$(curl -fsSL -A "WinoMC Bedrock Runtime" "${RESOLVE_XUID_API_URL}/${encoded}" \
    | jq -r '.xuid // empty' 2>/dev/null || true)"

  if [ -n "${xuid}" ] && [ "${xuid}" != "null" ]; then
    echo "${xuid}"
    return 0
  fi

  echo "WARN: Could not resolve XUID for ${value}; writing value as-is" >&2
  echo "${value}"
}

write_allowlist() {
  tmp_file="$(mktemp)"
  allowed_values="$(list_values "${ALLOW_LIST_USERS:-}")"

  old_ifs="${IFS}"
  IFS=','

  for entry in ${allowed_values}; do
    entry="$(trim_value "${entry}")"

    if [ -z "${entry}" ]; then
      continue
    fi

    jq -n --arg name "${entry}" \
      '{ignoresPlayerLimit:false,name:$name}' >> "${tmp_file}"
  done

  IFS="${old_ifs}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/allowlist.json"
  rm -f "${tmp_file}"

  echo "WinoMC native allowlist.json written"
}

append_permission_entries() {
  permission="$1"
  values="$(list_values "${2:-}")"
  tmp_file="$3"

  old_ifs="${IFS}"
  IFS=','

  for entry in ${values}; do
    entry="$(trim_value "${entry}")"

    if [ -z "${entry}" ]; then
      continue
    fi

    xuid="$(resolve_xuid "${entry}" || true)"

    if [ -z "${xuid}" ]; then
      continue
    fi

    jq -n \
      --arg permission "${permission}" \
      --arg xuid "${xuid}" \
      '{permission:$permission,xuid:$xuid}' >> "${tmp_file}"
  done

  IFS="${old_ifs}"
}

write_permissions() {
  tmp_file="$(mktemp)"

  append_permission_entries "operator" "${OPS:-}" "${tmp_file}"
  append_permission_entries "member" "${MEMBERS:-}" "${tmp_file}"
  append_permission_entries "visitor" "${VISITORS:-}" "${tmp_file}"

  json_array_from_lines "${tmp_file}" > "${SERVER_DATA_DIR}/permissions.json"
  rm -f "${tmp_file}"

  echo "WinoMC native permissions.json written"
}

write_access_files() {
  write_allowlist
  write_permissions
}

cleanup_old_bds_files() {
  echo "Cleaning old Bedrock runtime files"

  rm -f bedrock_server bedrock_server-* *.so release-notes.txt bedrock_server_how_to.html valid_known_packs.json 2>/dev/null || true
  rm -rf premium_cache 2>/dev/null || true

  # Mojang-Packs dürfen bei Updates ersetzt werden.
  rm -rf resource_packs/vanilla resource_packs/chemistry resource_packs/editor 2>/dev/null || true
  find behavior_packs \( -name 'vanilla*' -o -name 'chemistry*' -o -name 'experimental*' \) -exec rm -rf {} + 2>/dev/null || true
}

install_bds() {
  url="$1"
  version="$2"

  tmp_dir="$(mktemp -d)"
  zip_file="${tmp_dir}/bedrock-server.zip"

  echo "WinoMC native BDS download: ${url}"
  curl -fL --retry 3 --retry-delay 3 -A "WinoMC Bedrock Runtime" -o "${zip_file}" "${url}"

  echo "WinoMC native BDS install version: ${version}"

  cleanup_old_bds_files

  unzip -oq "${zip_file}" -d "${SERVER_DATA_DIR}"

  chmod +x "${SERVER_DATA_DIR}/bedrock_server"

  printf '%s\n' "${version}" > "${BDS_VERSION_FILE}"
  printf '%s\n' "${url}" > "${BDS_URL_FILE}"

  rm -rf "${tmp_dir}"
}

cd "${SERVER_DATA_DIR}"

installed_version="$(cat "${BDS_VERSION_FILE}" 2>/dev/null || true)"
version_mode="$(version_upper "${VERSION}")"

echo "WinoMC native runtime"
echo "Installed BDS version: ${installed_version:-none}"
echo "Requested VERSION: ${VERSION}"
echo "BDS auto update: ${BDS_AUTO_UPDATE}"

if [ "${version_mode}" = "EXISTING" ]; then
  if [ ! -x "${SERVER_DATA_DIR}/bedrock_server" ]; then
    echo "ERROR: VERSION=EXISTING but no executable bedrock_server found" >&2
    exit 1
  fi

  echo "Using existing Bedrock Dedicated Server"
  write_access_files
  /usr/local/bin/winomc-write-server-properties
  echo "Starting native Bedrock Dedicated Server"
  LD_LIBRARY_PATH="${SERVER_DATA_DIR}:${LD_LIBRARY_PATH:-}" ./bedrock_server
  exit 0
fi

if [ -x "${SERVER_DATA_DIR}/bedrock_server" ] && ! is_true "${BDS_AUTO_UPDATE}" && [ -z "${BDS_DIRECT_DOWNLOAD_URL}" ]; then
  echo "BDS_AUTO_UPDATE=false and existing server found. Skipping lookup and download."
  write_access_files
  /usr/local/bin/winomc-write-server-properties
  echo "Starting native Bedrock Dedicated Server"
  LD_LIBRARY_PATH="${SERVER_DATA_DIR}:${LD_LIBRARY_PATH:-}" ./bedrock_server
  exit 0
fi

if [ -n "${BDS_DIRECT_DOWNLOAD_URL}" ]; then
  target_url="${BDS_DIRECT_DOWNLOAD_URL}"
else
  case "${version_mode}" in
    PREVIEW)
      echo "Looking up latest Bedrock preview version..."
      target_url="$(lookup_download_url serverBedrockPreviewLinux)" || {
        echo "ERROR: Could not resolve latest Bedrock preview Linux download URL" >&2
        exit 1
      }
      ;;
    LATEST|"")
      echo "Looking up latest Bedrock version..."
      target_url="$(lookup_download_url serverBedrockLinux)" || {
        echo "ERROR: Could not resolve latest Bedrock Linux download URL" >&2
        exit 1
      }
      ;;
    *)
      echo "Looking up Bedrock download URL for requested version ${VERSION}..."
      base_url="$(lookup_download_url serverBedrockLinux)" || {
        echo "ERROR: Could not resolve base Bedrock Linux download URL" >&2
        exit 1
      }
      target_url="$(replace_version_in_url "${base_url}" "${VERSION}")"
      ;;
  esac
fi

target_version="$(extract_version_from_url "${target_url}" || true)"

if [ -z "${target_version}" ]; then
  target_version="${VERSION}"
fi

echo "Target BDS version: ${target_version}"

if [ ! -x "${SERVER_DATA_DIR}/bedrock_server" ]; then
  echo "No Bedrock server binary found. Installing BDS."
  install_bds "${target_url}" "${target_version}"
elif is_true "${BDS_AUTO_UPDATE}" && [ "${installed_version}" != "${target_version}" ]; then
  echo "BDS update detected: ${installed_version:-none} -> ${target_version}"
  install_bds "${target_url}" "${target_version}"
else
  echo "BDS already installed. Skipping download."
fi

write_access_files
/usr/local/bin/winomc-write-server-properties

echo "Starting native Bedrock Dedicated Server"
LD_LIBRARY_PATH="${SERVER_DATA_DIR}:${LD_LIBRARY_PATH:-}" ./bedrock_server